{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "dataCollectionRuleName": {
            "type": "string",
            "defaultValue": "dcr-checkmarx-sast-log-ingestion",
            "metadata": {
                "description": "Name of the Data Collection Rule"
            }
        },
        "location": {
            "type": "string",
            "metadata": {
                "description": "Location for the Data Collection Rule. Must match Log Analytics Workspace location."
            }
        },
        "workspaceResourceId": {
            "type": "string",
            "metadata": {
                "description": "Full Resource ID of the Log Analytics workspace"
            }
        },
        "dataCollectionEndpointResourceId": {
            "type": "string",
            "metadata": {
                "description": "Full Resource ID of the Data Collection Endpoint"
            }
        }
    },
    "variables": {
        "tableName": "CheckmarxSASTFindings_CL",
        "streamName": "Custom-CheckmarxSASTFindings_CL"
    },
    "resources": [
        {
            "type": "Microsoft.Insights/dataCollectionRules",
            "apiVersion": "2023-03-11",
            "name": "[parameters('dataCollectionRuleName')]",
            "location": "[parameters('location')]",
            "properties": {
                "dataCollectionEndpointId": "[parameters('dataCollectionEndpointResourceId')]",
                "streamDeclarations": {
                    "[variables('streamName')]": {
                        "columns": [
                            {
                                "name": "TimeGenerated",
                                "type": "datetime"
                            },
                            {
                                "name": "ResultHash",
                                "type": "string"
                            },
                            {
                                "name": "QueryID",
                                "type": "string"
                            },
                            {
                                "name": "QueryName",
                                "type": "string"
                            },
                            {
                                "name": "LanguageName",
                                "type": "string"
                            },
                            {
                                "name": "VulnerabilityGroup",
                                "type": "string"
                            },
                            {
                                "name": "CweID",
                                "type": "int"
                            },
                            {
                                "name": "Severity",
                                "type": "string"
                            },
                            {
                                "name": "CvssScore",
                                "type": "real"
                            },
                            {
                                "name": "SimilarityID",
                                "type": "int"
                            },
                            {
                                "name": "State",
                                "type": "string"
                            },
                            {
                                "name": "Status",
                                "type": "string"
                            },
                            {
                                "name": "ConfidenceLevel",
                                "type": "int"
                            },
                            {
                                "name": "FirstFoundAt",
                                "type": "datetime"
                            },
                            {
                                "name": "FoundAt",
                                "type": "datetime"
                            },
                            {
                                "name": "FirstScanID",
                                "type": "string"
                            },
                            {
                                "name": "Compliances",
                                "type": "string"
                            },
                            {
                                "name": "SourceFileName",
                                "type": "string"
                            },
                            {
                                "name": "SourceLine",
                                "type": "int"
                            },
                            {
                                "name": "SourceColumn",
                                "type": "int"
                            },
                            {
                                "name": "NodeCount",
                                "type": "int"
                            },
                            {
                                "name": "NodesJson",
                                "type": "string"
                            },
                            {
                                "name": "ScanID",
                                "type": "string"
                            }
                        ]
                    }
                },
                "dataSources": {},
                "destinations": {
                    "logAnalytics": [
                        {
                            "workspaceResourceId": "[parameters('workspaceResourceId')]",
                            "name": "clv2ws1"
                        }
                    ]
                },
                "dataFlows": [
                    {
                        "streams": [
                            "[variables('streamName')]"
                        ],
                        "destinations": [
                            "clv2ws1"
                        ],
                        "transformKql": "source",
                        "outputStream": "[variables('streamName')]"
                    }
                ]
            }
        }
    ],
    "outputs": {
        "dcrImmutableId": {
            "type": "string",
            "value": "[reference(resourceId('Microsoft.Insights/dataCollectionRules', parameters('dataCollectionRuleName'))).immutableId]"
        },
        "dcrResourceId": {
            "type": "string",
            "value": "[resourceId('Microsoft.Insights/dataCollectionRules', parameters('dataCollectionRuleName'))]"
        }
    }
}
