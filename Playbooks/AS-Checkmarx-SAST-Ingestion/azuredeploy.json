{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "metadata": {
        "title": "AS-Checkmarx-SAST-Ingestion",
        "description": "This playbook ingests Checkmarx SAST scan findings into a custom Microsoft Sentinel table on a daily schedule.",
        "prerequisites": [
            "1. A Key Vault secret containing the Checkmarx client secret or refresh token",
            "2. The CheckmarxSASTFindings_CL custom table deployed to Log Analytics",
            "3. A Data Collection Endpoint (DCE) deployed",
            "4. A Data Collection Rule (DCR) deployed and linked to the DCE"
        ],
        "postDeployment": [
            "1. Add the Logic App managed identity to Key Vault with 'Key Vault Secrets User' role",
            "2. Add the Logic App managed identity to the SAST DCR with 'Monitoring Metrics Publisher' role"
        ],
        "lastUpdateTime": "2026-03-06T00:00:00Z",
        "support": {
            "tier": "partner"
        },
        "author": {
            "name": "Accelerynt"
        }
    },
    "parameters": {
        "PlaybookName": {
            "type": "string",
            "defaultValue": "AS-Checkmarx-SAST-Ingestion",
            "metadata": {
                "description": "Name of the Logic App"
            }
        },
        "KeyVaultName": {
            "type": "string",
            "metadata": {
                "description": "Name of the Key Vault containing the Checkmarx credential"
            }
        },
        "KeyVaultSecretName": {
            "type": "string",
            "metadata": {
                "description": "Name of the Key Vault secret (refresh token or client secret depending on GrantType)"
            }
        },
        "CheckmarxIAMBaseUrl": {
            "type": "string",
            "metadata": {
                "description": "Checkmarx IAM base URL for authentication (e.g., https://us.iam.checkmarx.net, https://eu.iam.checkmarx.net)"
            }
        },
        "CheckmarxASTBaseUrl": {
            "type": "string",
            "metadata": {
                "description": "Checkmarx AST base URL for API calls (e.g., https://us.ast.checkmarx.net, https://eu.ast.checkmarx.net)"
            }
        },
        "CheckmarxTenant": {
            "type": "string",
            "metadata": {
                "description": "Checkmarx tenant/realm name used in the authentication URL"
            }
        },
        "CheckmarxClientId": {
            "type": "string",
            "metadata": {
                "description": "Checkmarx OAuth Client ID (e.g., ast-app)"
            }
        },
        "GrantType": {
            "type": "string",
            "allowedValues": [
                "refresh_token",
                "client_credentials"
            ],
            "metadata": {
                "description": "OAuth grant type. Use 'refresh_token' with a refresh token or 'client_credentials' with a client secret stored in Key Vault."
            }
        },
        "DCELogsIngestionEndpoint": {
            "type": "string",
            "metadata": {
                "description": "Data Collection Endpoint logs ingestion URL (e.g., https://dce-checkmarx-xxxx.westus2-1.ingest.monitor.azure.com)"
            }
        },
        "DCRSASTImmutableId": {
            "type": "string",
            "metadata": {
                "description": "Immutable ID of the SAST Results Data Collection Rule"
            }
        },
        "BatchSize": {
            "type": "int",
            "metadata": {
                "description": "Number of SAST results to send per batch to the DCR endpoint (to stay under the 1 MB payload limit). Recommended: 200"
            }
        }
    },
    "resources": [
        {
            "type": "Microsoft.Web/connections",
            "apiVersion": "2016-06-01",
            "name": "[concat('keyvault-', parameters('PlaybookName'))]",
            "location": "[resourceGroup().location]",
            "kind": "V1",
            "properties": {
                "displayName": "[concat('keyvault-', parameters('PlaybookName'))]",
                "parameterValueType": "Alternative",
                "alternativeParameterValues": {
                    "vaultName": "[parameters('KeyVaultName')]"
                },
                "api": {
                    "id": "[subscriptionResourceId('Microsoft.Web/locations/managedApis', resourceGroup().location, 'keyvault')]"
                }
            }
        },
        {
            "type": "Microsoft.Logic/workflows",
            "apiVersion": "2019-05-01",
            "name": "[parameters('PlaybookName')]",
            "location": "[resourceGroup().location]",
            "dependsOn": [
                "[resourceId('Microsoft.Web/connections', concat('keyvault-', parameters('PlaybookName')))]"
            ],
            "identity": {
                "type": "SystemAssigned"
            },
            "properties": {
                "state": "Disabled",
                "definition": {
                    "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
                    "contentVersion": "1.0.0.0",
                    "parameters": {
                        "$connections": {
                            "type": "Object",
                            "defaultValue": {}
                        }
                    },
                    "triggers": {
                        "Recurrence": {
                            "type": "Recurrence",
                            "recurrence": {
                                "interval": 1,
                                "frequency": "Day"
                            }
                        }
                    },
                    "actions": {

                        "Initialize_BatchSize": {
                            "type": "InitializeVariable",
                            "inputs": {
                                "variables": [
                                    {
                                        "name": "BatchSize",
                                        "type": "integer",
                                        "value": "[parameters('BatchSize')]"
                                    }
                                ]
                            },
                            "runAfter": {}
                        },

                        "Initialize_CurrentIndex": {
                            "type": "InitializeVariable",
                            "inputs": {
                                "variables": [
                                    {
                                        "name": "CurrentIndex",
                                        "type": "integer",
                                        "value": 0
                                    }
                                ]
                            },
                            "runAfter": {
                                "Initialize_BatchSize": [ "Succeeded" ]
                            }
                        },

                        "Initialize_TotalResults": {
                            "type": "InitializeVariable",
                            "inputs": {
                                "variables": [
                                    {
                                        "name": "TotalResults",
                                        "type": "integer",
                                        "value": 0
                                    }
                                ]
                            },
                            "runAfter": {
                                "Initialize_CurrentIndex": [ "Succeeded" ]
                            }
                        },

                        "Get_secret": {
                            "type": "ApiConnection",
                            "inputs": {
                                "host": {
                                    "connection": {
                                        "name": "@parameters('$connections')['keyvault']['connectionId']"
                                    }
                                },
                                "method": "get",
                                "path": "[concat('/secrets/@{encodeURIComponent(''', parameters('KeyVaultSecretName'), ''')}/value')]"
                            },
                            "runAfter": {
                                "Initialize_TotalResults": [ "Succeeded" ]
                            },
                            "runtimeConfiguration": {
                                "secureData": {
                                    "properties": [
                                        "inputs",
                                        "outputs"
                                    ]
                                }
                            }
                        },

                        "HTTP_-_Get_Token": {
                            "type": "Http",
                            "inputs": {
                                "uri": "[concat(parameters('CheckmarxIAMBaseUrl'), '/auth/realms/', parameters('CheckmarxTenant'), '/protocol/openid-connect/token')]",
                                "method": "POST",
                                "headers": {
                                    "Content-Type": "application/x-www-form-urlencoded"
                                },
                                "body": "[if(equals(parameters('GrantType'), 'client_credentials'), concat('grant_type=client_credentials&client_id=', parameters('CheckmarxClientId'), '&client_secret=@{body(''Get_secret'')?[''value'']}'), concat('grant_type=refresh_token&client_id=', parameters('CheckmarxClientId'), '&refresh_token=@{body(''Get_secret'')?[''value'']}'))]"
                            },
                            "runAfter": {
                                "Get_secret": [ "Succeeded" ]
                            },
                            "runtimeConfiguration": {
                                "secureData": {
                                    "properties": [
                                        "inputs",
                                        "outputs"
                                    ]
                                }
                            }
                        },

                        "HTTP_-_Get_Scans": {
                            "type": "Http",
                            "inputs": {
                                "uri": "[concat(parameters('CheckmarxASTBaseUrl'), '/api/scans?statuses=Completed&from-date=@{addDays(utcNow(), -1, ''yyyy-MM-ddTHH:mm:ssZ'')}')]",
                                "method": "GET",
                                "headers": {
                                    "Accept": "application/json",
                                    "Authorization": "Bearer @{body('HTTP_-_Get_Token')?['access_token']}"
                                }
                            },
                            "runAfter": {
                                "HTTP_-_Get_Token": [ "Succeeded" ]
                            },
                            "runtimeConfiguration": {
                                "secureData": {
                                    "properties": [
                                        "inputs"
                                    ]
                                }
                            }
                        },

                        "For_Each_Scan": {
                            "type": "Foreach",
                            "foreach": "@body('HTTP_-_Get_Scans')?['scans']",
                            "operationOptions": "Sequential",
                            "actions": {

                                "HTTP_-_Get_SAST_Results_Page": {
                                    "type": "Http",
                                    "inputs": {
                                        "uri": "[concat(parameters('CheckmarxASTBaseUrl'), '/api/sast-results/?scan-id=@{items(''For_Each_Scan'')?[''id'']}')]",
                                        "method": "GET",
                                        "headers": {
                                            "Accept": "application/json",
                                            "Authorization": "Bearer @{body('HTTP_-_Get_Token')?['access_token']}"
                                        }
                                    },
                                    "runAfter": {},
                                    "runtimeConfiguration": {
                                        "secureData": {
                                            "properties": [
                                                "inputs"
                                            ]
                                        }
                                    }
                                },

                                "Condition_-_SAST_Results_Exist": {
                                    "type": "If",
                                    "expression": {
                                        "and": [
                                            {
                                                "greater": [
                                                    "@length(coalesce(body('HTTP_-_Get_SAST_Results_Page')?['results'], json('[]')))",
                                                    0
                                                ]
                                            }
                                        ]
                                    },
                                    "actions": {
                                        "Select_SAST_Results": {
                                            "type": "Select",
                                            "inputs": {
                                                "from": "@body('HTTP_-_Get_SAST_Results_Page')?['results']",
                                                "select": {
                                                    "TimeGenerated": "@utcNow()",
                                                    "ResultHash": "@item()?['resultHash']",
                                                    "QueryID": "@item()?['queryIDStr']",
                                                    "QueryName": "@item()?['queryName']",
                                                    "LanguageName": "@item()?['languageName']",
                                                    "VulnerabilityGroup": "@item()?['group']",
                                                    "CweID": "@item()?['cweID']",
                                                    "Severity": "@item()?['severity']",
                                                    "CvssScore": "@item()?['cvssScore']",
                                                    "SimilarityID": "@item()?['similarityID']",
                                                    "State": "@item()?['state']",
                                                    "Status": "@item()?['status']",
                                                    "ConfidenceLevel": "@item()?['confidenceLevel']",
                                                    "FirstFoundAt": "@item()?['firstFoundAt']",
                                                    "FoundAt": "@item()?['foundAt']",
                                                    "FirstScanID": "@item()?['firstScanID']",
                                                    "Compliances": "@join(item()?['compliances'], ', ')",
                                                    "SourceFileName": "@item()?['nodes'][0]?['fileName']",
                                                    "SourceLine": "@item()?['nodes'][0]?['line']",
                                                    "SourceColumn": "@item()?['nodes'][0]?['column']",
                                                    "NodeCount": "@length(item()?['nodes'])",
                                                    "NodesJson": "@string(item()?['nodes'])",
                                                    "ScanID": "@items('For_Each_Scan')?['id']"
                                                }
                                            },
                                            "runAfter": {}
                                        },
                                        "Compose_TotalResults": {
                                            "type": "Compose",
                                            "inputs": "@length(body('Select_SAST_Results'))",
                                            "runAfter": {
                                                "Select_SAST_Results": [ "Succeeded" ]
                                            }
                                        },
                                        "Set_TotalResults": {
                                            "type": "SetVariable",
                                            "inputs": {
                                                "name": "TotalResults",
                                                "value": "@outputs('Compose_TotalResults')"
                                            },
                                            "runAfter": {
                                                "Compose_TotalResults": [ "Succeeded" ]
                                            }
                                        },
                                        "Compose_ResetIndex": {
                                            "type": "Compose",
                                            "inputs": 0,
                                            "runAfter": {
                                                "Set_TotalResults": [ "Succeeded" ]
                                            }
                                        },
                                        "Set_CurrentIndex_to_Zero": {
                                            "type": "SetVariable",
                                            "inputs": {
                                                "name": "CurrentIndex",
                                                "value": "@outputs('Compose_ResetIndex')"
                                            },
                                            "runAfter": {
                                                "Compose_ResetIndex": [ "Succeeded" ]
                                            }
                                        },
                                        "Until_All_Batches_Sent": {
                                            "type": "Until",
                                            "expression": "@greaterOrEquals(variables('CurrentIndex'), variables('TotalResults'))",
                                            "limit": {
                                                "count": 500,
                                                "timeout": "PT1H"
                                            },
                                            "actions": {
                                                "Compose_Current_Batch": {
                                                    "type": "Compose",
                                                    "inputs": "@take(skip(body('Select_SAST_Results'), variables('CurrentIndex')), variables('BatchSize'))",
                                                    "runAfter": {}
                                                },
                                                "HTTP_-_Send_SAST_Batch_to_DCR": {
                                                    "type": "Http",
                                                    "inputs": {
                                                        "uri": "[concat(parameters('DCELogsIngestionEndpoint'), '/dataCollectionRules/', parameters('DCRSASTImmutableId'), '/streams/Custom-CheckmarxSASTFindings_CL?api-version=2023-01-01')]",
                                                        "method": "POST",
                                                        "headers": {
                                                            "Content-Type": "application/json"
                                                        },
                                                        "body": "@outputs('Compose_Current_Batch')",
                                                        "authentication": {
                                                            "type": "ManagedServiceIdentity",
                                                            "audience": "https://monitor.azure.com"
                                                        },
                                                        "retryPolicy": {
                                                            "type": "exponential",
                                                            "count": 4,
                                                            "interval": "PT10S",
                                                            "minimumInterval": "PT10S",
                                                            "maximumInterval": "PT1M"
                                                        }
                                                    },
                                                    "runAfter": {
                                                        "Compose_Current_Batch": [ "Succeeded" ]
                                                    }
                                                },
                                                "Compose_Next_Index": {
                                                    "type": "Compose",
                                                    "inputs": "@add(variables('CurrentIndex'), variables('BatchSize'))",
                                                    "runAfter": {
                                                        "HTTP_-_Send_SAST_Batch_to_DCR": [ "Succeeded" ]
                                                    }
                                                },
                                                "Set_CurrentIndex": {
                                                    "type": "SetVariable",
                                                    "inputs": {
                                                        "name": "CurrentIndex",
                                                        "value": "@outputs('Compose_Next_Index')"
                                                    },
                                                    "runAfter": {
                                                        "Compose_Next_Index": [ "Succeeded" ]
                                                    }
                                                }
                                            },
                                            "runAfter": {
                                                "Set_CurrentIndex_to_Zero": [ "Succeeded" ]
                                            }
                                        }
                                    },
                                    "else": {
                                        "actions": {}
                                    },
                                    "runAfter": {
                                        "HTTP_-_Get_SAST_Results_Page": [ "Succeeded" ]
                                    }
                                }
                            },
                            "runAfter": {
                                "HTTP_-_Get_Scans": [ "Succeeded" ]
                            }
                        }
                    },
                    "outputs": {}
                },
                "parameters": {
                    "$connections": {
                        "value": {
                            "keyvault": {
                                "id": "[subscriptionResourceId('Microsoft.Web/locations/managedApis', resourceGroup().location, 'keyvault')]",
                                "connectionId": "[resourceId('Microsoft.Web/connections', concat('keyvault-', parameters('PlaybookName')))]",
                                "connectionName": "[concat('keyvault-', parameters('PlaybookName'))]",
                                "connectionProperties": {
                                    "authentication": {
                                        "type": "ManagedServiceIdentity"
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    ],
    "outputs": {
        "logicAppName": {
            "type": "string",
            "value": "[parameters('PlaybookName')]"
        },
        "logicAppResourceId": {
            "type": "string",
            "value": "[resourceId('Microsoft.Logic/workflows', parameters('PlaybookName'))]"
        },
        "logicAppPrincipalId": {
            "type": "string",
            "value": "[reference(resourceId('Microsoft.Logic/workflows', parameters('PlaybookName')), '2019-05-01', 'full').identity.principalId]"
        }
    }
}
