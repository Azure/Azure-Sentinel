{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "metadata": {
        "title": "AS-Checkmarx-SAST-Ingestion",
        "description": "This playbook ingests Checkmarx SAST scan findings into a custom Microsoft Sentinel table on a daily schedule. This single template deploys the custom Log Analytics table, Data Collection Endpoint, Data Collection Rule, Key Vault API connection, Logic App, and all required role assignments.",
        "prerequisites": [
            "1. A Key Vault secret containing the Checkmarx refresh token",
            "2. An existing Log Analytics workspace"
        ],
        "postDeployment": [
            "1. Allow up to 10 minutes for role assignments to propagate",
            "2. Enable the Logic App (deployed in Disabled state) and run it to backfill"
        ],
        "lastUpdateTime": "2026-04-23T00:00:00Z",
        "support": {
            "tier": "partner"
        },
        "author": {
            "name": "Accelerynt"
        }
    },
    "parameters": {
        "PlaybookName": {
            "type": "string",
            "defaultValue": "AS-Checkmarx-SAST-Ingestion",
            "metadata": {
                "description": "Name of the Logic App"
            }
        },
        "WorkspaceName": {
            "type": "string",
            "metadata": {
                "description": "Name of the Log Analytics workspace where the custom table will be created"
            }
        },
        "WorkspaceResourceId": {
            "type": "string",
            "metadata": {
                "description": "Full resource ID of the Log Analytics workspace"
            }
        },
        "WorkspaceLocation": {
            "type": "string",
            "metadata": {
                "description": "Azure region of the Log Analytics workspace (used for the DCE and DCR; may differ from the resource group region)"
            }
        },
        "KeyVaultName": {
            "type": "string",
            "metadata": {
                "description": "Name of the Key Vault containing the Checkmarx refresh token"
            }
        },
        "KeyVaultResourceGroup": {
            "type": "string",
            "metadata": {
                "description": "Resource group containing the Key Vault"
            }
        },
        "KeyVaultSecretName": {
            "type": "string",
            "defaultValue": "checkmarx-integration-secret",
            "metadata": {
                "description": "Name of the Key Vault secret (refresh token or client secret depending on GrantType)"
            }
        },
        "CheckmarxIAMBaseUrl": {
            "type": "string",
            "defaultValue": "https://us.iam.checkmarx.net",
            "metadata": {
                "description": "Checkmarx IAM base URL for authentication (e.g., https://us.iam.checkmarx.net, https://eu.iam.checkmarx.net)"
            }
        },
        "CheckmarxASTBaseUrl": {
            "type": "string",
            "defaultValue": "https://us.ast.checkmarx.net",
            "metadata": {
                "description": "Checkmarx AST base URL for API calls (e.g., https://us.ast.checkmarx.net, https://eu.ast.checkmarx.net)"
            }
        },
        "CheckmarxTenant": {
            "type": "string",
            "metadata": {
                "description": "Checkmarx tenant/realm name used in the authentication URL"
            }
        },
        "CheckmarxClientId": {
            "type": "string",
            "metadata": {
                "description": "Checkmarx OAuth Client ID (e.g., ast-app)"
            }
        },
        "GrantType": {
            "type": "string",
            "allowedValues": [
                "refresh_token",
                "client_credentials"
            ],
            "metadata": {
                "description": "OAuth grant type. Use 'refresh_token' with a refresh token, or 'client_credentials' with a client secret stored in Key Vault."
            }
        },
        "LookbackDays": {
            "type": "int",
            "defaultValue": 7,
            "minValue": 1,
            "metadata": {
                "description": "Number of days prior to each run to pull completed Checkmarx scans from. Set higher for an initial backfill, then lower for steady-state daily runs."
            }
        },
        "ScanPageSize": {
            "type": "int",
            "defaultValue": 100,
            "metadata": {
                "description": "Page size for the Checkmarx /api/scans pagination loop"
            }
        },
        "BatchSize": {
            "type": "int",
            "defaultValue": 200,
            "metadata": {
                "description": "Number of SAST results sent per DCR ingestion request. The DCR API enforces a 1 MB maximum payload size; this controls how results are chunked to stay under that limit."
            }
        }
    },
    "variables": {
        "tableName": "CheckmarxSASTFindings_CL",
        "streamName": "Custom-CheckmarxSASTFindings_CL",
        "dataCollectionEndpointName": "dce-checkmarx-sast-ingestion",
        "dataCollectionRuleName": "dcr-checkmarx-sast-ingestion",
        "connectionName": "[concat('keyvault-', parameters('PlaybookName'))]",
        "keyVaultRoleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '4633458b-17de-408a-b874-0445c86b69e6')]",
        "monitoringMetricsPublisherRoleId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '3913510d-42f4-4e42-8a64-420c390055eb')]",
        "kvRoleAssignmentDeploymentName": "[concat('kv-role-', uniqueString(parameters('PlaybookName'), parameters('KeyVaultName'), resourceGroup().id))]",
        "dcrRoleAssignmentName": "[guid(resourceId('Microsoft.Insights/dataCollectionRules', variables('dataCollectionRuleName')), parameters('PlaybookName'), 'MonitoringMetricsPublisher')]"
    },
    "resources": [
        {
            "type": "Microsoft.OperationalInsights/workspaces/tables",
            "apiVersion": "2022-10-01",
            "name": "[concat(parameters('WorkspaceName'), '/', variables('tableName'))]",
            "properties": {
                "totalRetentionInDays": 90,
                "plan": "Analytics",
                "schema": {
                    "name": "[variables('tableName')]",
                    "columns": [
                        { "name": "TimeGenerated", "type": "datetime", "description": "Populated by the DCR transform at ingestion. Declared here because Sentinel custom tables require it (MSG 1005). NOT declared in the DCR stream declaration and NOT populated in the Logic App Select — the transform is the single source of truth." },
                        { "name": "ResultHash", "type": "string", "description": "Unique hash for the result" },
                        { "name": "QueryID", "type": "string", "description": "ID of the query that found the vulnerability" },
                        { "name": "QueryName", "type": "string", "description": "Name of the vulnerability query" },
                        { "name": "LanguageName", "type": "string", "description": "Programming language" },
                        { "name": "VulnerabilityGroup", "type": "string", "description": "Category/group of the vulnerability" },
                        { "name": "CweID", "type": "int", "description": "Common Weakness Enumeration ID" },
                        { "name": "Severity", "type": "string", "description": "Severity level (HIGH, MEDIUM, LOW, INFO)" },
                        { "name": "CvssScore", "type": "real", "description": "CVSS vulnerability score" },
                        { "name": "SimilarityID", "type": "int", "description": "ID for similar vulnerabilities" },
                        { "name": "State", "type": "string", "description": "Current state (TO_VERIFY, CONFIRMED, etc.)" },
                        { "name": "Status", "type": "string", "description": "Status (NEW, RECURRENT, FIXED)" },
                        { "name": "ConfidenceLevel", "type": "int", "description": "Confidence level of the finding" },
                        { "name": "FirstFoundAt", "type": "datetime", "description": "When the vulnerability was first found" },
                        { "name": "FoundAt", "type": "datetime", "description": "When the vulnerability was found in this scan" },
                        { "name": "FirstScanID", "type": "string", "description": "ID of the first scan that found this vulnerability" },
                        { "name": "Compliances", "type": "string", "description": "Comma-separated list of compliance frameworks" },
                        { "name": "SourceFileName", "type": "string", "description": "Source file containing the vulnerability" },
                        { "name": "SourceLine", "type": "int", "description": "Line number in the source file" },
                        { "name": "SourceColumn", "type": "int", "description": "Column number in the source file" },
                        { "name": "NodeCount", "type": "int", "description": "Number of nodes in the vulnerability path" },
                        { "name": "NodesJson", "type": "string", "description": "JSON representation of the data flow nodes" },
                        { "name": "ScanID", "type": "string", "description": "ID of the scan" },
                        { "name": "ProjectName", "type": "string", "description": "Name of the Checkmarx project, sourced from the top-level scan payload" },
                        { "name": "Initiator", "type": "string", "description": "User or system that initiated the scan, sourced from the top-level scan payload" }
                    ]
                }
            }
        },
        {
            "type": "Microsoft.Insights/dataCollectionEndpoints",
            "apiVersion": "2022-06-01",
            "name": "[variables('dataCollectionEndpointName')]",
            "location": "[parameters('WorkspaceLocation')]",
            "properties": {
                "networkAcls": {
                    "publicNetworkAccess": "Enabled"
                }
            }
        },
        {
            "type": "Microsoft.Insights/dataCollectionRules",
            "apiVersion": "2022-06-01",
            "name": "[variables('dataCollectionRuleName')]",
            "location": "[parameters('WorkspaceLocation')]",
            "dependsOn": [
                "[resourceId('Microsoft.Insights/dataCollectionEndpoints', variables('dataCollectionEndpointName'))]",
                "[resourceId('Microsoft.OperationalInsights/workspaces/tables', parameters('WorkspaceName'), variables('tableName'))]"
            ],
            "properties": {
                "dataCollectionEndpointId": "[resourceId('Microsoft.Insights/dataCollectionEndpoints', variables('dataCollectionEndpointName'))]",
                "streamDeclarations": {
                    "[variables('streamName')]": {
                        "columns": [
                            { "name": "ResultHash", "type": "string" },
                            { "name": "QueryID", "type": "string" },
                            { "name": "QueryName", "type": "string" },
                            { "name": "LanguageName", "type": "string" },
                            { "name": "VulnerabilityGroup", "type": "string" },
                            { "name": "CweID", "type": "int" },
                            { "name": "Severity", "type": "string" },
                            { "name": "CvssScore", "type": "real" },
                            { "name": "SimilarityID", "type": "int" },
                            { "name": "State", "type": "string" },
                            { "name": "Status", "type": "string" },
                            { "name": "ConfidenceLevel", "type": "int" },
                            { "name": "FirstFoundAt", "type": "datetime" },
                            { "name": "FoundAt", "type": "datetime" },
                            { "name": "FirstScanID", "type": "string" },
                            { "name": "Compliances", "type": "string" },
                            { "name": "SourceFileName", "type": "string" },
                            { "name": "SourceLine", "type": "int" },
                            { "name": "SourceColumn", "type": "int" },
                            { "name": "NodeCount", "type": "int" },
                            { "name": "NodesJson", "type": "string" },
                            { "name": "ScanID", "type": "string" },
                            { "name": "ProjectName", "type": "string" },
                            { "name": "Initiator", "type": "string" }
                        ]
                    }
                },
                "destinations": {
                    "logAnalytics": [
                        {
                            "workspaceResourceId": "[parameters('WorkspaceResourceId')]",
                            "name": "LogAnalyticsDestination"
                        }
                    ]
                },
                "dataFlows": [
                    {
                        "streams": [
                            "[variables('streamName')]"
                        ],
                        "destinations": [
                            "LogAnalyticsDestination"
                        ],
                        "transformKql": "source | extend TimeGenerated = now()",
                        "outputStream": "[variables('streamName')]"
                    }
                ]
            }
        },
        {
            "type": "Microsoft.Web/connections",
            "apiVersion": "2016-06-01",
            "name": "[variables('connectionName')]",
            "location": "[resourceGroup().location]",
            "kind": "V1",
            "properties": {
                "displayName": "[variables('connectionName')]",
                "parameterValueType": "Alternative",
                "alternativeParameterValues": {
                    "vaultName": "[parameters('KeyVaultName')]"
                },
                "api": {
                    "id": "[concat('/subscriptions/', subscription().subscriptionId, '/providers/Microsoft.Web/locations/', resourceGroup().location, '/managedApis/keyvault')]"
                }
            }
        },
        {
            "type": "Microsoft.Logic/workflows",
            "apiVersion": "2019-05-01",
            "name": "[parameters('PlaybookName')]",
            "location": "[resourceGroup().location]",
            "identity": {
                "type": "SystemAssigned"
            },
            "dependsOn": [
                "[resourceId('Microsoft.Web/connections', variables('connectionName'))]",
                "[resourceId('Microsoft.Insights/dataCollectionEndpoints', variables('dataCollectionEndpointName'))]",
                "[resourceId('Microsoft.Insights/dataCollectionRules', variables('dataCollectionRuleName'))]"
            ],
            "properties": {
                "state": "Disabled",
                "definition": {
                    "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
                    "contentVersion": "1.0.0.0",
                    "triggers": {
                        "Recurrence": {
                            "type": "Recurrence",
                            "recurrence": {
                                "interval": 1,
                                "frequency": "Day"
                            }
                        }
                    },
                    "actions": {
                        "Initialize_Variables": {
                            "type": "InitializeVariable",
                            "inputs": {
                                "variables": [
                                    {
                                        "name": "BatchSize",
                                        "type": "integer",
                                        "value": "[parameters('BatchSize')]"
                                    },
                                    {
                                        "name": "ScanPageSize",
                                        "type": "integer",
                                        "value": "[parameters('ScanPageSize')]"
                                    },
                                    {
                                        "name": "FromDate",
                                        "type": "string",
                                        "value": "[concat('@{addDays(utcNow(), -', parameters('LookbackDays'), ', ''yyyy-MM-ddTHH:mm:ssZ'')}')]"
                                    },
                                    {
                                        "name": "CurrentIndex",
                                        "type": "integer",
                                        "value": 0
                                    },
                                    {
                                        "name": "TotalResults",
                                        "type": "integer",
                                        "value": 0
                                    },
                                    {
                                        "name": "AllScans",
                                        "type": "array",
                                        "value": []
                                    },
                                    {
                                        "name": "ScanOffset",
                                        "type": "integer",
                                        "value": 0
                                    },
                                    {
                                        "name": "ScanFilteredTotal",
                                        "type": "integer",
                                        "value": 1
                                    }
                                ]
                            },
                            "runAfter": {}
                        },
                        "Get_secret": {
                            "type": "ApiConnection",
                            "inputs": {
                                "host": {
                                    "connection": {
                                        "name": "@parameters('$connections')['keyvault']['connectionId']"
                                    }
                                },
                                "method": "get",
                                "path": "[concat('/secrets/@{encodeURIComponent(''', parameters('KeyVaultSecretName'), ''')}/value')]"
                            },
                            "runAfter": {
                                "Initialize_Variables": [
                                    "Succeeded"
                                ]
                            },
                            "runtimeConfiguration": {
                                "secureData": {
                                    "properties": [
                                        "inputs",
                                        "outputs"
                                    ]
                                }
                            }
                        },
                        "HTTP_-_Get_Token": {
                            "type": "Http",
                            "inputs": {
                                "uri": "[concat(parameters('CheckmarxIAMBaseUrl'), '/auth/realms/', parameters('CheckmarxTenant'), '/protocol/openid-connect/token')]",
                                "method": "POST",
                                "headers": {
                                    "Content-Type": "application/x-www-form-urlencoded"
                                },
                                "body": "[if(equals(parameters('GrantType'), 'client_credentials'), concat('grant_type=client_credentials&client_id=', parameters('CheckmarxClientId'), '&client_secret=@{body(''Get_secret'')?[''value'']}'), concat('grant_type=refresh_token&client_id=', parameters('CheckmarxClientId'), '&refresh_token=@{body(''Get_secret'')?[''value'']}'))]",
                                "retryPolicy": {
                                    "type": "exponential",
                                    "count": 3,
                                    "interval": "PT10S",
                                    "minimumInterval": "PT10S",
                                    "maximumInterval": "PT1M"
                                }
                            },
                            "runAfter": {
                                "Get_secret": [
                                    "Succeeded"
                                ]
                            },
                            "runtimeConfiguration": {
                                "secureData": {
                                    "properties": [
                                        "inputs",
                                        "outputs"
                                    ]
                                }
                            }
                        },
                        "Until_All_Scans_Retrieved": {
                            "type": "Until",
                            "expression": "@greaterOrEquals(variables('ScanOffset'), variables('ScanFilteredTotal'))",
                            "limit": {
                                "count": 100,
                                "timeout": "PT30M"
                            },
                            "actions": {
                                "HTTP_-_Get_Scans_Page": {
                                    "type": "Http",
                                    "inputs": {
                                        "uri": "[concat(parameters('CheckmarxASTBaseUrl'), '/api/scans?statuses=Completed&from-date=@{variables(''FromDate'')}&limit=@{variables(''ScanPageSize'')}&offset=@{variables(''ScanOffset'')}')]",
                                        "method": "GET",
                                        "headers": {
                                            "Accept": "application/json",
                                            "Authorization": "Bearer @{body('HTTP_-_Get_Token')?['access_token']}"
                                        },
                                        "retryPolicy": {
                                            "type": "exponential",
                                            "count": 3,
                                            "interval": "PT10S",
                                            "minimumInterval": "PT10S",
                                            "maximumInterval": "PT1M"
                                        }
                                    },
                                    "runtimeConfiguration": {
                                        "secureData": {
                                            "properties": [
                                                "inputs"
                                            ]
                                        }
                                    }
                                },
                                "Set_ScanFilteredTotal": {
                                    "type": "SetVariable",
                                    "inputs": {
                                        "name": "ScanFilteredTotal",
                                        "value": "@body('HTTP_-_Get_Scans_Page')?['filteredTotalCount']"
                                    },
                                    "runAfter": {
                                        "HTTP_-_Get_Scans_Page": [
                                            "Succeeded"
                                        ]
                                    }
                                },
                                "Compose_Union_Scans": {
                                    "type": "Compose",
                                    "inputs": "@union(variables('AllScans'), coalesce(body('HTTP_-_Get_Scans_Page')?['scans'], json('[]')))",
                                    "runAfter": {
                                        "Set_ScanFilteredTotal": [
                                            "Succeeded"
                                        ]
                                    }
                                },
                                "Set_AllScans": {
                                    "type": "SetVariable",
                                    "inputs": {
                                        "name": "AllScans",
                                        "value": "@outputs('Compose_Union_Scans')"
                                    },
                                    "runAfter": {
                                        "Compose_Union_Scans": [
                                            "Succeeded"
                                        ]
                                    }
                                },
                                "Compose_Next_ScanOffset": {
                                    "type": "Compose",
                                    "inputs": "@add(variables('ScanOffset'), variables('ScanPageSize'))",
                                    "runAfter": {
                                        "Set_AllScans": [
                                            "Succeeded"
                                        ]
                                    }
                                },
                                "Set_ScanOffset": {
                                    "type": "SetVariable",
                                    "inputs": {
                                        "name": "ScanOffset",
                                        "value": "@outputs('Compose_Next_ScanOffset')"
                                    },
                                    "runAfter": {
                                        "Compose_Next_ScanOffset": [
                                            "Succeeded"
                                        ]
                                    }
                                }
                            },
                            "runAfter": {
                                "HTTP_-_Get_Token": [
                                    "Succeeded"
                                ]
                            }
                        },
                        "For_Each_Scan": {
                            "type": "Foreach",
                            "foreach": "@variables('AllScans')",
                            "actions": {
                                "HTTP_-_Get_SAST_Results_Page": {
                                    "type": "Http",
                                    "inputs": {
                                        "uri": "[concat(parameters('CheckmarxASTBaseUrl'), '/api/sast-results/?scan-id=@{items(''For_Each_Scan'')?[''id'']}')]",
                                        "method": "GET",
                                        "headers": {
                                            "Accept": "application/json",
                                            "Authorization": "Bearer @{body('HTTP_-_Get_Token')?['access_token']}"
                                        },
                                        "retryPolicy": {
                                            "type": "exponential",
                                            "count": 3,
                                            "interval": "PT10S",
                                            "minimumInterval": "PT10S",
                                            "maximumInterval": "PT1M"
                                        }
                                    },
                                    "runtimeConfiguration": {
                                        "secureData": {
                                            "properties": [
                                                "inputs"
                                            ]
                                        }
                                    }
                                },
                                "Condition_-_SAST_Results_Exist": {
                                    "type": "If",
                                    "expression": {
                                        "and": [
                                            {
                                                "greater": [
                                                    "@length(coalesce(body('HTTP_-_Get_SAST_Results_Page')?['results'], json('[]')))",
                                                    0
                                                ]
                                            }
                                        ]
                                    },
                                    "actions": {
                                        "Select_SAST_Results": {
                                            "type": "Select",
                                            "inputs": {
                                                "from": "@body('HTTP_-_Get_SAST_Results_Page')?['results']",
                                                "select": {
                                                    "ResultHash": "@item()?['resultHash']",
                                                    "QueryID": "@item()?['queryIDStr']",
                                                    "QueryName": "@item()?['queryName']",
                                                    "LanguageName": "@item()?['languageName']",
                                                    "VulnerabilityGroup": "@item()?['group']",
                                                    "CweID": "@item()?['cweID']",
                                                    "Severity": "@item()?['severity']",
                                                    "CvssScore": "@item()?['cvssScore']",
                                                    "SimilarityID": "@item()?['similarityID']",
                                                    "State": "@item()?['state']",
                                                    "Status": "@item()?['status']",
                                                    "ConfidenceLevel": "@item()?['confidenceLevel']",
                                                    "FirstFoundAt": "@item()?['firstFoundAt']",
                                                    "FoundAt": "@item()?['foundAt']",
                                                    "FirstScanID": "@item()?['firstScanID']",
                                                    "Compliances": "@join(item()?['compliances'], ', ')",
                                                    "SourceFileName": "@item()?['nodes'][0]?['fileName']",
                                                    "SourceLine": "@item()?['nodes'][0]?['line']",
                                                    "SourceColumn": "@item()?['nodes'][0]?['column']",
                                                    "NodeCount": "@length(item()?['nodes'])",
                                                    "NodesJson": "@string(item()?['nodes'])",
                                                    "ScanID": "@items('For_Each_Scan')?['id']",
                                                    "ProjectName": "@items('For_Each_Scan')?['projectName']",
                                                    "Initiator": "@items('For_Each_Scan')?['initiator']"
                                                }
                                            }
                                        },
                                        "Set_TotalResults": {
                                            "type": "SetVariable",
                                            "inputs": {
                                                "name": "TotalResults",
                                                "value": "@length(body('Select_SAST_Results'))"
                                            },
                                            "runAfter": {
                                                "Select_SAST_Results": [
                                                    "Succeeded"
                                                ]
                                            }
                                        },
                                        "Set_CurrentIndex_to_Zero": {
                                            "type": "SetVariable",
                                            "inputs": {
                                                "name": "CurrentIndex",
                                                "value": 0
                                            },
                                            "runAfter": {
                                                "Set_TotalResults": [
                                                    "Succeeded"
                                                ]
                                            }
                                        },
                                        "Until_All_Batches_Sent": {
                                            "type": "Until",
                                            "expression": "@greaterOrEquals(variables('CurrentIndex'), variables('TotalResults'))",
                                            "limit": {
                                                "count": 500,
                                                "timeout": "PT1H"
                                            },
                                            "actions": {
                                                "Compose_Current_Batch": {
                                                    "type": "Compose",
                                                    "inputs": "@take(skip(body('Select_SAST_Results'), variables('CurrentIndex')), variables('BatchSize'))"
                                                },
                                                "HTTP_-_Send_SAST_Batch_to_DCR": {
                                                    "type": "Http",
                                                    "inputs": {
                                                        "uri": "[concat(reference(resourceId('Microsoft.Insights/dataCollectionEndpoints', variables('dataCollectionEndpointName'))).logsIngestion.endpoint, '/dataCollectionRules/', reference(resourceId('Microsoft.Insights/dataCollectionRules', variables('dataCollectionRuleName'))).immutableId, '/streams/', variables('streamName'), '?api-version=2023-01-01')]",
                                                        "method": "POST",
                                                        "headers": {
                                                            "Content-Type": "application/json"
                                                        },
                                                        "body": "@outputs('Compose_Current_Batch')",
                                                        "authentication": {
                                                            "type": "ManagedServiceIdentity",
                                                            "audience": "https://monitor.azure.com"
                                                        },
                                                        "retryPolicy": {
                                                            "type": "exponential",
                                                            "count": 4,
                                                            "interval": "PT10S",
                                                            "minimumInterval": "PT10S",
                                                            "maximumInterval": "PT1M"
                                                        }
                                                    },
                                                    "runAfter": {
                                                        "Compose_Current_Batch": [
                                                            "Succeeded"
                                                        ]
                                                    }
                                                },
                                                "Compose_Next_Index": {
                                                    "type": "Compose",
                                                    "inputs": "@add(variables('CurrentIndex'), variables('BatchSize'))",
                                                    "runAfter": {
                                                        "HTTP_-_Send_SAST_Batch_to_DCR": [
                                                            "Succeeded"
                                                        ]
                                                    }
                                                },
                                                "Set_CurrentIndex": {
                                                    "type": "SetVariable",
                                                    "inputs": {
                                                        "name": "CurrentIndex",
                                                        "value": "@outputs('Compose_Next_Index')"
                                                    },
                                                    "runAfter": {
                                                        "Compose_Next_Index": [
                                                            "Succeeded"
                                                        ]
                                                    }
