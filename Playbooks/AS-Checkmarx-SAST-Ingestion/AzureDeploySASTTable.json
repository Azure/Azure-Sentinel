{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "workspaceName": {
            "type": "string",
            "metadata": {
                "description": "Name of the Log Analytics workspace"
            }
        }
    },
    "variables": {
        "tableName": "CheckmarxSASTFindings_CL"
    },
    "resources": [
        {
            "type": "Microsoft.OperationalInsights/workspaces/tables",
            "apiVersion": "2022-10-01",
            "name": "[concat(parameters('workspaceName'), '/', variables('tableName'))]",
            "properties": {
                "totalRetentionInDays": 90,
                "plan": "Analytics",
                "schema": {
                    "name": "[variables('tableName')]",
                    "columns": [
                        {
                            "name": "TimeGenerated",
                            "type": "datetime",
                            "description": "Time the record was ingested"
                        },
                        {
                            "name": "ResultHash",
                            "type": "string",
                            "description": "Unique hash for the result"
                        },
                        {
                            "name": "QueryID",
                            "type": "string",
                            "description": "ID of the query that found the vulnerability"
                        },
                        {
                            "name": "QueryName",
                            "type": "string",
                            "description": "Name of the vulnerability query"
                        },
                        {
                            "name": "LanguageName",
                            "type": "string",
                            "description": "Programming language"
                        },
                        {
                            "name": "VulnerabilityGroup",
                            "type": "string",
                            "description": "Category/group of the vulnerability"
                        },
                        {
                            "name": "CweID",
                            "type": "int",
                            "description": "Common Weakness Enumeration ID"
                        },
                        {
                            "name": "Severity",
                            "type": "string",
                            "description": "Severity level (HIGH, MEDIUM, LOW, INFO)"
                        },
                        {
                            "name": "CvssScore",
                            "type": "real",
                            "description": "CVSS vulnerability score"
                        },
                        {
                            "name": "SimilarityID",
                            "type": "int",
                            "description": "ID for similar vulnerabilities"
                        },
                        {
                            "name": "State",
                            "type": "string",
                            "description": "Current state (TO_VERIFY, CONFIRMED, etc.)"
                        },
                        {
                            "name": "Status",
                            "type": "string",
                            "description": "Status (NEW, RECURRENT, FIXED)"
                        },
                        {
                            "name": "ConfidenceLevel",
                            "type": "int",
                            "description": "Confidence level of the finding"
                        },
                        {
                            "name": "FirstFoundAt",
                            "type": "datetime",
                            "description": "When the vulnerability was first found"
                        },
                        {
                            "name": "FoundAt",
                            "type": "datetime",
                            "description": "When the vulnerability was found in this scan"
                        },
                        {
                            "name": "FirstScanID",
                            "type": "string",
                            "description": "ID of the first scan that found this"
                        },
                        {
                            "name": "Compliances",
                            "type": "string",
                            "description": "Comma-separated list of compliance frameworks"
                        },
                        {
                            "name": "SourceFileName",
                            "type": "string",
                            "description": "Source file containing the vulnerability"
                        },
                        {
                            "name": "SourceLine",
                            "type": "int",
                            "description": "Line number in the source file"
                        },
                        {
                            "name": "SourceColumn",
                            "type": "int",
                            "description": "Column number in the source file"
                        },
                        {
                            "name": "NodeCount",
                            "type": "int",
                            "description": "Number of nodes in the vulnerability path"
                        },
                        {
                            "name": "NodesJson",
                            "type": "string",
                            "description": "JSON representation of the data flow nodes"
                        },
                        {
                            "name": "ScanID",
                            "type": "string",
                            "description": "ID of the scan"
                        }
                    ]
                },
                "retentionInDays": 90
            }
        }
    ],
    "outputs": {
        "tableName": {
            "type": "string",
            "value": "[variables('tableName')]"
        }
    }
}
