{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "metadata": {
        "title": "AS-Checkmarx-Audit-Ingestion",
        "description": "This playbook ingests Checkmarx audit log events into a custom Microsoft Sentinel table on a daily schedule. This single template deploys the custom Log Analytics table, Data Collection Endpoint, Data Collection Rule, Key Vault API connection, Logic App, and all required role assignments.",
        "prerequisites": [
            "1. A Key Vault secret containing the Checkmarx client secret or refresh token",
            "2. An existing Log Analytics workspace"
        ],
        "postDeployment": [
            "1. Allow up to 10 minutes for role assignments to propagate",
            "2. Enable the Logic App (deployed in Disabled state) and run it"
        ],
        "lastUpdateTime": "2026-06-12T00:00:00.000Z",
        "support": {
            "tier": "partner"
        },
        "author": {
            "name": "Accelerynt"
        }
    },
    "parameters": {
        "PlaybookName": {
            "type": "string",
            "defaultValue": "AS-Checkmarx-Audit-Ingestion",
            "metadata": {
                "description": "Name of the Logic App"
            }
        },
        "WorkspaceName": {
            "type": "string",
            "metadata": {
                "description": "Name of the Log Analytics workspace where the custom table will be created"
            }
        },
        "WorkspaceResourceId": {
            "type": "string",
            "metadata": {
                "description": "Full resource ID of the Log Analytics workspace"
            }
        },
        "WorkspaceLocation": {
            "type": "string",
            "metadata": {
                "description": "Azure region of the Log Analytics workspace (used for the DCE and DCR; may differ from the resource group region)"
            }
        },
        "KeyVaultName": {
            "type": "string",
            "metadata": {
                "description": "Name of the Key Vault containing the Checkmarx client secret or refresh token"
            }
        },
        "KeyVaultResourceGroup": {
            "type": "string",
            "metadata": {
                "description": "Resource group containing the Key Vault"
            }
        },
        "KeyVaultSecretName": {
            "type": "string",
            "defaultValue": "checkmarx-integration-secret",
            "metadata": {
                "description": "Name of the Key Vault secret containing the Checkmarx client secret or refresh token"
            }
        },
        "DataCollectionEndpointName": {
            "type": "string",
            "defaultValue": "dce-checkmarx-audit-ingestion",
            "metadata": {
                "description": "Name of the Data Collection Endpoint. Override the default if deploying multiple ingestion playbooks into the same resource group to avoid name collisions."
            }
        },
        "DataCollectionRuleName": {
            "type": "string",
            "defaultValue": "dcr-checkmarx-audit-ingestion",
            "metadata": {
                "description": "Name of the Data Collection Rule. Override the default if deploying multiple ingestion playbooks into the same resource group to avoid name collisions."
            }
        },
        "CheckmarxIAMBaseUrl": {
            "type": "string",
            "defaultValue": "https://us.iam.checkmarx.net",
            "metadata": {
                "description": "Checkmarx IAM base URL for authentication (e.g., https://us.iam.checkmarx.net, https://eu.iam.checkmarx.net)"
            }
        },
        "CheckmarxASTBaseUrl": {
            "type": "string",
            "defaultValue": "https://us.ast.checkmarx.net",
            "metadata": {
                "description": "Checkmarx AST base URL for API calls (e.g., https://us.ast.checkmarx.net, https://eu.ast.checkmarx.net)"
            }
        },
        "CheckmarxTenant": {
            "type": "string",
            "metadata": {
                "description": "Checkmarx tenant/realm name used in the authentication URL"
            }
        },
        "CheckmarxClientId": {
            "type": "string",
            "metadata": {
                "description": "Checkmarx OAuth Client ID (e.g., ast-app)"
            }
        },
        "GrantType": {
            "type": "string",
            "allowedValues": [
                "refresh_token",
                "client_credentials"
            ],
            "metadata": {
                "description": "OAuth grant type. Use 'refresh_token' with a refresh token stored in Key Vault, or 'client_credentials' with a client secret stored in Key Vault."
            }
        },
        "LookbackDays": {
            "type": "int",
            "defaultValue": 2,
            "minValue": 1,
            "metadata": {
                "description": "Number of days prior to each run to pull audit events from. Default is 2. For the initial backfill, set this higher (up to 365, the Checkmarx retention maximum) to ingest historical events, then reduce for steady-state daily operation. Can be changed later by editing the LookbackDays variable in the Logic App's Initialize_Variables action."
            }
        }
    },
    "variables": {
        "tableName": "CheckmarxAuditEvents_CL",
        "streamName": "Custom-CheckmarxAuditEvents_CL",
        "connectionName": "[concat('keyvault-', parameters('PlaybookName'))]",
        "keyVaultRoleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '4633458b-17de-408a-b874-0445c86b69e6')]",
        "monitoringMetricsPublisherRoleId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '3913510d-42f4-4e42-8a64-420c390055eb')]",
        "kvRoleAssignmentDeploymentName": "[concat('kv-role-', uniqueString(parameters('PlaybookName'), parameters('KeyVaultName'), resourceGroup().id))]",
        "dcrRoleAssignmentName": "[guid(resourceId('Microsoft.Insights/dataCollectionRules', parameters('DataCollectionRuleName')), parameters('PlaybookName'), 'MonitoringMetricsPublisher')]"
    },
    "resources": [
        {
            "type": "Microsoft.OperationalInsights/workspaces/tables",
            "apiVersion": "2022-10-01",
            "name": "[concat(parameters('WorkspaceName'), '/', variables('tableName'))]",
            "properties": {
                "totalRetentionInDays": 90,
                "plan": "Analytics",
                "schema": {
                    "name": "[variables('tableName')]",
                    "columns": [
                        { "name": "TimeGenerated", "type": "datetime", "description": "Populated by the DCR transform at ingestion. Declared here because Sentinel custom tables require it (MSG 1005). NOT declared in the DCR stream declaration and NOT populated in the Logic App Select \u2014 the transform is the single source of truth." },
                        { "name": "EventID", "type": "string" },
                        { "name": "EventDate", "type": "datetime", "description": "Date and time of the audit event" },
                        { "name": "EventType", "type": "string", "description": "Type of audit event (e.g., events.cxiam.user.account.login)" },
                        { "name": "AuditResource", "type": "string", "description": "Resource being audited (e.g., user.account)" },
                        { "name": "ActionType", "type": "string", "description": "Type of action performed (e.g., login)" },
                        { "name": "ActionUserId", "type": "string", "description": "User ID who performed the action" },
                        { "name": "IpAddress", "type": "string", "description": "IP address of the user" },
                        { "name": "TenantID", "type": "string" },
                        { "name": "UserId", "type": "string", "description": "User ID from data payload" },
                        { "name": "Status", "type": "string", "description": "Status of the action (e.g., OK)" },
                        { "name": "Username", "type": "string", "description": "Username who performed the action" },
                        { "name": "DataJson", "type": "string", "description": "Full JSON data payload" }
                    ]
                }
            }
        },
        {
            "type": "Microsoft.Insights/dataCollectionEndpoints",
            "apiVersion": "2022-06-01",
            "name": "[parameters('DataCollectionEndpointName')]",
            "location": "[parameters('WorkspaceLocation')]",
            "properties": {
                "networkAcls": {
                    "publicNetworkAccess": "Enabled"
                }
            }
        },
        {
            "type": "Microsoft.Insights/dataCollectionRules",
            "apiVersion": "2022-06-01",
            "name": "[parameters('DataCollectionRuleName')]",
            "location": "[parameters('WorkspaceLocation')]",
            "dependsOn": [
                "[resourceId('Microsoft.Insights/dataCollectionEndpoints', parameters('DataCollectionEndpointName'))]",
                "[resourceId('Microsoft.OperationalInsights/workspaces/tables', parameters('WorkspaceName'), variables('tableName'))]"
            ],
            "properties": {
                "dataCollectionEndpointId": "[resourceId('Microsoft.Insights/dataCollectionEndpoints', parameters('DataCollectionEndpointName'))]",
                "streamDeclarations": {
                    "[variables('streamName')]": {
                        "columns": [
                            { "name": "EventID", "type": "string" },
                            { "name": "EventDate", "type": "datetime" },
                            { "name": "EventType", "type": "string" },
                            { "name": "AuditResource", "type": "string" },
                            { "name": "ActionType", "type": "string" },
                            { "name": "ActionUserId", "type": "string" },
                            { "name": "IpAddress", "type": "string" },
                            { "name": "TenantID", "type": "string" },
                            { "name": "UserId", "type": "string" },
                            { "name": "Status", "type": "string" },
                            { "name": "Username", "type": "string" },
                            { "name": "DataJson", "type": "string" }
                        ]
                    }
                },
                "destinations": {
                    "logAnalytics": [
                        {
                            "workspaceResourceId": "[parameters('WorkspaceResourceId')]",
                            "name": "LogAnalyticsDestination"
                        }
                    ]
                },
                "dataFlows": [
                    {
                        "streams": [
                            "[variables('streamName')]"
                        ],
                        "destinations": [
                            "LogAnalyticsDestination"
                        ],
                        "transformKql": "source | extend TimeGenerated = now()",
                        "outputStream": "[variables('streamName')]"
                    }
                ]
            }
        },
        {
            "type": "Microsoft.Web/connections",
            "apiVersion": "2016-06-01",
            "name": "[variables('connectionName')]",
            "location": "[resourceGroup().location]",
            "kind": "V1",
            "properties": {
                "displayName": "[variables('connectionName')]",
                "parameterValueType": "Alternative",
                "alternativeParameterValues": {
                    "vaultName": "[parameters('KeyVaultName')]"
                },
                "api": {
                    "id": "[concat('/subscriptions/', subscription().subscriptionId, '/providers/Microsoft.Web/locations/', resourceGroup().location, '/managedApis/keyvault')]"
                }
            }
        },
        {
            "type": "Microsoft.Logic/workflows",
            "apiVersion": "2019-05-01",
            "name": "[parameters('PlaybookName')]",
            "location": "[resourceGroup().location]",
            "identity": {
                "type": "SystemAssigned"
            },
            "dependsOn": [
                "[resourceId('Microsoft.Web/connections', variables('connectionName'))]",
                "[resourceId('Microsoft.Insights/dataCollectionEndpoints', parameters('DataCollectionEndpointName'))]",
                "[resourceId('Microsoft.Insights/dataCollectionRules', parameters('DataCollectionRuleName'))]"
            ],
            "properties": {
                "state": "Disabled",
                "definition": {
                    "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
                    "contentVersion": "1.0.0.0",
                    "triggers": {
                        "Recurrence": {
                            "type": "Recurrence",
                            "recurrence": {
                                "interval": 1,
                                "frequency": "Day"
                            }
                        }
                    },
                    "actions": {
                        "Initialize_Variables": {
                            "type": "InitializeVariable",
                            "inputs": {
                                "variables": [
                                    {
                                        "name": "AuditPageSize",
                                        "type": "integer",
                                        "value": 1000
                                    },
                                    {
                                        "name": "FromDate",
                                        "type": "string",
                                        "value": "[concat('@{addDays(utcNow(), -', parameters('LookbackDays'), ', ''yyyy-MM-ddTHH:mm:ssZ'')}')]"
                                    },
                                    {
                                        "name": "NextPageUrl",
                                        "type": "string",
                                        "value": ""
                                    },
                                    {
                                        "name": "CheckmarxASTBaseUrl",
                                        "type": "string",
                                        "value": "[parameters('CheckmarxASTBaseUrl')]"
                                    }
                                ]
                            },
                            "runAfter": {}
                        },
                        "Get_secret": {
                            "type": "ApiConnection",
                            "inputs": {
                                "host": {
                                    "connection": {
                                        "name": "@parameters('$connections')['keyvault']['connectionId']"
                                    }
                                },
                                "method": "get",
                                "path": "[concat('/secrets/@{encodeURIComponent(''', parameters('KeyVaultSecretName'), ''')}/value')]"
                            },
                            "runAfter": {
                                "Initialize_Variables": [
                                    "Succeeded"
                                ]
                            },
                            "runtimeConfiguration": {
                                "secureData": {
                                    "properties": [
                                        "inputs",
                                        "outputs"
                                    ]
                                }
                            }
                        },
                        "Set_Variable_-_NextPageUrl_Initial": {
                            "type": "SetVariable",
                            "inputs": {
                                "name": "NextPageUrl",
                                "value": "[concat('@{concat(''', parameters('CheckmarxASTBaseUrl'), '/api/audit-events/?startDate='', variables(''FromDate''), ''&offset=0&limit='', variables(''AuditPageSize''))}')]"
                            },
                            "runAfter": {
                                "Get_secret": [
                                    "Succeeded"
                                ]
                            }
                        },
                        "Until_-_Paginate_Audit_Logs": {
                                    "type": "Until",
                                    "expression": "@equals(variables('NextPageUrl'), '')",
                                    "limit": {
                                        "count": 100,
                                        "timeout": "PT15M"
                                    },
                                    "actions": {
                                        "HTTP_-_Get_Token": {
                                            "type": "Http",
                                            "inputs": {
                                                "method": "POST",
                                                "uri": "[concat(parameters('CheckmarxIAMBaseUrl'), '/auth/realms/', parameters('CheckmarxTenant'), '/protocol/openid-connect/token')]",
                                                "headers": {
                                                    "Content-Type": "application/x-www-form-urlencoded"
                                                },
                                                "body": "[if(equals(parameters('GrantType'), 'client_credentials'), concat('grant_type=client_credentials&client_id=', parameters('CheckmarxClientId'), '&client_secret=@{body(''Get_secret'')?[''value'']}'), concat('grant_type=refresh_token&client_id=', parameters('CheckmarxClientId'), '&refresh_token=@{body(''Get_secret'')?[''value'']}'))]",
                                                "retryPolicy": {
                                                    "type": "exponential",
                                                    "count": 3,
                                                    "interval": "PT10S",
                                                    "minimumInterval": "PT10S",
                                                    "maximumInterval": "PT1M"
                                                }
                                            },
                                            "runAfter": {},
                                            "runtimeConfiguration": {
                                                "secureData": {
                                                    "properties": [
                                                        "inputs",
                                                        "outputs"
                                                    ]
                                                }
                                            }
                                        },
                                        "HTTP_-_Get_Audit_Events_Page": {
                                            "type": "Http",
                                            "inputs": {
                                                "method": "GET",
                                                "uri": "@{variables('NextPageUrl')}",
                                                "headers": {
                                                    "Accept": "*/*; version=1.0",
                                                    "Authorization": "Bearer @{body('HTTP_-_Get_Token')?['access_token']}"
                                                },
                                                "retryPolicy": {
                                                    "type": "exponential",
                                                    "count": 3,
                                                    "interval": "PT10S",
                                                    "minimumInterval": "PT10S",
                                                    "maximumInterval": "PT1M"
                                                }
                                            },
                                            "runAfter": {
                                                "HTTP_-_Get_Token": [
                                                    "Succeeded"
                                                ]
                                            },
                                            "runtimeConfiguration": {
                                                "secureData": {
                                                    "properties": [
                                                        "inputs"
                                                    ]
                                                }
                                            }
                                        },
                                        "Condition_-_Audit_Page_Has_Events": {
                                            "type": "If",
                                            "expression": {
                                                "and": [
                                                    {
                                                        "greater": [
                                                            "@length(coalesce(body('HTTP_-_Get_Audit_Events_Page')?['events'], json('[]')))",
                                                            0
                                                        ]
                                                    }
                                                ]
                                            },
                                            "actions": {
                                                "Select_-_Audit_Events": {
                                                    "type": "Select",
                                                    "inputs": {
                                                        "from": "@body('HTTP_-_Get_Audit_Events_Page')?['events']",
                                                        "select": {
                                                            "EventID": "@item()?['eventID']",
                                                            "EventDate": "@item()?['eventDate']",
                                                            "EventType": "@item()?['eventType']",
                                                            "AuditResource": "@item()?['auditResource']",
                                                            "ActionType": "@item()?['actionType']",
                                                            "ActionUserId": "@item()?['actionUserId']",
                                                            "IpAddress": "@coalesce(item()?['ipAddress'], '')",
                                                            "TenantID": "@item()?['tenantID']",
                                                            "UserId": "@item()?['data']?['id']",
                                                            "Status": "@item()?['data']?['status']",
                                                            "Username": "@item()?['data']?['username']",
                                                            "DataJson": "@string(item()?['data'])"
                                                        }
                                                    },
                                                    "runAfter": {}
                                                },
                                                "HTTP_-_Send_Audit_Events_to_DCR": {
                                                    "type": "Http",
                                                    "inputs": {
                                                        "method": "POST",
                                                        "uri": "[concat(reference(resourceId('Microsoft.Insights/dataCollectionEndpoints', parameters('DataCollectionEndpointName'))).logsIngestion.endpoint, '/dataCollectionRules/', reference(resourceId('Microsoft.Insights/dataCollectionRules', parameters('DataCollectionRuleName'))).immutableId, '/streams/', variables('streamName'), '?api-version=2023-01-01')]",
                                                        "headers": {
                                                            "Content-Type": "application/json"
                                                        },
                                                        "body": "@body('Select_-_Audit_Events')",
                                                        "authentication": {
                                                            "type": "ManagedServiceIdentity",
                                                            "audience": "https://monitor.azure.com"
                                                        },
                                                        "retryPolicy": {
                                                            "type": "exponential",
                                                            "count": 4,
                                                            "interval": "PT10S",
                                                            "minimumInterval": "PT10S",
                                                            "maximumInterval": "PT1M"
                                                        }
                                                    },
                                                    "runAfter": {
                                                        "Select_-_Audit_Events": [
                                                            "Succeeded"
                                                        ]
                                                    }
                                                }
                                            },
                                            "else": {
                                                "actions": {}
                                            },
                                            "runAfter": {
                                                "HTTP_-_Get_Audit_Events_Page": [
                                                    "Succeeded"
                                                ]
                                            }
                                        },
                                        "Compose_-_NextRelativeHref": {
                                            "type": "Compose",
                                            "inputs": "@coalesce(body('HTTP_-_Get_Audit_Events_Page')?['Links']?['_links']?['next']?['href'], '')",
                                            "runAfter": {
                                                "Condition_-_Audit_Page_Has_Events": [
                                                    "Succeeded"
                                                ]
                                            }
                                        },
                                        "Set_Variable_-_NextPageUrl": {
                                            "type": "SetVariable",
                                            "inputs": {
                                                "name": "NextPageUrl",
                                                "value": "@if(empty(outputs('Compose_-_NextRelativeHref')), '', concat(variables('CheckmarxASTBaseUrl'), outputs('Compose_-_NextRelativeHref')))"
                                            },
                                            "runAfter": {
                                                "Compose_-_NextRelativeHref": [
                                                    "Succeeded"
                                                ]
                                            }
                                        }
                                    },
                                    "runAfter": {
                                        "Set_Variable_-_NextPageUrl_Initial": [
                                            "Succeeded"
                                        ]
                                    }
                                }
                    },
                    "outputs": {},
                    "parameters": {
                        "$connections": {
                            "type": "Object",
                            "defaultValue": {}
                        }
                    }
                },
                "parameters": {
                    "$connections": {
                        "value": {
                            "keyvault": {
                                "id": "[concat('/subscriptions/', subscription().subscriptionId, '/providers/Microsoft.Web/locations/', resourceGroup().location, '/managedApis/keyvault')]",
                                "connectionId": "[resourceId('Microsoft.Web/connections', variables('connectionName'))]",
                                "connectionName": "[variables('connectionName')]",
                                "connectionProperties": {
                                    "authentication": {
                                        "type": "ManagedServiceIdentity"
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        {
            "type": "Microsoft.Authorization/roleAssignments",
            "apiVersion": "2022-04-01",
            "scope": "[resourceId('Microsoft.Insights/dataCollectionRules', parameters('DataCollectionRuleName'))]",
            "name": "[variables('dcrRoleAssignmentName')]",
            "dependsOn": [
                "[resourceId('Microsoft.Logic/workflows', parameters('PlaybookName'))]",
                "[resourceId('Microsoft.Insights/dataCollectionRules', parameters('DataCollectionRuleName'))]"
            ],
            "properties": {
                "roleDefinitionId": "[variables('monitoringMetricsPublisherRoleId')]",
                "principalId": "[reference(resourceId('Microsoft.Logic/workflows', parameters('PlaybookName')), '2019-05-01', 'Full').identity.principalId]",
                "principalType": "ServicePrincipal"
            }
        },
        {
            "type": "Microsoft.Resources/deployments",
            "apiVersion": "2021-04-01",
            "name": "[variables('kvRoleAssignmentDeploymentName')]",
            "resourceGroup": "[parameters('KeyVaultResourceGroup')]",
            "dependsOn": [
                "[resourceId('Microsoft.Logic/workflows', parameters('PlaybookName'))]"
            ],
            "properties": {
                "mode": "Incremental",
                "expressionEvaluationOptions": {
                    "scope": "inner"
                },
                "parameters": {
                    "KeyVaultName": {
                        "value": "[parameters('KeyVaultName')]"
                    },
                    "PrincipalId": {
                        "value": "[reference(resourceId('Microsoft.Logic/workflows', parameters('PlaybookName')), '2019-05-01', 'Full').identity.principalId]"
                    },
                    "RoleDefinitionId": {
                        "value": "[variables('keyVaultRoleDefinitionId')]"
                    },
                    "RoleAssignmentName": {
                        "value": "[guid(parameters('KeyVaultName'), parameters('PlaybookName'), 'KeyVaultSecretsUser')]"
                    }
                },
                "template": {
                    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
                    "contentVersion": "1.0.0.0",
                    "parameters": {
                        "KeyVaultName": {
                            "type": "string"
                        },
                        "PrincipalId": {
                            "type": "string"
                        },
                        "RoleDefinitionId": {
                            "type": "string"
                        },
                        "RoleAssignmentName": {
                            "type": "string"
                        }
                    },
                    "resources": [
                        {
                            "type": "Microsoft.KeyVault/vaults/providers/roleAssignments",
                            "apiVersion": "2022-04-01",
                            "name": "[concat(parameters('KeyVaultName'), '/Microsoft.Authorization/', parameters('RoleAssignmentName'))]",
                            "properties": {
                                "roleDefinitionId": "[parameters('RoleDefinitionId')]",
                                "principalId": "[parameters('PrincipalId')]",
                                "principalType": "ServicePrincipal"
                            }
                        }
                    ]
                }
            }
        }
    ],
    "outputs": {
        "playbookName": {
            "type": "string",
            "value": "[parameters('PlaybookName')]"
        },
        "tableName": {
            "type": "string",
            "value": "[variables('tableName')]"
        },
        "streamName": {
            "type": "string",
            "value": "[variables('streamName')]"
        },
        "dataCollectionEndpointId": {
            "type": "string",
            "value": "[resourceId('Microsoft.Insights/dataCollectionEndpoints', parameters('DataCollectionEndpointName'))]"
        },
        "dataCollectionRuleId": {
            "type": "string",
            "value": "[resourceId('Microsoft.Insights/dataCollectionRules', parameters('DataCollectionRuleName'))]"
        },
        "dcrImmutableId": {
            "type": "string",
            "value": "[reference(resourceId('Microsoft.Insights/dataCollectionRules', parameters('DataCollectionRuleName'))).immutableId]"
        },
        "logsIngestionEndpoint": {
            "type": "string",
            "value": "[reference(resourceId('Microsoft.Insights/dataCollectionEndpoints', parameters('DataCollectionEndpointName'))).logsIngestion.endpoint]"
        },
        "managedIdentityPrincipalId": {
            "type": "string",
            "value": "[reference(resourceId('Microsoft.Logic/workflows', parameters('PlaybookName')), '2019-05-01', 'Full').identity.principalId]"
        }
    }
}