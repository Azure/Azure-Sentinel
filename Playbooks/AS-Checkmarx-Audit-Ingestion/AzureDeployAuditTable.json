{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "workspaceName": {
            "type": "string",
            "metadata": {
                "description": "Name of the Log Analytics workspace"
            }
        }
    },
    "variables": {
        "tableName": "CheckmarxAuditEvents_CL"
    },
    "resources": [
        {
            "type": "Microsoft.OperationalInsights/workspaces/tables",
            "apiVersion": "2022-10-01",
            "name": "[concat(parameters('workspaceName'), '/', variables('tableName'))]",
            "properties": {
                "totalRetentionInDays": 90,
                "plan": "Analytics",
                "schema": {
                    "name": "[variables('tableName')]",
                    "columns": [
                        {
                            "name": "TimeGenerated",
                            "type": "datetime",
                            "description": "Time the record was ingested"
                        },
                        {
                            "name": "EventDate",
                            "type": "datetime",
                            "description": "Date and time of the audit event"
                        },
                        {
                            "name": "EventType",
                            "type": "string",
                            "description": "Type of audit event"
                        },
                        {
                            "name": "AuditResource",
                            "type": "string",
                            "description": "Resource being audited"
                        },
                        {
                            "name": "ActionType",
                            "type": "string",
                            "description": "Type of action performed"
                        },
                        {
                            "name": "ActionUserId",
                            "type": "string",
                            "description": "User ID who performed the action"
                        },
                        {
                            "name": "IpAddress",
                            "type": "string",
                            "description": "IP address of the user"
                        },
                        {
                            "name": "UserId",
                            "type": "string",
                            "description": "User ID from data payload"
                        },
                        {
                            "name": "Status",
                            "type": "string",
                            "description": "Status of the action"
                        },
                        {
                            "name": "Username",
                            "type": "string",
                            "description": "Username who performed the action"
                        },
                        {
                            "name": "DataJson",
                            "type": "string",
                            "description": "Full JSON data payload"
                        }
                    ]
                },
                "retentionInDays": 90
            }
        }
    ],
    "outputs": {
        "tableName": {
            "type": "string",
            "value": "[variables('tableName')]"
        }
    }
}
