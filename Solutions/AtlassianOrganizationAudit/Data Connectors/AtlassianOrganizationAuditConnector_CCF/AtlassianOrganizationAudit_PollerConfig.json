{
  "type": "Microsoft.SecurityInsights/dataConnectors",
  "apiVersion": "2024-09-01",
  "name": "[[concat('parameters('workspace')', '/Microsoft.SecurityInsights/','Custom-AtlassianAuditEvents_CL' , uniqueString(parameters('friendlyName')) )]",
  "location": "{{location}}",
  "kind": "RestApiPoller",
  "properties": {
    "auth": {
      "type": "APIKey",
      "ApiKey": "[[parameters('apiKey')]",
      "ApiKeyName": "Authorization",
      "ApiKeyIdentifier": "Bearer"
    },
    "request": {
      "apiEndpoint": "[[concat(parameters('atlassianApiBaseUrl'), '/admin/v1/orgs/', parameters('organizationId'), '/events-stream')]",
      "httpMethod": "GET",
      "rateLimitQPS": 1,
      "queryWindowInMin": 5,
      "retryCount": 4,
      "timeoutInSeconds": 60,
      "headers": {
        "Accept": "application/json"
      },
      "queryParameters": {
        "limit": "200",
        "sortOrder": "asc"
      }
    },
    "response": {
      "eventsJsonPaths": [
        "$.data[*]"
      ],
      "format": "json"
    },
    "paging": {
      "pagingType": "PersistentToken",
      "nextPageTokenJsonPath": "$.meta.next",
      "nextPageParaName": "cursor",
      "pageSize": 200
    },
    "connectorDefinitionName": "AtlassianAuditEventsConnector",
    "dataType": "Custom-AtlassianAuditEvents_CL",
    "dcrConfig": {
      "streamName": "Custom-AtlassianAuditEvents_CL",
      "dataCollectionEndpoint": "{{dataCollectionEndpoint}}",
      "dataCollectionRuleImmutableId": "{{dataCollectionRuleImmutableId}}"
    },
    "addOnAttributes": {
      "friendlyName": "[[parameters('friendlyName')]",
      "apiUrl": "[[parameters('atlassianApiBaseUrl')]",
      "organizationId": "[[parameters('organizationId')]",
      "dataType": "AtlassianAuditEvents"
    }
  }
}