{
  "name": "AtlassianAuditEventsDCR",
  "apiVersion": "2023-03-11",
  "type": "Microsoft.Insights/dataCollectionRules",
  "location": "{{location}}",
  "properties": {
    "dataCollectionEndpointId": "{{dataCollectionEndpointId}}",
    "streamDeclarations": {
      "Custom-AtlassianAuditEvents_CL": {
        "columns": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "attributes",
            "type": "dynamic"
          },
          {
            "name": "message",
            "type": "dynamic"
          },
          {
            "name": "links",
            "type": "dynamic"
          }
        ]
      }
    },
    "destinations": {
      "logAnalytics": [
        {
          "workspaceResourceId": "{{workspaceResourceId}}",
          "name": "clv2ws1"
        }
      ]
    },
    "dataFlows": [
      {
        "streams": [
          "Custom-AtlassianAuditEvents_CL"
        ],
        "destinations": [
          "clv2ws1"
        ],
        "outputStream": "Custom-AtlassianAuditEvents_CL",
        "transformKql": "source  | project TimeGenerated=now(),EventId=tostring(id),Action=tostring(attributes.action),EventMessage=tostring(message.content),ActorEmail=tostring(attributes.actor.email),ActorId=tostring(attributes.actor.id),ActorName=tostring(attributes.actor.name),AuthType=tostring(attributes.actor.auth.authType),AuthTokenLabel=tostring(attributes.actor.auth.tokenLabel),OnBehalfOfEmail=tostring(attributes.actor.onBehalfOf.email),AppId=tostring(attributes.actor.app.id),SrcIpAddr=tostring(attributes.location.ip),CountryName=tostring(attributes.location.countryName),CityName=tostring(attributes.location.city),Context=todynamic(attributes.context),Container=todynamic(attributes.container),ProcessedAt=todatetime(attributes.processedAt),EventUrl=tostring(links.self)"
      }
    ]
  }
}