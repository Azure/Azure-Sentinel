[
  {
    "name": "dcr-vaikora-agent-signals",
    "apiVersion": "2024-03-11",
    "type": "Microsoft.Insights/dataCollectionRules",
    "location": "{{location}}",
    "properties": {
      "dataCollectionEndpointId": "{{dataCollectionEndpointId}}",
      "streamDeclarations": {
        "Custom-Vaikora_AgentSignals_Raw": {
          "columns": [
            { "name": "id", "type": "string" },
            { "name": "agent_id", "type": "string" },
            { "name": "action_type", "type": "string" },
            { "name": "resource_type", "type": "string" },
            { "name": "resource_id", "type": "string" },
            { "name": "status", "type": "string" },
            { "name": "severity", "type": "string" },
            { "name": "policy_id", "type": "string" },
            { "name": "policy_decision", "type": "string" },
            { "name": "is_anomaly", "type": "boolean" },
            { "name": "anomaly_score", "type": "real" },
            { "name": "anomaly_reason", "type": "string" },
            { "name": "log_hash", "type": "string" },
            { "name": "timestamp", "type": "datetime" }
          ]
        }
      },
      "destinations": {
        "logAnalytics": [
          {
            "workspaceResourceId": "{{workspaceResourceId}}",
            "name": "clv2ws1"
          }
        ]
      },
      "dataFlows": [
        {
          "streams": [ "Custom-Vaikora_AgentSignals_Raw" ],
          "destinations": [ "clv2ws1" ],
          "transformKql": "source | project TimeGenerated = todatetime(timestamp), action_id_s = tostring(id), agent_id_s = tostring(agent_id), action_type_s = tostring(action_type), resource_type_s = tostring(resource_type), status_s = tostring(status), severity_s = tostring(severity), policy_id_s = tostring(policy_id), policy_decision_s = tostring(policy_decision), is_anomaly_b = tobool(is_anomaly), anomaly_score_d = toreal(anomaly_score), anomaly_reason_s = tostring(anomaly_reason), log_hash_s = tostring(log_hash)",
          "outputStream": "Custom-Vaikora_AgentSignals_CL"
        }
      ]
    }
  }
]
