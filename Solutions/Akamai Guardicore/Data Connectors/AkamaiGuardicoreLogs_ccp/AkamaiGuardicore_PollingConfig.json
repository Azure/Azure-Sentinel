[
  {
    "name": "AkamaiGuardicorePollerAgents",
    "apiVersion": "2025-09-01",
    "type": "Microsoft.SecurityInsights/dataConnectors",
    "kind": "RestApiPoller",
    "properties": {
      "connectorDefinitionName": "AkamaiGuardicore",
      "dcrConfig": {
        "streamName": "Custom-GuardicoreAgents_CL",
        "dataCollectionEndpoint": "{{dataCollectionEndpoint}}",
        "dataCollectionRuleImmutableId": "{{dataCollectionRuleImmutableId}}"
      },
      "dataType": "GuardicoreAgents_CL",
      "auth": {
        "type": "JwtToken",
        "IsJsonRequest": true,
        "JwtTokenJsonPath": "$.access_token",
        "TokenEndpoint": "[[concat(parameters('guardicoreUrl'), '/api/v3.0/authenticate')]",
        "userName": { "key": "username", "value": "[[parameters('guardicoreUser')]" },
        "password": { "key": "password", "value": "[[parameters('guardicorePassword')]" }
      },
      "request": {
        "apiEndpoint": "[[concat(parameters('guardicoreUrl'), '/api/v3.0/agents')]",
        "httpMethod": "GET",
        "queryWindowInMin": 10,
        "headers": {
          "Accept": "application/json",
          "User-Agent": "Microsoft-Sentinel-AkamaiGuardicore-CCF/3.0.0"
        },
        "rateLimitQPS": 10,
        "retryCount": 3,
        "timeoutInSeconds": 60
      },
      "paging": {
        "pagingType": "Offset",
        "offsetParaName": "offset",
        "pageSizeParaName": "limit",
        "pageSize": 1000
      },
      "response": {
        "eventsJsonPaths": ["$.objects"],
        "format": "json"
      }
    }
  },
