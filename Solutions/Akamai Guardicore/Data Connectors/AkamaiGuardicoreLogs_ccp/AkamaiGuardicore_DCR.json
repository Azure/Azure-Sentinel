    "dataSources": {},
    "destinations": {
      "logAnalytics": [
        {
          "workspaceResourceId": "{{workspaceResourceId}}",
          "name": "akamaiGuardicoreWs"
        }
      ]
    },
    "dataFlows": [
      {
        "streams": [
          "Custom-GuardicoreAgents_CL"
        ],
        "destinations": [
          "akamaiGuardicoreWs"
        ],
        "transformKql": "source | project-rename id = ['_id'] | extend TimeGenerated = now(), sampling_timestamp = toint(datetime_diff(\"second\", bin(now(), 5m), datetime(1970-01-01))) | extend is_agent_enforcing = iff(tostring(parse_json(tostring(configuration)).enforcementagent.agent_operating_mode) == \"Enforcing\", true, false)",
        "outputStream": "Custom-GuardicoreAgents_CL"
      },
      {
        "streams": [
          "Custom-GuardicoreAssets_CL"
        ],
        "destinations": [
          "akamaiGuardicoreWs"
        ],
        "transformKql": "source | project-rename id = ['_id'] | extend TimeGenerated = now(), sampling_timestamp = toint(datetime_diff(\"second\", bin(now(), 5m), datetime(1970-01-01)))",
        "outputStream": "Custom-GuardicoreAssets_CL"
      },
      {
        "streams": [
          "Custom-GuardicoreApplications_CL"
        ],
        "destinations": [
          "akamaiGuardicoreWs"
        ],
        "transformKql": "source | project-rename id = ['_id'] | extend TimeGenerated = now(), sampling_timestamp = toint(datetime_diff(\"second\", bin(now(), 5m), datetime(1970-01-01)))",
