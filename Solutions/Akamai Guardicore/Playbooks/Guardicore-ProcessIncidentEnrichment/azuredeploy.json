{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "title": "Guardicore-ProcessIncidentEnrichment",
    "description": "This playbook reacts to a Microsoft Sentinel incident, computes the 3-slot fan-out over the incident's IP entities, writes slot-claim rows to the GuardicoreConnectionSlots Azure Table, and posts one slot-manifest record per slot to the GuardicoreProcessedIncidents_CL custom log via the Logs Ingestion API. The actual Guardicore /api/v3.0/connections fetch is performed asynchronously by the companion Guardicore-EnrichmentRunner Logic App. (Function-App-free architecture.)",
    "mainSteps": [
      "When a new incident is created:",
      "1. Extract IP addresses from incident entities (kind == 'Ip').",
      "2. Compute 3 time slots at offsets -5, 0, +5 minutes from the incident's createdTimeUtc, each rounded down to a 5-minute boundary.",
      "3. For each slot: insert (with dedup) into the GuardicoreConnectionSlots Azure Table.",
      "4. For each slot: post one manifest row to GuardicoreProcessedIncidents_CL via the Logs Ingestion API."
    ],
    "prerequisites": [
      "1. Storage Account hosting the GuardicoreConnectionSlots Azure Table (deployed by the AkamaiGuardicoreEnrichment infrastructure ARM template).",
      "2. Data Collection Endpoint and Data Collection Rule for the GuardicoreProcessedIncidents_CL custom log (deployed by the same infra template).",
      "3. Appropriate permissions for the playbook's system-assigned managed identity (Monitoring Metrics Publisher on the DCR).",
      "4. Credentials and FQDN to the Guardicore instance."
    ],
    "lastUpdateTime": "2026-04-26T00:00:00.000Z",
    "entities": [
      "IP"
    ],
    "tags": [
      "Enrichment",
      "Guardicore",
      "Connection Data"
    ],
    "support": {
      "tier": "community"
    },
    "author": {
      "name": "Akamai Guardicore"
    }
  },
  "parameters": {
    "PlaybookName": {
      "defaultValue": "Guardicore-ProcessIncidentEnrichment",
      "type": "string",
      "metadata": {
        "description": "Name of the playbook (Logic Apps resource) which will be created."
      }
    },
    "StorageAccountName": {
      "type": "string",
      "metadata": {
        "description": "Storage account hosting the GuardicoreConnectionSlots Azure Table (output of the AkamaiGuardicoreEnrichment infrastructure ARM template)."
      }
    },
    "StorageAccountConnectionString": {
      "type": "securestring",
      "metadata": {
        "description": "Connection string for the Storage Account hosting the GuardicoreConnectionSlots Azure Table; used by the azuretables managed-API connection (which does not support managed identity)."
      }
    },
    "DataCollectionEndpoint": {
      "type": "string",
      "metadata": {
        "description": "Logs ingestion endpoint URL of the Data Collection Endpoint (e.g. https://<dce-name>-<region-suffix>.ingest.monitor.azure.com)."
      }
    },
    "DataCollectionRuleImmutableId": {
      "type": "string",
      "metadata": {
        "description": "Immutable ID of the Data Collection Rule (output of the AkamaiGuardicoreEnrichment infrastructure ARM template)."
      }
    }
  },
  "variables": {
    "AzureSentinelConnectionName": "[concat('azuresentinel-', parameters('PlaybookName'))]",
    "AzureTablesConnectionName": "[concat('azuretables-', parameters('PlaybookName'))]"
  },
  "resources": [
    {
      "type": "Microsoft.Web/connections",
      "apiVersion": "2016-06-01",
      "name": "[variables('AzureSentinelConnectionName')]",
      "location": "[resourceGroup().location]",
      "kind": "V1",
      "properties": {
        "displayName": "[variables('AzureSentinelConnectionName')]",
        "customParameterValues": {},
        "parameterValueType": "Alternative",
        "api": {
          "id": "[concat('/subscriptions/', subscription().subscriptionId, '/providers/Microsoft.Web/locations/', resourceGroup().location, '/managedApis/azuresentinel')]"
        }
      }
    },
    {
      "type": "Microsoft.Web/connections",
      "apiVersion": "2016-06-01",
      "name": "[variables('AzureTablesConnectionName')]",
      "location": "[resourceGroup().location]",
      "kind": "V1",
      "properties": {
        "displayName": "[variables('AzureTablesConnectionName')]",
        "api": {
          "id": "[concat('/subscriptions/', subscription().subscriptionId, '/providers/Microsoft.Web/locations/', resourceGroup().location, '/managedApis/azuretables')]"
        },
        "parameterValues": {
          "storageaccount": "[parameters('StorageAccountName')]",
          "sharedkey": "[parameters('StorageAccountConnectionString')]"
        }
      }
    },
    {
      "type": "Microsoft.Logic/workflows",
      "apiVersion": "2017-07-01",
      "name": "[parameters('PlaybookName')]",
      "location": "[resourceGroup().location]",
      "tags": {
        "LogicAppsCategory": "security",
        "hidden-SentinelTemplateName": "Guardicore-ProcessIncidentEnrichment",
        "hidden-SentinelTemplateVersion": "1.1"
      },
      "identity": {
        "type": "SystemAssigned"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/connections', variables('AzureSentinelConnectionName'))]",
        "[resourceId('Microsoft.Web/connections', variables('AzureTablesConnectionName'))]"
      ],
      "properties": {
        "state": "Enabled",
        "definition": {
          "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
          "contentVersion": "1.0.0.0",
          "parameters": {
            "$connections": {
              "type": "Object",
              "defaultValue": {}
            }
          },
          "triggers": {
            "Microsoft_Sentinel_incident": {
              "type": "ApiConnectionWebhook",
              "inputs": {
                "host": {
                  "connection": {
                    "name": "@parameters('$connections')['azuresentinel']['connectionId']"
                  }
                },
                "body": {
                  "callback_url": "@{listCallbackUrl()}"
                },
                "path": "/incident-creation"
              }
            }
          },
          "actions": {
            "Extract_IPs": {
              "type": "Select",
              "runAfter": {
                "Filter_IP_Entities": [
                  "Succeeded"
                ]
              },
              "inputs": {"from": "@body('Filter_IP_Entities')", "select": "@item()?['properties']?['address']"}
            },
            "Skip_if_no_ips": {
              "type": "If",
              "runAfter": {
                "Extract_IPs": [
                  "Succeeded"
                ]
              },
              "expression": {
                "and": [
                  {
                    "equals": [
                      "@length(body('Extract_IPs'))",
                      0
                    ]
                  }
                ]
              },
              "actions": {
                "Terminate_no_ips": {
                  "type": "Terminate",
                  "runAfter": {},
                  "inputs": {
                    "runStatus": "Succeeded"
                  }
                }
              }
            },
            "Compose_event_time_floored": {
              "type": "Compose",
              "runAfter": {
                "Skip_if_no_ips": [
                  "Succeeded"
                ]
              },
              "inputs": "@addMinutes(formatDateTime(triggerBody()?['object']?['properties']?['createdTimeUtc'], 'yyyy-MM-ddTHH:mm:00Z'), mul(-1, mod(int(formatDateTime(triggerBody()?['object']?['properties']?['createdTimeUtc'], 'mm')), 5)))"
            },
            "Compose_row_key": {
              "type": "Compose",
              "runAfter": {
                "Compose_event_time_floored": [
                  "Succeeded"
                ]
              },
              "inputs": "@toLower(replace(replace(replace(base64(string(join(body('Extract_IPs'), ','))), '/', '-'), '+', '_'), '=', ''))"
            },
            "Compute_Slots": {
              "type": "Compose",
              "runAfter": {
                "Compose_row_key": [
                  "Succeeded"
                ]
              },
              "inputs": [
                {
                  "slot_start": "@{addMinutes(outputs('Compose_event_time_floored'), -5)}",
                  "partition_key": "@{formatDateTime(addMinutes(outputs('Compose_event_time_floored'), -5), 'yyyyMMddHHmm')}",
                  "row_key": "@{outputs('Compose_row_key')}",
                  "slot_id": "@{concat(formatDateTime(addMinutes(outputs('Compose_event_time_floored'), -5), 'yyyyMMddHHmm'), '_', outputs('Compose_row_key'))}",
                  "ips": "@body('Extract_IPs')",
                  "created": "@{utcNow()}"
                },
                {
                  "slot_start": "@{outputs('Compose_event_time_floored')}",
                  "partition_key": "@{formatDateTime(outputs('Compose_event_time_floored'), 'yyyyMMddHHmm')}",
                  "row_key": "@{outputs('Compose_row_key')}",
                  "slot_id": "@{concat(formatDateTime(outputs('Compose_event_time_floored'), 'yyyyMMddHHmm'), '_', outputs('Compose_row_key'))}",
                  "ips": "@body('Extract_IPs')",
                  "created": "@{utcNow()}"
                },
                {
                  "slot_start": "@{addMinutes(outputs('Compose_event_time_floored'), 5)}",
                  "partition_key": "@{formatDateTime(addMinutes(outputs('Compose_event_time_floored'), 5), 'yyyyMMddHHmm')}",
                  "row_key": "@{outputs('Compose_row_key')}",
                  "slot_id": "@{concat(formatDateTime(addMinutes(outputs('Compose_event_time_floored'), 5), 'yyyyMMddHHmm'), '_', outputs('Compose_row_key'))}",
                  "ips": "@body('Extract_IPs')",
                  "created": "@{utcNow()}"
                }
              ]
            },
            "For_each_slot": {
              "type": "Foreach",
              "runAfter": {
                "Compute_Slots": [
                  "Succeeded"
                ]
              },
              "foreach": "@outputs('Compute_Slots')",
              "actions": {
                "Try_insert_slot": {
                  "type": "ApiConnection",
                  "runAfter": {},
                  "inputs": {
                    "host": {
                      "connection": {
                        "name": "@parameters('$connections')['azuretables']['connectionId']"
                      }
                    },
                    "method": "post",
                    "path": "/Tables/@{encodeURIComponent('GuardicoreConnectionSlots')}/entities",
                    "body": {
                      "PartitionKey": "@{items('For_each_slot')['partition_key']}",
                      "RowKey": "@{items('For_each_slot')['row_key']}",
                      "slot_start": "@{items('For_each_slot')['slot_start']}",
                      "slot_id": "@{items('For_each_slot')['slot_id']}",
                      "ips": "@{string(items('For_each_slot')['ips'])}",
                      "status": "pending",
                      "created": "@{items('For_each_slot')['created']}",
                      "last_updated": "@{utcNow()}",
                      "attempt_count": 0
                    }
                  }
                },
                "Swallow_dedup_conflict": {
                  "type": "Compose",
                  "runAfter": {
                    "Try_insert_slot": [
                      "Failed"
                    ]
                  },
                  "inputs": {
                    "dedup_outcome": "existing_row_preserved",
                    "partition_key": "@{items('For_each_slot')['partition_key']}",
                    "row_key": "@{items('For_each_slot')['row_key']}",
                    "note": "Insert failed (likely 409 Conflict); the existing PENDING/IN_PROGRESS/COMPLETED row is left untouched per dedup contract."
                  }
                },
                "Post_manifest": {
                  "type": "Http",
                  "runAfter": {
                    "Try_insert_slot": [
                      "Succeeded",
                      "Failed"
                    ]
                  },
                  "inputs": {
                    "method": "POST",
                    "uri": "[concat(parameters('DataCollectionEndpoint'), '/dataCollectionRules/', parameters('DataCollectionRuleImmutableId'), '/streams/Custom-GuardicoreProcessedIncidents_CL?api-version=2023-01-01')]",
                    "headers": {
                      "Content-Type": "application/json"
                    },
                    "body": [
                      {
                        "slot_id": "@{items('For_each_slot')['slot_id']}",
                        "slot_start": "@{items('For_each_slot')['slot_start']}",
                        "ips": "@items('For_each_slot')['ips']",
                        "incidentId": "@{coalesce(triggerBody()?['object']?['properties']?['providerIncidentId'], last(split(coalesce(triggerBody()?['object']?['id'], ''), '/')))}",
                        "incidentArmId": "@{triggerBody()?['object']?['id']}",
                        "incidentTitle": "@{triggerBody()?['object']?['properties']?['title']}",
                        "partition_key": "@{items('For_each_slot')['partition_key']}",
                        "row_key": "@{items('For_each_slot')['row_key']}",
                        "created": "@{items('For_each_slot')['created']}"
                      }
                    ],
                    "authentication": {
                      "type": "ManagedServiceIdentity",
                      "audience": "https://monitor.azure.com"
                    },
                    "retryPolicy": {
                      "type": "exponential",
                      "count": 4,
                      "interval": "PT10S",
                      "maximumInterval": "PT1M"
                    }
                  }
                }
              }
            },
            "Filter_IP_Entities": {
              "type": "Query",
              "runAfter": {},
              "inputs": {
                "from": "@coalesce(triggerBody()?['object']?['properties']?['relatedEntities'], json('[]'))",
                "where": "@equals(item()?['kind'], 'Ip')"
              }
            }
          },
          "outputs": {}
        },
        "parameters": {
          "$connections": {
            "value": {
              "azuresentinel": {
                "connectionId": "[resourceId('Microsoft.Web/connections', variables('AzureSentinelConnectionName'))]",
                "connectionName": "[variables('AzureSentinelConnectionName')]",
                "id": "[concat('/subscriptions/', subscription().subscriptionId, '/providers/Microsoft.Web/locations/', resourceGroup().location, '/managedApis/azuresentinel')]",
                "connectionProperties": {
                  "authentication": {
                    "type": "ManagedServiceIdentity"
                  }
                }
              },
              "azuretables": {
                "connectionId": "[resourceId('Microsoft.Web/connections', variables('AzureTablesConnectionName'))]",
                "connectionName": "[variables('AzureTablesConnectionName')]",
                "id": "[concat('/subscriptions/', subscription().subscriptionId, '/providers/Microsoft.Web/locations/', resourceGroup().location, '/managedApis/azuretables')]"
              }
            }
          }
        }
      }
    }
  ]
}