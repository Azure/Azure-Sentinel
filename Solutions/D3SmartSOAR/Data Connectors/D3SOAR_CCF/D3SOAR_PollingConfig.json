{
  "type": "Microsoft.SecurityInsights/dataConnectors",
  "apiVersion": "2023-02-01-preview",
  "name": "D3SOARIncidentsPolling",
  "location": "{{location}}",
  "kind": "RestApiPoller",
  "properties": {
    "connectorDefinitionName": "D3SOARConnectorDefinition",
    "dataType": "D3SOARIncidents_CL",
    "dcrConfig": {
      "streamName": "Custom-D3SOARIncidents",
      "dataCollectionEndpoint": "{{dataCollectionEndpoint}}",
      "dataCollectionRuleImmutableId": "{{dataCollectionRuleImmutableId}}"
    },
    "auth": {
      "type": "APIKey",
      "ApiKey": "{{D3Jwt}}",
      "ApiKeyName": "d3jwt"
    },
    "request": {
      "apiEndpoint": "{{BaseUrl}}/api/command/GetIncidentsWithNewParameters",
      "httpMethod": "POST",
      "queryWindowInMin": 5,
      "queryTimeFormat": "yyyy-MM-dd HH:mm:ss",
      "rateLimitQps": 1,
      "retryCount": 3,
      "timeoutInSeconds": 60,
      "headers": {
        "Accept": "application/json",
        "Content-Type": "application/json"
      },
      "isPostPayloadJson": true,
      "queryParametersTemplate": "{ \"Username\": \"{{Username}}\", \"Site\": \"{{Site}}\", \"CommandParams\": { \"Static Fields\": [ \"IR Number\", \"IR Type\", \"Title\", \"Status\", \"Severity\", \"Stage\", \"Priority\", \"Disposition\", \"Tags\", \"Owner\", \"Creator\", \"Timezone\", \"Date Created\", \"Date Modified\", \"Playbook\", \"Description\", \"Conclusion\", \"Investigation Team\", \"Linked Incidents\", \"Incident Raw Data\", \"Event Raw Data\" ], \"Start Time\": \"{_QueryWindowStartTime}\", \"End Time\": \"{_QueryWindowEndTime}\", \"Output Format\": 2, \"PageIndex\": 0, \"PageSize\": 100, \"PollFromSentinel\": true } }"
    },
    "paging": {
      "pagingType": "CountBasedPaging",
      "pageNumberParaName": "$.CommandParams.PageIndex",
      "zeroBasedIndexing": true,
      "pageCountJsonPath": "$.outputData.TotalPages"
    },
    "response": {
      "format": "json",
      "eventsJsonPaths": [
        "$.rawData.incidents[*]"
      ]
    }
  }
}



