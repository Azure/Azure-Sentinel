    {
      "type": "Microsoft.OperationalInsights/workspaces/providers/contentTemplates",
      "apiVersion": "2023-04-01-preview",
      "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/', variables('dataConnectorTemplateNameConnections1'), variables('dataConnectorCCPVersion'))]",
      "location": "[parameters('workspace-location')]",
      "dependsOn": [
        "[extensionResourceId(resourceId('Microsoft.OperationalInsights/workspaces', parameters('workspace')), 'Microsoft.SecurityInsights/contentPackages', variables('_solutionId'))]"
      ],
      "properties": {
        "contentId": "[variables('_dataConnectorContentIdConnections1')]",
        "displayName": "D3 Smart SOAR Incidents",
        "contentKind": "ResourcesDataConnector",
        "mainTemplate": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "[variables('dataConnectorCCPVersion')]",
          "parameters": {
            "guidValue": {
              "defaultValue": "[[newGuid()]",
              "type": "securestring"
            },
            "innerWorkspace": {
              "defaultValue": "[parameters('workspace')]",
              "type": "securestring"
            },
            "connectorDefinitionName": {
              "defaultValue": "D3 Smart SOAR Incidents",
              "type": "securestring",
              "minLength": 1
            },
            "workspace": {
              "defaultValue": "[parameters('workspace')]",
              "type": "securestring"
            },
            "dcrConfig": {
              "defaultValue": {
                "dataCollectionEndpoint": "data collection Endpoint",
                "dataCollectionRuleImmutableId": "data collection rule immutableId"
              },
              "type": "object"
            },
            "BaseUrl": {
              "defaultValue": "BaseUrl",
              "type": "securestring",
              "minLength": 1
            },
            "Username": {
              "defaultValue": "Username",
              "type": "securestring",
              "minLength": 1
            },
            "Site": {
              "defaultValue": "Site",
              "type": "securestring",
              "minLength": 1
            },
            "D3Jwt": {
              "defaultValue": "D3Jwt",
              "type": "securestring",
              "minLength": 1
            }
          },
          "variables": {
            "_dataConnectorContentIdConnections1": "[variables('_dataConnectorContentIdConnections1')]"
          },
          "resources": [
            {
              "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/',concat('DataConnector-', variables('_dataConnectorContentIdConnections1')))]",
              "apiVersion": "2022-01-01-preview",
              "type": "Microsoft.OperationalInsights/workspaces/providers/metadata",
              "properties": {
                "parentId": "[extensionResourceId(resourceId('Microsoft.OperationalInsights/workspaces', parameters('workspace')), 'Microsoft.SecurityInsights/dataConnectors', variables('_dataConnectorContentIdConnections1'))]",
                "contentId": "[variables('_dataConnectorContentIdConnections1')]",
                "kind": "ResourcesDataConnector",
                "version": "[variables('dataConnectorCCPVersion')]",
                "source": {
                  "sourceId": "[variables('_solutionId')]",
                  "name": "[variables('_solutionName')]",
                  "kind": "Solution"
                },
                "author": {
                  "name": "D3 Security",
                  "email": "[variables('_email')]"
                },
                "support": {
                  "tier": "Partner",
                  "name": "D3 Security",
                  "email": "d3support@d3security.com",
                  "link": "https://d3security.com/"
                }
              }
            },
            {
              "name": "[[concat(parameters('innerWorkspace'),'/Microsoft.SecurityInsights/', 'D3SOARIncidentsPolling', parameters('guidValue'))]",
              "apiVersion": "2023-02-01-preview",
              "type": "Microsoft.OperationalInsights/workspaces/providers/dataConnectors",
              "location": "[parameters('workspace-location')]",
              "kind": "RestApiPoller",
              "properties": {
                "connectorDefinitionName": "D3SOARConnectorDefinition",
                "dataType": "D3SOARIncidents_CL",
                "dcrConfig": {
                  "streamName": "Custom-D3SOARIncidents",
                  "dataCollectionEndpoint": "[[parameters('dcrConfig').dataCollectionEndpoint]",
                  "dataCollectionRuleImmutableId": "[[parameters('dcrConfig').dataCollectionRuleImmutableId]"
                },
                "auth": {
                  "type": "APIKey",
                  "ApiKey": "[[parameters('D3Jwt')]",
                  "ApiKeyName": "d3jwt"
                },
                "request": {
                  "apiEndpoint": "[[concat(parameters('BaseUrl'),'/api/command/GetIncidentsWithNewParameters')]",
                  "httpMethod": "POST",
                  "queryWindowInMin": 5,
                  "queryTimeFormat": "yyyy-MM-dd HH:mm:ss",
                  "rateLimitQps": 1,
                  "retryCount": 3,
                  "timeoutInSeconds": 60,
                  "headers": {
                    "Accept": "application/json",
                    "Content-Type": "application/json"
                  },
                  "isPostPayloadJson": true,
                  "queryParametersTemplate": "[[concat('{ \"Username\": \"',parameters('Username'),'\", \"Site\": \"',parameters('Site'),'\", \"CommandParams\": { \"Static Fields\": [ \"IR Number\", \"IR Type\", \"Title\", \"Status\", \"Severity\", \"Stage\", \"Priority\", \"Disposition\", \"Tags\", \"Owner\", \"Creator\", \"Timezone\", \"Date Created\", \"Date Modified\", \"Playbook\", \"Description\", \"Conclusion\", \"Investigation Team\", \"Linked Incidents\", \"Incident Raw Data\", \"Event Raw Data\" ], \"Start Time\": \"{_QueryWindowStartTime}\", \"End Time\": \"{_QueryWindowEndTime}\", \"Output Format\": 2, \"PageIndex\": 0, \"PageSize\": 100, \"PollFromSentinel\": true } }')]"
                },
                "paging": {
                  "pagingType": "CountBasedPaging",
                  "pageNumberParaName": "$.CommandParams.PageIndex",
                  "zeroBasedIndexing": true,
                  "pageCountJsonPath": "$.outputData.TotalPages"
                },
                "response": {
                  "format": "json",
                  "eventsJsonPaths": [
                    "$.rawData.incidents[*]"
                  ]
                }
              }
            }
          ]
        },
