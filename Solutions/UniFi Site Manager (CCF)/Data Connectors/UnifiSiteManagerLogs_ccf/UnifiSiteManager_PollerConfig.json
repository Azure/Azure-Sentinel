[
  {
    "name": "UniFiSiteManagerSitesPoller",
    "apiVersion": "2023-02-01-preview",
    "type": "Microsoft.SecurityInsights/dataConnectors",
    "kind": "RestApiPoller",
    "properties": {
      "connectorDefinitionName": "UniFiSiteManagerConnector",
      "dataType": "Unifi_Cloud_Sites_CL",
      "dcrConfig": {
        "dataCollectionEndpoint": "[[parameters('dcrConfig').dataCollectionEndpoint]",
        "dataCollectionRuleImmutableId": "[[parameters('dcrConfig').dataCollectionRuleImmutableId]",
        "streamName": "Custom-Unifi_Cloud_Sites_CL"
      },
      "auth": {
        "type": "APIKey",
        "ApiKey": "[[parameters('apiKey')]",
        "ApiKeyName": "X-API-Key",
        "ApiKeyIdentifier": ""
      },
      "request": {
        "apiEndpoint": "https://api.ui.com/v1/sites",
        "httpMethod": "GET",
        "queryParameters": {
          "pageSize": "200"
        },
        "headers": {
          "Accept": "application/json"
        },
        "rateLimitQPS": 100,
        "queryWindowInMin": 5,
        "retryCount": 3,
        "timeoutInSeconds": 120
      },
      "response": {
        "eventsJsonPaths": [
          "$.data[*]"
        ],
        "format": "json"
      },
      "paging": {
        "pagingType": "NextPageToken",
        "nextPageTokenJsonPath": "$.nextToken",
        "nextPageParaName": "nextToken"
      },
      "isActive": true
    }
  },
