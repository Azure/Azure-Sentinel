{
  "name": "UnifiSiteManagerDCR",
  "apiVersion": "2021-09-01-preview",
  "type": "Microsoft.Insights/dataCollectionRules",
  "kind": "WorkspaceTransforms",
  "properties": {
    "dataCollectionEndpointId": "{{dataCollectionEndpointId}}",
    "streamDeclarations": {
      "Custom-Unifi_SiteManager_Sites_CL": {
        "columns": [
          {
            "name": "siteId",
            "type": "string"
          },
          {
            "name": "hostId",
            "type": "string"
          },
          {
            "name": "meta",
            "type": "dynamic"
          },
          {
            "name": "statistics",
            "type": "dynamic"
          },
          {
            "name": "permission",
            "type": "string"
          },
          {
            "name": "isOwner",
            "type": "boolean"
          }
        ]
      },
      "Custom-Unifi_SiteManager_Devices_CL": {
        "columns": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "mac",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "model",
            "type": "string"
          },
          {
            "name": "shortname",
            "type": "string"
          },
          {
            "name": "ip",
            "type": "string"
          },
          {
            "name": "productLine",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string"
          },
          {
            "name": "version",
            "type": "string"
          },
          {
            "name": "firmwareStatus",
            "type": "string"
          },
          {
            "name": "updateAvailable",
            "type": "string"
          },
          {
            "name": "isConsole",
            "type": "boolean"
          },
          {
            "name": "isManaged",
            "type": "boolean"
          },
          {
            "name": "startupTime",
            "type": "string"
          },
          {
            "name": "adoptionTime",
            "type": "string"
          },
          {
            "name": "note",
            "type": "string"
          },
          {
            "name": "uidb",
            "type": "dynamic"
          }
        ]
      },
      "Custom-Unifi_SiteManager_Hosts_CL": {
        "columns": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "hardwareId",
            "type": "string"
          },
          {
            "name": "type",
            "type": "string"
          },
          {
            "name": "ipAddress",
            "type": "string"
          },
          {
            "name": "owner",
            "type": "boolean"
          },
          {
            "name": "isBlocked",
            "type": "boolean"
          },
          {
            "name": "registrationTime",
            "type": "string"
          },
          {
            "name": "lastConnectionStateChange",
            "type": "string"
          },
          {
            "name": "latestBackupTime",
            "type": "string"
          },
          {
            "name": "userData",
            "type": "dynamic"
          },
          {
            "name": "reportedState",
            "type": "dynamic"
          }
        ]
      },
      "Custom-Unifi_SiteManager_ISPMetrics_CL": {
        "columns": [
          {
            "name": "metricType",
            "type": "string"
          },
          {
            "name": "hostId",
            "type": "string"
          },
          {
            "name": "siteId",
            "type": "string"
          },
          {
            "name": "periods",
            "type": "dynamic"
          }
        ]
      }
    },
    "destinations": {
      "logAnalytics": [
        {
          "workspaceResourceId": "{{workspaceResourceId}}",
          "name": "clv2ws1"
        }
      ]
    },
    "dataFlows": [
      {
        "streams": [
          "Custom-Unifi_SiteManager_Sites_CL"
        ],
        "destinations": [
          "clv2ws1"
        ],
        "transformKql": "source | extend TimeGenerated = now() | project-rename siteStatistics = statistics",
        "outputStream": "Custom-Unifi_SiteManager_Sites_CL"
      },
      {
        "streams": [
          "Custom-Unifi_SiteManager_Devices_CL"
        ],
        "destinations": [
          "clv2ws1"
        ],
        "transformKql": "source | extend TimeGenerated = now()",
        "outputStream": "Custom-Unifi_SiteManager_Devices_CL"
      },
      {
        "streams": [
          "Custom-Unifi_SiteManager_Hosts_CL"
        ],
        "destinations": [
          "clv2ws1"
        ],
        "transformKql": "source | extend TimeGenerated = now() | project-rename hostType = type",
        "outputStream": "Custom-Unifi_SiteManager_Hosts_CL"
      },
      {
        "streams": [
          "Custom-Unifi_SiteManager_ISPMetrics_CL"
        ],
        "destinations": [
          "clv2ws1"
        ],
        "transformKql": "source | extend TimeGenerated = now()",
        "outputStream": "Custom-Unifi_SiteManager_ISPMetrics_CL"
      }
    ]
  }
}