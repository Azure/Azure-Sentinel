[
  {
    "name": "TrendAIVisionOneWorkbenchPoller",
    "apiVersion": "2023-02-01-preview",
    "type": "Microsoft.SecurityInsights/dataConnectors",
    "kind": "RestApiPoller",
    "properties": {
      "connectorDefinitionName": "TrendAIVisionOneWorkbench",
      "dcrConfig": {
        "streamName": "Custom-TrendAI_XDR_WORKBENCH_V2_CL",
        "dataCollectionEndpoint": "[[parameters('dcrConfig').dataCollectionEndpoint]]",
        "dataCollectionRuleImmutableId": "[[parameters('dcrConfig').dataCollectionRuleImmutableId]]"
      },
      "dataType": "TrendAI_XDR_WORKBENCH_V2_CL",
      "auth": {
        "type": "APIKey",
        "ApiKey": "[[concat('Bearer ', parameters('apiToken'))]]",
        "ApiKeyName": "Authorization"
      },
      "request": {
        "apiEndpoint": "[[concat('https://', parameters('apiDomain'), '/v3.0/workbench/alerts')]]",
        "rateLimitQPS": 1,
        "queryWindowInMin": 5,
        "httpMethod": "GET",
        "queryTimeFormat": "yyyy-MM-dd'T'HH:mm:ss'Z'",
        "startTimeAttributeName": "startDateTime",
        "endTimeAttributeName": "endDateTime",
        "retryCount": 3,
        "timeoutInSeconds": 60,
        "headers": {
          "Accept": "application/json",
          "TMV1-Filter": "[[parameters('workbenchFilter')]]"
        },
        "queryParameters": {
          "top": "200"
        }
      },
      "response": {
        "eventsJsonPaths": [
          "$.items"
        ],
        "format": "json"
      },
      "paging": {
        "pagingType": "LinkHeader",
        "linkHeaderTokenJsonPath": "$.nextLink"
      }
    }
  }
]
