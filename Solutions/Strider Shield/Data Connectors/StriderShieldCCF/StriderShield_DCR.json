[
    {
        "name": "strider-shield-dcr",
        "apiVersion": "2022-06-01",
        "type": "Microsoft.Insights/dataCollectionRules",
        "location": "{{location}}",
        "properties": {
            "dataCollectionEndpointId": "{{dataCollectionEndpointId}}",
            "streamDeclarations": {
                "Custom-StriderShield": {
                    "columns": [
                       {
                            "name": "TimeGenerated",
                            "type": "datetime"
                        },
                        {
                            "name": "isNew",
                            "type": "int"
                        },
                        {
                            "name": "md5",
                            "type": "string"
                        },
                        {
                            "name": "itemType",
                            "type": "string"
                        },
                        {
                            "name": "itemNamePrimary",
                            "type": "string"
                        },
                        {
                            "name": "collections",
                            "type": "dynamic"
                        },
                        {
                            "name": "counterparties",
                            "type": "string"
                        },
                        {
                            "name": "riskSignal",
                            "type": "string"
                        },
                        {
                            "name": "descriptions",
                            "type": "string"
                        },
                        {
                            "name": "dates_added",
                            "type": "datetime"
                        },
                        {
                            "name": "itemNameSecondary",
                            "type": "string"
                        },
                        {
                            "name": "changes",
                            "type": "string"
                        },
                        {
                            "name": "riskSignalsCount",
                            "type": "int"
                        },
                        {
                            "name": "risk_category_abbr",
                            "type": "string"
                        },
                        {
                            "name": "risk_category_name",
                            "type": "string"
                        },
                        {
                            "name": "risk_category_description",
                            "type": "string"
                        },
                        {
                            "name": "risk_category_email",
                            "type": "string"
                        },
                        {
                            "name": "risk_category_domain",
                            "type": "string"
                        },
                        {
                            "name": "risk_category_term",
                            "type": "string"
                        }
                    ]
                }
            },
            "destinations": {
                  "logAnalytics": [
                    {
                      "workspaceResourceId": "{{workspaceResourceId}}",
                      "name": "{{workspace}}"
                    }
                  ]
                },
                "dataFlows": [
                  {
                    "streams": [
                      "Custom-StriderShield"
                    ],
                    "destinations": [
                      "{{workspace}}"
                    ],
                    "transformKql": "source | where isnotempty(itemType) and itemType == \"emailAddress\" | extend TimeGenerated = now()",
                    "outputStream": "Custom-StriderShieldEmailAddresses_CL"
                  },
                  {
                    "streams": [
                      "Custom-StriderShield"
                    ],
                    "destinations": [
                      "{{workspace}}"
                    ],
                    "transformKql": "source | where isnotempty(itemType) and itemType == \"emailDomain\" | extend TimeGenerated = now()",
                    "outputStream": "Custom-StriderShieldEmailDomains_CL"
                  },
                  {
                    "streams": [
                      "Custom-StriderShield"
                    ],
                    "destinations": [
                      "{{workspace}}"
                    ],
                    "transformKql": "source | where isnotempty(riskSignalsCount) | extend TimeGenerated = now()",
                    "outputStream": "Custom-StriderShieldRiskSignals_CL"
                  },
                  {
                    "streams": [
                      "Custom-StriderShield"
                    ],
                    "destinations": [
                      "{{workspace}}"
                    ],
                    "transformKql": "source | where isnotempty(risk_category_abbr) | extend TimeGenerated = now()",
                    "outputStream": "Custom-StriderShieldRiskSignalsDefinitions_CL"
                  },
                  {
                    "streams": [
                      "Custom-StriderShield"
                    ],
                    "destinations": [
                      "{{workspace}}"
                    ],
                    "transformKql": "source | where isnotempty(itemType) and itemType == \"term\" | extend TimeGenerated = now()",
                    "outputStream": "Custom-StriderShieldTerms_CL"
                  }
            ]
        }
    }
]