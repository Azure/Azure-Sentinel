{
  "type": "Microsoft.SecurityInsights/dataConnectors",
  "apiVersion": "2022-10-01-preview",
  "name": "sqsDataPoller",
  "location": "{{location}}",
  "kind": "AmazonWebServicesS3",
  "properties": {
    "sqsConfig": {
      "queueUrl": "[[parameters('queueUrl')]",
      "maxNumberOfMessages": 10,
      "visibilityTimeout": 30,
      "waitTimeSeconds": 20,
      "deleteMessageAfterReceive": true,
      "messageAttributeNames": [
        "All"
      ],
      "attributeNames": [
        "All"
      ]
    },
    "response": {
      "format": "json",
      "eventsJsonPaths": [
        "$[*]"
      ]
    },
    "roleArn": "[[parameters('roleArn')]",
    "sqsUrls": [
      "[[parameters('queueUrl')]"
    ],
    "dataTypes": {
      "logs": {
        "state": "enabled"
      }
    },
    "destinationTable": "",
    "dataFormat": {
      "Format": "Json",
      "IsCompressed": true,
      "compressType": "Gzip"
    },
    "connectorDefinitionName": "AWSEKSDefinition",
    "dataType": "AWSEKSLogs_CL",
    "dcrConfig": {
      "streamName": "Custom-AWSEKSLogs_CL",
      "dataCollectionEndpoint": "{{dataCollectionEndpoint}}",
      "dataCollectionRuleImmutableId": "{{dataCollectionRuleImmutableId}}"
    }
  }
}