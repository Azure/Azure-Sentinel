{
  "name": "AWSEKSDCR",
  "apiVersion": "2021-09-01-preview",
  "type": "Microsoft.Insights/dataCollectionRules",
  "location": "{{location}}",
  "properties": {
    "dataCollectionEndpointId": "{{dataCollectionEndpointId}}",
    "streamDeclarations": {
      "Custom-AWSEKSLogs_CL": {
        "columns": [
          {
            "name": "TimeGenerated",
            "type": "datetime"
          },
          {
            "name": "AwsAccountId",
            "type": "string"
          },
          {
            "name": "Region",
            "type": "string"
          },
          {
            "name": "ClusterName",
            "type": "string"
          },
          {
            "name": "Verb",
            "type": "string"
          },
          {
            "name": "User",
            "type": "string"
          },
          {
            "name": "SourceIPs",
            "type": "dynamic"
          },
          {
            "name": "UserAgent",
            "type": "string"
          },
          {
            "name": "ObjectRef",
            "type": "string"
          },
          {
            "name": "ResponseCode",
            "type": "int"
          },
          {
            "name": "Stage",
            "type": "string"
          },
          {
            "name": "AuthDecision",
            "type": "string"
          },
          {
            "name": "RawEvent",
            "type": "dynamic"
          }
        ]
      }
    },
    "destinations": {
      "logAnalytics": [
        {
          "workspaceResourceId": "{{workspaceResourceId}}",
          "name": "clv2ws2"
        }
      ]
    },
    "dataFlows": [
      {
        "streams": [
          "Custom-AWSEKSLogs_CL"
        ],
        "destinations": [
          "clv2ws2"
        ],
        "outputStream": "Custom-AWSEKSLogs_CL",
        "transformKql": "source | extend TimeGenerated = now() | project TimeGenerated , AwsAccountId , Region , ClusterName , Verb , User , SourceIPs , UserAgent , ObjectRef , ResponseCode , Stage , AuthDecision , RawEvent"
      }
    ]
  }
}