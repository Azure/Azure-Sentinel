    "dataFlows": [
      {
        "streams": [
          "Custom-ContrastADRAttackEvents"
        ],
        "destinations": [
          "[concat('RuleDest', variables('suffix'))]"
        ],
        "transformKql": "source\n| extend\n    TimeGenerated = todatetime(now()),\n    json_server = parse_json(server),\n    json_application = parse_json(application),\n    json_host = parse_json(host),\n    json_attackPayload = parse_json(attackPayload),\n    json_request = parse_json(request),\n    json_applicationMetadata = parse_json(applicationMetadata)\n| extend \n    json_attackPayload_attackerInput = parse_json(json_attackPayload.attackerInput),\n    json_request_headers = parse_json(json_request.headers)\n| extend \n    server_id = toreal(json_server.id),\n    server_name = tostring(json_server.name),\n    application_id = tostring(json_application.id),\n    application_name = tostring(json_application.name),\n    application_agentLanguage = tostring(json_application.agentLanguage),\n    host_operatingSystem = tostring(json_host.operatingSystem),\n    host_runtimePath = tostring(json_host.runtimePath),\n    host_runtimeVersion = tostring(json_host.runtimeVersion),\n    host_hostname = tostring(json_host.hostname),\n    host_isKubernetes = tobool(json_host.isKubernetes),\n    host_isDocker = tobool(json_host.isDocker),\n    attackPayload_attackerInput_confirmedAttack = tobool(json_attackPayload_attackerInput.confirmedAttack),\n    attackPayload_attackerInput_effectiveAttack = tobool(json_attackPayload_attackerInput.effectiveAttack),\n    attackPayload_attackerInput_applicableAttack = tobool(json_attackPayload_attackerInput.applicableAttack),\n    attackPayload_attackerInput_patternsMatched = todynamic(json_attackPayload_attackerInput.patternsMatched),\n    attackPayload_attackerInput_filters = todynamic(json_attackPayload_attackerInput.filters),\n    attackPayload_attackerInput_name = tostring(json_attackPayload_attackerInput.name),\n    attackPayload_attackerInput_inputType = tostring(json_attackPayload_attackerInput.inputType),\n    attackPayload_attackerInput_type = tostring(json_attackPayload_attackerInput.type),\n    attackPayload_attackerInput_documentType = tostring(json_attackPayload_attackerInput.documentType),\n    attackPayload_attackerInput_documentPath = tostring(json_attackPayload_attackerInput.documentPath),\n    attackPayload_url = tostring(json_attackPayload.url),\n    attackPayload_value = tostring(json_attackPayload.value),\n    request_method = tostring(json_request.method),\n    request_protocol = tostring(json_request.protocol),\n    request_protocolVersion = tostring(json_request.protocolVersion),\n    request_headers_accept = todynamic(json_request_headers.accept),\n    request_headers_connection = todynamic(json_request_headers.connection),\n    request_headers_user_agent = todynamic(json_request_headers['user-agent']),\n    request_headers_referer = todynamic(json_request_headers.referer),\n    request_headers_host = todynamic(json_request_headers.host),\n    request_headers_contrasttraceparent = todynamic(json_request_headers.contrasttraceparent),\n    request_headers_x_request_id = todynamic(json_request_headers['x-request-id']),\n    request_headers_content_length = todynamic(json_request_headers['content-length']),\n    request_headers_x_forwarded_proto = todynamic(json_request_headers['x-forwarded-proto']),\n    request_headers_x_forwarded_port = todynamic(json_request_headers['x-forwarded-port']),\n    request_headers_x_real_ip = todynamic(json_request_headers['x-real-ip']),\n    request_headers_x_forwarded_scheme = todynamic(json_request_headers['x-forwarded-scheme']),\n    request_headers_x_forwarded_host = todynamic(json_request_headers['x-forwarded-host']),\n    request_headers_content_type = todynamic(json_request_headers['content-type']),\n    request_headers_x_scheme = todynamic(json_request_headers['x-scheme']),\n    request_headers_accept_encoding = todynamic(json_request_headers['accept-encoding']),\n    request_headers_cookie = todynamic(json_request_headers['cookie']),\n    request_body = tostring(json_request.body),\n    request_queryString = tostring(json_request.queryString)\n| project-away json_server, json_application, json_host, json_attackPayload, json_attackPayload_attackerInput, json_request, json_request_headers, json_applicationMetadata",
        "outputStream": "Custom-ContrastADRAttackEvents_CL"
      },
