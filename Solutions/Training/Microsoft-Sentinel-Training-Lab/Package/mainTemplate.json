                        }
                    ]
                },
                "providers": [
                    "Microsoft"
                ],
                "categories": {
                    "domains": [ "Training and Tutorials" ]
                },
                "keywords": [
                    "333d839a-47fa-4181-8bfc-d00429b0bb33"
                ],
                "firstPublishDate": "2024-01-01",
                "lastPublishDate": "2026-03-09"
            }
