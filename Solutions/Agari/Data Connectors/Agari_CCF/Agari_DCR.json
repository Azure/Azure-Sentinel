{
  "name": "AgariDCR",
  "apiVersion": "2023-03-11",
  "type": "Microsoft.Insights/dataCollectionRules",
  "location": "{{location}}",
  "properties": {
    "dataCollectionEndpointId": "{{dataCollectionEndpointId}}",
    "streamDeclarations": {
      "Custom-AgariBPAlertsLog_CL": {
        "columns": [
          {
            "name": "id",
            "type": "long"
          },
          {
            "name": "alert_type",
            "type": "string"
          },
          {
            "name": "last_notified_at",
            "type": "datetime"
          },
          {
            "name": "resolved_at",
            "type": "datetime"
          },
          {
            "name": "created_at",
            "type": "datetime"
          },
          {
            "name": "updated_at",
            "type": "datetime"
          },
          {
            "name": "summary",
            "type": "string"
          },
          {
            "name": "domain",
            "type": "string"
          },
          {
            "name": "spf_fail_hosts",
            "type": "dynamic"
          },
          {
            "name": "dkim_fail_hosts",
            "type": "dynamic"
          },
          {
            "name": "links",
            "type": "dynamic"
          }
        ]
      },
      "Custom-AgariAPDPolicyLog_CL": {
        "columns": [
          {
            "name": "id",
            "type": "long"
          },
          {
            "name": "alert_definition_name",
            "type": "string"
          },
          {
            "name": "created_at",
            "type": "datetime"
          },
          {
            "name": "updated_at",
            "type": "datetime"
          },
          {
            "name": "summary",
            "type": "boolean"
          },
          {
            "name": "policy_action",
            "type": "string"
          },
          {
            "name": "policy_enabled",
            "type": "boolean"
          },
          {
            "name": "notified_original_recipients",
            "type": "boolean"
          },
          {
            "name": "admin_recipients",
            "type": "dynamic"
          }
        ]
      },
      "Custom-AgariAPDTCLog_CL": {
        "columns": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "to",
            "type": "string"
          },
          {
            "name": "from",
            "type": "string"
          },
          {
            "name": "from_domain",
            "type": "string"
          },
          {
            "name": "attack_types",
            "type": "dynamic"
          },
          {
            "name": "timestamp_ms",
            "type": "long"
          },
          {
            "name": "date",
            "type": "datetime"
          },
          {
            "name": "subject",
            "type": "string"
          },
          {
            "name": "ip",
            "type": "string"
          },
          {
            "name": "sbrs",
            "type": "string"
          },
          {
            "name": "domain_reputation",
            "type": "int"
          },
          {
            "name": "policy_ids",
            "type": "dynamic"
          },
          {
            "name": "domain_tags",
            "type": "dynamic"
          },
          {
            "name": "has_attachment",
            "type": "boolean"
          },
          {
            "name": "message_details_link",
            "type": "string"
          },
          {
            "name": "attachment_sha256",
            "type": "dynamic"
          },
          {
            "name": "attachment_extensions",
            "type": "dynamic"
          },
          {
            "name": "attachment_filenames",
            "type": "dynamic"
          }
        ]
      },
      "Custom-AgariBPThreatFeedSubs_CL": {
        "columns": [
          {
            "name": "id",
            "type": "long"
          },
          {
            "name": "uri",
            "type": "string"
          },
          {
            "name": "created_at",
            "type": "datetime"
          },
          {
            "name": "threat_feed_id",
            "type": "long"
          }
        ]
      },
      "Custom-AgariAPRInvestigationsLog_CL": {
        "columns": [
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "filename",
            "type": "string"
          },
          {
            "name": "content_type",
            "type": "string"
          },
          {
            "name": "size",
            "type": "long"
          },
          {
            "name": "sha256",
            "type": "string"
          },
          {
            "name": "created_at",
            "type": "datetime"
          },
          {
            "name": "type",
            "type": "string"
          },
          {
            "name": "url",
            "type": "string"
          }
        ]
      }
    },
    "destinations": {
      "logAnalytics": [
        {
          "workspaceResourceId": "{{workspaceResourceId}}",
          "name": "clv2ws1"
        }
      ]
    },
    "dataFlows": [
      {
        "streams": [
          "Custom-AgariBPAlertsLog_CL"
        ],
        "destinations": [
          "clv2ws1"
        ],
        "outputStream": "Custom-AgariBPAlertsLog_CL",
        "transformKql": "source | extend TimeGenerated = now() , Id = ['id'] , AlertType = ['alert_type'] , LastNotifiedAt = ['last_notified_at'] , ResolvedAt = ['resolved_at'] , CreatedAt = ['created_at'] , UpdatedAt = ['updated_at'] , Summary = ['summary'] , Domain = ['domain'] , SpfFailHosts = ['spf_fail_hosts'] , DkimFailHosts = ['dkim_fail_hosts'] , Links = ['links'] | project TimeGenerated , Id , AlertType , LastNotifiedAt , ResolvedAt , CreatedAt , UpdatedAt , Summary , Domain , SpfFailHosts , DkimFailHosts , Links"
      },
      {
        "streams": [
          "Custom-AgariAPDPolicyLog_CL"
        ],
        "destinations": [
          "clv2ws1"
        ],
        "outputStream": "Custom-AgariAPDPolicyLog_CL",
        "transformKql": "source | extend TimeGenerated = now() , Id = ['id'] , AlertDefinitionName = ['alert_definition_name'] , CreatedAt = ['created_at'] , UpdatedAt = ['updated_at'] , Summary = ['summary'] , PolicyAction = ['policy_action'] , PolicyEnabled = ['policy_enabled'] , NotifiedOriginalRecipients = ['notified_original_recipients'] , AdminRecipients = ['admin_recipients'] | project TimeGenerated , Id , AlertDefinitionName , CreatedAt , UpdatedAt , Summary , PolicyAction , PolicyEnabled , NotifiedOriginalRecipients , AdminRecipients"
      },
      {
        "streams": [
          "Custom-AgariAPDTCLog_CL"
        ],
        "destinations": [
          "clv2ws1"
        ],
        "outputStream": "Custom-AgariAPDTCLog_CL",
        "transformKql": "source | extend TimeGenerated = now() , Id = ['id'] , To = ['to'] , From = ['from'] , FromDomain = ['from_domain'] , AttackTypes = ['attack_types'] , TimestampMs = ['timestamp_ms'] , MessageDate = ['date'] , Subject = ['subject'] , Ip = ['ip'] , Sbrs = ['sbrs'] , DomainReputation = ['domain_reputation'] , PolicyIds = ['policy_ids'] , DomainTags = ['domain_tags'] , HasAttachment = ['has_attachment'] , MessageDetailsLink = ['message_details_link'] , AttachmentSha256 = ['attachment_sha256'] , AttachmentExtensions = ['attachment_extensions'] , AttachmentFilenames = ['attachment_filenames'] | project TimeGenerated , Id , To , From , FromDomain , AttackTypes , TimestampMs , MessageDate , Subject , Ip , Sbrs , DomainReputation , PolicyIds , DomainTags , HasAttachment , MessageDetailsLink , AttachmentSha256 , AttachmentExtensions , AttachmentFilenames"
      },
      {
        "streams": [
          "Custom-AgariBPThreatFeedSubs_CL"
        ],
        "destinations": [
          "clv2ws1"
        ],
        "outputStream": "Custom-AgariBPThreatFeedSubs_CL",
        "transformKql": "source | extend TimeGenerated = now() , Id = ['id'] , Uri = ['uri'] , CreatedAt = ['created_at'] , ThreatFeedId = ['threat_feed_id'] | project TimeGenerated , Id , Uri , CreatedAt , ThreatFeedId"
      },
      {
        "streams": [
          "Custom-AgariAPRInvestigationsLog_CL"
        ],
        "destinations": [
          "clv2ws1"
        ],
        "outputStream": "Custom-AgariAPRInvestigationsLog_CL",
        "transformKql": "source | extend TimeGenerated = now() , Id = ['id'] , Filename = ['filename'] , ContentType = ['content_type'] , Size = ['size'] , Sha256 = ['sha256'] , CreatedAt = ['created_at'] , AttachmentType = ['type'] , Url = ['url'] | project TimeGenerated , Id , Filename , ContentType , Size , Sha256 , CreatedAt , AttachmentType , Url"
      }
    ]
  }
}