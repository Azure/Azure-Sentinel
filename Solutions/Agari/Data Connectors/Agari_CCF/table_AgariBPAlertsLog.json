{
  "name": "AgariBPAlertsLog_CL",
  "type": "Microsoft.OperationalInsights/workspaces/tables",
  "apiVersion": "2022-10-01",
  "tags": {
    "StreamName": "Custom-AgariBPAlertsLog_CL",
    "DataSource": "Agari",
    "Category": "Security"
  },
  "properties": {
    "retentionInDays": 180,
    "schema": {
      "name": "AgariBPAlertsLog_CL",
      "description": "Agari Brand Protection alert events",
      "columns": [
        {
          "name": "TimeGenerated",
          "type": "datetime",
          "isDefaultDisplay": true
        },
        {
          "name": "Id",
          "type": "long",
          "description": "Unique identifier for the alert"
        },
        {
          "name": "AlertType",
          "type": "string",
          "description": "Type of alert (e.g., authentication_spike, phishing)"
        },
        {
          "name": "LastNotifiedAt",
          "type": "datetime",
          "description": "Timestamp when the alert was last notified"
        },
        {
          "name": "ResolvedAt",
          "type": "datetime",
          "description": "Timestamp when the alert was resolved"
        },
        {
          "name": "CreatedAt",
          "type": "datetime",
          "description": "Timestamp when the alert was created"
        },
        {
          "name": "UpdatedAt",
          "type": "datetime",
          "description": "Timestamp when the alert was last updated"
        },
        {
          "name": "Summary",
          "type": "string",
          "description": "Human-readable summary of the alert"
        },
        {
          "name": "Domain",
          "type": "string",
          "description": "Domain associated with the alert"
        },
        {
          "name": "SpfFailHosts",
          "type": "dynamic",
          "description": "Array of hosts with SPF authentication failures"
        },
        {
          "name": "DkimFailHosts",
          "type": "dynamic",
          "description": "Array of hosts with DKIM authentication failures"
        },
        {
          "name": "Links",
          "type": "dynamic",
          "description": "Related API links for failure stats and samples"
        }
      ]
    }
  }
}