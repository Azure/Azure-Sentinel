          "User-Agent": "AgariSentinel APD_Integration/v1.0"
        },
        "queryParameters": {
          "start_date": "{_QueryWindowStartTime}",
          "end_date": "{_QueryWindowEndTime}",
          "sort": "created_at DESC",
          "policy_enabled": "true"
        }
      },
      "response": {
        "eventsJsonPaths": [
          "$.alert_events[*]"
