[
  {
    "type": "Microsoft.SecurityInsights/dataConnectors",
    "apiVersion": "2024-09-01",
    "name": "BPAlertsPoller",
    "location": "[parameters('workspace-location')]",
    "kind": "RestApiPoller",
    "properties": {
      "auth": {
        "type": "OAuth2",
        "ClientId": "[[parameters('clientId')]",
        "ClientSecret": "[[parameters('clientSecret')]",
        "GrantType": "client_credentials",
        "TokenEndpoint": "[[concat(parameters('apiUrl'),'/v1/cp/oauth/token')]",
        "TokenEndpointHeaders": {
          "Accept": "application/json",
          "Content-Type": "application/x-www-form-urlencoded"
        }
      },
      "request": {
        "apiEndpoint": "[[concat(parameters('apiUrl'),'/v1/cp/alert_events')]",
        "httpMethod": "GET",
        "rateLimitQPS": 1,
        "queryWindowInMin": 5,
        "queryTimeFormat": "yyyy-MM-ddTHH:mm:ssZ",
        "retryCount": 5,
        "timeoutInSeconds": 40,
        "headers": {
          "Accept": "application/json",
          "User-Agent": "AgariSentinel BP_Integration/v1.0"
        },
        "queryParameters": {
          "start_date": "{_QueryWindowStartTime}",
          "end_date": "{_QueryWindowEndTime}",
          "fields": "id",
          "sort": "created_at ASC"
        }
      },
      "response": {
        "eventsJsonPaths": [
          "$.alert_events[*]"
        ],
        "format": "json"
      },
      "paging": {
        "pagingType": "Offset",
        "offsetParaName": "offset",
        "pageSize": 200,
        "pageSizeParameterName": "limit"
      },
      "stepInfo": {
        "stepType": "Nested",
        "nextSteps": [
          {
            "stepId": "bp_alert_details",
            "stepPlaceholdersParsingKql": "source | project res = parse_json(data) | project id_placeholder = tostring(res.id)"
          }
        ]
      },
      "stepCollectorConfigs": {
        "bp_alert_details": {
          "shouldJoinNestedData": false,
          "request": {
            "apiEndpoint": "[[concat(parameters('apiUrl'),'/v1/cp/alert_events/$id_placeholder$')]",
            "httpMethod": "GET",
            "rateLimitQPS": 1,
            "queryWindowInMin": 5,
            "retryCount": 5,
            "timeoutInSeconds": 40,
            "logResponseContent": true,
            "headers": {
              "Accept": "application/json",
              "User-Agent": "AgariSentinel BP_Integration/v1.0"
            }
          },
          "response": {
            "eventsJsonPaths": [
              "$.alert_event"
            ],
            "format": "json"
          }
        }
      },
      "connectorDefinitionName": "AgariConnector",
      "dataType": "AgariBPAlertsLog_CL",
      "dcrConfig": {
        "streamName": "Custom-AgariBPAlertsLog_CL",
        "dataCollectionEndpoint": "{{dataCollectionEndpoint}}",
        "dataCollectionRuleImmutableId": "{{dataCollectionRuleImmutableId}}"
      }
    },
    "condition": "[[contains(parameters('enabledPollers'), 'BPAlerts')]"
  },
  {
    "type": "Microsoft.SecurityInsights/dataConnectors",
