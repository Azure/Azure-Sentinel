[
  {
    "condition": "[[equals(parameters('selectedStream')[0], 'detections')]",
    "name": "[[concat(parameters('workspace'),'/Microsoft.SecurityInsights/', uniqueString(concat('VectraDetectionsPoller', parameters('alias'))))]",
    "apiVersion": "2022-12-01-preview",
    "type": "Microsoft.OperationalInsights/workspaces/providers/dataConnectors",
    "location": "{{location}}",
    "kind": "RestApiPoller",
    "properties": {
      "auth": {
        "type": "OAuth2",
        "ClientId": "[[parameters('clientId')]",
        "ClientSecret": "[[parameters('clientSecret')]",
        "GrantType": "client_credentials",
        "TokenEndpoint": "[[concat(parameters('vectraApiUrl'), '/oauth2/token')]",
        "TokenEndpointHeaders": {
          "Accept": "application/json",
          "Content-Type": "application/x-www-form-urlencoded",
          "Authorization": "[[concat('Basic ', base64(concat(parameters('clientId'), ':', parameters('clientSecret'))))]",
          "User-Agent": "Vectra-Sentinel-3.5.0"
        }
      },
      "request": {
        "apiEndpoint": "[[concat(parameters('vectraApiUrl'), '/api/v3.5/events/detections')]",
        "httpMethod": "GET",
        "rateLimitQPS": 1,
        "retryCount": 3,
        "timeoutInSeconds": 180,
        "headers": {
          "Content-Type": "application/json",
          "Accept": "application/json",
          "User-Agent": "Vectra-Sentinel-3.5.0"
        },
        "queryParameters": {
          "include_triaged": "false",
          "include_info_category": "true",
          "size": "[[if(equals(parameters('ingestDetectionDetails'), 'false'), 'regular', 'detailed')]",
          "ordering": "id",
          "from": "[[parameters('detectionsStartingCheckpoint')]"
        }
      },
      "response": {
        "eventsJsonPaths": [
          "$.events[*]"
        ],
        "format": "json"
      },
      "paging": {
        "pagingType": "PersistentToken",
        "nextPageTokenJsonPath": "$.next_checkpoint",
        "NextPageParaName": "from",
        "pageSize": 100,
        "pageSizeParameterName": "limit"
      },
      "connectorDefinitionName": "[[parameters('connectorDefinitionName')]",
      "dataType": "Detections_Data_CL",
      "dcrConfig": {
        "streamName": "Custom-Detections_Data_CL",
        "dataCollectionEndpoint": "[[parameters('dcrConfig').dataCollectionEndpoint]",
        "dataCollectionRuleImmutableId": "[[parameters('dcrConfig').dataCollectionRuleImmutableId]"
      },
      "addOnAttributes": {
        "alias": "[[parameters('alias')]",
        "streamType": "Detections",
        "apiUrl": "[[parameters('vectraApiUrl')]",
        "checkpointMode": "PersistentToken",
        "checkpointVersion": "2.0",
        "checkpointField": "next_checkpoint",
        "checkpointParam": "from",
        "startingCheckpoint": "[[parameters('detectionsStartingCheckpoint')]"
      }
    }
  },
  {
    "condition": "[[equals(parameters('selectedStream')[0], 'lockdown')]",
    "name": "[[concat(parameters('workspace'),'/Microsoft.SecurityInsights/', uniqueString(concat('VectraLockdownPoller', parameters('alias'))))]",
    "apiVersion": "2022-12-01-preview",
    "type": "Microsoft.OperationalInsights/workspaces/providers/dataConnectors",
    "location": "{{location}}",
    "kind": "RestApiPoller",
    "properties": {
      "auth": {
        "type": "OAuth2",
        "ClientId": "[[parameters('clientId')]",
        "ClientSecret": "[[parameters('clientSecret')]",
        "GrantType": "client_credentials",
        "TokenEndpoint": "[[concat(parameters('vectraApiUrl'), '/oauth2/token')]",
        "TokenEndpointHeaders": {
          "Accept": "application/json",
          "Content-Type": "application/x-www-form-urlencoded",
          "Authorization": "[[concat('Basic ', base64(concat(parameters('clientId'), ':', parameters('clientSecret'))))]",
          "User-Agent": "Vectra-Sentinel-3.5.0"
        }
      },
      "request": {
        "apiEndpoint": "[[concat(parameters('vectraApiUrl'), '/api/v3.4/lockdown')]",
        "httpMethod": "GET",
        "rateLimitQPS": 1,
        "queryWindowInMin": 5,
        "retryCount": 3,
        "timeoutInSeconds": 180,
        "headers": {
          "Content-Type": "application/json",
          "Accept": "application/json",
          "User-Agent": "Vectra-Sentinel-3.5.0"
        },
        "queryParameters": {
          "type": "account,host,traffic"
        }
      },
      "response": {
        "eventsJsonPaths": [
          "$[*]"
        ],
        "format": "json"
      },
      "connectorDefinitionName": "[[parameters('connectorDefinitionName')]",
      "dataType": "Lockdown_Data_CL",
      "dcrConfig": {
        "streamName": "Custom-Lockdown_Data_CL",
        "dataCollectionEndpoint": "[[parameters('dcrConfig').dataCollectionEndpoint]",
        "dataCollectionRuleImmutableId": "[[parameters('dcrConfig').dataCollectionRuleImmutableId]"
      },
      "addOnAttributes": {
        "alias": "[[parameters('alias')]",
        "streamType": "Lockdown",
        "apiUrl": "[[parameters('vectraApiUrl')]"
      }
    }
  },
  {
    "condition": "[[equals(parameters('selectedStream')[0], 'entities')]",
    "name": "[[concat(parameters('workspace'),'/Microsoft.SecurityInsights/', uniqueString(concat('VectraEntitiesPoller', parameters('alias'))))]",
    "apiVersion": "2022-12-01-preview",
    "type": "Microsoft.OperationalInsights/workspaces/providers/dataConnectors",
    "location": "{{location}}",
    "kind": "RestApiPoller",
    "properties": {
      "auth": {
        "type": "OAuth2",
        "ClientId": "[[parameters('clientId')]",
        "ClientSecret": "[[parameters('clientSecret')]",
        "GrantType": "client_credentials",
        "TokenEndpoint": "[[concat(parameters('vectraApiUrl'), '/oauth2/token')]",
        "TokenEndpointHeaders": {
          "Accept": "application/json",
          "Content-Type": "application/x-www-form-urlencoded",
          "Authorization": "[[concat('Basic ', base64(concat(parameters('clientId'), ':', parameters('clientSecret'))))]",
          "User-Agent": "Vectra-Sentinel-3.5.0"
        }
      },
      "request": {
        "apiEndpoint": "[[concat(parameters('vectraApiUrl'), '/api/v3.4/entities')]",
        "httpMethod": "GET",
        "rateLimitQPS": 1,
        "queryWindowInMin": 10,
        "queryTimeFormat": "yyyy-MM-ddTHH:mm:ssZ",
        "startTimeAttributeName": "last_modified_timestamp_gte",
        "retryCount": 3,
        "timeoutInSeconds": 180,
        "headers": {
          "Content-Type": "application/json",
          "Accept": "application/json",
          "User-Agent": "Vectra-Sentinel-3.5.0"
        },
        "queryParameters": {
          "ordering": "last_modified_timestamp",
          "page_size": "5000",
          "state": "active"
        }
      },
      "response": {
        "eventsJsonPaths": [
          "$.results[*]"
        ],
        "format": "json"
      },
      "connectorDefinitionName": "[[parameters('connectorDefinitionName')]",
      "dataType": "Entities_Data_CL",
      "dcrConfig": {
        "streamName": "Custom-Entities_Data_CL",
        "dataCollectionEndpoint": "[[parameters('dcrConfig').dataCollectionEndpoint]",
        "dataCollectionRuleImmutableId": "[[parameters('dcrConfig').dataCollectionRuleImmutableId]"
      },
      "addOnAttributes": {
        "alias": "[[parameters('alias')]",
        "streamType": "Entities",
        "apiUrl": "[[parameters('vectraApiUrl')]",
        "checkpointMode": "SlidingWindowViaStartTime",
        "checkpointField": "last_modified_timestamp",
        "checkpointParam": "last_modified_timestamp_gte",
        "queryWindowInMin": "10"
      }
    }
  }
]
