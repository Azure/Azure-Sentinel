[
  {
    "name": "CloudflareAuditLogPoller",
    "apiVersion": "2025-03-01",
    "type": "Microsoft.SecurityInsights/dataConnectors",
    "location": "{{location}}",
    "kind": "RestApiPoller",
    "properties": {
      "connectorDefinitionName": "CloudflareAuditLogDefinition",
      "dataType": "CloudflareAuditLog_CL",
      "dcrConfig": {
        "streamName": "Custom-CloudflareAuditLog_CL",
        "dataCollectionEndpoint": "{{dataCollectionEndpoint}}",
        "dataCollectionRuleImmutableId": "{{dataCollectionRuleImmutableId}}"
      },
      "auth": {
        "type": "APIKey",
        "ApiKey": "{{apikey}}",
        "ApiKeyName": "Authorization",
        "ApiKeyIdentifier": "Bearer"
      },
      "request": {
        "apiEndpoint": "[[concat('https://api.cloudflare.com/client/v4/accounts/', parameters('accountId'), '/logs/audit')]",
        "httpMethod": "GET",
        "queryWindowInMin": 5,
        "queryTimeFormat": "yyyy-MM-ddTHH:mm:ssZ",
        "startTimeAttributeName": "since",
        "endTimeAttributeName": "before",
        "rateLimitQPS": 1200,
        "retryCount": 3,
        "timeoutInSeconds": 60,
        "headers": {
          "Accept": "application/json",
          "User-Agent": "Scuba"
        },
        "queryParameters": {
          "direction": "asc"
        }
      },
      "response": {
        "eventsJsonPaths": [
          "$.result"
        ],
        "format": "json"
      },
      "paging": {
        "pagingType": "NextPageToken",
        "pageSize": 1000,
        "pageSizeParaName": "limit",
        "nextPageParaName": "cursor",
        "nextPageTokenJsonPath": "$.result_info.cursor"
      }
    }
  }
]