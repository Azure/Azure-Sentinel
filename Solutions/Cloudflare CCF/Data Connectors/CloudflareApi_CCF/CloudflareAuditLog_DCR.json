[
  {
    "name": "CloudflareAuditLogDCR",
    "apiVersion": "2023-04-01-preview",
    "type": "Microsoft.Insights/dataCollectionRules",
    "location": "{{location}}",
    "properties": {
      "dataCollectionEndpointId": "{{dataCollectionEndpointId}}",
      "streamDeclarations": {
        "Custom-CloudflareAuditLog_CL": {
          "columns": [
            {
              "name": "id",
              "type": "string"
            },
            {
              "name": "account",
              "type": "dynamic"
            },
            {
              "name": "action",
              "type": "dynamic"
            },
            {
              "name": "actor",
              "type": "dynamic"
            },
            {
              "name": "raw",
              "type": "dynamic"
            },
            {
              "name": "resource",
              "type": "dynamic"
            },
            {
              "name": "zone",
              "type": "dynamic"
            }
          ]
        }
      },
      "destinations": {
        "logAnalytics": [
          {
            "workspaceResourceId": "{{workspaceResourceId}}",
            "name": "clv2ws1"
          }
        ]
      },
      "dataFlows": [
        {
          "streams": [
            "Custom-CloudflareAuditLog_CL"
          ],
          "destinations": [
            "clv2ws1"
          ],
          "transformKql": "source | extend TimeGenerated = todatetime(action['time']) | project-rename Id=id, Account=account, Action=action, Actor=actor, Raw=raw, Resource=resource, Zone=zone",
          "outputStream": "Custom-CloudflareAuditLog_CL"
        }
      ]
    }
  }
]