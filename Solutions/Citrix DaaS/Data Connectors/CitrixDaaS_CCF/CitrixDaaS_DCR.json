{
  "name": "CitrixDaaSActionsDCR",
  "apiVersion": "2023-04-01-preview",
  "type": "Microsoft.Insights/dataCollectionRules",
  "location": "{{location}}",
  "properties": {
    "dataCollectionEndpointId": "{{dataCollectionEndpointId}}",
    "streamDeclarations": {
      "Custom-CitrixDaaSConfigOps_CL": {
        "columns": [
          {
            "name": "Id",
            "type": "string"
          },
          {
            "name": "Text",
            "type": "string"
          },
          {
            "name": "User",
            "type": "string"
          },
          {
            "name": "UserIdentity",
            "type": "string"
          },
          {
            "name": "Source",
            "type": "string"
          },
          {
            "name": "AdminMachineIP",
            "type": "string"
          },
          {
            "name": "FormattedStartTime",
            "type": "datetime"
          },
          {
            "name": "FormattedEndTime",
            "type": "datetime"
          },
          {
            "name": "IsSuccessful",
            "type": "boolean"
          },
          {
            "name": "OperationType",
            "type": "string"
          },
          {
            "name": "CitrixCustomerId",
            "type": "string"
          }
        ]
      },
      "Custom-CitrixDaaSSessions_CL": {
        "columns": [
          {
            "name": "Id",
            "type": "string"
          },
          {
            "name": "SessionType",
            "type": "string"
          },
          {
            "name": "State",
            "type": "string"
          },
          {
            "name": "AppState",
            "type": "string"
          },
          {
            "name": "UntrustedUserName",
            "type": "string"
          },
          {
            "name": "FormattedStartTime",
            "type": "datetime"
          },
          {
            "name": "FormattedStateChangeTime",
            "type": "datetime"
          },
          {
            "name": "IsAnonymousUser",
            "type": "boolean"
          },
          {
            "name": "CitrixCustomerId",
            "type": "string"
          },
          {
            "name": "Connection",
            "type": "dynamic"
          },
          {
            "name": "Client",
            "type": "dynamic"
          }
        ]
      }
    },
    "destinations": {
      "logAnalytics": [
        {
          "workspaceResourceId": "{{workspaceResourceId}}",
          "name": "clv2ws1"
        }
      ]
    },
    "dataFlows": [
      {
        "streams": [
          "Custom-CitrixDaaSConfigOps_CL"
        ],
        "destinations": [
          "clv2ws1"
        ],
        "outputStream": "Custom-CitrixDaaSConfigOps_CL",
        "transformKql": "source | extend TimeGenerated = iff(isnotempty(FormattedEndTime), todatetime(FormattedEndTime), iff(isnotempty(FormattedStartTime), todatetime(FormattedStartTime), now())) , OperationId = ['Id'] , OperationText = ['Text'] , AdminMachineIp = ['AdminMachineIP'] , StartTime = ['FormattedStartTime'] , EndTime = ['FormattedEndTime'] | project TimeGenerated , OperationId , OperationText , User , UserIdentity , Source , AdminMachineIp , StartTime , EndTime , IsSuccessful , OperationType , CitrixCustomerId"
      },
      {
        "streams": [
          "Custom-CitrixDaaSSessions_CL"
        ],
        "destinations": [
          "clv2ws1"
        ],
        "outputStream": "Custom-CitrixDaaSSessions_CL",
        "transformKql": "source | extend TimeGenerated = iff(isnotempty(FormattedStartTime), todatetime(FormattedStartTime), now()) , SessionId = ['Id'] , UserName = ['UntrustedUserName'] , StartTime = ['FormattedStartTime'] , StateChangeTime = ['FormattedStateChangeTime'] , ConnectionProtocol = tostring(Connection.Protocol) , ConnectedViaIp = tostring(Connection.ConnectedViaIP) , ClientIpAddress = tostring(Client.IPAddress) , ClientName = tostring(Client.Name) | project TimeGenerated , SessionId , SessionType , State , AppState , UserName , StartTime , StateChangeTime , IsAnonymousUser , ConnectionProtocol , ConnectedViaIp , ClientIpAddress , ClientName , CitrixCustomerId"
      }
    ]
  }
}
