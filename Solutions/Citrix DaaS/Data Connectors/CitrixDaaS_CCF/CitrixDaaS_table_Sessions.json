{
  "name": "CitrixDaaSSessions_CL",
  "type": "Microsoft.OperationalInsights/workspaces/tables",
  "apiVersion": "2022-10-01",
  "tags": {
    "StreamName": "Custom-CitrixDaaSSessions_CL",
    "DataSource": "CitrixDaaS",
    "Category": "AuditLogs"
  },
  "properties": {
    "retentionInDays": 180,
    "schema": {
      "name": "CitrixDaaSSessions_CL",
      "description": "Citrix DaaS session activity logs",
      "columns": [
        {
          "name": "TimeGenerated",
          "type": "datetime"
        },
        {
          "name": "SessionId",
          "type": "string",
          "description": "Unique session identifier"
        },
        {
          "name": "SessionType",
          "type": "string",
          "description": "Type of session (Desktop, Application)"
        },
        {
          "name": "State",
          "type": "string",
          "description": "Session state (Active, Disconnected, etc.)"
        },
        {
          "name": "AppState",
          "type": "string",
          "description": "Application state"
        },
        {
          "name": "UserName",
          "type": "string",
          "description": "User name for the session"
        },
        {
          "name": "StartTime",
          "type": "datetime",
          "description": "Session start time"
        },
        {
          "name": "StateChangeTime",
          "type": "datetime",
          "description": "Last state change time"
        },
        {
          "name": "IsAnonymousUser",
          "type": "boolean",
          "description": "Whether user is anonymous"
        },
        {
          "name": "ConnectionProtocol",
          "type": "string",
          "description": "Connection protocol"
        },
        {
          "name": "ConnectedViaIp",
          "type": "string",
          "description": "IP connected via"
        },
        {
          "name": "ClientIpAddress",
          "type": "string",
          "description": "Client IP address"
        },
        {
          "name": "ClientName",
          "type": "string",
          "description": "Client device name"
        },
        {
          "name": "CitrixCustomerId",
          "type": "string",
          "description": "Citrix Cloud Customer ID of the connection that produced this record; enables multi-tenant differentiation."
        }
      ]
    }
  }
}
