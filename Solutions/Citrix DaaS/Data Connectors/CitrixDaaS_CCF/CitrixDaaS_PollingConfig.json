[
  {
    "type": "Microsoft.SecurityInsights/dataConnectors",
    "apiVersion": "2025-03-01",
    "name": "[[concat('parameters('workspace')', '/Microsoft.SecurityInsights/','CitrixDaaSSessions' , uniqueString(parameters('customerId')), uniqueString('Sessions') )]",
    "location": "[resourceGroup().location]",
    "kind": "RestApiPoller",
    "properties": {
      "auth": {
        "type": "JwtToken",
        "userName": {
          "key": "client_id",
          "value": "[[parameters('clientId')]"
        },
        "password": {
          "key": "client_secret",
          "value": "[[parameters('clientSecret')]"
        },
        "TokenEndpoint": "https://api.cloud.com/cctrustoauth2/root/tokens/clients",
        "Headers": {
          "Content-Type": "application/x-www-form-urlencoded"
        },
        "JwtTokenJsonPath": "$.access_token",
        "UserTokenPrepend": "CWSAuth bearer="
      },
      "request": {
        "apiEndpoint": "[[concat(parameters('baseApiUrl'), '/Sessions')]",
        "httpMethod": "GET",
        "rateLimitQPS": 10,
        "queryWindowInMin": 15,
        "retryCount": 3,
        "timeoutInSeconds": 40,
        "headers": {
          "Citrix-CustomerId": "[[parameters('customerId')]",
          "Citrix-InstanceId": "[[parameters('siteId')]",
          "Accept": "application/json"
        }
      },
      "response": {
        "eventsJsonPaths": [
          "$.Items[*]"
        ],
        "format": "json"
      },
      "paging": {
        "pagingType": "NextPageToken",
        "nextPageTokenJsonPath": "$.ContinuationToken",
        "NextPageParaName": "ContinuationToken",
        "pagingInfoPlacement": "QueryString",
        "pagingQueryParamOnly": true
      },
      "checkConnectivityRequest": {
        "apiEndpoint": "https://postman-echo.com/status/200",
        "httpMethod": "GET",
        "retryCount": 3,
        "timeoutInSeconds": 20
      },
      "connectorDefinitionName": "CitrixDaaSActionsConnector",
      "dataType": "CitrixDaaSSessions",
      "dcrConfig": {
        "streamName": "Custom-CitrixDaaSSessions_CL",
        "dataCollectionEndpoint": "{{dataCollectionEndpoint}}",
        "dataCollectionRuleImmutableId": "{{dataCollectionRuleImmutableId}}"
      },
      "addOnAttributes": {
        "CitrixCustomerId": "[[parameters('customerId')]"
      }
    }
  },
  {
    "type": "Microsoft.SecurityInsights/dataConnectors",
    "apiVersion": "2025-03-01",
    "name": "[[concat('parameters('workspace')', '/Microsoft.SecurityInsights/','CitrixDaaSConfigOps' , uniqueString(parameters('customerId')), uniqueString('ConfigOps') )]",
    "location": "[resourceGroup().location]",
    "kind": "RestApiPoller",
    "properties": {
      "auth": {
        "type": "JwtToken",
        "userName": {
          "key": "client_id",
          "value": "[[parameters('clientId')]"
        },
        "password": {
          "key": "client_secret",
          "value": "[[parameters('clientSecret')]"
        },
        "TokenEndpoint": "https://api.cloud.com/cctrustoauth2/root/tokens/clients",
        "Headers": {
          "Content-Type": "application/x-www-form-urlencoded"
        },
        "JwtTokenJsonPath": "$.access_token",
        "UserTokenPrepend": "CWSAuth bearer="
      },
      "request": {
        "apiEndpoint": "[[concat(parameters('baseApiUrl'), '/ConfigLog/Operations')]",
        "httpMethod": "GET",
        "rateLimitQPS": 10,
        "queryWindowInMin": 15,
        "retryCount": 3,
        "timeoutInSeconds": 40,
        "headers": {
          "Citrix-CustomerId": "[[parameters('customerId')]",
          "Citrix-InstanceId": "[[parameters('siteId')]",
          "Accept": "application/json"
        }
      },
      "response": {
        "eventsJsonPaths": [
          "$.Items[*]"
        ],
        "format": "json"
      },
      "paging": {
        "pagingType": "NextPageToken",
        "nextPageTokenJsonPath": "$.ContinuationToken",
        "NextPageParaName": "ContinuationToken",
        "pagingInfoPlacement": "QueryString",
        "pagingQueryParamOnly": true
      },
      "checkConnectivityRequest": {
        "apiEndpoint": "https://postman-echo.com/status/200",
        "httpMethod": "GET",
        "retryCount": 3,
        "timeoutInSeconds": 20
      },
      "connectorDefinitionName": "CitrixDaaSActionsConnector",
      "dataType": "CitrixDaaSConfigOps",
      "dcrConfig": {
        "streamName": "Custom-CitrixDaaSConfigOps_CL",
        "dataCollectionEndpoint": "{{dataCollectionEndpoint}}",
        "dataCollectionRuleImmutableId": "{{dataCollectionRuleImmutableId}}"
      },
      "addOnAttributes": {
        "CitrixCustomerId": "[[parameters('customerId')]"
      }
    }
  }
]
