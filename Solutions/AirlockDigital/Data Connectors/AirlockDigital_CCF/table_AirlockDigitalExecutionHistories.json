{
  "name": "AirlockDigitalExecutionHistories_CL",
  "type": "Microsoft.OperationalInsights/workspaces/tables",
  "apiVersion": "2022-10-01",
  "tags": {
    "StreamName": "Custom-AirlockDigitalExecutionHistories_CL",
    "DataSource": "AirlockDigital",
    "Category": "ExecutionHistory"
  },
  "properties": {
    "retentionInDays": 90,
    "schema": {
      "name": "AirlockDigitalExecutionHistories_CL",
      "description": "Airlock Digital Execution History Logs",
      "columns": [
        {
          "name": "TimeGenerated",
          "type": "datetime",
          "isDefaultDisplay": true
        },
        {
          "name": "Checkpoint",
          "type": "string",
          "description": "Event checkpoint identifier for incremental retrieval"
        },
        {
          "name": "EventDateTime",
          "type": "string",
          "description": "Timestamp of execution event"
        },
        {
          "name": "ExecutionType",
          "type": "int",
          "description": "Execution type code (0-18): Trusted, Blocked, Audit, OTP, etc."
        },
        {
          "name": "Username",
          "type": "string",
          "description": "User account that executed the file"
        },
        {
          "name": "Hostname",
          "type": "string",
          "description": "Host machine name where execution occurred"
        },
        {
          "name": "NetDomain",
          "type": "string",
          "description": "Network domain"
        },
        {
          "name": "FileName",
          "type": "string",
          "description": "Full path of the executed file"
        },
        {
          "name": "ParentPolicy",
          "type": "string",
          "description": "Parent policy group name"
        },
        {
          "name": "PolicyName",
          "type": "string",
          "description": "Airlock policy name applied"
        },
        {
          "name": "PolicyVersion",
          "type": "string",
          "description": "Policy version identifier"
        },
        {
          "name": "CommandLine",
          "type": "string",
          "description": "Command line arguments"
        },
        {
          "name": "Publisher",
          "type": "string",
          "description": "Code signing publisher"
        },
        {
          "name": "ParentProcess",
          "type": "string",
          "description": "Parent process name"
        },
        {
          "name": "GrandparentProcess",
          "type": "string",
          "description": "Grandparent process name"
        },
        {
          "name": "SHA256",
          "type": "string",
          "description": "SHA-256 file hash"
        },
        {
          "name": "MD5",
          "type": "string",
          "description": "MD5 file hash"
        },
        {
          "name": "SHA128",
          "type": "string",
          "description": "SHA-128 file hash"
        },
        {
          "name": "SHA384",
          "type": "string",
          "description": "SHA-384 file hash"
        },
        {
          "name": "SHA512",
          "type": "string",
          "description": "SHA-512 file hash"
        },
        {
          "name": "IPAddress",
          "type": "string",
          "description": "IP address"
        },
        {
          "name": "LocalIPAddress",
          "type": "string",
          "description": "Local IP address"
        },
        {
          "name": "ExtensionId",
          "type": "string",
          "description": "Browser extension ID"
        },
        {
          "name": "ExtensionName",
          "type": "string",
          "description": "Browser extension name"
        },
        {
          "name": "ExtensionType",
          "type": "string",
          "description": "Extension type (1=CRX, 2=XPI)"
        },
        {
          "name": "ExtensionBrowser",
          "type": "string",
          "description": "Browser type (1=Chrome, 2=Firefox, 3=Edge)"
        }
      ]
    }
  }
}