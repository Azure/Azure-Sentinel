{
  "name": "AirlockDigitalFileActivitySummary_CL",
  "type": "Microsoft.OperationalInsights/workspaces/tables",
  "apiVersion": "2022-10-01",
  "tags": {
    "StreamName": "Custom-AirlockDigitalFileActivitySummary_CL",
    "DataSource": "AirlockDigital",
    "Category": "Summary"
  },
  "properties": {
    "retentionInDays": 90,
    "schema": {
      "name": "AirlockDigitalFileActivitySummary_CL",
      "description": "Airlock Digital File Activity Summary",
      "columns": [
        {
          "name": "TimeGenerated",
          "type": "datetime",
          "isDefaultDisplay": true
        },
        {
          "name": "TimePeriod",
          "type": "string",
          "description": "Time period for the summary"
        },
        {
          "name": "StartDate",
          "type": "string",
          "description": "Start date of the summary period"
        },
        {
          "name": "EndDate",
          "type": "string",
          "description": "End date of the summary period"
        },
        {
          "name": "PolicyFilter",
          "type": "string",
          "description": "Policy filter name (if applied)"
        },
        {
          "name": "NewFilesCount",
          "type": "int",
          "description": "Count of unique new file hashes"
        },
        {
          "name": "MaliciousFilesCount",
          "type": "int",
          "description": "Count of malicious files (optional)"
        },
        {
          "name": "TotalUntrustedTotal",
          "type": "int",
          "description": "Total count of untrusted executions"
        },
        {
          "name": "TotalUntrustedUnique",
          "type": "int",
          "description": "Unique count of untrusted executions"
        },
        {
          "name": "BlockedTotal",
          "type": "int",
          "description": "Total count of blocked executions"
        },
        {
          "name": "BlockedUnique",
          "type": "int",
          "description": "Unique count of blocked executions"
        },
        {
          "name": "AuditTotal",
          "type": "int",
          "description": "Total count of audited executions"
        },
        {
          "name": "AuditUnique",
          "type": "int",
          "description": "Unique count of audited executions"
        },
        {
          "name": "TrustedTotal",
          "type": "int",
          "description": "Total count of trusted executions"
        },
        {
          "name": "OtpTotal",
          "type": "int",
          "description": "Total count of one-time password executions"
        },
        {
          "name": "BlocklistTotal",
          "type": "int",
          "description": "Total count of blocklist executions"
        },
        {
          "name": "BlocklistAuditTotal",
          "type": "int",
          "description": "Total count of blocklist audit executions"
        }
      ]
    }
  }
}