{
  "name": "AirlockDigitalServerActivities_CL",
  "type": "Microsoft.OperationalInsights/workspaces/tables",
  "apiVersion": "2022-10-01",
  "tags": {
    "StreamName": "Custom-AirlockDigitalServerActivities_CL",
    "DataSource": "AirlockDigital",
    "Category": "ServerActivities"
  },
  "properties": {
    "retentionInDays": 90,
    "schema": {
      "name": "AirlockDigitalServerActivities_CL",
      "description": "Airlock Digital Server Activity History Logs",
      "columns": [
        {
          "name": "TimeGenerated",
          "type": "datetime",
          "isDefaultDisplay": true
        },
        {
          "name": "Checkpoint",
          "type": "string",
          "description": "Event checkpoint identifier for incremental retrieval"
        },
        {
          "name": "EventDateTime",
          "type": "string",
          "description": "Event timestamp (when server activity occurred)"
        },
        {
          "name": "Task",
          "type": "string",
          "description": "Type of server task performed"
        },
        {
          "name": "User",
          "type": "string",
          "description": "User associated with the task"
        },
        {
          "name": "Description",
          "type": "string",
          "description": "Detailed description of the server activity"
        },
        {
          "name": "ConnectorName",
          "type": "string",
          "description": "Connector Friendly Name assigned during connector setup"
        }
      ]
    }
  }
}