[
    {
              "name": "CrowdStrikeDCRApps",
              "apiVersion": "2025-09-01",
              "type": "Microsoft.Insights/dataCollectionRules",
              "location": "[parameters('workspace-location')]",
              "kind": null,
              "properties": {
                "streamDeclarations": {
                  "Custom-CrowdstrikeApps": {
                    "columns": [
                      { "name": "TimeGenerated", "type": "datetime" },
                      { "name": "id", "type": "string" },
                      { "name": "cid", "type": "string" },
                      { "name": "name", "type": "string" },
                      { "name": "vendor", "type": "string" },
                      { "name": "version", "type": "string" },
                      { "name": "software_type", "type": "string" },
                      { "name": "name_vendor", "type": "string" },
                      { "name": "name_vendor_version", "type": "string" },
                      { "name": "versioning_scheme", "type": "string" },
                      { "name": "category", "type": "string" },
                      { "name": "architectures", "type": "dynamic" },
                      { "name": "installation_paths", "type": "dynamic" },
                      { "name": "installation_timestamp", "type": "datetime" },
                      { "name": "first_seen_timestamp", "type": "datetime" },
                      { "name": "last_updated_timestamp", "type": "datetime" },
                      { "name": "is_suspicious", "type": "boolean" },
                      { "name": "is_normalized", "type": "boolean" },
                      { "name": "host", "type": "dynamic" },
					  { "name": "connectionName", "type": "string" }
                    ]
                  }
                },
                "destinations": {
                  "logAnalytics": [
                    {
                      "workspaceResourceId": "[variables('workspaceResourceId')]",
                      "name": "clv2ws1"
                    }
                  ]
                },
                "dataFlows": [
                  {
                    "streams": [
                      "Custom-CrowdstrikeApps"
                    ],
                    "destinations": [
                      "clv2ws1"
                    ],
                    "transformKql": "source | project TimeGenerated = now(), Id = id, Cid = cid, Name = name, Vendor = vendor, Version = version, SoftwareType = software_type, NameVendor = name_vendor, NameVendorVersion = name_vendor_version, VersioningScheme = versioning_scheme, Category = category, Architectures = todynamic(architectures), InstallationPaths = todynamic(installation_paths), InstallationTimestamp = installation_timestamp, FirstSeenTimestamp = first_seen_timestamp, LastUpdatedTimestamp = last_updated_timestamp, IsSuspicious = is_suspicious, IsNormalized = is_normalized, Host = host,ConnectionName = connectionName",
                    "outputStream": "Custom-CrowdstrikeApps_CL"
                  }
                ],
                "dataCollectionEndpointId": "[concat('/subscriptions/', parameters('subscription'), '/resourceGroups/', parameters('resourceGroupName'), '/providers/Microsoft.Insights/dataCollectionEndpoints/', parameters('workspace'))]"
              }
            }
        ]