{
    "$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "FunctionName": {
            "defaultValue": "CSFalconIOC",
            "type": "string",
            "minLength": 1,
            "maxLength": 11,
            "metadata": {
                "description": "Name of the Azure Function App."
            }
        },
        "CrowdStrikeClientId": {
            "defaultValue": "",
            "type": "secureString",
            "metadata": {
                "description": "CrowdStrike client id."
            }
        },
        "CrowdStrikeClientSecret": {
            "defaultValue": "",
            "type": "secureString",
            "metadata": {
                "description": "CrowdStrike client secret."
            }
        },
        "CrowdStrikeBaseUrl": {
            "defaultValue": "",
            "type": "string",
            "metadata": {
                "description": "Base URL for the CrowdStrike credentials."
            }
        },
        "WorkspaceId": {
            "defaultValue": "",
            "type": "string",
            "metadata": {
                "description": "Log anayltics workspace for Miscrosoft Sentinel."
            }
        },
        "TenantId": {
            "defaultValue": "",
            "type": "string",
            "metadata": {
                "description": "Tenant ID where Microsoft Sentinel is hosted in."
            }
        },
        "Indicators": {
            "type": "string",
            "defaultValue": "url,hash_md5,hash_sha256,hash_sha1,domain,ip_address,mutex_name,password,file_name,email_address,bitcoin_address,username,persona_name,ip_address_block,coin_address",
            "metadata": {
                "description": "The indicator types that should be fetched."
            }
        },
        "AadClientId": {
            "defaultValue": "",
            "type": "secureString",
            "metadata": {
                "description": "The client id of the Entra App created."
            }
        },
        "AadClientSecret": {
            "defaultValue": "",
            "type": "secureString",
            "metadata": {
                "description": "The client secret of the Entra App created."
            }
        },
        "LookBackDays": {
            "defaultValue": 1,
            "type": "int",
            "minValue": 1,
            "maxValue": 60,
            "metadata": {
                "description": "How many days worth of indicator history should be fetched."
            }
        },
        "AppInsightsWorkspaceResourceId": {
            "defaultValue": "",
            "type": "string",
            "metadata": {
                "description": "Resource ID of the Log Analytics workspace for Application Insights."
            }
        },
        "EnableVNetIntegration": {
            "type": "bool",
            "defaultValue": false,
            "metadata": {
                "description": "Set to true to deploy a VNet and integrate the Function App with it. When false, VNet resources are skipped and storage remains publicly accessible."
            }
        },
        "VNetAddressPrefix": {
            "type": "string",
            "defaultValue": "10.0.0.0/16",
            "metadata": {
                "description": "Address space for the Virtual Network in CIDR notation (e.g. 10.0.0.0/16)."
            }
        },
        "SubnetName": {
            "type": "string",
            "defaultValue": "snet-functionapp",
            "metadata": {
                "description": "Name of the subnet delegated to the Function App for VNet Integration."
            }
        },
        "SubnetAddressPrefix": {
            "type": "string",
            "defaultValue": "10.0.0.0/24",
            "metadata": {
                "description": "Address prefix for the Function App integration subnet in CIDR notation. Must be within the VNet address space. Minimum /28."
            }
        },
        "PrivateEndpointSubnetName": {
            "type": "string",
            "defaultValue": "snet-privateendpoints",
            "metadata": {
                "description": "Name of the subnet used for storage private endpoints. Must not be delegated."
            }
        },
        "PrivateEndpointSubnetAddressPrefix": {
            "type": "string",
            "defaultValue": "10.0.1.0/24",
            "metadata": {
                "description": "Address prefix for the private endpoint subnet in CIDR notation. Must be within the VNet address space and not overlap with the Function App subnet."
            }
        },
        "UseExistingDnsZones": {
            "type": "bool",
            "defaultValue": false,
            "metadata": {
                "description": "Set to true when the private DNS zones and their VNet links already exist (e.g. from a prior deployment). When true, the template skips creating DNS zones and VNet links to avoid conflicts."
            }
        }
    },
    "variables": {
        "FunctionName": "[concat(toLower(parameters('FunctionName')), uniqueString(resourceGroup().id))]",
        "StorageSuffix": "[environment().suffixes.storage]",
        "AppServicePlanName": "[concat(variables('FunctionName'), '-asp')]",
        "vnetName": "[concat('vnet-', variables('FunctionName'))]",
        "SubnetResourceId": "[resourceId('Microsoft.Network/virtualNetworks/subnets', variables('vnetName'), parameters('SubnetName'))]",
        "PrivateEndpointSubnetResourceId": "[resourceId('Microsoft.Network/virtualNetworks/subnets', variables('vnetName'), parameters('PrivateEndpointSubnetName'))]",
        "enableVNet": "[parameters('EnableVNetIntegration')]",
        "createDnsZones": "[and(variables('enableVNet'), not(parameters('UseExistingDnsZones')))]",
        "appServicePlanSku": "[if(variables('enableVNet'), 'EP1', 'Y1')]",
        "appServicePlanTier": "[if(variables('enableVNet'), 'ElasticPremium', 'Dynamic')]",
        "appServicePlanKind": "[if(variables('enableVNet'), 'elastic', 'functionapp')]",
        "blobPrivateDnsZoneName": "[concat('privatelink.blob.', environment().suffixes.storage)]",
        "filePrivateDnsZoneName": "[concat('privatelink.file.', environment().suffixes.storage)]"
    },
    "resources": [
        {
            "type": "Microsoft.Insights/components",
            "apiVersion": "2020-02-02",
            "name": "[variables('FunctionName')]",
            "location": "[resourceGroup().location]",
            "kind": "web",
            "properties": {
                "Application_Type": "web",
                "ApplicationId": "[variables('FunctionName')]",
                "WorkspaceResourceId": "[parameters('AppInsightsWorkspaceResourceId')]"
            }
        },
        {
            "type": "Microsoft.Storage/storageAccounts",
            "apiVersion": "2021-09-01",
            "name": "[tolower(variables('FunctionName'))]",
            "location": "[resourceGroup().location]",
            "dependsOn": [
                "[resourceId('Microsoft.Network/virtualNetworks', variables('vnetName'))]"
            ],
            "sku": {
                "name": "Standard_LRS",
                "tier": "Standard"
            },
            "kind": "StorageV2",
            "properties": {
                "networkAcls": {
                    "bypass": "AzureServices",
                    "virtualNetworkRules": [],
                    "ipRules": [],
                    "defaultAction": "[if(variables('enableVNet'), 'Deny', 'Allow')]"
                },
                "publicNetworkAccess": "[if(variables('enableVNet'), 'Disabled', 'Enabled')]",
                "supportsHttpsTrafficOnly": true,
                "encryption": {
                    "services": {
                        "file": {
                            "keyType": "Account",
                            "enabled": true
                        },
                        "blob": {
                            "keyType": "Account",
                            "enabled": true
                        }
                    },
                    "keySource": "Microsoft.Storage"
                }
            }
        },
        {
            "type": "Microsoft.Storage/storageAccounts/blobServices",
            "apiVersion": "2019-06-01",
            "name": "[concat(variables('FunctionName'), '/default')]",
            "dependsOn": [
                "[resourceId('Microsoft.Storage/storageAccounts', tolower(variables('FunctionName')))]"
            ],
            "sku": {
                "name": "Standard_LRS",
                "tier": "Standard"
            },
            "properties": {
                "cors": {
                    "corsRules": []
                },
                "deleteRetentionPolicy": {
                    "enabled": false
                }
            }
        },
        {
            "type": "Microsoft.Storage/storageAccounts/fileServices",
            "apiVersion": "2019-06-01",
            "name": "[concat(variables('FunctionName'), '/default')]",
            "dependsOn": [
                "[resourceId('Microsoft.Storage/storageAccounts', tolower(variables('FunctionName')))]"
            ],
            "sku": {
                "name": "Standard_LRS",
                "tier": "Standard"
            },
            "properties": {
                "cors": {
                    "corsRules": []
                }
            }
        },
        {
            "condition": "[variables('enableVNet')]",
            "type": "Microsoft.Network/virtualNetworks",
            "apiVersion": "2021-02-01",
            "name": "[variables('vnetName')]",
            "location": "[resourceGroup().location]",
            "properties": {
                "addressSpace": {
                    "addressPrefixes": [
                        "[parameters('VNetAddressPrefix')]"
                    ]
                },
                "subnets": [
                    {
                        "name": "[parameters('SubnetName')]",
                        "properties": {
                            "addressPrefix": "[parameters('SubnetAddressPrefix')]",
                            "delegations": [
                                {
                                    "name": "delegation-webapp",
                                    "properties": {
                                        "serviceName": "Microsoft.Web/serverFarms"
                                    }
                                }
                            ]
                        }
                    },
                    {
                        "name": "[parameters('PrivateEndpointSubnetName')]",
                        "properties": {
                            "addressPrefix": "[parameters('PrivateEndpointSubnetAddressPrefix')]",
                            "privateEndpointNetworkPolicies": "Disabled"
                        }
                    }
                ]
            }
        },
        {
            "type": "Microsoft.Web/serverfarms",
            "apiVersion": "2021-02-01",
            "name": "[variables('AppServicePlanName')]",
            "location": "[resourceGroup().location]",
            "sku": {
                "name": "[variables('appServicePlanSku')]",
                "tier": "[variables('appServicePlanTier')]"
            },
            "kind": "[variables('appServicePlanKind')]",
            "properties": "[if(variables('enableVNet'), createObject('maximumElasticWorkerCount', 20, 'reserved', true()), createObject('reserved', true()))]"
        },
        {
            "type": "Microsoft.Web/sites",
            "apiVersion": "2021-02-01",
            "name": "[variables('FunctionName')]",
            "location": "[resourceGroup().location]",
            "dependsOn": [
                "[resourceId('Microsoft.Storage/storageAccounts', tolower(variables('FunctionName')))]",
                "[resourceId('Microsoft.Insights/components', variables('FunctionName'))]",
                "[resourceId('Microsoft.Web/serverfarms', variables('AppServicePlanName'))]",
                "[if(variables('enableVNet'), resourceId('Microsoft.Network/privateEndpoints/privateDnsZoneGroups', concat(variables('FunctionName'), '-blob-pe'), 'default'), resourceId('Microsoft.Storage/storageAccounts', tolower(variables('FunctionName'))))]",
                "[if(variables('enableVNet'), resourceId('Microsoft.Network/privateEndpoints/privateDnsZoneGroups', concat(variables('FunctionName'), '-file-pe'), 'default'), resourceId('Microsoft.Storage/storageAccounts', tolower(variables('FunctionName'))))]"
            ],
            "kind": "functionapp,linux",
            "identity": {
                "type": "SystemAssigned"
            },
            "properties": {
                "name": "[variables('FunctionName')]",
                "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('AppServicePlanName'))]",
                "httpsOnly": true,
                "clientAffinityEnabled": true,
                "alwaysOn": "[variables('enableVNet')]",
                "reserved": true,
                "virtualNetworkSubnetId": "[if(variables('enableVNet'), variables('SubnetResourceId'), json('null'))]",
                "siteConfig": {
                    "linuxFxVersion": "python|3.12",
                    "ftpsState": "Disabled",
                    "vnetRouteAllEnabled": "[variables('enableVNet')]"
                }
            },
            "resources": [
                {
                    "apiVersion": "2018-11-01",
                    "type": "config",
                    "name": "appsettings",
                    "dependsOn": [
                        "[concat('Microsoft.Web/sites/', variables('FunctionName'))]"
                    ],
                    "properties": {
                        "FUNCTIONS_EXTENSION_VERSION": "~4",
                        "FUNCTIONS_WORKER_RUNTIME": "python",
                        "AzureWebJobsFeatureFlags": "EnableWorkerIndexing",
                        "APPLICATIONINSIGHTS_CONNECTION_STRING": "[reference(resourceId('Microsoft.insights/components', variables('FunctionName')), '2020-02-02').ConnectionString]",
                        "FILE_STORAGE_CONNECTION_STRING": "[concat('DefaultEndpointsProtocol=https;AccountName=', toLower(variables('FunctionName')),';AccountKey=',listKeys(resourceId('Microsoft.Storage/storageAccounts', toLower(variables('FunctionName'))), '2019-06-01').keys[0].value, ';EndpointSuffix=',toLower(variables('StorageSuffix')))]",
                        "AzureWebJobsStorage": "[concat('DefaultEndpointsProtocol=https;AccountName=', toLower(variables('FunctionName')),';AccountKey=',listKeys(resourceId('Microsoft.Storage/storageAccounts', toLower(variables('FunctionName'))), '2019-06-01').keys[0].value, ';EndpointSuffix=',toLower(variables('StorageSuffix')))]",
                        "CROWDSTRIKE_CLIENT_ID": "[parameters('CrowdStrikeClientId')]",
                        "CROWDSTRIKE_CLIENT_SECRET": "[parameters('CrowdStrikeClientSecret')]",
                        "CROWDSTRIKE_BASE_URL": "[parameters('CrowdStrikeBaseUrl')]",
                        "TENANT_ID": "[parameters('TenantId')]",
                        "INDICATORS": "[parameters('Indicators')]",
                        "AAD_CLIENT_ID": "[parameters('AadClientId')]",
                        "AAD_CLIENT_SECRET": "[parameters('AadClientSecret')]",
                        "LOOK_BACK_DAYS": "[parameters('LookBackDays')]",
                        "WORKSPACE_ID": "[parameters('WorkspaceId')]",
                        "WEBSITE_RUN_FROM_PACKAGE": "https://aka.ms/sentinel-CrowdStrikeFalconAdversaryIntelligence-Functionapp",
                        "WEBSITE_CONTENTOVERVNET": "[if(variables('enableVNet'), '1', '0')]",
                        "WEBSITE_CONTENTAZUREFILECONNECTIONSTRING": "[concat('DefaultEndpointsProtocol=https;AccountName=', toLower(variables('FunctionName')),';AccountKey=',listKeys(resourceId('Microsoft.Storage/storageAccounts', toLower(variables('FunctionName'))), '2019-06-01').keys[0].value, ';EndpointSuffix=',toLower(variables('StorageSuffix')))]",
                        "WEBSITE_CONTENTSHARE": "[tolower(variables('FunctionName'))]"
                    }
                }
            ]
        },
        {
            "type": "Microsoft.Storage/storageAccounts/blobServices/containers",
            "apiVersion": "2019-06-01",
            "name": "[concat(variables('FunctionName'), '/default/azure-webjobs-hosts')]",
            "dependsOn": [
                "[resourceId('Microsoft.Storage/storageAccounts/blobServices', variables('FunctionName'), 'default')]",
                "[resourceId('Microsoft.Storage/storageAccounts', variables('FunctionName'))]"
            ],
            "properties": {
                "publicAccess": "None"
            }
        },
        {
            "type": "Microsoft.Storage/storageAccounts/blobServices/containers",
            "apiVersion": "2019-06-01",
            "name": "[concat(variables('FunctionName'), '/default/azure-webjobs-secrets')]",
            "dependsOn": [
                "[resourceId('Microsoft.Storage/storageAccounts/blobServices', variables('FunctionName'), 'default')]",
                "[resourceId('Microsoft.Storage/storageAccounts', variables('FunctionName'))]"
            ],
            "properties": {
                "publicAccess": "None"
            }
        },
        {
            "type": "Microsoft.Storage/storageAccounts/fileServices/shares",
            "apiVersion": "2019-06-01",
            "name": "[concat(variables('FunctionName'), '/default/', tolower(variables('FunctionName')))]",
            "dependsOn": [
                "[resourceId('Microsoft.Storage/storageAccounts/fileServices', variables('FunctionName'), 'default')]",
                "[resourceId('Microsoft.Storage/storageAccounts', variables('FunctionName'))]"
            ],
            "properties": {
                "shareQuota": 5120
            }
        },
        {
            "condition": "[variables('createDnsZones')]",
            "type": "Microsoft.Network/privateDnsZones",
            "apiVersion": "2020-06-01",
            "name": "[variables('blobPrivateDnsZoneName')]",
            "location": "global"
        },
        {
            "condition": "[variables('createDnsZones')]",
            "type": "Microsoft.Network/privateDnsZones",
            "apiVersion": "2020-06-01",
            "name": "[variables('filePrivateDnsZoneName')]",
            "location": "global"
        },
        {
            "condition": "[variables('createDnsZones')]",
            "type": "Microsoft.Network/privateDnsZones/virtualNetworkLinks",
            "apiVersion": "2020-06-01",
            "name": "[concat(variables('blobPrivateDnsZoneName'), '/', variables('FunctionName'), '-', variables('vnetName'), '-blob-link')]",
            "location": "global",
            "dependsOn": [
                "[if(variables('createDnsZones'), resourceId('Microsoft.Network/privateDnsZones', variables('blobPrivateDnsZoneName')), resourceId('Microsoft.Network/virtualNetworks', variables('vnetName')))]",
                "[resourceId('Microsoft.Network/virtualNetworks', variables('vnetName'))]"
            ],
            "properties": {
                "registrationEnabled": false,
                "virtualNetwork": {
                    "id": "[resourceId('Microsoft.Network/virtualNetworks', variables('vnetName'))]"
                }
            }
        },
        {
            "condition": "[variables('createDnsZones')]",
            "type": "Microsoft.Network/privateDnsZones/virtualNetworkLinks",
            "apiVersion": "2020-06-01",
            "name": "[concat(variables('filePrivateDnsZoneName'), '/', variables('FunctionName'), '-', variables('vnetName'), '-file-link')]",
            "location": "global",
            "dependsOn": [
                "[if(variables('createDnsZones'), resourceId('Microsoft.Network/privateDnsZones', variables('filePrivateDnsZoneName')), resourceId('Microsoft.Network/virtualNetworks', variables('vnetName')))]",
                "[resourceId('Microsoft.Network/virtualNetworks', variables('vnetName'))]"
            ],
            "properties": {
                "registrationEnabled": false,
                "virtualNetwork": {
                    "id": "[resourceId('Microsoft.Network/virtualNetworks', variables('vnetName'))]"
                }
            }
        },
        {
            "condition": "[variables('enableVNet')]",
            "type": "Microsoft.Network/privateEndpoints",
            "apiVersion": "2021-02-01",
            "name": "[concat(variables('FunctionName'), '-blob-pe')]",
            "location": "[resourceGroup().location]",
            "dependsOn": [
                "[resourceId('Microsoft.Storage/storageAccounts', tolower(variables('FunctionName')))]",
                "[resourceId('Microsoft.Network/virtualNetworks', variables('vnetName'))]"
            ],
            "properties": {
                "subnet": {
                    "id": "[variables('PrivateEndpointSubnetResourceId')]"
                },
                "privateLinkServiceConnections": [
                    {
                        "name": "[concat(variables('FunctionName'), '-blob-pe')]",
                        "properties": {
                            "privateLinkServiceId": "[resourceId('Microsoft.Storage/storageAccounts', tolower(variables('FunctionName')))]",
                            "groupIds": [
                                "blob"
                            ]
                        }
                    }
                ]
            }
        },
        {
            "condition": "[variables('enableVNet')]",
            "type": "Microsoft.Network/privateEndpoints",
            "apiVersion": "2021-02-01",
            "name": "[concat(variables('FunctionName'), '-file-pe')]",
            "location": "[resourceGroup().location]",
            "dependsOn": [
                "[resourceId('Microsoft.Storage/storageAccounts', tolower(variables('FunctionName')))]",
                "[resourceId('Microsoft.Network/virtualNetworks', variables('vnetName'))]"
            ],
            "properties": {
                "subnet": {
                    "id": "[variables('PrivateEndpointSubnetResourceId')]"
                },
                "privateLinkServiceConnections": [
                    {
                        "name": "[concat(variables('FunctionName'), '-file-pe')]",
                        "properties": {
                            "privateLinkServiceId": "[resourceId('Microsoft.Storage/storageAccounts', tolower(variables('FunctionName')))]",
                            "groupIds": [
                                "file"
                            ]
                        }
                    }
                ]
            }
        },
        {
            "condition": "[variables('enableVNet')]",
            "type": "Microsoft.Network/privateEndpoints/privateDnsZoneGroups",
            "apiVersion": "2021-02-01",
            "name": "[concat(variables('FunctionName'), '-blob-pe/default')]",
            "dependsOn": [
                "[resourceId('Microsoft.Network/privateEndpoints', concat(variables('FunctionName'), '-blob-pe'))]",
                "[if(variables('createDnsZones'), resourceId('Microsoft.Network/privateDnsZones', variables('blobPrivateDnsZoneName')), resourceId('Microsoft.Network/privateEndpoints', concat(variables('FunctionName'), '-blob-pe')))]"
            ],
            "properties": {
                "privateDnsZoneConfigs": [
                    {
                        "name": "blob-dns-config",
                        "properties": {
                            "privateDnsZoneId": "[resourceId('Microsoft.Network/privateDnsZones', variables('blobPrivateDnsZoneName'))]"
                        }
                    }
                ]
            }
        },
        {
            "condition": "[variables('enableVNet')]",
            "type": "Microsoft.Network/privateEndpoints/privateDnsZoneGroups",
            "apiVersion": "2021-02-01",
            "name": "[concat(variables('FunctionName'), '-file-pe/default')]",
            "dependsOn": [
                "[resourceId('Microsoft.Network/privateEndpoints', concat(variables('FunctionName'), '-file-pe'))]",
                "[if(variables('createDnsZones'), resourceId('Microsoft.Network/privateDnsZones', variables('filePrivateDnsZoneName')), resourceId('Microsoft.Network/privateEndpoints', concat(variables('FunctionName'), '-file-pe')))]"
            ],
            "properties": {
                "privateDnsZoneConfigs": [
                    {
                        "name": "file-dns-config",
                        "properties": {
                            "privateDnsZoneId": "[resourceId('Microsoft.Network/privateDnsZones', variables('filePrivateDnsZoneName'))]"
                        }
                    }
                ]
            }
        }
    ]
}
