[
{
              "name": "CrowdStrikeDCR-Sensor",
              "apiVersion": "2025-09-01",
              "type": "Microsoft.Insights/dataCollectionRules",
              "location": "[parameters('workspace-location')]",
              "kind": null,
              "properties": {
                "streamDeclarations": {
                  "Custom-CrowdStrikeSensor": {
                    "columns": [
                      { "name": "TimeGenerated", "type": "datetime" },
					  { "name": "name", "type": "string" },
                      { "name": "description", "type": "string" },
                      { "name": "platform", "type": "string" },
                      { "name": "os", "type": "string" },
                      { "name": "os_version", "type": "string" },
                      { "name": "sha256", "type": "string" },
                      { "name": "release_date", "type": "string" },
                      { "name": "version", "type": "string" },
                      { "name": "file_size", "type": "int" },
                      { "name": "file_type", "type": "string" },
                      { "name": "architectures","type": "dynamic" },
					  { "name": "connectionName", "type": "string" }
                    ]
                  }
                },
                "destinations": {
                  "logAnalytics": [
                    {
                      "workspaceResourceId": "[variables('workspaceResourceId')]",
                      "name": "clv2ws1"
                    }
                  ]
                },
                "dataFlows": [
                  {
                    "streams": [
                      "Custom-CrowdStrikeSensor"
                    ],
                    "destinations": [
                      "clv2ws1"
                    ],
                    "transformKql": "source | project TimeGenerated = now(), Name = name, Description = description, Platform = platform, Os = os, OsVersion = os_version, Sha256 = sha256, ReleaseDate = release_date, Version = version, FileSize = file_size, FileType = file_type, Architectures = todynamic(architectures), ConnectionName = connectionName",
                    "outputStream": "Custom-CrowdStrikeSensor_CL"
                  }
                ],
                "dataCollectionEndpointId": "[concat('/subscriptions/', parameters('subscription'), '/resourceGroups/', parameters('resourceGroupName'), '/providers/Microsoft.Insights/dataCollectionEndpoints/', parameters('workspace'))]"
              }
            }
        ]