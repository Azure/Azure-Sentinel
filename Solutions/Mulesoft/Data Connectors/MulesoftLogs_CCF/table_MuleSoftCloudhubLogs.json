{
  "name": "MuleSoftCloudhubLogs_CL",
  "type": "Microsoft.OperationalInsights/workspaces/tables",
  "apiVersion": "2022-10-01",
  "tags": {
    "StreamName": "Custom-MuleSoftCloudhubLogs_CL",
    "DataSource": "MuleSoft",
    "Category": "ApplicationLogs",
    "Method": "Push"
  },
  "properties": {
    "retentionInDays": 90,
    "schema": {
      "name": "MuleSoftCloudhubLogs_CL",
      "description": "MuleSoft CloudHub application logs streamed in real-time via Log4j HTTP appender. Contains standard Log4j fields plus MuleSoft-specific context and flexible custom application data.",
      "columns": [
        {
          "name": "TimeGenerated",
          "type": "datetime",
          "isDefaultDisplay": true
        },
        {
          "name": "EventTime",
          "type": "datetime",
          "description": "Timestamp when the log was generated"
        },
        {
          "name": "Level",
          "type": "string",
          "description": "Log level (INFO, WARN, ERROR, DEBUG, FATAL)"
        },
        {
          "name": "Logger",
          "type": "string",
          "description": "Logger name (Java class or component)"
        },
        {
          "name": "Message",
          "type": "string",
          "description": "Log message content"
        },
        {
          "name": "Thread",
          "type": "string",
          "description": "Thread name that generated the log"
        },
        {
          "name": "Exception",
          "type": "string",
          "description": "Exception stack trace if present"
        },
        {
          "name": "ApplicationDomainName",
          "type": "string",
          "description": "MuleSoft CloudHub application domain name"
        },
        {
          "name": "InstanceId",
          "type": "string",
          "description": "CloudHub worker instance ID"
        },
        {
          "name": "WorkerId",
          "type": "string",
          "description": "Worker identifier (e.g., worker-0)"
        },
        {
          "name": "Environment",
          "type": "string",
          "description": "MuleSoft environment name"
        },
        {
          "name": "Region",
          "type": "string",
          "description": "CloudHub region"
        },
        {
          "name": "ApplicationData",
          "type": "dynamic",
          "description": "Customer-specific application data in JSON format"
        }
      ]
    }
  }
}