{
  "name": "MulesoftCloudhubLogsPushDCR",
  "apiVersion": "2022-06-01",
  "type": "Microsoft.Insights/dataCollectionRules",
  "location": "{{location}}",
  "properties": {
    "dataCollectionEndpointId": "[resourceId('Microsoft.Insights/dataCollectionEndpoints', 'MuleSoftLogsPush-DCE')]",
    "streamDeclarations": {
      "Custom-MuleSoftCloudhubLogs_CL": {
        "columns": [
          {
            "name": "EventTime",
            "type": "datetime"
          },
          {
            "name": "Level",
            "type": "string"
          },
          {
            "name": "Logger",
            "type": "string"
          },
          {
            "name": "Message",
            "type": "string"
          },
          {
            "name": "Thread",
            "type": "string"
          },
          {
            "name": "Exception",
            "type": "string"
          },
          {
            "name": "ApplicationDomainName",
            "type": "string"
          },
          {
            "name": "InstanceId",
            "type": "string"
          },
          {
            "name": "WorkerId",
            "type": "string"
          },
          {
            "name": "Environment",
            "type": "string"
          },
          {
            "name": "Region",
            "type": "string"
          },
          {
            "name": "ApplicationData",
            "type": "dynamic"
          }
        ]
      }
    },
    "destinations": {
      "logAnalytics": [
        {
          "workspaceResourceId": "{{workspaceResourceId}}",
          "name": "clv2ws1"
        }
      ]
    },
    "dataFlows": [
      {
        "streams": [
          "Custom-MuleSoftCloudhubLogs_CL"
        ],
        "destinations": [
          "clv2ws1"
        ],
        "outputStream": "Custom-MuleSoftCloudhubLogs_CL",
        "transformKql": "source | extend TimeGenerated = iff(isnull(EventTime), now(), todatetime(EventTime)) | project TimeGenerated , EventTime , Level , Logger , Message , Thread , Exception , ApplicationDomainName , InstanceId , WorkerId , Environment , Region , ApplicationData"
      }
    ]
  }
}