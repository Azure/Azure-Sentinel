{
  "name": "MulesoftCloudhubAlerts_CL",
  "type": "Microsoft.OperationalInsights/workspaces/tables",
  "apiVersion": "2022-10-01",
  "tags": {
    "StreamName": "Custom-MulesoftCloudhubAlerts_CL",
    "DataSource": "Mulesoft",
    "Category": "ApplicationMonitoring"
  },
  "properties": {
    "retentionInDays": 90,
    "schema": {
      "name": "MulesoftCloudhubAlerts_CL",
      "description": "Mulesoft CloudHub alerts from the CloudHub API v2",
      "columns": [
        {
          "name": "TimeGenerated",
          "type": "datetime",
          "isDefaultDisplay": true
        },
        {
          "name": "CreatedAt",
          "type": "datetime",
          "description": "Timestamp when the alert was created (Unix epoch milliseconds)"
        },
        {
          "name": "LastModified",
          "type": "datetime",
          "description": "Timestamp when the alert was last modified (Unix epoch milliseconds)"
        },
        {
          "name": "Id",
          "type": "string",
          "description": "Unique identifier for the alert"
        },
        {
          "name": "Name",
          "type": "string",
          "description": "Name of the alert"
        },
        {
          "name": "Severity",
          "type": "string",
          "description": "Alert severity level"
        },
        {
          "name": "OrganizationId",
          "type": "string",
          "description": "Mulesoft organization identifier"
        },
        {
          "name": "EnvironmentId",
          "type": "string",
          "description": "Mulesoft environment identifier"
        },
        {
          "name": "ProductName",
          "type": "string",
          "description": "Product name (e.g., cloudhub)"
        },
        {
          "name": "Enabled",
          "type": "boolean",
          "description": "Whether the alert is enabled"
        },
        {
          "name": "IsSystem",
          "type": "boolean",
          "description": "Whether this is a system-generated alert"
        },
        {
          "name": "Condition",
          "type": "dynamic",
          "description": "Alert condition configuration including type, resources, and resource type"
        },
        {
          "name": "Actions",
          "type": "dynamic",
          "description": "Alert actions configuration including notification settings"
        }
      ]
    }
  }
}