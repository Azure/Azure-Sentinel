{
  "name": "MulesoftCloudhubDCR",
  "apiVersion": "2023-04-01-preview",
  "type": "Microsoft.Insights/dataCollectionRules",
  "location": "{{location}}",
  "properties": {
    "dataCollectionEndpointId": "{{dataCollectionEndpointId}}",
    "streamDeclarations": {
      "Custom-MulesoftCloudhubAlerts_CL": {
        "columns": [
          {
            "name": "createdAt",
            "type": "long"
          },
          {
            "name": "lastModified",
            "type": "long"
          },
          {
            "name": "id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "severity",
            "type": "string"
          },
          {
            "name": "organizationId",
            "type": "string"
          },
          {
            "name": "environmentId",
            "type": "string"
          },
          {
            "name": "productName",
            "type": "string"
          },
          {
            "name": "enabled",
            "type": "boolean"
          },
          {
            "name": "isSystem",
            "type": "boolean"
          },
          {
            "name": "condition",
            "type": "dynamic"
          },
          {
            "name": "actions",
            "type": "dynamic"
          }
        ]
      }
    },
    "destinations": {
      "logAnalytics": [
        {
          "workspaceResourceId": "{{workspaceResourceId}}",
          "name": "clv2ws1"
        }
      ]
    },
    "dataFlows": [
      {
        "streams": [
          "Custom-MulesoftCloudhubAlerts_CL"
        ],
        "destinations": [
          "clv2ws1"
        ],
        "outputStream": "Custom-MulesoftCloudhubAlerts_CL",
        "transformKql": "source | extend TimeGenerated = iff(isnull(['lastModified']), datetime(1970-01-01) + (['createdAt'] * 1ms), datetime(1970-01-01) + (['lastModified'] * 1ms)) , CreatedAt = datetime(1970-01-01) + (['createdAt'] * 1ms) , LastModified = datetime(1970-01-01) + (['lastModified'] * 1ms) , Id = ['id'] , Name = ['name'] , Severity = ['severity'] , OrganizationId = ['organizationId'] , EnvironmentId = ['environmentId'] , ProductName = ['productName'] , Enabled = ['enabled'] , IsSystem = ['isSystem'] , Condition = ['condition'] , Actions = ['actions'] | project TimeGenerated , CreatedAt , LastModified , Id , Name , Severity , OrganizationId , EnvironmentId , ProductName , Enabled , IsSystem , Condition , Actions"
      }
    ]
  }
}