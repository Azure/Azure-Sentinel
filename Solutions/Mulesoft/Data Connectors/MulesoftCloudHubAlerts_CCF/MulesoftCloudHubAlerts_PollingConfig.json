{
  "type": "Microsoft.SecurityInsights/dataConnectors",
  "apiVersion": "2022-10-01-preview",
  "name": "[[concat('parameters('workspace')', '/Microsoft.SecurityInsights/','MulesoftCloudhubAlerts_CL' , uniqueString(parameters('connectionAlias')) )]",
  "location": "{{location}}",
  "kind": "RestApiPoller",
  "properties": {
    "auth": {
      "type": "Basic",
      "UserName": "[[parameters('username')]",
      "Password": "[[parameters('password')]"
    },
    "request": {
      "apiEndpoint": "[[concat(parameters('mulesoftBaseUrl'),'/v2/alerts')]",
      "httpMethod": "GET",
      "rateLimitQPS": 15,
      "queryWindowInMin": 5,
      "retryCount": 3,
      "timeoutInSeconds": 30,
      "headers": {
        "Accept": "application/json",
        "User-Agent": "MS-Sentinel-CCP-Mulesoft",
        "X-ANYPNT-ENV-ID": "[[parameters('environmentId')]"
      },
      "queryParameters": {
        "offset": "0",
        "resource": "[[parameters('applicationName')]"
      }
    },
    "response": {
      "eventsJsonPaths": [
        "$[*]"
      ],
      "format": "json"
    },
    "paging": {
      "pagingType": "Offset",
      "offsetParaName": "offset",
      "pageSize": 1000,
      "pageSizeParameterName": "limit"
    },
    "connectorDefinitionName": "MulesoftCloudhubConnector",
    "dataType": "MulesoftCloudhubAlerts_CL",
    "dcrConfig": {
      "streamName": "Custom-MulesoftCloudhubAlerts_CL",
      "dataCollectionEndpoint": "{{dataCollectionEndpoint}}",
      "dataCollectionRuleImmutableId": "{{dataCollectionRuleImmutableId}}"
    },
    "addOnAttributes": {
      "connectionAlias": "[[parameters('connectionAlias')]",
      "streamType": "Alerts",
      "mulesoftBaseUrl": "[[parameters('mulesoftBaseUrl')]"
    }
  }
}