{
  "name": "fortigatefirewallPush",
  "apiVersion": "2022-09-01-preview",
  "type": "Microsoft.SecurityInsights/dataConnectorDefinitions",
  "location": "{{location}}",
  "kind": "Customizable",
  "properties": {
    "connectorUiConfig": {
      "id": "fortigatefirewallPush",
      "title": "Fortigate Firewall",
      "publisher": "Fortigate Firewall",
      "logo": "<svg width=\"75px\" height=\"75px\" viewBox=\"0 0 100 100\" xmlns=\"http://www.w3.org/2000/svg\"><circle cx=\"50\" cy=\"50\" r=\"40\" stroke=\"black\" stroke-width=\"3\" fill=\"red\" /><!-- <img src=\".svg\" /> --></svg>",
      "descriptionMarkdown": "This connector integrates Fortigate Firewall logs into Microsoft Sentinel using push ingestion. For more information, see the [Fortigate Firewall documentation](https://docs.fortinet.com/document/fortigate-firewall).",
      "graphQueries": [
        {
          "metricName": "Audit Logs",
          "legend": "fortigatefirewall_audit_logs_CL",
          "baseQuery": "fortigatefirewall_audit_logs_CL | where TimeGenerated >= ago(1h)"
        },
        {
          "metricName": "Alerts",
          "legend": "fortigatefirewall_alerts_CL",
          "baseQuery": "fortigatefirewall_alerts_CL | where TimeGenerated >= ago(1h)"
        },
        {
          "metricName": "Device Inventory",
          "legend": "fortigatefirewall_device_inventory_CL",
          "baseQuery": "fortigatefirewall_device_inventory_CL | where TimeGenerated >= ago(1h)"
        }
      ],
      "sampleQueries": [
        {
          "description": "Show last 50 audit log entries",
          "query": "fortigatefirewall_audit_logs_CL | sort by TimeGenerated desc | take 50"
        },
        {
          "description": "Show last 50 alert entries",
          "query": "fortigatefirewall_alerts_CL | sort by TimeGenerated desc | take 50"
        },
        {
          "description": "Show last 50 device inventory records",
          "query": "fortigatefirewall_device_inventory_CL | sort by TimeGenerated desc | take 50"
        }
      ],
      "dataTypes": [
        {
          "name": "fortigatefirewall_audit_logs_CL",
          "lastDataReceivedQuery": "fortigatefirewall_audit_logs_CL\n| summarize LastLog=min(TimeGenerated)"
        },
        {
          "name": "fortigatefirewall_alerts_CL",
          "lastDataReceivedQuery": "fortigatefirewall_alerts_CL\n| summarize LastLog=min(TimeGenerated)"
        },
        {
          "name": "fortigatefirewall_device_inventory_CL",
          "lastDataReceivedQuery": "fortigatefirewall_device_inventory_CL\n| summarize LastLog=min(TimeGenerated)"
        }
      ],
      "connectivityCriteria": [
        {
          "type": "IsConnectedQuery",
          "value": [
            "fortigatefirewall_audit_logs_CL | summarize arg_max(TimeGenerated, *)"
          ]
        }
      ],
      "availability": {
        "status": 1
      },
      "permissions": {
        "resourceProvider": [
          {
            "provider": "Microsoft.OperationalInsights/workspaces",
            "permissionsDisplayText": "read and write permissions are required.",
            "providerDisplayName": "Workspace",
            "scope": "Workspace",
            "requiredPermissions": {
              "write": true,
              "read": true,
              "delete": true
            }
          }
        ],
        "customs": [
          {
            "name": "Microsoft Entra",
            "description": "Permission to create an app registration in Microsoft Entra ID. Typically requires Entra ID Application Developer role or higher."
          },
          {
            "name": "Microsoft Azure",
            "description": "Permission to assign Monitoring Metrics Publisher role on data collection rule (DCR). Typically requires Azure RBAC Owner or User Access Administrator role."
          }
        ]
      },
      "instructionSteps": [
        {
          "title": "1. Deploy ARM Resources for Fortigate Firewall",
          "description": "This step deploys the necessary ARM resources to enable push ingestion from your Fortigate Firewall. The connector uses push ingestion to send logs directly to Microsoft Sentinel.",
          "instructions": [
            {
              "type": "Markdown",
              "parameters": {
                "content": "To get started, create an Entra application and deploy a Data Collection Rule (DCR) using the provided ARM template."
              }
            },
            {
              "type": "DeployPushConnectorButton",
              "parameters": {
                "label": "Deploy Fortigate Firewall Connector",
                "applicationDisplayName": "Fortigate Firewall"
              }
            }
          ]
        },
        {
          "title": "2. Configure Your Fortigate Firewall Platform",
          "description": "Use the following workspace parameters to configure the Fortigate Firewall connector for data ingestion.",
          "instructions": [
            {
              "type": "CopyableLabel",
              "parameters": {
                "label": "TenantId",
                "value": "{{tenantId}}",
                "fillWith": [
                  "tenantId"
                ]
              }
            },
            {
              "type": "CopyableLabel",
              "parameters": {
                "label": "ApplicationId",
                "value": "{{applicationId}}",
                "fillWith": [
                  "applicationId"
                ]
              }
            },
            {
              "type": "CopyableLabel",
              "parameters": {
                "label": "ApplicationSecret",
                "value": "{{applicationSecret}}",
                "fillWith": [
                  "applicationSecret"
                ]
              }
            },
            {
              "type": "CopyableLabel",
              "parameters": {
                "label": "DataCollectionEndpoint",
                "value": "{{dataCollectionEndpoint}}",
                "fillWith": [
                  "dataCollectionEndpoint"
                ]
              }
            },
            {
              "type": "CopyableLabel",
              "parameters": {
                "label": "DataCollectionRuleId",
                "value": "{{dataCollectionRuleId}}",
                "fillWith": [
                  "dataCollectionRuleId"
                ]
              }
            },
            {
              "type": "CopyableLabel",
              "parameters": {
                "label": "Audit Logs Stream Name",
                "value": "Custom-fortigatefirewall_audit_logs"
              }
            },
            {
              "type": "CopyableLabel",
              "parameters": {
                "label": "Alerts Stream Name",
                "value": "Custom-fortigatefirewall_alerts"
              }
            },
            {
              "type": "CopyableLabel",
              "parameters": {
                "label": "Device Inventory Stream Name",
                "value": "Custom-fortigatefirewall_device_inventory"
              }
            }
          ]
        }
      ]
    }
  }
}