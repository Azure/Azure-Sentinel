[
  {
    "type": "Microsoft.SecurityInsights/dataConnectors",
    "apiVersion": "2023-02-01-preview",
    "name": "UtimacoESKMKmipServerLogsConnector",
    "location": "{{location}}",
    "kind": "RestApiPoller",
    "properties": {
      "connectorDefinitionName": "UtimacoESKMConnector",
      "dataType": "UtimacoESKMKmipServerLogs_CL",
      "dcrConfig": {
        "streamName": "Custom-UtimacoESKMKmipServerLogs_CL",
        "dataCollectionEndpoint": "{{dataCollectionEndpoint}}",
        "dataCollectionRuleImmutableId": "{{dataCollectionRuleImmutableId}}"
      },
      "auth": {
        "type": "Basic",
        "UserName": "{{username}}",
        "Password": "{{password}}"
      },
      "request": {
        "apiEndpoint": "{{BaseUrl}}/api/manage/v1/log/kmipserver",
        "httpMethod": "GET",
        "rateLimitQPS": 10,
        "queryWindowInMin": 5,
        "retryCount": 3,
        "timeoutInSeconds": 60,
        "queryTimeFormat": "yyyy-MM-ddTHH:mm:ss.fffZ",
        "startTimeAttributeName": "startTime",
        "endTimeAttributeName": "endTime",
        "headers": {
          "Accept": "application/json"
        },
        "queryParameters": {
          "log": "current",
          "lines": "500"
        }
      },
      "paging": {
        "pagingType": "NextPageToken",
        "nextPageTokenJsonPath": "$.nextOffset",
        "nextPageParaName": "offset"
      },
      "response": {
        "eventsJsonPaths": [
          "$.logs"
        ],
        "format": "json"
      }
    }
  }
]