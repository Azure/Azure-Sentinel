[{
    "name": "PhysicalThreatsDCR",
    "apiVersion": "2021-09-01-preview",
    "type": "Microsoft.Insights/dataCollectionRules",
    "location": "{{location}}",
    "kind": "Direct",
    "properties": {
        "streamDeclarations": {
            "Custom-ZeroFoxPhysicalThreats_CL": {
                "columns": [
                    {
                        "name": "id",
                        "type": "string"
                    },
                    {
                        "name": "locations",
                        "type": "dynamic"
                    },
                    {
                        "name": "offending_content_url",
                        "type": "string"
                    },
                    {
                        "name": "content",
                        "type": "string"
                    },
                    {
                        "name": "notes",
                        "type": "string"
                    },
                    {
                        "name": "event_date",
                        "type": "datetime"
                    },
                    {
                        "name": "enterprise_id",
                        "type": "int"
                    },
                    {
                        "name": "entity_id",
                        "type": "int"
                    },
                    {
                        "name": "tags",
                        "type": "string"
                    },
                    {
                        "name": "source_tags",
                        "type": "string"
                    },
                    {
                        "name": "network",
                        "type": "string"
                    },
                    {
                        "name": "alert_id",
                        "type": "string"
                    },
                    {
                        "name": "attendees_interested",
                        "type": "int"
                    },
                    {
                        "name": "attendees_going",
                        "type": "int"
                    },
                    {
                        "name": "post_date",
                        "type": "datetime"
                    },
                    {
                        "name": "timestamp",
                        "type": "datetime"
                    },
                    {
                        "name": "incident_group",
                        "type": "string"
                    },
                    {
                        "name": "incident_type",
                        "type": "string"
                    },
                    {
                        "name": "incident_subtype",
                        "type": "string"
                    },
                    {
                        "name": "timeframe",
                        "type": "string"
                    }
                    
                ]
            }
        },
        "destinations": {
            "logAnalytics": [
                {
                    "workspaceResourceId": "{{workspaceResourceId}}",
                    "name": "clv2ws1"
                }
            ]
        },
        "dataFlows": [
            {
                "streams": [
                    "Custom-ZeroFoxPhysicalThreats_CL"
                ],
                "destinations": [
                    "clv2ws1"
                ],
                "transformKql": "source\n| project-rename TimeGenerated = event_date\n| project TimeGenerated, id, locations, offending_content_url, content, notes, event_date, enterprise_id, entity_id, tags, source_tags, network, alert_id, attendees_interested, attendees_going, post_date, incident_group, incident_type, incident_subtype, timeframe",
                "outputStream": "Custom-ZeroFoxPhysicalThreats_CL"
            }
        ]
    }
}]
