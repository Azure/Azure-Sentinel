            {
                "streams": [
                    "Custom-ZeroFoxIndicators_CL"
                ],
                "destinations": [
                    "clv2ws1"
                ],
                "transformKql": "source\n| project-rename TimeGenerated = first_seen\n| project TimeGenerated, last_seen, created_at, last_modified, expired, id, type, value, domain, filename, url, confidence, ttl, ransom_note, top_1m, ip_addresses, tags, ports, malware_family, sha1, sha256, sha512, md5, c2_ip_addresses, c2_domains, events, file_location, cloud_provider, bot_name, associations, note, asn, asn_description, source_registry, ttp_ids, emails, crypto_wallets, note_urls, ransomware_name",
