[{
    "name": "CreditCardsDCR",
    "apiVersion": "2021-09-01-preview",
    "type": "Microsoft.Insights/dataCollectionRules",
    "location": "{{location}}",
    "kind": "Direct",
    "properties": {
        "streamDeclarations": {
            "Custom-ZeroFoxCreditCards_CL": {
                "columns": [
                    {
                        "name": "created_at",
                        "type": "datetime"
                    },
                    {
                        "name": "id",
                        "type": "string"
                    },
                    {
                        "name": "cc_num",
                        "type": "string"
                    },
                    {
                        "name": "cc_bin",
                        "type": "string"
                    },
                    {
                        "name": "month",
                        "type": "string"
                    },
                    {
                        "name": "year",
                        "type": "string"
                    },
                    {
                        "name": "cvv",
                        "type": "string"
                    },
                    {
                        "name": "issuer",
                        "type": "string"
                    },
                    {
                        "name": "source",
                        "type": "string"
                    },
                    {
                        "name": "breach_name",
                        "type": "string"
                    }
                ]
            }
        },
        "destinations": {
            "logAnalytics": [
                {
                    "workspaceResourceId": "{{workspaceResourceId}}",
                    "name": "clv2ws1"
                }
            ]
        },
        "dataFlows": [
            {
                "streams": [
                    "Custom-ZeroFoxCreditCards_CL"
                ],
                "destinations": [
                    "clv2ws1"
                ],
                "transformKql": "source\n| project-rename TimeGenerated = created_at\n| project TimeGenerated, id, cc_num, cc_bin, month, year, cvv, issuer, source, breach_name",
                "outputStream": "Custom-ZeroFoxCreditCards_CL"
            }
        ]
    }
}]
