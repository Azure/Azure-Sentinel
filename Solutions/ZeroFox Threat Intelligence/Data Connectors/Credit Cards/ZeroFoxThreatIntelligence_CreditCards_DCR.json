[{
    "name": "CreditCardsDCR",
    "apiVersion": "2022-06-01",
    "type": "Microsoft.Insights/dataCollectionRules",
    "location": "{{location}}",
    "kind": "Direct",
    "properties": {
        "streamDeclarations": {
            "Custom-ZeroFoxCreditCards_CL": {
                "columns": [
                    {
                        "name": "created_at",
                        "type": "datetime"
                    },
                    {
                        "name": "id",
                        "type": "string"
                    },
                    {
                        "name": "cc_num",
                        "type": "string"
                    },
                    {
                        "name": "cc_bin",
                        "type": "string"
                    },
                    {
                        "name": "month",
                        "type": "string"
                    },
                    {
                        "name": "year",
                        "type": "string"
                    },
                    {
                        "name": "cvv",
                        "type": "string"
                    },
                    {
                        "name": "issuer",
                        "type": "string"
                    },
                    {
                        "name": "source",
                        "type": "string"
                    },
                    {
                        "name": "breach_name",
                        "type": "string"
                    }
                ]
            }
        },
        "destinations": {
            "logAnalytics": [
                {
                    "workspaceResourceId": "{{workspaceResourceId}}",
                    "name": "clv2ws1"
                }
            ]
        },
        "dataFlows": [
            {
                "streams": [
                    "Custom-ZeroFoxCreditCards_CL"
                ],
                "destinations": [
                    "clv2ws1"
                ],
                "transformKql": "source | extend TimeGenerated = created_at, created_at_t = created_at, id_s = tostring(id), cc_num_s = tostring(cc_num), cc_bin_s = tostring(cc_bin), month_s = tostring(month), year_s = tostring(year), cvv_s = tostring(cvv), issuer_s = tostring(issuer), source_s = tostring(['source']), breach_name_s = tostring(breach_name) | project TimeGenerated, created_at_t, id_s, cc_num_s, cc_bin_s, month_s, year_s, cvv_s, issuer_s, source_s, breach_name_s",
                "outputStream": "Custom-ZeroFoxCreditCards_CL"
            }
        ],
        "dataCollectionEndpointId": "{{dataCollectionEndpointId}}"
    }
  }
]
