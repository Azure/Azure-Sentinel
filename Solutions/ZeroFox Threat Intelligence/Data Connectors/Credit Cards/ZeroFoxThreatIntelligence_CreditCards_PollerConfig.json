[
  {
    "name": "ZeroFoxCTICreditCardsPoller",
    "apiVersion": "2022-10-01-preview",
    "type": "Microsoft.SecurityInsights/dataConnectors",
    "location": "{{location}}",
    "kind": "RestApiPoller",
    "properties": {
      "connectorDefinitionName": "ZeroFoxCreditCardsDefinition",
      "dcrConfig": {
        "streamName": "Custom-ZeroFoxCreditCards_CL",
        "dataCollectionEndpoint": "{{dataCollectionEndpoint}}",
        "dataCollectionRuleImmutableId": "{{dataCollectionRuleImmutableId}}"
      },
      "dataType": "ZeroFoxCreditCards_CL",
      "auth": {
        "type": "JwtToken",
        "userName": {
          "key": "username",
          "value": "[[parameters('username')]]"
        },
        "password": {
          "key": "password",
          "value": "[[parameters('apikey')]]"
        },
        "TokenEndpoint": "https://api.zerofox.com/auth/token/",
        "IsJsonRequest": true,
        "JwtTokenJsonPath": "$.access"
      },
      "request": {
        "apiEndpoint": "https://api.zerofox.com/cti/credit-cards/",
        "rateLimitQPS": 10,
        "queryWindowInMin": "{{queryWindowInMin}}",
        "httpMethod": "GET",
        "queryTimeFormat": "yyyy-MM-ddTHH:mm:ssZ",
        "startTimeAttributeName": "created_after",
        "endTimeAttributeName": "created_before",
        "retryCount": 3,
        "timeoutInSeconds": 60,
        "headers": {
          "Accept": "application/json",
          "User-Agent": "Microsoft-Sentinel-ZeroFox-CTI-Connector",
          "zf-source": "Microsoft-Sentinel"
        }
      },
      "paging": {
        "pagingType": "NextPageUrl",
        "nextPageTokenJsonPath": "$.next",
        "hasNextFlagJsonPath": "$.next"
      },
      "response": {
        "eventsJsonPaths": ["$.results[*]"],
        "format": "json"
      }
    }
  }
]
