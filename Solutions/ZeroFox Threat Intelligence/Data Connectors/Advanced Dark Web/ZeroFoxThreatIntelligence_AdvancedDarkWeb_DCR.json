[{
    "name": "AdvancedDarkWebDCR",
    "apiVersion": "2021-09-01-preview",
    "type": "Microsoft.Insights/dataCollectionRules",
    "location": "{{location}}",
    "properties": {
        "dataCollectionEndpointId": "{{dataCollectionEndpointId}}",
        "streamDeclarations": {
            "Custom-ZeroFoxAdvancedDarkWeb_CL": {
                "columns": [
                    {
                        "name": "created_at",
                        "type": "datetime"
                    },
                    {
                        "name": "id",
                        "type": "int"
                    },
                    {
                        "name": "title",
                        "type": "string"
                    },
                    {
                        "name": "confidence",
                        "type": "string"
                    },
                    {
                        "name": "reliability",
                        "type": "string"
                    },
                    {
                        "name": "tlp",
                        "type": "string"
                    },
                    {
                        "name": "contents",
                        "type": "dynamic"
                    },
                    {
                        "name": "comments",
                        "type": "dynamic"
                    },
                    {
                        "name": "iocs",
                        "type": "dynamic"
                    },
                    {
                        "name": "threat_types",
                        "type": "dynamic"
                    },
                    {
                        "name": "target",
                        "type": "dynamic"
                    },
                    {
                        "name": "languages",
                        "type": "dynamic"
                    },
                    {
                        "name": "actors",
                        "type": "dynamic"
                    },
                    {
                        "name": "tags",
                        "type": "dynamic"
                    },
                    {
                        "name": "source",
                        "type": "dynamic"
                    }
                ]
            }
        },
        "destinations": {
            "logAnalytics": [
                {
                    "workspaceResourceId": "{{workspaceResourceId}}",
                    "name": "clv2ws1"
                }
            ]
        },
        "dataFlows": [
            {
                "streams": [
                    "Custom-ZeroFoxAdvancedDarkWeb_CL"
                ],
                "destinations": [
                    "clv2ws1"
                ],
                "transformKql": "source\n| project-rename TimeGenerated = created_at\n| project TimeGenerated, id, title, confidence, reliability, tlp, contents, comments, iocs, threat_types, target, languages, actors, tags, source",
                "outputStream": "Custom-ZeroFoxAdvancedDarkWeb_CL"
            }
        ]
    }
}]
