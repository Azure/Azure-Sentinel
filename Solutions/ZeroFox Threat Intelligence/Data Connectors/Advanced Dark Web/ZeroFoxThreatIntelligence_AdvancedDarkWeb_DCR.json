[
  {
    "name": "AdvancedDarkWebDCR",
    "apiVersion": "2022-06-01",
    "type": "Microsoft.Insights/dataCollectionRules",
    "location": "{{location}}",
    "kind": "Direct",
    "properties": {
      "streamDeclarations": {
        "Custom-ZeroFoxAdvancedDarkWeb_CL": {
          "columns": [
            {
              "name": "created_at",
              "type": "datetime"
            },
            {
              "name": "title",
              "type": "string"
            },
            {
              "name": "confidence",
              "type": "string"
            },
            {
              "name": "reliability",
              "type": "string"
            },
            {
              "name": "tlp",
              "type": "string"
            },
            {
              "name": "contents",
              "type": "dynamic"
            },
            {
              "name": "comments",
              "type": "dynamic"
            },
            {
              "name": "iocs",
              "type": "dynamic"
            },
            {
              "name": "threat_types",
              "type": "dynamic"
            },
            {
              "name": "target",
              "type": "dynamic"
            },
            {
              "name": "languages",
              "type": "dynamic"
            },
            {
              "name": "actors",
              "type": "dynamic"
            },
            {
              "name": "tags",
              "type": "dynamic"
            },
            {
              "name": "source",
              "type": "dynamic"
            },
            {
              "name": "id",
              "type": "int"
            }
          ]
        }
      },
      "destinations": {
        "logAnalytics": [
          {
            "workspaceResourceId": "{{workspaceResourceId}}",
            "name": "clv2ws1"
          }
        ]
      },
      "dataFlows": [
        {
          "streams": [
            "Custom-ZeroFoxAdvancedDarkWeb_CL"
          ],
          "destinations": [
            "clv2ws1"
          ],
          "transformKql": "source | extend TimeGenerated = created_at, title_s = tostring(['title']), confidence_s = tostring(confidence), reliability_s = tostring(reliability), tlp_s = tostring(tlp), contents_d = contents, comments_d = comments, iocs_d = iocs, threat_types_d = threat_types, target_targets_s = tostring(target['targets']), target_regions_s = tostring(target['regions']), target_industries_s = tostring(target['industries']), languages_d = languages, actors_d = actors, tags_d = tags, source_col = ['source'], id_s = tostring(id) | extend source_names_d = source_col['names'], source_urls_d = source_col['urls'] | project TimeGenerated, title_s, confidence_s, reliability_s, tlp_s, contents_d, comments_d, iocs_d, threat_types_d, target_targets_s, target_regions_s, target_industries_s, languages_d, actors_d, tags_d, source_names_d, source_urls_d, id_s",
          "outputStream": "Custom-ZeroFoxAdvancedDarkWeb_CL"
        }
      ],
      "dataCollectionEndpointId": "{{dataCollectionEndpointId}}"
    }
  }
]
