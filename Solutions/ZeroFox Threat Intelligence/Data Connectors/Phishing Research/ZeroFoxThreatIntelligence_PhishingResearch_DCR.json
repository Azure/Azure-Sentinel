[{
    "name": "PhishingResearchDCR",
    "apiVersion": "2021-09-01-preview",
    "type": "Microsoft.Insights/dataCollectionRules",
    "location": "{{location}}",
    "properties": {
        "dataCollectionEndpointId": "{{dataCollectionEndpointId}}",
        "streamDeclarations": {
            "Custom-ZeroFoxPhishingResearch_CL": {
                "columns": [
                    {
                        "name": "scanned",
                        "type": "datetime"
                    },
                    {
                        "name": "domain",
                        "type": "string"
                    },
                    {
                        "name": "url",
                        "type": "string"
                    },
                    {
                        "name": "cert",
                        "type": "dynamic"
                    },
                    {
                        "name": "host",
                        "type": "dynamic"
                    }
                ]
            }
        },
        "destinations": {
            "logAnalytics": [
                {
                    "workspaceResourceId": "{{workspaceResourceId}}",
                    "name": "clv2ws1"
                }
            ]
        },
        "dataFlows": [
            {
                "streams": [
                    "Custom-ZeroFoxPhishingResearch_CL"
                ],
                "destinations": [
                    "clv2ws1"
                ],
                "transformKql": "source\n| project-rename TimeGenerated = scanned\n| project TimeGenerated, domain, url, cert, host",
                "outputStream": "Custom-ZeroFoxPhishingResearch_CL"
            }
        ]
    }
}]
