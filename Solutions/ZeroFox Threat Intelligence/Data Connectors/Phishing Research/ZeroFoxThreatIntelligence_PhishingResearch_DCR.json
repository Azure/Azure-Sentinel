[{
    "name": "PhishingResearchDCR",
    "apiVersion": "2022-06-01",
    "type": "Microsoft.Insights/dataCollectionRules",
    "location": "{{location}}",
    "kind": "Direct",
    "properties": {
        "streamDeclarations": {
            "Custom-ZeroFoxPhishingResearch_CL": {
                "columns": [
                    {
                        "name": "scanned",
                        "type": "datetime"
                    },
                    {
                        "name": "domain",
                        "type": "string"
                    },
                    {
                        "name": "url",
                        "type": "string"
                    },
                    {
                        "name": "cert",
                        "type": "dynamic"
                    },
                    {
                        "name": "host",
                        "type": "dynamic"
                    }
                ]
            }
        },
        "destinations": {
            "logAnalytics": [
                {
                    "workspaceResourceId": "{{workspaceResourceId}}",
                    "name": "clv2ws1"
                }
            ]
        },
        "dataFlows": [
            {
                "streams": [
                    "Custom-ZeroFoxPhishingResearch_CL"
                ],
                "destinations": [
                    "clv2ws1"
                ],
                "transformKql": "source | extend TimeGenerated = scanned, scanned_t = scanned, domain_s = tostring(domain), url_s = tostring(url), cert_col = cert, host_col = host | extend cert_authority_s = tostring(cert_col['authority']), cert_fingerprint_s = tostring(cert_col['fingerprint']), cert_issued_t = todatetime(cert_col['issued']), host_ip_s = tostring(host_col['ip']), host_asn_s = toint(host_col['asn']), host_geo_s = tostring(host_col['geo']) | project TimeGenerated, scanned_t, domain_s, url_s, cert_authority_s, cert_fingerprint_s, cert_issued_t, host_ip_s, host_asn_s, host_geo_s",
                "outputStream": "Custom-ZeroFoxPhishingResearch_CL"
            }
        ],
        "dataCollectionEndpointId": "{{dataCollectionEndpointId}}"
    }
}]
