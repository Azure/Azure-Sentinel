[{
    "name": "CompromisedCredentialsDCR",
    "apiVersion": "2022-06-01",
    "type": "Microsoft.Insights/dataCollectionRules",
    "location": "{{location}}",
    "kind": "Direct",
    "properties": {
        "streamDeclarations": {
            "Custom-ZeroFoxCompromisedCredentials_CL": {
                "columns": [
                    {
                        "name": "created_at",
                        "type": "datetime"
                    },
                    {
                        "name": "domain",
                        "type": "string"
                    },
                    {
                        "name": "email",
                        "type": "string"
                    },
                    {
                        "name": "username",
                        "type": "string"
                    },
                    {
                        "name": "password",
                        "type": "string"
                    },
                    {
                        "name": "password_type",
                        "type": "string"
                    },
                    {
                        "name": "breach_name",
                        "type": "string"
                    },
                    {
                        "name": "breach_id",
                        "type": "string"
                    },
                    {
                        "name": "breached_at",
                        "type": "datetime"
                    },
                    {
                        "name": "impacted_domain",
                        "type": "string"
                    },
                    {
                        "name": "data_exposure_at",
                        "type": "datetime"
                    },
                    {
                        "name": "tags",
                        "type": "dynamic"
                    },
                    {
                        "name": "combolist",
                        "type": "boolean"
                    }
                ]
            }
        },
        "destinations": {
            "logAnalytics": [
                {
                    "workspaceResourceId": "{{workspaceResourceId}}",
                    "name": "clv2ws1"
                }
            ]
        },
        "dataFlows": [
            {
                "streams": [
                    "Custom-ZeroFoxCompromisedCredentials_CL"
                ],
                "destinations": [
                    "clv2ws1"
                ],
                "transformKql": "source | extend TimeGenerated = created_at, created_at_t = created_at, domain_s = tostring(domain), email_s = tostring(email), username_s = tostring(username), password_s = tostring(password), password_type_s = tostring(password_type), breach_name_s = tostring(breach_name), breach_id_s = tostring(breach_id), breached_at_t = breached_at, impacted_domain_s = tostring(impacted_domain), data_exposure_at_t = data_exposure_at, tags_s = tostring(tags), combolist_s = tostring(combolist) | project TimeGenerated, created_at_t, domain_s, email_s, username_s, password_s, password_type_s, breach_name_s, breach_id_s, breached_at_t, impacted_domain_s, data_exposure_at_t, tags_s, combolist_s",
                "outputStream": "Custom-ZeroFoxCompromisedCredentials_CL"
            }
        ],
        "dataCollectionEndpointId": "{{dataCollectionEndpointId}}"
    }
}]
