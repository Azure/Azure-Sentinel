[{
    "name": "CompromisedCredentialsDCR",
    "apiVersion": "2021-09-01-preview",
    "type": "Microsoft.Insights/dataCollectionRules",
    "location": "{{location}}",
    "kind": "Direct",
    "properties": {
        "streamDeclarations": {
            "Custom-ZeroFoxCompromisedCredentials_CL": {
                "columns": [
                    {
                        "name": "created_at",
                        "type": "datetime"
                    },
                    {
                        "name": "id",
                        "type": "string"
                    },
                    {
                        "name": "domain",
                        "type": "string"
                    },
                    {
                        "name": "email",
                        "type": "string"
                    },
                    {
                        "name": "username",
                        "type": "string"
                    },
                    {
                        "name": "password",
                        "type": "string"
                    },
                    {
                        "name": "password_type",
                        "type": "string"
                    },
                    {
                        "name": "breach_name",
                        "type": "string"
                    },
                    {
                        "name": "breach_id",
                        "type": "string"
                    },
                    {
                        "name": "breached_at",
                        "type": "datetime"
                    },
                    {
                        "name": "impacted_domain",
                        "type": "string"
                    },
                    {
                        "name": "data_exposure_at",
                        "type": "datetime"
                    },
                    {
                        "name": "tags",
                        "type": "dynamic"
                    },
                    {
                        "name": "combolist",
                        "type": "string"
                    }
                ]
            }
        },
        "destinations": {
            "logAnalytics": [
                {
                    "workspaceResourceId": "{{workspaceResourceId}}",
                    "name": "clv2ws1"
                }
            ]
        },
        "dataFlows": [
            {
                "streams": [
                    "Custom-ZeroFoxCompromisedCredentials_CL"
                ],
                "destinations": [
                    "clv2ws1"
                ],
                "transformKql": "source\n| project-rename TimeGenerated = created_at\n| project TimeGenerated, id, domain, email, username, password, password_type, breach_name, breach_id, breached_at, impacted_domain, data_exposure_at, tags, combolist",
                "outputStream": "Custom-ZeroFoxCompromisedCredentials_CL"
            }
        ]
    }
}]
