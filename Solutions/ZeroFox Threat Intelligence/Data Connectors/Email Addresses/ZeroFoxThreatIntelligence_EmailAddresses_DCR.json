[{
    "name": "EmailAddressesDCR",
    "apiVersion": "2022-06-01",
    "type": "Microsoft.Insights/dataCollectionRules",
    "location": "{{location}}",
    "kind": "Direct",
    "properties": {
        "streamDeclarations": {
            "Custom-ZeroFoxEmailAddresses_CL": {
                "columns": [
                    {
                        "name": "created_at",
                        "type": "datetime"
                    },
                    {
                        "name": "email",
                        "type": "string"
                    },
                    {
                        "name": "domain",
                        "type": "string"
                    },
                    {
                        "name": "tags",
                        "type": "dynamic"
                    }
                ]
            }
        },
        "destinations": {
            "logAnalytics": [
                {
                    "workspaceResourceId": "{{workspaceResourceId}}",
                    "name": "clv2ws1"
                }
            ]
        },
        "dataFlows": [
            {
                "streams": [
                    "Custom-ZeroFoxEmailAddresses_CL"
                ],
                "destinations": [
                    "clv2ws1"
                ],
                "transformKql": "source | extend TimeGenerated = created_at, created_at_t = created_at, email_s = tostring(email), domain_s = tostring(domain), tags_s = tostring(tags) | project TimeGenerated, created_at_t, email_s, domain_s, tags_s",
                "outputStream": "Custom-ZeroFoxEmailAddresses_CL"
            }
        ],
        "dataCollectionEndpointId": "{{dataCollectionEndpointId}}"
    }
}]
