[{
    "name": "VulnerabilitiesDCR",
    "apiVersion": "2022-06-01",
    "type": "Microsoft.Insights/dataCollectionRules",
    "location": "{{location}}",
    "kind": "Direct",
    "properties": {
        "streamDeclarations": {
            "Custom-ZeroFoxVulnerabilities_CL": {
                "columns": [
                    {
                        "name": "created_at",
                        "type": "datetime"
                    },
                    {
                        "name": "updated_at",
                        "type": "datetime"
                    },
                    {
                        "name": "cve",
                        "type": "string"
                    },
                    {
                        "name": "description",
                        "type": "string"
                    },
                    {
                        "name": "summary",
                        "type": "string"
                    },
                    {
                        "name": "remediation",
                        "type": "string"
                    },
                    {
                        "name": "vector_string",
                        "type": "string"
                    },
                    {
                        "name": "base_score",
                        "type": "real"
                    },
                    {
                        "name": "exploitability_score",
                        "type": "real"
                    },
                    {
                        "name": "impact_score",
                        "type": "real"
                    },
                    {
                        "name": "products",
                        "type": "dynamic"
                    }
                ]
            }
        },
        "destinations": {
            "logAnalytics": [
                {
                    "workspaceResourceId": "{{workspaceResourceId}}",
                    "name": "clv2ws1"
                }
            ]
        },
        "dataFlows": [
            {
                "streams": [
                    "Custom-ZeroFoxVulnerabilities_CL"
                ],
                "destinations": [
                    "clv2ws1"
                ],
                "transformKql": "source | extend TimeGenerated = created_at, created_at_t = created_at, updated_at_t = updated_at, cve_s = tostring(cve), description_s = tostring(description), summary_s = tostring(summary), remediation_s = tostring(remediation), vector_string_s = tostring(vector_string), base_score_s = base_score, exploitability_score_s = exploitability_score, impact_score_s = impact_score, products_d = products | project TimeGenerated, created_at_t, updated_at_t, cve_s, description_s, summary_s, remediation_s, vector_string_s, base_score_s, exploitability_score_s, impact_score_s, products_d",
                "outputStream": "Custom-ZeroFoxVulnerabilities_CL"
            }
        ],
        "dataCollectionEndpointId": "{{dataCollectionEndpointId}}"
    }
}]
