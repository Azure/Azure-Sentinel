[{
    "name": "VulnerabilitiesDCR",
    "apiVersion": "2021-09-01-preview",
    "type": "Microsoft.Insights/dataCollectionRules",
    "location": "{{location}}",
    "properties": {
        "dataCollectionEndpointId": "{{dataCollectionEndpointId}}",
        "streamDeclarations": {
            "Custom-ZeroFoxVulnerabilities_CL": {
                "columns": [
                    {
                        "name": "created_at",
                        "type": "datetime"
                    },
                    {
                        "name": "updated_at",
                        "type": "datetime"
                    },
                    {
                        "name": "cve",
                        "type": "string"
                    },
                    {
                        "name": "description",
                        "type": "string"
                    },
                    {
                        "name": "summary",
                        "type": "string"
                    },
                    {
                        "name": "remediation",
                        "type": "string"
                    },
                    {
                        "name": "vector_string",
                        "type": "string"
                    },
                    {
                        "name": "base_score",
                        "type": "real"
                    },
                    {
                        "name": "exploitability_score",
                        "type": "real"
                    },
                    {
                        "name": "impact_score",
                        "type": "real"
                    },
                    {
                        "name": "products",
                        "type": "dynamic"
                    }
                ]
            }
        },
        "destinations": {
            "logAnalytics": [
                {
                    "workspaceResourceId": "{{workspaceResourceId}}",
                    "name": "clv2ws1"
                }
            ]
        },
        "dataFlows": [
            {
                "streams": [
                    "Custom-ZeroFoxVulnerabilities_CL"
                ],
                "destinations": [
                    "clv2ws1"
                ],
                "transformKql": "source\n| project-rename TimeGenerated = created_at\n| project TimeGenerated, updated_at, cve, description, summary, remediation, vector_string, base_score, exploitability_score, impact_score, products",
                "outputStream": "Custom-ZeroFoxVulnerabilities_CL"
            }
        ]
    }
}]
