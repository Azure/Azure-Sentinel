[{
    "name": "BotnetDCR",
    "apiVersion": "2021-09-01-preview",
    "type": "Microsoft.Insights/dataCollectionRules",
    "location": "{{location}}",
    "kind": "Direct",
    "properties": {
        "streamDeclarations": {
            "Custom-ZeroFoxBotnet_CL": {
                "columns": [
                    {
                        "name": "listed_at",
                        "type": "datetime"
                    },
                    {
                        "name": "ip_address",
                        "type": "string"
                    },
                    {
                        "name": "bot_name",
                        "type": "string"
                    },
                    {
                        "name": "c2_ip_address",
                        "type": "string"
                    },
                    {
                        "name": "c2_domain",
                        "type": "string"
                    },
                    {
                        "name": "is_common_domain",
                        "type": "boolean"
                    },
                    {
                        "name": "file_location",
                        "type": "string"
                    },
                    {
                        "name": "operating_system",
                        "type": "string"
                    },
                    {
                        "name": "anti_viruses",
                        "type": "dynamic"
                    },
                    {
                        "name": "country_code",
                        "type": "string"
                    },
                    {
                        "name": "zip_code",
                        "type": "string"
                    },
                    {
                        "name": "location",
                        "type": "string"
                    },
                    {
                        "name": "current_language",
                        "type": "string"
                    },
                    {
                        "name": "available_keyboards",
                        "type": "dynamic"
                    },
                    {
                        "name": "uac",
                        "type": "string"
                    },
                    {
                        "name": "process_elevation",
                        "type": "string"
                    },
                    {
                        "name": "acquired_at",
                        "type": "datetime"
                    },
                    {
                        "name": "logged_at",
                        "type": "datetime"
                    },
                    {
                        "name": "estimated_infected_at",
                        "type": "datetime"
                    },
                    {
                        "name": "breached_at",
                        "type": "datetime"
                    },
                    {
                        "name": "tags",
                        "type": "dynamic"
                    }
                ]
            }
        },
        "destinations": {
            "logAnalytics": [
                {
                    "workspaceResourceId": "{{workspaceResourceId}}",
                    "name": "clv2ws1"
                }
            ]
        },
        "dataFlows": [
            {
                "streams": [
                    "Custom-ZeroFoxBotnet_CL"
                ],
                "destinations": [
                    "clv2ws1"
                ],
                "transformKql": "source\n| project-rename TimeGenerated = listed_at\n| project TimeGenerated, ip_address, bot_name, c2_ip_address, c2_domain, is_common_domain, file_location, operating_system, anti_viruses, country_code, zip_code, location, current_language, available_keyboards, uac, process_elevation, acquired_at, logged_at, estimated_infected_at, breached_at, tags",
                "outputStream": "Custom-ZeroFoxBotnet_CL"
            }
        ]
    }
}]
