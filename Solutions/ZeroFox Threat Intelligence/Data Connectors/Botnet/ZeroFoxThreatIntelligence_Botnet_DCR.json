[{
    "name": "BotnetDCR",
    "apiVersion": "2022-06-01",
    "type": "Microsoft.Insights/dataCollectionRules",
    "location": "{{location}}",
    "kind": "Direct",
    "properties": {
        "streamDeclarations": {
            "Custom-ZeroFoxBotnet_CL": {
                "columns": [
                    {
                        "name": "listed_at",
                        "type": "datetime"
                    },
                    {
                        "name": "ip_address",
                        "type": "string"
                    },
                    {
                        "name": "bot_name",
                        "type": "string"
                    },
                    {
                        "name": "c2_ip_address",
                        "type": "string"
                    },
                    {
                        "name": "c2_domain",
                        "type": "string"
                    },
                    {
                        "name": "is_common_domain",
                        "type": "boolean"
                    },
                    {
                        "name": "file_location",
                        "type": "string"
                    },
                    {
                        "name": "operating_system",
                        "type": "string"
                    },
                    {
                        "name": "anti_viruses",
                        "type": "dynamic"
                    },
                    {
                        "name": "country_code",
                        "type": "string"
                    },
                    {
                        "name": "zip_code",
                        "type": "string"
                    },
                    {
                        "name": "location",
                        "type": "string"
                    },
                    {
                        "name": "current_language",
                        "type": "string"
                    },
                    {
                        "name": "available_keyboards",
                        "type": "dynamic"
                    },
                    {
                        "name": "uac",
                        "type": "string"
                    },
                    {
                        "name": "process_elevation",
                        "type": "string"
                    },
                    {
                        "name": "acquired_at",
                        "type": "datetime"
                    },
                    {
                        "name": "logged_at",
                        "type": "datetime"
                    },
                    {
                        "name": "estimated_infected_at",
                        "type": "datetime"
                    },
                    {
                        "name": "breached_at",
                        "type": "datetime"
                    },
                    {
                        "name": "tags",
                        "type": "dynamic"
                    }
                ]
            }
        },
        "destinations": {
            "logAnalytics": [
                {
                    "workspaceResourceId": "{{workspaceResourceId}}",
                    "name": "clv2ws1"
                }
            ]
        },
        "dataFlows": [
            {
                "streams": [
                    "Custom-ZeroFoxBotnet_CL"
                ],
                "destinations": [
                    "clv2ws1"
                ],
                "transformKql": "source | extend TimeGenerated = listed_at, listed_at_t = listed_at, ip_address_s = tostring(ip_address), bot_name_s = tostring(bot_name), c2_ip_address_s = tostring(c2_ip_address), c2_domain_s = tostring(c2_domain), is_common_domain_b = is_common_domain, file_location_s = tostring(file_location), operating_system_s = tostring(operating_system), anti_viruses_s = tostring(anti_viruses), country_code_s = tostring(country_code), zip_code_s = tostring(zip_code), location_s = tostring(['location']), current_language_s = tostring(current_language), available_keyboards_s = tostring(available_keyboards), uac_s = tostring(uac), process_elevation_s = tostring(process_elevation), acquired_at_t = acquired_at, logged_at_t = logged_at, estimated_infected_at_t = estimated_infected_at, breached_at_t = breached_at, tags_s = tostring(tags) | project TimeGenerated, listed_at_t, ip_address_s, bot_name_s, c2_ip_address_s, c2_domain_s, is_common_domain_b, file_location_s, operating_system_s, anti_viruses_s, country_code_s, zip_code_s, location_s, current_language_s, available_keyboards_s, uac_s, process_elevation_s, acquired_at_t, logged_at_t, estimated_infected_at_t, breached_at_t, tags_s",
                "outputStream": "Custom-ZeroFoxBotnet_CL"
            }
        ],
        "dataCollectionEndpointId": "{{dataCollectionEndpointId}}"
    }
  }
]
