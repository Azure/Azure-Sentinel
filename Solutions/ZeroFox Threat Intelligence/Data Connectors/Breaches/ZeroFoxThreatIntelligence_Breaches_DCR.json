[{
    "name": "BreachesDCR",
    "apiVersion": "2021-09-01-preview",
    "type": "Microsoft.Insights/dataCollectionRules",
    "location": "{{location}}",
    "kind": "Direct",
    "properties": {
        "streamDeclarations": {
            "Custom-ZeroFoxBreaches_CL": {
                "columns": [
                    {
                        "name": "id",
                        "type": "string"
                    },
                    {
                        "name": "name",
                        "type": "string"
                    },
                    {
                        "name": "description",
                        "type": "string"
                    },
                    {
                        "name": "breach_date",
                        "type": "datetime"
                    },
                    {
                        "name": "created_at",
                        "type": "datetime"
                    },
                    {
                        "name": "included_fields",
                        "type": "dynamic"
                    },
                    {
                        "name": "record_count",
                        "type": "int"
                    },
                    {
                        "name": "threat_type",
                        "type": "dynamic"
                    },
                    {
                        "name": "geography",
                        "type": "dynamic"
                    },
                    {
                        "name": "confidence",
                        "type": "string"
                    },
                    {
                        "name": "reliability",
                        "type": "string"
                    },
                    {
                        "name": "tlp",
                        "type": "string"
                    },
                    {
                        "name": "industry",
                        "type": "dynamic"
                    }
                ]
            }
        },
        "destinations": {
            "logAnalytics": [
                {
                    "workspaceResourceId": "{{workspaceResourceId}}",
                    "name": "clv2ws1"
                }
            ]
        },
        "dataFlows": [
            {
                "streams": [
                    "Custom-ZeroFoxBreaches_CL"
                ],
                "destinations": [
                    "clv2ws1"
                ],
                "transformKql": "source\n| project-rename TimeGenerated = created_at\n| project TimeGenerated, id, name, description, breach_date, included_fields, record_count, threat_type, geography, confidence, reliability, tlp, industry",
                "outputStream": "Custom-ZeroFoxBreaches_CL"
            }
        ]
    }
}]
