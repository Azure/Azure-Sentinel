[{
    "name": "IdentityBreachDCR",
    "apiVersion": "2021-09-01-preview",
    "type": "Microsoft.Insights/dataCollectionRules",
    "location": "{{location}}",
    "kind": "Direct",
    "properties": {
        "streamDeclarations": {
            "Custom-ZeroFoxIdentityBreach_CL": {
                "columns": [
                    {
                        "name": "cac_username_hash",
                        "type": "string"
                    },
                    {
                        "name": "cac_email_hash",
                        "type": "string"
                    },
                    {
                        "name": "cac_password_hash",
                        "type": "string"
                    },
                    {
                        "name": "ncid_id_hash",
                        "type": "string"
                    },
                    {
                        "name": "cc_num_hash",
                        "type": "string"
                    },
                    {
                        "name": "passport_id_hash",
                        "type": "string"
                    },
                    {
                        "name": "bank_account_id_hash",
                        "type": "string"
                    },
                    {
                        "name": "medical_account_id_hash",
                        "type": "string"
                    },
                    {
                        "name": "phone_number_e164_hash",
                        "type": "string"
                    },
                    {
                        "name": "dl_id_hash",
                        "type": "string"
                    },
                    {
                        "name": "ui_discovered_ts",
                        "type": "string"
                    },
                    {
                        "name": "ui_insertion_ts",
                        "type": "string"
                    },
                    {
                        "name": "ui_breach_id",
                        "type": "string"
                    },
                    {
                        "name": "ui_breach_name",
                        "type": "string"
                    },
                    {
                        "name": "ui_breach_description",
                        "type": "string"
                    }
                ]
            }
        },
        "destinations": {
            "logAnalytics": [
                {
                    "workspaceResourceId": "{{workspaceResourceId}}",
                    "name": "clv2ws1"
                }
            ]
        },
        "dataFlows": [
            {
                "streams": [
                    "Custom-ZeroFoxIdentityBreach_CL"
                ],
                "destinations": [
                    "clv2ws1"
                ],
                "transformKql": "source\n| project-rename TimeGenerated = ui_insertion_ts\n| project TimeGenerated, ui_insertion_ts, ui_breach_id, ui_breach_name, ui_breach_description",
                "outputStream": "Custom-ZeroFoxIdentityBreach_CL"
            }
        ]
    }
}]
