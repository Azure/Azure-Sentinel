[{
    "name": "DisruptionDCR",
    "apiVersion": "2022-06-01",
    "type": "Microsoft.Insights/dataCollectionRules",
    "location": "{{location}}",
    "kind": "Direct",
    "properties": {
        "streamDeclarations": {
            "Custom-ZeroFoxDisruption_CL": {
                "columns": [
                    {
                        "name": "created_at",
                        "type": "datetime"
                    },
                    {
                        "name": "updated_at",
                        "type": "datetime"
                    },
                    {
                        "name": "url",
                        "type": "string"
                    },
                    {
                        "name": "fqdn",
                        "type": "string"
                    },
                    {
                        "name": "ip",
                        "type": "string"
                    },
                    {
                        "name": "host",
                        "type": "string"
                    },
                    {
                        "name": "registrar",
                        "type": "string"
                    },
                    {
                        "name": "threat_type",
                        "type": "string"
                    },
                    {
                        "name": "http_status",
                        "type": "int"
                    },
                    {
                        "name": "asn",
                        "type": "int"
                    },
                    {
                        "name": "iana",
                        "type": "int"
                    },
                    {
                        "name": "category",
                        "type": "string"
                    },
                    {
                        "name": "network",
                        "type": "string"
                    }
                ]
            }
        },
        "destinations": {
            "logAnalytics": [
                {
                    "workspaceResourceId": "{{workspaceResourceId}}",
                    "name": "clv2ws1"
                }
            ]
        },
        "dataFlows": [
            {
                "streams": [
                    "Custom-ZeroFoxDisruption_CL"
                ],
                "destinations": [
                    "clv2ws1"
                ],
                "transformKql": "source | extend TimeGenerated = created_at, created_at_t = created_at, updated_at_t = updated_at, url_s = tostring(url), fqdn_s = tostring(fqdn), ip_s = tostring(ip), host_s = tostring(host), registrar_s = tostring(registrar), threat_type_s = tostring(threat_type), http_status_s = http_status, asn_s = asn, iana_s = iana, category_s = tostring(category), network_s = tostring(network) | project TimeGenerated, created_at_t, updated_at_t, url_s, fqdn_s, ip_s, host_s, registrar_s, threat_type_s, http_status_s, asn_s, iana_s, category_s, network_s",
                "outputStream": "Custom-ZeroFoxDisruption_CL"
            }
        ],
        "dataCollectionEndpointId": "{{dataCollectionEndpointId}}"
    }
}]
