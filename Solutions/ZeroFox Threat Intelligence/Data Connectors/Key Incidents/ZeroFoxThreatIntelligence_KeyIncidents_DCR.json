[{
    "name": "KeyIncidentsDCR",
    "apiVersion": "2021-09-01-preview",
    "type": "Microsoft.Insights/dataCollectionRules",
    "location": "{{location}}",
    "kind": "Direct",
    "properties": {
        "streamDeclarations": {
            "Custom-ZeroFoxKeyIncidents_CL": {
                "columns": [
                    {
                        "name": "created_at",
                        "type": "datetime"
                    },
                    {
                        "name": "updated_at",
                        "type": "datetime"
                    },
                    {
                        "name": "id",
                        "type": "string"
                    },
                    {
                        "name": "incident_id",
                        "type": "string"
                    },
                    {
                        "name": "title",
                        "type": "string"
                    },
                    {
                        "name": "headline",
                        "type": "string"
                    },
                    {
                        "name": "analysis",
                        "type": "string"
                    },
                    {
                        "name": "solution",
                        "type": "string"
                    },
                    {
                        "name": "risk_level",
                        "type": "string"
                    },
                    {
                        "name": "url",
                        "type": "string"
                    },
                    {
                        "name": "matchingContent",
                        "type": "string"
                    },
                    {
                        "name": "highlightedContent",
                        "type": "string"
                    },
                    {
                        "name": "tags",
                        "type": "dynamic"
                    },
                    {
                        "name": "target_types",
                        "type": "dynamic"
                    },
                    {
                        "name": "threat_types",
                        "type": "dynamic"
                    },
                    {
                        "name": "attachments",
                        "type": "dynamic"
                    }
                ]
            }
        },
        "destinations": {
            "logAnalytics": [
                {
                    "workspaceResourceId": "{{workspaceResourceId}}",
                    "name": "clv2ws1"
                }
            ]
        },
        "dataFlows": [
            {
                "streams": [
                    "Custom-ZeroFoxKeyIncidents_CL"
                ],
                "destinations": [
                    "clv2ws1"
                ],
                "transformKql": "source\n| project-rename TimeGenerated = created_at\n| project TimeGenerated, updated_at, id, incident_id, title, headline, analysis, solution, risk_level, url, matchingContent, highlightedContent, tags, target_types, threat_types, attachments",
                "outputStream": "Custom-ZeroFoxKeyIncidents_CL"
            }
        ]
    }
}]
