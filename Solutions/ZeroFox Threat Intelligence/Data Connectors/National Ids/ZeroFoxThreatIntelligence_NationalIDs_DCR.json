[{
    "name": "NationalIDsDCR",
    "apiVersion": "2022-06-01",
    "type": "Microsoft.Insights/dataCollectionRules",
    "location": "{{location}}",
    "kind": "Direct",
    "properties": {
        "streamDeclarations": {
            "Custom-ZeroFoxNationalIds_CL": {
                "columns": [
                    {
                        "name": "created_at",
                        "type": "datetime"
                    },
                    {
                        "name": "national_identifier",
                        "type": "string"
                    },
                    {
                        "name": "country",
                        "type": "string"
                    },
                    {
                        "name": "first_name",
                        "type": "string"
                    },
                    {
                        "name": "last_name",
                        "type": "string"
                    },
                    {
                        "name": "person_name",
                        "type": "string"
                    },
                    {
                        "name": "source",
                        "type": "string"
                    },
                    {
                        "name": "breach_name",
                        "type": "string"
                    }
                ]
            }
        },
        "destinations": {
            "logAnalytics": [
                {
                    "workspaceResourceId": "{{workspaceResourceId}}",
                    "name": "clv2ws1"
                }
            ]
        },
        "dataFlows": [
            {
                "streams": [
                    "Custom-ZeroFoxNationalIds_CL"
                ],
                "destinations": [
                    "clv2ws1"
                ],
                "transformKql": "source | extend TimeGenerated = created_at, created_at_t = created_at, national_identifier_s = tostring(national_identifier), country_s = tostring(country), first_name_s = tostring(first_name), last_name_s = tostring(last_name), person_name_s = tostring(person_name), source_s = tostring(['source']), breach_name_s = tostring(breach_name) | project TimeGenerated, created_at_t, national_identifier_s, country_s, first_name_s, last_name_s, person_name_s, source_s, breach_name_s",
                "outputStream": "Custom-ZeroFoxNationalIds_CL"
            }
        ],
        "dataCollectionEndpointId": "{{dataCollectionEndpointId}}"
    }
}]
