[{
    "name": "DiscordDCR",
    "apiVersion": "2021-09-01-preview",
    "type": "Microsoft.Insights/dataCollectionRules",
    "location": "{{location}}",
    "properties": {
        "dataCollectionEndpointId": "{{dataCollectionEndpointId}}",
        "streamDeclarations": {
            "Custom-ZeroFoxDiscord_CL": {
                "columns": [
                    {
                        "name": "timestamp",
                        "type": "datetime"
                    },
                    {
                        "name": "id",
                        "type": "string"
                    },
                    {
                        "name": "author",
                        "type": "dynamic"
                    },
                    {
                        "name": "channel_name",
                        "type": "string"
                    },
                    {
                        "name": "content",
                        "type": "string"
                    },
                    {
                        "name": "server_name",
                        "type": "string"
                    },
                    {
                        "name": "thread_url",
                        "type": "string"
                    }
                ]
            }
        },
        "destinations": {
            "logAnalytics": [
                {
                    "workspaceResourceId": "{{workspaceResourceId}}",
                    "name": "clv2ws1"
                }
            ]
        },
        "dataFlows": [
            {
                "streams": [
                    "Custom-ZeroFoxDiscord_CL"
                ],
                "destinations": [
                    "clv2ws1"
                ],
                "transformKql": "source\n| project-rename TimeGenerated = timestamp\n| project TimeGenerated, id, author, channel_name, content, server_name, thread_url",
                "outputStream": "Custom-ZeroFoxDiscord_CL"
            }
        ]
    }
}]
