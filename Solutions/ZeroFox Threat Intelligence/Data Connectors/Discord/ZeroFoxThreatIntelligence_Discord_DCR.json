[
  {
    "name": "DiscordDCR",
    "apiVersion": "2022-06-01",
    "type": "Microsoft.Insights/dataCollectionRules",
    "location": "{{location}}",
    "kind": "Direct",
    "properties": {
      "streamDeclarations": {
        "Custom-ZeroFoxDiscord_CL": {
          "columns": [
            {
              "name": "timestamp",
              "type": "datetime"
            },
            {
              "name": "id",
              "type": "string"
            },
            {
              "name": "author",
              "type": "dynamic"
            },
            {
              "name": "channel_name",
              "type": "string"
            },
            {
              "name": "content",
              "type": "string"
            },
            {
              "name": "server_name",
              "type": "string"
            },
            {
              "name": "thread_url",
              "type": "string"
            }
          ]
        }
      },
      "destinations": {
        "logAnalytics": [
          {
            "workspaceResourceId": "{{workspaceResourceId}}",
            "name": "clv2ws1"
          }
        ]
      },
      "dataFlows": [
        {
          "streams": [
            "Custom-ZeroFoxDiscord_CL"
          ],
          "destinations": [
            "clv2ws1"
          ],
          "transformKql": "source | extend TimeGenerated = ['timestamp'], timestamp_t = ['timestamp'], id_s = tostring(id), author_id_s = tostring(author['id']), author_username_s = tostring(author['username']), channel_name_s = tostring(channel_name), content_s = tostring(content), server_name_s = tostring(server_name), thread_url_s = tostring(thread_url) | project TimeGenerated, timestamp_t, id_s, author_id_s, author_username_s, channel_name_s, content_s, server_name_s, thread_url_s",
          "outputStream": "Custom-ZeroFoxDiscord_CL"
        }
      ],
      "dataCollectionEndpointId": "{{dataCollectionEndpointId}}"
    }
  }
]
