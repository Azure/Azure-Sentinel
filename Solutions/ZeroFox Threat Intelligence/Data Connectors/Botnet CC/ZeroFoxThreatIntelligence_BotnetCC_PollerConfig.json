[
  {
    "name": "[[concat(parameters('innerWorkspace'),'/Microsoft.SecurityInsights/', 'ZeroFoxBotnetCCPoller', parameters('guidValue'))]",
    "apiVersion": "2023-02-01-preview",
    "type": "Microsoft.SecurityInsights/dataConnectors",
    "location": "{{location}}",
    "kind": "RestApiPoller",
    "properties": {
      "connectorDefinitionName": "ZeroFoxBotnetCCDefinition",
      "dataType": "ZeroFoxBotnetCC_CL",
      "dcrConfig": {
        "streamName": "Custom-ZeroFoxBotnetCC_CL",
        "dataCollectionEndpoint": "[[parameters('dcrConfig').dataCollectionEndpoint]",
        "dataCollectionRuleImmutableId": "[[parameters('dcrConfig').dataCollectionRuleImmutableId]"
      },
      "auth": {
        "type": "JwtToken",
        "userName": {
          "key": "username",
          "value": "[[parameters('username')]"
        },
        "password": {
          "key": "password",
          "value": "[[parameters('apikey')]"
        },
        "TokenEndpoint": "https://api.zerofox.com/auth/token/",
        "IsJsonRequest": true,
        "JwtTokenJsonPath": "$.access"
      },
      "request": {
        "apiEndpoint": "https://api.zerofox.com/cti/botnet-compromised-credentials/",
        "rateLimitQPS": 10,
        "queryWindowInMin": "[[first(parameters('pollingFrequency'))]",
        "httpMethod": "GET",
        "queryTimeFormat": "yyyy-MM-ddTHH:mm:ssZ",
        "startTimeAttributeName": "created_after",
        "endTimeAttributeName": "created_before",
        "retryCount": 3,
        "timeoutInSeconds": 60,
        "headers": {
          "Accept": "application/json",
          "User-Agent": "Microsoft-Sentinel-ZeroFox-CTI-Connector",
          "zf-source": "Microsoft-Sentinel"
        }
      },
      "paging": {
        "pagingType": "NextPageUrl",
        "nextPageUrl": "https://api.zerofox.com/cti/botnet-compromised-credentials/",
        "nextPageTokenJsonPath": "$.next",
        "nextPageParaName": "next",
        "hasNextFlagJsonPath": "$.next"
      },
      "response": {
        "eventsJsonPaths": [
          "$.results[*]"
        ],
        "format": "json"
      }
    }
  }
]
