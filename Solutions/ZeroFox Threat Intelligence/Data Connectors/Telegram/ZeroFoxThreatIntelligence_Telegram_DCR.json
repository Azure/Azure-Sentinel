[{
    "name": "TelegramDCR",
    "apiVersion": "2021-09-01-preview",
    "type": "Microsoft.Insights/dataCollectionRules",
    "location": "{{location}}",
    "kind": "Direct",
    "properties": {
        "streamDeclarations": {
            "Custom-ZeroFoxTelegram_CL": {
                "columns": [
                    {
                        "name": "timestamp",
                        "type": "datetime"
                    },
                    {
                        "name": "id",
                        "type": "string"
                    },
                    {
                        "name": "channel_name",
                        "type": "string"
                    },
                    {
                        "name": "first_name",
                        "type": "string"
                    },
                    {
                        "name": "last_name",
                        "type": "string"
                    },
                    {
                        "name": "user",
                        "type": "string"
                    },
                    {
                        "name": "message",
                        "type": "string"
                    },
                    {
                        "name": "message_url",
                        "type": "string"
                    }
                ]
            }
        },
        "destinations": {
            "logAnalytics": [
                {
                    "workspaceResourceId": "{{workspaceResourceId}}",
                    "name": "clv2ws1"
                }
            ]
        },
        "dataFlows": [
            {
                "streams": [
                    "Custom-ZeroFoxTelegram_CL"
                ],
                "destinations": [
                    "clv2ws1"
                ],
                "transformKql": "source\n| project-rename TimeGenerated = timestamp\n| project TimeGenerated, id, channel_name, first_name, last_name, user, message, message_url",
                "outputStream": "Custom-ZeroFoxTelegram_CL"
            }
        ]
    }
}]
