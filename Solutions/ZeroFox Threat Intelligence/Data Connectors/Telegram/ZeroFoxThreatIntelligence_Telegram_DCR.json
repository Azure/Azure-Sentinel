[{
    "name": "TelegramDCR",
    "apiVersion": "2022-06-01",
    "type": "Microsoft.Insights/dataCollectionRules",
    "location": "{{location}}",
    "kind": "Direct",
    "properties": {
        "streamDeclarations": {
            "Custom-ZeroFoxTelegram_CL": {
                "columns": [
                    {
                        "name": "timestamp",
                        "type": "datetime"
                    },
                    {
                        "name": "channel_name",
                        "type": "string"
                    },
                    {
                        "name": "first_name",
                        "type": "string"
                    },
                    {
                        "name": "last_name",
                        "type": "string"
                    },
                    {
                        "name": "user",
                        "type": "string"
                    },
                    {
                        "name": "message",
                        "type": "string"
                    },
                    {
                        "name": "message_url",
                        "type": "string"
                    }
                ]
            }
        },
        "destinations": {
            "logAnalytics": [
                {
                    "workspaceResourceId": "{{workspaceResourceId}}",
                    "name": "clv2ws1"
                }
            ]
        },
        "dataFlows": [
            {
                "streams": [
                    "Custom-ZeroFoxTelegram_CL"
                ],
                "destinations": [
                    "clv2ws1"
                ],
                "transformKql": "source | extend TimeGenerated = ['timestamp'], timestamp_t = ['timestamp'], channel_name_s = tostring(channel_name), first_name_s = tostring(first_name), last_name_s = tostring(last_name), user_s = tostring(user), message_s = tostring(message), message_url_s = tostring(message_url) | project TimeGenerated, timestamp_t, channel_name_s, first_name_s, last_name_s, user_s, message_s, message_url_s",
                "outputStream": "Custom-ZeroFoxTelegram_CL"
            }
        ],
        "dataCollectionEndpointId": "{{dataCollectionEndpointId}}"
    }
}]
