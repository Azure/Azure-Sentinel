{
  "$schema": "https://schema.management.azure.com/schemas/0.1.2/CreateUIDefinition.MultiVm.json#",
  "handler": "Microsoft.Azure.CreateUIDef",
  "version": "0.1.2",
  "parameters": {
    "config": {
      "basics": {
        "resourceGroup": {
          "allowExisting": true
        }
      }
    },
    "basics": [],
    "steps": [
      {
        "name": "connection",
        "label": "Open Systems Logs-API",
        "elements": [
          {
            "name": "openSystemsLogsAPIEndpoint",
            "type": "Microsoft.Common.TextBox",
            "label": "Logs API Endpoint",
            "placeholder": "logs-your-namespace.servicebus.windows.net:9093",
            "multiLine": false,
            "constraints": {
              "required": true
            },
            "toolTip": "Provide the Logs-API endpoint for your Open Systems account."
          },
          {
            "name": "openSystemsLogsAPIConnectionString",
            "type": "Microsoft.Common.PasswordBox",
            "label": {
              "password": "Logs-API Connection String"
            },
            "constraints": {
              "required": true
            },
            "toolTip": "Provide the precreated connection string for the EventHub.",
            "options": {
              "hideConfirmation": true
            }
          },
          {
            "name": "secureWebGateway",
            "type": "Microsoft.Common.CheckBox",
            "label": "Secure Web Gateway Logs",
            "defaultValue": true,
            "toolTip": "Enable ingestion of Secure Web Gateway logs."
          },
          {
            "name": "proxyConsumerThreads",
            "type": "Microsoft.Common.TextBox",
            "label": "Secure Web Gateway Consumer Threads",
            "defaultValue": "1",
            "multiLine": false,
            "constraints": {
              "required": false,
              "validation": {
                "constraint": "Int",
                "minValue": 1,
                "maxValue": 100
              }
            },
            "toolTip": "Number of consumer threads for Secure Web Gateway logs (1-100)."
          },
          {
            "name": "identity",
            "type": "Microsoft.Common.CheckBox",
            "label": "Identity Service Logs",
            "defaultValue": true,
            "toolTip": "Enable ingestion of Identity service logs."
          },
          {
            "name": "identityConsumerThreads",
            "type": "Microsoft.Common.TextBox",
            "label": "Identity Consumer Threads",
            "defaultValue": "1",
            "multiLine": false,
            "constraints": {
              "required": false,
              "validation": {
                "constraint": "Int",
                "minValue": 1,
                "maxValue": 100
              }
            },
            "toolTip": "Number of consumer threads for Identity logs (1-100)."
          },
          {
            "name": "firewall",
            "type": "Microsoft.Common.CheckBox",
            "label": "Firewall Logs",
            "defaultValue": true,
            "toolTip": "Enable ingestion of Firewall logs."
          },
          {
            "name": "firewallConsumerThreads",
            "type": "Microsoft.Common.TextBox",
            "label": "Firewall Consumer Threads",
            "defaultValue": "1",
            "multiLine": false,
            "constraints": {
              "required": false,
              "validation": {
                "constraint": "Int",
                "minValue": 1,
                "maxValue": 100
              }
            },
            "toolTip": "Number of consumer threads for Firewall logs (1-100)."
          },
          {
            "name": "zeroTrustNetworkAccess",
            "type": "Microsoft.Common.CheckBox",
            "label": "Zero Trust Network Access Logs",
            "defaultValue": true,
            "toolTip": "Enable ingestion of Zero Trust Network Access logs."
          },
          {
            "name": "ztnaConsumerThreads",
            "type": "Microsoft.Common.TextBox",
            "label": "ZTNA Consumer Threads",
            "defaultValue": "1",
            "multiLine": false,
            "constraints": {
              "required": false,
              "validation": {
                "constraint": "Int",
                "minValue": 1,
                "maxValue": 100
              }
            },
            "toolTip": "Number of consumer threads for Zero Trust Network Access logs (1-100)."
          },
          {
            "name": "secureE-MailGateway",
            "type": "Microsoft.Common.CheckBox",
            "label": "Secure E-Mail Gateway Logs",
            "defaultValue": false,
            "toolTip": "Enable ingestion of Secure E-Mail Gateway logs."
          },
          {
            "name": "secureE-MailGatewayConsumerThreads",
            "type": "Microsoft.Common.TextBox",
            "label": "Secure E-Mail Gateway Consumer Threads",
            "defaultValue": "1",
            "multiLine": false,
            "constraints": {
              "required": false,
              "validation": {
                "constraint": "Int",
                "minValue": 1,
                "maxValue": 100
              }
            },
            "toolTip": "Number of consumer threads for Secure E-Mail Gateway logs (1-100)."
          },
          {
            "name": "intrusionDetectionSystem",
            "type": "Microsoft.Common.CheckBox",
            "label": "Intrusion Detection System Logs",
            "defaultValue": false,
            "toolTip": "Enable ingestion of Intrusion Detection System logs."
          },
          {
            "name": "intrusionDetectionSystemConsumerThreads",
            "type": "Microsoft.Common.TextBox",
            "label": "Intrusion Detection System Consumer Threads",
            "defaultValue": "1",
            "multiLine": false,
            "constraints": {
              "required": false,
              "validation": {
                "constraint": "Int",
                "minValue": 1,
                "maxValue": 100
              }
            },
            "toolTip": "Number of consumer threads for Intrusion Detection System logs (1-100)."
          }
        ]
      },
      {
        "name": "logsWorkspace",
        "label": "Log Analytics",
        "elements": [
          {
            "name": "logsWorkspaceSelector",
            "type": "Microsoft.Solutions.ResourceSelector",
            "label": "Select Log Analytics workspace",
            "resourceType": "Microsoft.OperationalInsights/workspaces",
            "toolTip": "Select the Log Analytics workspace for Microsoft Sentinel."
          },
          {
            "name": "servicePrincipal",
            "type": "Microsoft.Common.ServicePrincipalSelector",
            "label": {
              "password": "Password",
              "sectionHeader": "Service Principal"
            },
            "toolTip": {
              "password": "For existing Service Principal please use pre-configured secret"
            },
            "defaultValue": {
              "principalId": "<default guid>",
              "name": "osag-logs-api-connector"
            },
            "constraints": {
              "required": true
            },
            "options": {
              "hideCertificate": true
            },
            "visible": true
          }
        ]
      },
      {
        "name": "scaling",
        "label": "Container Configuration",
        "elements": [
          {
            "name": "containerCpu",
            "type": "Microsoft.Common.TextBox",
            "label": "Container CPU",
            "defaultValue": "2.0",
            "multiLine": false,
            "constraints": {
              "required": false,
              "validation": {
                "constraint": "Float",
                "minValue": 0.5,
                "maxValue": 4.0
              }
            },
            "toolTip": "CPU cores for the container (0.5-4.0)."
          },
          {
            "name": "containerMemory",
            "type": "Microsoft.Common.TextBox",
            "label": "Container Memory (GiB)",
            "defaultValue": "4",
            "multiLine": false,
            "constraints": {
              "required": false,
              "validation": {
                "constraint": "Int",
                "minValue": 1,
                "maxValue": 8
              }
            },
            "toolTip": "Memory in GiB for the container (1-8)."
          },
          {
            "name": "enableAutoScale",
            "type": "Microsoft.Common.CheckBox",
            "label": "Enable AutoScale",
            "defaultValue": true,
            "toolTip": "Enable autoscaling based on CPU usage."
          },
          {
            "name": "xmxPercentage",
            "type": "Microsoft.Common.TextBox",
            "label": "Xmx Percentage",
            "defaultValue": "75",
            "multiLine": false,
            "constraints": {
              "required": false,
              "validation": {
                "constraint": "Int",
                "minValue": 1,
                "maxValue": 100
              }
            },
            "toolTip": "JVM Xmx as percentage of container memory (1-100)."
          },
          {
            "name": "xmsPercentage",
            "type": "Microsoft.Common.TextBox",
            "label": "Xms Percentage",
            "defaultValue": "70",
            "multiLine": false,
            "constraints": {
              "required": false,
              "validation": {
                "constraint": "Int",
                "minValue": 1,
                "maxValue": 100
              }
            },
            "toolTip": "JVM Xms as percentage of container memory (1-100)."
          },
          {
            "name": "containerImage",
            "type": "Microsoft.Common.TextBox",
            "label": "Container Image",
            "defaultValue": "docker.elastic.co/logstash/logstash-oss:8.12.0",
            "multiLine": false,
            "constraints": {
              "required": false
            },
            "toolTip": "Logstash container image URL."
          },
          {
            "name": "collectContainerLogs",
            "type": "Microsoft.Common.CheckBox",
            "label": "Collect Container App Logs",
            "toolTip": "Ingests Logstash logs into selected Log Analytics Workspace",
            "defaultValue": false
          }
        ]
      }
    ],
    "outputs": {
      "workspace": "[steps('logsWorkspace').logsWorkspaceSelector.name]",
      "workspace-location": "[steps('logsWorkspace').logsWorkspaceSelector.location]",
      "location": "[resourceGroup().location]",
      "principalId": "[first(steps('logsWorkspace').servicePrincipal.objectId)]",
      "principalClientId": "[steps('logsWorkspace').servicePrincipal.appId]",
      "principalSecret": "[steps('logsWorkspace').servicePrincipal.password]",
      "openSystemsLogsAPIEndpoint": "[steps('connection').openSystemsLogsAPIEndpoint]",
      "openSystemsLogsAPIConnectionString": "[steps('connection').openSystemsLogsAPIConnectionString]",
      "secureWebGateway": "[steps('connection').secureWebGateway]",
      "identity": "[steps('connection').identity]",
      "firewall": "[steps('connection').firewall]",
      "zeroTrustNetworkAccess": "[steps('connection').zeroTrustNetworkAccess]",
      "secureE-MailGateway": "[steps('connection').secureE-MailGateway]",
      "intrusionDetectionSystem": "[steps('connection').intrusionDetectionSystem]",
      "proxyConsumerThreads": "[steps('connection').proxyConsumerThreads]",
      "identityConsumerThreads": "[steps('connection').identityConsumerThreads]",
      "firewallConsumerThreads": "[steps('connection').firewallConsumerThreads]",
      "ztnaConsumerThreads": "[steps('connection').ztnaConsumerThreads]",
      "secureE-MailGatewayConsumerThreads": "[steps('connection').secureE-MailGatewayConsumerThreads]",
      "intrusionDetectionSystemConsumerThreads": "[steps('connection').intrusionDetectionSystemConsumerThreads]",
      "collectContainerLogs": "[steps('scaling').collectContainerLogs]",
      "containerCpu": "[steps('scaling').containerCpu]",
      "containerMemory": "[steps('scaling').containerMemory]",
      "enableAutoScale": "[steps('scaling').enableAutoScale]",
      "xmxPercentage": "[steps('scaling').xmxPercentage]",
      "xmsPercentage": "[steps('scaling').xmsPercentage]",
      "containerImage": "[steps('scaling').containerImage]"
    }
  }
}
