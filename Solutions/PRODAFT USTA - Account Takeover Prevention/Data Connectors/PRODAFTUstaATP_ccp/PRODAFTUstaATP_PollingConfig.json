      "auth": {
        "type": "APIKey",
        "apiKey": "{{apiKey}}",
        "apiKeyName": "Authorization",
        "apiKeyIdentifier": "Bearer"
      },
      "request": {
        "apiEndpoint": "{{ustaBaseUrl}}/api/threat-stream/v4/security-intelligence/account-takeover-prevention/compromised-credentials-tickets",
