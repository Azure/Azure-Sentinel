[
  {
    "type": "Microsoft.SecurityInsights/dataConnectors",
    "apiVersion": "2023-02-01",
    "name": "PRODAFTUstaCompromisedCredentialsPolling",
    "location": "{{location}}",
    "kind": "RestApiPoller",
    "properties": {
      "connectorDefinitionName": "PRODAFTUstaATPCCPDefinition",
