{
  "type": "Microsoft.SecurityInsights/dataConnectors",
  "apiVersion": "2024-09-01",
  "name": "[[concat('parameters('workspace')', '/Microsoft.SecurityInsights/','AkamaiSIEMEvent' , uniqueString(parameters('configId')) )]",
  "location": "{{location}}",
  "kind": "RestApiPoller",
  "properties": {
    "auth": {
      "type": "EdgeGrid",
      "ClientToken": "[[parameters('clientToken')]",
      "AccessToken": "[[parameters('accessToken')]",
      "ClientSecret": "[[parameters('clientSecret')]"
    },
    "request": {
      "apiEndpoint": "[[concat('https://', parameters('akamaiHost'), '/siem/v1/configs/', replace(parameters('configId'), ';', '%3B'))]",
      "httpMethod": "GET",
      "rateLimitQPS": 1,
      "queryWindowInMin": 5,
      "queryTimeFormat": "UnixTimestamp",
      "retryCount": 3,
      "timeoutInSeconds": 120,
      "headers": {
        "Accept": "application/json"
      },
      "queryParameters": {
        "from": "{_QueryWindowStartTime}",
        "to": "{_QueryWindowEndTime}"
      }
    },
    "response": {
      "eventsJsonPaths": [
        "$"
      ],
      "format": "json"
    },
    "paging": {
      "pagingType": "NextPageToken",
      "nextPageTokenJsonPath": "$.offset",
      "NextPageParaName": "offset",
      "hasNextFlagJsonPath": "$.total",
      "pageSize": 500,
      "pageSizeParameterName": "limit"
    },
    "connectorDefinitionName": "AkamaiSIEMConnector",
    "dataType": "AkamaiSIEMEvent",
    "dcrConfig": {
      "streamName": "Custom-AkamaiSIEMEvent_CL",
      "dataCollectionEndpoint": "{{dataCollectionEndpoint}}",
      "dataCollectionRuleImmutableId": "{{dataCollectionRuleImmutableId}}"
    },
    "addOnAttributes": {
      "configId": "[[parameters('configId')]",
      "akamaiHost": "[[parameters('akamaiHost')]"
    }
  }
}