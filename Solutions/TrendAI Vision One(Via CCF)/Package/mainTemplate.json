      "properties": {
        "displayName": "TrendAI Vision One - OAT Detections Connector",
        "description": "Template spec for TrendAI OAT data connector connections"
      }
    },
    {
      "type": "Microsoft.Resources/templateSpecs/versions",
      "apiVersion": "2022-02-01",
      "name": "[concat(variables('oatConnectionsTemplateName'), '/', variables('dataConnectorCCPVersion'))]",
      "location": "[parameters('workspace-location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Resources/templateSpecs', variables('oatConnectionsTemplateName'))]",
        "[resourceId('Microsoft.Insights/dataCollectionEndpoints', variables('dceName'))]",
        "[resourceId('Microsoft.Insights/dataCollectionRules', variables('oatDcrName'))]"
      ],
      "tags": {
        "hidden-sentinelWorkspaceId": "[variables('workspaceResourceId')]",
        "hidden-sentinelContentType": "DataConnector"
      },
      "properties": {
        "mainTemplate": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "[variables('dataConnectorCCPVersion')]",
          "parameters": {
            "connectorDefinitionName": {"defaultValue": "TrendAIVisionOneOAT", "type": "string"},
            "workspace": {"defaultValue": "[parameters('workspace')]", "type": "string"},
            "dcrConfig": {
              "type": "object",
              "defaultValue": {
                "dataCollectionEndpoint": "[reference(resourceId('Microsoft.Insights/dataCollectionEndpoints', variables('dceName')), '2024-03-11').logsIngestion.endpoint]",
                "dataCollectionRuleImmutableId": "[reference(resourceId('Microsoft.Insights/dataCollectionRules', variables('oatDcrName')), '2024-03-11').immutableId]"
              }
            },
            "apiDomain": {"type": "string", "minLength": 1, "defaultValue": "api.xdr.trendmicro.com"},
            "apiToken": {"type": "securestring", "minLength": 1},
            "oatFilter": {"type": "string", "defaultValue": ""},
            "excludeThirdPartyOat": {"type": "string", "defaultValue": "false"}
          },
          "variables": {},
          "resources": [
            {
              "name": "[[concat(parameters('workspace'), '/Microsoft.SecurityInsights/TrendAIOAT-', uniqueString(parameters('apiDomain')))]",
              "apiVersion": "2023-02-01-preview",
              "type": "Microsoft.OperationalInsights/workspaces/providers/dataConnectors",
              "location": "[parameters('workspace-location')]",
              "kind": "RestApiPoller",
              "properties": {
                "connectorDefinitionName": "[[parameters('connectorDefinitionName')]",
                "dataType": "TrendAI_XDR_OAT_V2_CL",
                "dcrConfig": {
                  "streamName": "Custom-TrendAI_XDR_OAT_V2_CL",
                  "dataCollectionEndpoint": "[[parameters('dcrConfig').dataCollectionEndpoint]",
                  "dataCollectionRuleImmutableId": "[[parameters('dcrConfig').dataCollectionRuleImmutableId]"
                },
                "auth": {
                  "type": "APIKey",
                  "ApiKey": "[[concat('Bearer ', parameters('apiToken'))]",
                  "ApiKeyName": "Authorization"
                },
                "request": {
                  "apiEndpoint": "[[concat('https://', parameters('apiDomain'), '/v3.0/oat/detections')]",
                  "rateLimitQPS": 10,
                  "queryWindowInMin": 5,
                  "httpMethod": "GET",
                  "queryTimeFormat": "yyyy-MM-ddTHH:mm:ssZ",
                  "startTimeAttributeName": "detectedStartDateTime",
                  "endTimeAttributeName": "detectedEndDateTime",
                  "retryCount": 3,
                  "timeoutInSeconds": 60,
                  "headers": "[[if(empty(parameters('oatFilter')), createObject('Accept', 'application/json'), createObject('Accept', 'application/json', 'TMV1-Filter', parameters('oatFilter')))]",
                  "queryParameters": "[[if(equals(parameters('excludeThirdPartyOat'), 'true'), createObject('top', '500'), createObject('top', '500'))]"
                },
                "response": {"eventsJsonPaths": ["$.items"], "format": "json"},
                "paging": {"pagingType": "LinkHeader", "linkHeaderTokenJsonPath": "$.nextLink"}
              }
            }
          ]
        }
      }
    },
    {
      "type": "Microsoft.OperationalInsights/workspaces/providers/dataConnectorDefinitions",
      "apiVersion": "2024-09-01",
      "name": "[concat(parameters('workspace'), '/Microsoft.SecurityInsights/', variables('workbenchConnectorId'))]",
      "location": "[parameters('workspace-location')]",
      "kind": "Customizable",
      "dependsOn": [
        "[resourceId('Microsoft.Insights/dataCollectionRules', variables('workbenchDcrName'))]",
        "[resourceId('Microsoft.Insights/dataCollectionEndpoints', variables('dceName'))]",
        "[resourceId('Microsoft.Resources/templateSpecs/versions', variables('workbenchConnectionsTemplateName'), variables('dataConnectorCCPVersion'))]"
      ],
      "properties": {
        "connectorUiConfig": {
          "id": "[variables('workbenchConnectorId')]",
          "title": "TrendAI Vision One™ - Workbench Alerts (via Codeless Connector Framework)",
          "publisher": "TrendAI",
          "logo": "[variables('logo')]",
          "descriptionMarkdown": "The [TrendAI Vision One™](https://www.trendmicro.com/en_us/business/products/detection-response/xdr.html) Workbench data connector ingests security alerts from the TrendAI Vision One™ into Microsoft Sentinel.",
          "graphQueriesTableName": "[variables('workbenchTableName')]",
          "graphQueries": [{
            "metricName": "Total Workbench alerts received",
            "legend": "TrendAI Vision One™ Workbench Alerts",
            "baseQuery": "[variables('workbenchTableName')]"
          }],
          "sampleQueries": [
            {"description": "Get sample of Workbench alerts", "query": "[concat(variables('workbenchTableName'), ' | take 10')]"},
            {"description": "High and critical severity alerts", "query": "[concat(variables('workbenchTableName'), ' | where severity_s in (''high'', ''critical'') | project TimeGenerated, workbenchId_s, workbenchName_s, severity_s, priorityScore_d')]"}
          ],
          "dataTypes": [{
            "name": "[variables('workbenchTableName')]",
            "lastDataReceivedQuery": "[concat(variables('workbenchTableName'), ' | where TimeGenerated > ago(12h) | summarize Time = max(TimeGenerated) | where isnotempty(Time)')]"
          }],
          "connectivityCriteria": [{"type": "HasDataConnectors"}],
          "availability": {"status": 1, "isPreview": false},
          "permissions": {
            "resourceProvider": [{
              "provider": "Microsoft.OperationalInsights/workspaces",
              "permissionsDisplayText": "Read and Write permissions are required.",
              "providerDisplayName": "Workspace",
              "scope": "Workspace",
              "requiredPermissions": {"read": true, "write": true, "delete": true}
            }]
          },
          "instructionSteps": [{
            "instructions": [
              {"type": "Markdown", "parameters": {"content": "#### 1. Retrieve your TrendAI Vision One™ API Token\n1. Log in to the TrendAI Vision One™ Console.\n2. Navigate to **Administration → API Keys**.\n3. Click **Generate New API Key**, select the **SIEM** role, and copy the token."}},
              {"type": "Markdown", "parameters": {"content": "#### 2. Select your TrendAI Vision One™ Region\nChoose the API domain that matches the region where your TrendAI Vision One™ tenant is hosted:\n- **US:** `api.xdr.trendmicro.com`\n- **EU:** `api.eu.xdr.trendmicro.com`\n- **SG:** `api.sg.xdr.trendmicro.com`\n- **JP:** `api.xdr.trendmicro.co.jp` / `api.jp.xdr.trendmicro.co.jp`\n- **AU:** `api.au.xdr.trendmicro.com`\n- **IN:** `api.in.xdr.trendmicro.com`\n- **MEA:** `api.mea.xdr.trendmicro.com`\n- **UK:** `api.uk.xdr.trendmicro.com`\n- **CA:** `api.ca.xdr.trendmicro.com`\n- **ZA (South Africa):** `api.za.xdr.trendmicro.com`"}},
              {"type": "Textbox", "parameters": {"label": "API Domain", "placeholder": "api.xdr.trendmicro.com", "type": "text", "name": "apiDomain", "required": true}},
              {"type": "Textbox", "parameters": {"label": "API Token", "placeholder": "Paste your TrendAI Vision One™ API token here", "type": "password", "name": "apiToken", "required": true}},
              {"type": "Textbox", "parameters": {"label": "TMV1-Filter (Optional)", "placeholder": "investigationStatus eq 'New' and contains(impactScopeEntityValue,'nimda')", "type": "text", "name": "workbenchFilter", "required": false}},
              {"type": "ConnectionToggleButton", "parameters": {"label": "toggle", "name": "toggle"}}
            ]
          }]
        },
        "connectionsConfig": {
          "templateSpecName": "[resourceId('Microsoft.Resources/templateSpecs', variables('workbenchConnectionsTemplateName'))]",
          "templateSpecVersion": "[variables('dataConnectorCCPVersion')]"
        }
      }
    },
    {
      "type": "Microsoft.OperationalInsights/workspaces/providers/dataConnectorDefinitions",
      "apiVersion": "2024-09-01",
      "name": "[concat(parameters('workspace'), '/Microsoft.SecurityInsights/', variables('oatConnectorId'))]",
      "location": "[parameters('workspace-location')]",
      "kind": "Customizable",
      "dependsOn": [
        "[resourceId('Microsoft.Insights/dataCollectionRules', variables('oatDcrName'))]",
        "[resourceId('Microsoft.Insights/dataCollectionEndpoints', variables('dceName'))]",
        "[resourceId('Microsoft.Resources/templateSpecs/versions', variables('oatConnectionsTemplateName'), variables('dataConnectorCCPVersion'))]"
      ],
      "properties": {
        "connectorUiConfig": {
          "id": "[variables('oatConnectorId')]",
          "title": "TrendAI Vision One™ - OAT Detections (via Codeless Connector Framework)",
          "publisher": "TrendAI",
          "logo": "[variables('logo')]",
          "descriptionMarkdown": "The [TrendAI Vision One™](https://www.trendmicro.com/en_us/business/products/detection-response/xdr.html) OAT data connector ingests Observed Attack Techniques (OAT) detections from the TrendAI Vision One™ into Microsoft Sentinel. Detections include full process trees, file hashes, network indicators, and MITRE ATT&CK mappings.",
          "graphQueriesTableName": "[variables('oatTableName')]",
          "graphQueries": [{
            "metricName": "Total OAT detections received",
            "legend": "TrendAI Vision One™ OAT Detections",
            "baseQuery": "[variables('oatTableName')]"
          }],
          "sampleQueries": [
            {"description": "Get sample of OAT detections", "query": "[concat(variables('oatTableName'), ' | take 10')]"},
            {"description": "High risk detections", "query": "[concat(variables('oatTableName'), ' | where detail_filterRiskLevel_s == ''high'' | project TimeGenerated, detail_endpointHostName_s, detail_processCmd_s')]"}
          ],
          "dataTypes": [{
            "name": "[variables('oatTableName')]",
            "lastDataReceivedQuery": "[concat(variables('oatTableName'), ' | where TimeGenerated > ago(12h) | summarize Time = max(TimeGenerated) | where isnotempty(Time)')]"
          }],
          "connectivityCriteria": [{"type": "HasDataConnectors"}],
          "availability": {"status": 1, "isPreview": false},
          "permissions": {
            "resourceProvider": [{
              "provider": "Microsoft.OperationalInsights/workspaces",
              "permissionsDisplayText": "Read and Write permissions are required.",
              "providerDisplayName": "Workspace",
              "scope": "Workspace",
              "requiredPermissions": {"read": true, "write": true, "delete": true}
            }]
          },
          "instructionSteps": [{
            "instructions": [
              {"type": "Markdown", "parameters": {"content": "#### 1. Retrieve your TrendAI Vision One™ API Token\n1. Log in to the TrendAI Vision One™ Console.\n2. Navigate to **Administration → API Keys**.\n3. Click **Generate New API Key**, select the **SIEM** role, and copy the token."}},
              {"type": "Markdown", "parameters": {"content": "#### 2. Select your TrendAI Vision One™ Region\nChoose the API domain that matches the region where your TrendAI Vision One™ tenant is hosted:\n- **US:** `api.xdr.trendmicro.com`\n- **EU:** `api.eu.xdr.trendmicro.com`\n- **SG:** `api.sg.xdr.trendmicro.com`\n- **JP:** `api.xdr.trendmicro.co.jp` / `api.jp.xdr.trendmicro.co.jp`\n- **AU:** `api.au.xdr.trendmicro.com`\n- **IN:** `api.in.xdr.trendmicro.com`\n- **MEA:** `api.mea.xdr.trendmicro.com`\n- **UK:** `api.uk.xdr.trendmicro.com`\n- **CA:** `api.ca.xdr.trendmicro.com`\n- **ZA (South Africa):** `api.za.xdr.trendmicro.com`"}},
              {"type": "Textbox", "parameters": {"label": "API Domain", "placeholder": "api.xdr.trendmicro.com", "type": "text", "name": "apiDomain", "required": true}},
              {"type": "Textbox", "parameters": {"label": "API Token", "placeholder": "Paste your TrendAI Vision One™ API token here", "type": "password", "name": "apiToken", "required": true}},
              {"type": "Textbox", "parameters": {"label": "TMV1-Filter (Optional)", "placeholder": "(riskLevel eq 'high') and (endpointName eq 'my-computer')", "type": "text", "name": "oatFilter", "required": false}},
              {"type": "Textbox", "parameters": {"label": "Exclude third-party OAT detections (productCode == 'tlc')", "type": "boolean", "name": "excludeThirdPartyOat", "required": false}},
              {"type": "ConnectionToggleButton", "parameters": {"label": "toggle", "name": "toggle"}}
            ]
          }]
        },
        "connectionsConfig": {
          "templateSpecName": "[resourceId('Microsoft.Resources/templateSpecs', variables('oatConnectionsTemplateName'))]",
          "templateSpecVersion": "[variables('dataConnectorCCPVersion')]"
        }
      }
    },
    {
      "type": "Microsoft.OperationalInsights/workspaces/savedSearches",
      "apiVersion": "2025-02-01",
      "name": "[concat(parameters('workspace'), '/', variables('parserName1'))]",
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces/tables', parameters('workspace'), variables('workbenchTableName'))]"
      ],
      "properties": {
        "etag": "*",
        "displayName": "TrendAI Workbench Complete Parser",
        "category": "TrendAI",
        "functionAlias": "[variables('parserName1')]",
        "query": "union isfuzzy=true (TrendMicro_XDR_WORKBENCH_CL | extend source_table = 'legacy'), (TrendAI_XDR_WORKBENCH_V2_CL | extend source_table = 'ccf' | extend indicators_parsed = todynamic(indicators_s) | mv-expand indicator = indicators_parsed | extend indicatorType = tostring(indicator.type), indicatorValue = tostring(indicator.value) | extend FileName_s = iff(indicatorType == 'file_name', indicatorValue, '') | extend FileHashValue_s = iff(indicatorType in ('file_sha1', 'file_sha256', 'file_md5'), indicatorValue, '') | extend DomainName_s = iff(indicatorType == 'domain', indicatorValue, '') | extend FileDirectory_s = iff(indicatorType == 'fullpath', indicatorValue, '') | extend IPAddress = iff(indicatorType == 'ip', indicatorValue, '') | extend URL_s = iff(indicatorType == 'url', indicatorValue, '') | extend ProcessCommandLine_s = iff(indicatorType == 'command_line', indicatorValue, '') | extend RegistryKey_s = iff(indicatorType == 'registry', indicatorValue, '') | extend MalwareName_s = iff(indicatorType == 'malware_name', indicatorValue, '') | extend entities_parsed = todynamic(impactScope_s) | mv-expand entity = entities_parsed.entities | extend entityType = tostring(entity.entityType) | extend HostHostName_s = iff(entityType in ('host', 'endpoint'), tostring(entity.entityValue.name), '') | extend UserAccountName_s = iff(entityType == 'account', tostring(entity.entityValue.name), '') | extend UserAccountNTDomain_s = iff(entityType == 'account', tostring(entity.entityValue.domain), '') | extend MailboxPrimaryAddress_s = iff(entityType == 'emailAddress', tostring(entity.entityValue.emailAddress), '') | summarize FileName_s = make_set_if(FileName_s, isnotempty(FileName_s)), FileHashValue_s = make_set_if(FileHashValue_s, isnotempty(FileHashValue_s)), DomainName_s = make_set_if(DomainName_s, isnotempty(DomainName_s)), FileDirectory_s = make_set_if(FileDirectory_s, isnotempty(FileDirectory_s)), IPAddress = make_set_if(IPAddress, isnotempty(IPAddress)), URL_s = make_set_if(URL_s, isnotempty(URL_s)), ProcessCommandLine_s = make_set_if(ProcessCommandLine_s, isnotempty(ProcessCommandLine_s)), RegistryKey_s = make_set_if(RegistryKey_s, isnotempty(RegistryKey_s)), MalwareName_s = make_set_if(MalwareName_s, isnotempty(MalwareName_s)), HostHostName_s = make_set_if(HostHostName_s, isnotempty(HostHostName_s)), UserAccountName_s = make_set_if(UserAccountName_s, isnotempty(UserAccountName_s)), UserAccountNTDomain_s = make_set_if(UserAccountNTDomain_s, isnotempty(UserAccountNTDomain_s)), MailboxPrimaryAddress_s = make_set_if(MailboxPrimaryAddress_s, isnotempty(MailboxPrimaryAddress_s)), source_table = any(source_table) by TimeGenerated, workbenchId_s, workbenchName_s, severity_s, priorityScore_d, description_s, workbenchLink_s, alertProvider_s, model_s, modelId_s, modelType_s, investigationStatus_s, alertStatus_s, investigationResult_s, createdTime_t, updatedTime_t, xdrCustomerID_g, impactScope_Summary_s, indicators_s, matchedRules_s)",
        "functionParameters": "",
        "version": 2
      }
    },
    {
      "type": "Microsoft.OperationalInsights/workspaces/savedSearches",
      "apiVersion": "2025-02-01",
      "name": "[concat(parameters('workspace'), '/', variables('parserName2'))]",
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces/tables', parameters('workspace'), variables('oatTableName'))]"
      ],
      "properties": {
        "etag": "*",
        "displayName": "TrendAI OAT Complete Parser",
        "category": "TrendAI",
        "functionAlias": "[variables('parserName2')]",
        "query": "union isfuzzy=true (TrendMicro_XDR_OAT_CL | extend source_table = 'legacy'), (TrendAI_XDR_OAT_V2_CL | extend source_table = 'ccf')",
        "functionParameters": "",
        "version": 2
      }
    },
    {
      "type": "Microsoft.OperationalInsights/workspaces/providers/contentPackages",
      "apiVersion": "2023-04-01-preview",
      "name": "[concat(parameters('workspace'), '/Microsoft.SecurityInsights/', variables('_solutionId'))]",
      "location": "[parameters('workspace-location')]",
      "properties": {
        "version": "[variables('_solutionVersion')]",
        "kind": "Solution",
        "contentSchemaVersion": "3.0.0",
        "displayName": "TrendAI Vision One",
        "publisherDisplayName": "TrendAI",
        "descriptionHtml": "<p>The TrendAI Vision One solution for Microsoft Sentinel provides two data connectors that ingest security data from the TrendAI Vision One platform using the Codeless Connector Framework (CCF):</p><ul><li><strong>Workbench Alerts</strong> – Security incidents, investigations, and alerts with IOC extraction</li><li><strong>OAT Detections</strong> – MITRE ATT&CK mapped detections with full process trees</li></ul><p>This solution also includes KQL parser functions, an analytic rule, and a workbook dashboard for Workbench Alerts.</p>",
        "contentKind": "Solution",
        "contentProductId": "[variables('_solutioncontentProductId')]",
        "id": "[variables('_solutioncontentProductId')]",
        "icon": "[variables('logo')]",
        "contentId": "[variables('_solutionId')]",
        "parentId": "[variables('_solutionId')]",
        "source": {
          "kind": "Solution",
          "name": "TrendAI Vision One",
          "sourceId": "[variables('_solutionId')]"
        },
        "author": {
          "name": "TrendAI",
          "email": "[variables('_email')]"
        },
        "support": {
          "name": "TrendAI",
          "tier": "Partner",
          "link": "https://success.trendmicro.com/"
        },
        "dependencies": {
          "criteria": [
            {"kind": "DataConnector", "contentId": "[variables('workbenchConnectorId')]", "version": "[variables('_solutionVersion')]"},
            {"kind": "DataConnector", "contentId": "[variables('oatConnectorId')]", "version": "[variables('_solutionVersion')]"},
            {"kind": "Parser", "contentId": "[variables('parserName1')]", "version": "[variables('_solutionVersion')]"},
            {"kind": "Parser", "contentId": "[variables('parserName2')]", "version": "[variables('_solutionVersion')]"}
          ]
        },
        "categories": {
          "domains": ["Security - Threat Protection"]
        }
      }
    }
  ],
  "outputs": {
    "dceEndpoint": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Insights/dataCollectionEndpoints', variables('dceName'))).logsIngestion.endpoint]"
    },
    "workbenchDcrImmutableId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Insights/dataCollectionRules', variables('workbenchDcrName'))).immutableId]"
    },
    "oatDcrImmutableId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Insights/dataCollectionRules', variables('oatDcrName'))).immutableId]"
    }
  }
}
