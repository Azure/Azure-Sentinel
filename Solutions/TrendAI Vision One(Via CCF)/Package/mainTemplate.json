    {
      "type": "Microsoft.Resources/templateSpecs/versions",
      "apiVersion": "2022-02-01",
      "name": "[concat(variables('workbenchConnectionsTemplateName'), '/', variables('dataConnectorCCPVersion'))]",
      "location": "[parameters('workspace-location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Resources/templateSpecs', variables('workbenchConnectionsTemplateName'))]",
        "[resourceId('Microsoft.Insights/dataCollectionEndpoints', variables('dceName'))]",
        "[resourceId('Microsoft.Insights/dataCollectionRules', variables('workbenchDcrName'))]"
      ],
      "tags": {
        "hidden-sentinelWorkspaceId": "[variables('workspaceResourceId')]",
