{
  "name": "TrendAIVisionOneWorkbench",
  "apiVersion": "2024-01-01-preview",
  "type": "Microsoft.SecurityInsights/dataConnectorDefinitions",
  "kind": "Customizable",
  "properties": {
    "connectorUiConfig": {
      "id": "TrendAIVisionOneWorkbench",
      "title": "TrendAI Vision One™ - Workbench Alerts (via Codeless Connector Framework)",
      "publisher": "TrendAI",
      "logo": "data:image/svg+xml;base64,",
      "descriptionMarkdown": "The [TrendAI Vision One™](https://www.trendmicro.com/en_us/business/products/detection-response/xdr.html) Workbench data connector ingests security alerts from the TrendAI Vision One™ into Microsoft Sentinel.",
      "graphQueries": [
        {
          "metricName": "Total Workbench alerts received",
          "legend": "TrendAI Vision One™ Workbench Alerts",
          "baseQuery": "TrendAI_XDR_WORKBENCH_V2_CL"
        }
      ],
      "sampleQueries": [
        {
          "description": "Get sample of Workbench alerts",
          "query": "TrendAI_XDR_WORKBENCH_V2_CL | take 10"
        },
        {
          "description": "High and critical severity alerts",
          "query": "TrendAI_XDR_WORKBENCH_V2_CL | where severity_s in ('high', 'critical') | project TimeGenerated, workbenchId_s, workbenchName_s, severity_s, priorityScore_d"
        }
      ],
      "dataTypes": [
        {
          "name": "TrendAI_XDR_WORKBENCH_V2_CL",
          "lastDataReceivedQuery": "TrendAI_XDR_WORKBENCH_V2_CL\n | where TimeGenerated > ago(12h) | summarize Time = max(TimeGenerated)\n | where isnotempty(Time)"
        }
      ],
      "connectivityCriteria": [
        {
          "type": "HasDataConnectors"
        }
      ],
      "availability": {
        "status": 1,
        "isPreview": false
      },
      "permissions": {
        "resourceProvider": [
          {
            "provider": "Microsoft.OperationalInsights/workspaces",
            "permissionsDisplayText": "Read and Write permissions are required.",
            "providerDisplayName": "Workspace",
            "scope": "Workspace",
            "requiredPermissions": {
              "read": true,
              "write": true,
              "delete": true,
              "action": false
            }
          }
        ]
      },
      "instructionSteps": [
        {
          "instructions": [
            {
              "type": "Markdown",
              "parameters": {
                "content": "#### 1. Retrieve your TrendAI Vision One™ API Token\n1. Log in to the TrendAI Vision One™ Console.\n2. Navigate to **Administration → API Keys**.\n3. Click **Generate New API Key**, select the **SIEM** role, and copy the token."
              }
            },
            {
              "type": "Markdown",
              "parameters": {
                "content": "#### 2. Select your TrendAI Vision One™ Region\nChoose the API domain that matches the region where your TrendAI Vision One™ tenant is hosted:\n- **US:** `api.xdr.trendmicro.com`\n- **EU:** `api.eu.xdr.trendmicro.com`\n- **SG:** `api.sg.xdr.trendmicro.com`\n- **JP:** `api.xdr.trendmicro.co.jp` / `api.jp.xdr.trendmicro.co.jp`\n- **AU:** `api.au.xdr.trendmicro.com`\n- **IN:** `api.in.xdr.trendmicro.com`\n- **MEA:** `api.mea.xdr.trendmicro.com`\n- **UK:** `api.uk.xdr.trendmicro.com`\n- **CA:** `api.ca.xdr.trendmicro.com`\n- **ZA (South Africa):** `api.za.xdr.trendmicro.com`"
              }
            },
            {
              "parameters": {
                "label": "API Domain",
                "placeholder": "api.xdr.trendmicro.com",
                "type": "text",
                "name": "apiDomain",
                "required": true
              },
              "type": "Textbox"
            },
            {
              "parameters": {
                "label": "API Token",
                "placeholder": "Paste your TrendAI Vision One™ API token here",
                "type": "password",
                "name": "apitoken",
                "required": true
              },
              "type": "Textbox"
            },
            {
              "parameters": {
                "label": "TMV1-Filter (Optional)",
                "placeholder": "investigationStatus eq ‘New’ and contains(impactScopeEntityValue,’nimda’)",
                "type": "text",
                "name": "workbenchFilter",
                "required": false
              },
              "type": "Textbox"
            },
            {
              "parameters": {
                "label": "toggle",
                "name": "toggle"
              },
              "type": "ConnectionToggleButton"
            }
          ]
        }
      ],
      "isConnectivityCriteriasMatchSome": false
    }
  }
}
