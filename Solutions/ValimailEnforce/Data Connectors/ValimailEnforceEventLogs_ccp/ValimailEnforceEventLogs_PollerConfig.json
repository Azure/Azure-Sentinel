[
  {
    "name": "ValimailReportingAPI",
    "apiVersion": "2025-09-01",
    "type": "Microsoft.SecurityInsights/dataConnectors",
    "kind": "RestApiPoller",
    "properties": {
      "connectorDefinitionName": "ValimailEnforceEventsConnector",
      "dcrConfig": {
        "streamName": "Custom-ValimailReporting_API"
      },
      "auth": {
        "type": "JwtToken",
        "userName": {
          "key": "client-id",
          "value": "[[parameters('clientid')]"
        },
        "password": {
          "key": "app-id",
          "value": "[[parameters('appid')]"
        },
        "TokenEndpoint": "https://atlas-api.vali-prod.net/auth",
        "Headers": {
          "Accept": "application/json",
          "Content-Type": "application/json"
        },
        "IsCredentialsInHeaders": false,
        "IsJsonRequest": true,
        "JwtTokenJsonPath": "$.token"
      },
      "request": {
        "apiEndpoint": "[[concat('https://atlas-api.vali-prod.net/accounts/', parameters('accountslug'), '/reports/events')]",
        "rateLimitQPS": 10,
        "queryWindowInMin": 5,
        "httpMethod": "GET",
        "queryTimeFormat": "yyyy-MM-ddTHH:mm:ssZ",
        "StartTimeAttributeName": "start-date",
        "EndTimeAttributeName": "end-date",
        "queryParameters": {
          "reverse": "false",
          "per-page": "100"
        },
        "retryCount": 3,
        "timeoutInSeconds": 60,
        "headers": {
          "Accept": "application/json"
        }
      },
      "paging": {
        "pagingType": "CountBasedPaging",
        "pageNumberParaName": "page",
        "PagingInfoPlacement": "QueryString",
        "pageSize": 100,
        "zeroBasedIndexing": false
      },
      "response": {
        "eventsJsonPaths": ["$"],
        "format": "json"
      }
    }
  }
]
