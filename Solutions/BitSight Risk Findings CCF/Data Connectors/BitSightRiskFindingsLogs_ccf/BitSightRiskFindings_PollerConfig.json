[
  {
    "name": "BitSightRiskFindingsPoller",
    "apiVersion": "2023-02-01-preview",
    "type": "Microsoft.SecurityInsights/dataConnectors",
    "kind": "RestApiPoller",
    "properties": {
      "connectorDefinitionName": "BitSightRiskFindingsCCFDefinition",
      "dataType": "BitsightRiskFindings_CL",
      "dcrConfig": {
        "streamName": "Custom-BitsightRiskFindingsRaw"
      },
      "auth": {
        "type": "APIKey",
        "ApiKey": "[[base64(concat(parameters('apiToken'), ':'))]",
        "ApiKeyName": "Authorization",
        "ApiKeyIdentifier": "Basic"
      },
      "request": {
        "apiEndpoint": "[[concat('https://api.bitsighttech.com/ratings/v1/companies/', parameters('companyGuid'), '/findings')]",
        "httpMethod": "GET",
        "queryWindowInMin": 2,
        "rateLimitQPS": 5,
        "paginatedCallsPerSecond": 5,
        "retryCount": 3,
        "timeoutInSeconds": 60,
        "headers": {
          "Accept": "application/json",
          "User-Agent": "Sentinel-CCF-Bitsight-Connector"
        },
        "queryParameters": {
          "limit": 100,
          "expand": "remediation_history,tag_details,attributed_companies"
        }
      },
      "response": {
        "eventsJsonPaths": [
          "$.results"
        ],
        "format": "json"
      },
      "paging": {
        "pagingType": "LinkHeader",
        "linkHeaderTokenJsonPath": "$.links.next",
        "pageSize": 100,
        "pageSizeParameterName": "limit",
        "pagingInfoPlacement": "QueryString"
      }
    }
  }
]