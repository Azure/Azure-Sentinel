{
  "type": "Microsoft.SecurityInsights/dataConnectors",
  "apiVersion": "2022-10-01-preview",
  "name": "[[concat('parameters('workspace')', '/Microsoft.SecurityInsights/','CyberSixgillAlertsV2_CL' , uniqueString(parameters('organizationId')) )]",
  "location": "{{location}}",
  "kind": "RestApiPoller",
  "properties": {
    "auth": {
      "type": "OAuth2",
      "ClientId": "[[parameters('clientId')]",
      "ClientSecret": "[[parameters('clientSecret')]",
      "GrantType": "client_credentials",
      "TokenEndpoint": "[[concat(parameters('baseUrl'), '/auth/token')]"
    },
    "request": {
      "apiEndpoint": "[[concat(parameters('baseUrl'), '/alerts/actionable-alert')]",
      "httpMethod": "GET",
      "rateLimitQPS": 5,
      "paginatedCallsPerSecond": 5.0,
      "queryWindowInMin": 30,
      "queryTimeFormat": "yyyy-MM-dd HH:mm:ss",
      "retryCount": 3,
      "timeoutInSeconds": 30,
      "headers": {
        "Content-Type": "application/json",
        "Accept": "application/json",
        "x-channel-id": "cea9a52effad4bc5e905a5a653f5cf9b"
      },
      "queryParameters": {
        "sort_order": "asc",
        "limit": "100",
        "organization_id": "[[parameters('organizationId')]"
      },
      "startTimeAttributeName": "from_date",
      "endTimeAttributeName": "to_date"
    },
    "response": {
      "eventsJsonPaths": [
        "$[*]"
      ],
      "format": "json"
    },
    "paging": {
      "pagingType": "Offset",
      "offsetParaName": "offset",
      "pageSize": 100,
      "pageSizeParameterName": "fetch_size",
      "initialCheckpointTimeUtc": "2026-05-01T00:00:00Z"
    },
    "stepInfo": {
      "stepType": "Nested",
      "nextSteps": [
        {
          "stepId": "alert_detail",
          "stepPlaceholdersParsingKql": "source | mv-expand res = parse_json(data) | project id_placeholder = tostring(res.id)"
        }
      ]
    },
    "stepCollectorConfigs": {
      "alert_detail": {
        "request": {
          "apiEndpoint": "[[concat(parameters('baseUrl'), '/alerts/actionable_alert/$id_placeholder$')]",
          "httpMethod": "GET",
          "rateLimitQPS": 5,
          "queryWindowInMin": 5,
          "retryCount": 3,
          "timeoutInSeconds": 30,
          "logResponseContent": true,
          "headers": {
            "Content-Type": "application/json",
            "Accept": "application/json",
            "x-channel-id": "cea9a52effad4bc5e905a5a653f5cf9b"
          },
          "queryParameters": {
            "organization_id": "[[parameters('organizationId')]"
          }
        },
        "response": {
          "eventsJsonPaths": [
            "$"
          ],
          "format": "json"
        }
      }
    },
    "connectorDefinitionName": "CybersixgillAlertsCCFConnector",
    "dataType": "CyberSixgillAlertsV2_CL",
    "dcrConfig": {
      "streamName": "Custom-CyberSixgillAlertsV2_CL",
      "dataCollectionEndpoint": "{{dataCollectionEndpoint}}",
      "dataCollectionRuleImmutableId": "{{dataCollectionRuleImmutableId}}"
    },
    "addOnAttributes": {
      "organizationId": "[[parameters('organizationId')]",
      "baseUrl": "[[parameters('baseUrl')]"
    }
  }
}