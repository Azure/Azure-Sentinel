{
  "name": "InfobloxSOCInsightsDCR",
  "apiVersion": "2023-04-01-preview",
  "type": "Microsoft.Insights/dataCollectionRules",
  "location": "{{location}}",
  "properties": {
    "dataCollectionEndpointId": "{{dataCollectionEndpointId}}",
    "streamDeclarations": {
      "Custom-InfobloxInsight_CL": {
        "columns": [
          {
            "name": "insightId",
            "type": "string"
          },
          {
            "name": "dateChanged",
            "type": "datetime"
          },
          {
            "name": "eventsNotBlockedCount",
            "type": "string"
          },
          {
            "name": "feedSource",
            "type": "string"
          },
          {
            "name": "mostRecentAt",
            "type": "datetime"
          },
          {
            "name": "numEvents",
            "type": "string"
          },
          {
            "name": "priorityText",
            "type": "string"
          },
          {
            "name": "startedAt",
            "type": "datetime"
          },
          {
            "name": "status",
            "type": "string"
          },
          {
            "name": "tClass",
            "type": "string"
          },
          {
            "name": "tFamily",
            "type": "string"
          },
          {
            "name": "threatType",
            "type": "string"
          },
          {
            "name": "eventsBlockedCount",
            "type": "string"
          },
          {
            "name": "friendlyName",
            "type": "string"
          },
          {
            "name": "tenantHost",
            "type": "string"
          }
        ]
      }
    },
    "destinations": {
      "logAnalytics": [
        {
          "workspaceResourceId": "{{workspaceResourceId}}",
          "name": "clv2ws1"
        }
      ]
    },
    "dataFlows": [
      {
        "streams": [
          "Custom-InfobloxInsight_CL"
        ],
        "destinations": [
          "clv2ws1"
        ],
        "outputStream": "Custom-InfobloxInsight_CL",
        "transformKql": "source  | project TimeGenerated=iff(isnull(startedAt),now(),todatetime(startedAt)),InsightId=tostring(insightId),DateChanged=todatetime(dateChanged),EventsNotBlockedCount=tostring(eventsNotBlockedCount),FeedSource=tostring(feedSource),MostRecentAt=todatetime(mostRecentAt),NumEvents=tostring(numEvents),PriorityText=tostring(priorityText),StartedAt=todatetime(startedAt),Status=tostring(status),TClass=tostring(tClass),TFamily=tostring(tFamily),ThreatType=tostring(threatType),EventsBlockedCount=tostring(eventsBlockedCount),ConnectorName=tostring(friendlyName),TenantHost=tostring(tenantHost)"
      }
    ]
  }
}