{
  "type": "Microsoft.SecurityInsights/dataConnectors",
  "apiVersion": "2025-03-01",
  "name": "[[concat('parameters('workspace')', '/Microsoft.SecurityInsights/','InfobloxInsight' , uniqueString(parameters('friendlyName')) )]",
  "location": "{{location}}",
  "kind": "RestApiPoller",
  "properties": {
    "auth": {
      "type": "APIKey",
      "ApiKey": "[[parameters('apiKey')]",
      "ApiKeyName": "Authorization",
      "ApiKeyIdentifier": "Token"
    },
    "request": {
      "apiEndpoint": "[[concat(parameters('infobloxApiUrl'),'/api/v1/insights')]",
      "httpMethod": "GET",
      "rateLimitQPS": 1,
      "queryWindowInMin": 1440,
      "retryCount": 3,
      "timeoutInSeconds": 90,
      "headers": {
        "Content-Type": "application/json",
        "Accept": "application/json"
      }
    },
    "response": {
      "eventsJsonPaths": [
        "$.insightList[*]"
      ],
      "format": "json"
    },
    "connectorDefinitionName": "InfobloxSOCInsightsConnector",
    "dataType": "InfobloxInsight",
    "dcrConfig": {
      "streamName": "Custom-InfobloxInsight_CL",
      "dataCollectionEndpoint": "{{dataCollectionEndpoint}}",
      "dataCollectionRuleImmutableId": "{{dataCollectionRuleImmutableId}}"
    },
    "addOnAttributes": {
      "friendlyName": "[[parameters('friendlyName')]",
      "tenantHost": "[[first(split(replace(replace(parameters('infobloxApiUrl'),'https://',''),'http://',''),'/'))]"
    }
  }
}