{
  "type": "Microsoft.SecurityInsights/dataConnectors",
  "apiVersion": "2023-02-01-preview",
  "name": "Panorays_Poller",
  "kind": "RestApiPoller",
  "properties": {
    "connectorDefinitionName": "Panorays_ConnectorDefinition",
    "dataType": "PanoraysCompanyFindingPOC_CL",
    "contentProductId": "panorays-sentinel-solution-3-0-0",
    "dcrConfig": {
      "streamName": "Custom-PanoraysCompanyFindings_API",
      "dataCollectionEndpoint": "[reference(resourceId('Microsoft.Insights/dataCollectionEndpoints', 'PanoraysDCE'), '2021-09-01-preview').logsIngestion.endpoint]",
      "dataCollectionRuleImmutableId": "[reference(resourceId('Microsoft.Insights/dataCollectionRules', 'PanoraysCompanyFindingsDCR'), '2022-06-01').immutableId]"
    },
    "auth": {
      "type": "APIKey",
      "ApiKey": "[parameters('apitoken')]",
      "ApiKeyName": "Authorization",
      "ApiKeyIdentifier": "Bearer"
    },
    "request": {
      "apiEndpoint": "[concat(parameters('panoraysAPIBaseUrl'), '/v2/findings')]",
      "rateLimitQPS": 10,
      "queryWindowInMin": 4320,
      "httpMethod": "GET",
      "queryTimeFormat": "yyyy-MM-ddTHH:mm:ssZ",
      "retryCount": 3,
      "timeoutInSeconds": 60,
      "headers": {
        "Accept": "application/json",
        "User-Agent": "PanoraysSentinelConnector/1.0"
      }
    },
    "paging": {
      "pagingType": "NextPageToken",
      "PageSize": "1000",
      "PageSizeParameterName": "limit",
      "NextPageTokenJsonPath": "$.pagination.nextCursor",
      "NextPageParaName": "cursor"
    },
    "response": {
      "eventsJsonPaths": [
        "$.data"
      ]
    }
  }
}