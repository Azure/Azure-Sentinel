{
  "$schema": "https://schema.management.azure.com/schemas/0.1.2-preview/CreateUIDefinition.MultiVm.json#",
  "handler": "Microsoft.Azure.CreateUIDef",
  "version": "0.1.2-preview",
  "parameters": {
    "config": {
      "isWizard": false,
      "basics": {
        "description": "The Panorays solution for Microsoft Sentinel.",
        "subscription": {
          "resourceProviders": [
            "Microsoft.OperationsManagement/solutions",
            "Microsoft.OperationalInsights/workspaces/providers/alertRules",
            "Microsoft.Insights/dataCollectionEndpoints",
            "Microsoft.Insights/dataCollectionRules"
          ]
        },
        "location": { "metadata": { "hidden": "Hiding location" }, "visible": false },
        "resourceGroup": { "allowExisting": true }
      }
    },
    "basics": [
      {
        "name": "getLAWorkspace",
        "type": "Microsoft.Solutions.ArmApiControl",
        "toolTip": "Filter workspaces",
        "condition": "[greater(length(resourceGroup().name),0)]",
        "request": {
          "method": "GET",
          "path": "[concat(subscription().id,'/providers/Microsoft.OperationalInsights/workspaces?api-version=2020-08-01')]"
        }
      },
      {
        "name": "workspace",
        "type": "Microsoft.Common.DropDown",
        "label": "Workspace",
        "placeholder": "Select a workspace",
        "toolTip": "Select the Log Analytics workspace where Panorays data will be stored.",
        "constraints": {
          "allowedValues": "[map(filter(basics('getLAWorkspace').value, (filter) => contains(toLower(filter.id), toLower(resourceGroup().name))), (item) => parse(concat('{\"label\":\"', item.name, '\",\"value\":\"', item.name, '\"}')))]",
          "required": true
        }
      }
    ],
    "steps": [
      {
        "name": "panoraysConfig",
        "label": "Panorays Configuration",
        "bladeTitle": "API Settings",
        "elements": [
          {
            "name": "apitoken",
            "type": "Microsoft.Common.TextBox",
            "label": "API Token",
            "toolTip": "The API Token provided by Panorays to authenticate the connector.",
            "options": { "isPassword": true },
            "constraints": { 
              "required": true,
              "validations": [
                {
                  "regex": "^.{1,1000}$",
                  "message": "The API Token is required."
                }
              ]
            }
          }
        ]
      }
    ],
    "outputs": {
      "location": "[first(map(filter(basics('getLAWorkspace').value, (filter) => and(contains(toLower(filter.id), toLower(resourceGroup().name)),equals(filter.name,basics('workspace')))), (item) => item.location))]",
      "workspace": "[basics('workspace')]",
      "apitoken": "[steps('panoraysConfig').apitoken]"
    }
  }
}