{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "author": "Panorays - support@panorays.com",
    "comments": "Solution template for Panorays"
  },
  "parameters": {
    "location": {
      "type": "string",
      "minLength": 1,
      "defaultValue": "[resourceGroup().location]",
      "metadata": { "description": "Location for resources" }
    },
    "workspace-location": {
      "type": "string",
      "defaultValue": "",
      "metadata": { "description": "Region of the Log Analytics Workspace" }
    },
    "workspace": {
      "defaultValue": "",
      "type": "string",
      "metadata": { "description": "Workspace name" }
    },
    "resourceGroupName": {
      "type": "string",
      "defaultValue": "[resourceGroup().name]"
    },
    "panoraysAPIBaseUrl": {
      "type": "string",
      "defaultValue": "https://api.panoraysapp.com",
      "metadata": { "description": "Base URL for Panorays API" }
    },
    "managementUrl": {
      "type": "string",
      "defaultValue": "https://www.panoraysapp.com/",
      "metadata": { "description": "Management URL for Panorays" }
    },
    "apitoken": {
      "type": "securestring",
      "metadata": { "description": "Company API Token" }
    }
  },
  "variables": {
    "email": "support@panorays.com",
    "_email": "[variables('email')]",
    "_solutionName": "Panorays",
    "_solutionVersion": "3.0.0",
    "solutionId": "azuresentinel.azure-sentinel-solution-panprays",
    "_solutionId": "[variables('solutionId')]",
    "workspaceResourceId": "[resourceId('microsoft.OperationalInsights/Workspaces', parameters('workspace'))]",
    "dataConnectorCCPVersion": "1.0.0",
    "_dataConnectorContentIdConnectorDefinition1": "ccpPanoraysCompanyFindingPOC",
    "_dataConnectorContentIdConnections1": "ccpPanoraysCompanyFindingPOCConnections",
    "_solutioncontentProductIdRaw": "[concat(take(variables('_solutionId'),50),'-','sl','-', uniqueString(concat(variables('_solutionId'),'-','Solution','-',variables('_solutionId'),'-', variables('_solutionVersion'))))]",
    "_solutioncontentProductId": "[variables('_solutioncontentProductIdRaw')]"
  },
  "resources": [
    {
      "type": "Microsoft.Insights/dataCollectionEndpoints",
      "apiVersion": "2021-09-01-preview",
      "name": "PanoraysDCE",
      "location": "[parameters('workspace-location')]",
      "properties": {
        "networkAcls": {
          "publicNetworkAccess": "Enabled"
        }
      }
    },
    {
      "name": "[concat(parameters('workspace'), '/PanoraysCompanyFindingPOC_CL')]",
      "type": "Microsoft.OperationalInsights/workspaces/tables",
      "apiVersion": "2022-10-01",
      "tags": {
        "created": "Panorays Ltd.",
        "CreatedAt": "December 2025"
      },
      "properties": {
        "totalRetentionInDays": 30,
        "plan": "Analytics",
        "schema": {
          "name": "PanoraysCompanyFindingPOC_CL",
          "columns": [
                {
                    "name": "asset_name",
                    "type": "string",
                    "description": "The specific digital asset where the finding was detected (e.g., a domain, subdomain, IP address, or URL)."
                },
                {
                    "name": "TimeGenerated",
                    "type": "datetime",
                    "isDefaultDisplay": true,
                    "description": "TThe UTC timestamp when this event was ingested into Microsoft Sentinel. Use this for time-range filtering in KQL"
                },
                {
                    "name": "category",
                    "type": "string",
                    "description": "The high-level security domain of the finding (Possible values: Human, Network and IT, Application)"
                },
                {
                    "name": "cves",
                    "type": "dynamic",
                    "description": "A list of Common Vulnerabilities and Exposures (CVE) IDs associated with this finding, if applicable (e.g., [CVE-2024-44228])."
                },
                {
                    "name": "description",
                    "type": "string",
                    "description": "A detailed explanation of the vulnerability, including why it is a risk and the potential impact"
                },
                {
                    "name": "evidence",
                    "type": "dynamic",
                    "description": "Technical proof collected during the scan. May include HTTP headers, open port nr., or specific configuration settings that triggered the finding."
                },
                {
                    "name": "finding_text",
                    "type": "string",
                    "description": "The headline or short title of the specific finding (e.g., Cloud Private Services Exposed)"
                },
                {
                    "name": "FindingKey",
                    "type": "string",
                    "description": "The unique identifier for this specific finding within the Panorays platform."
                },
                {
                    "name": "is_hidden",
                    "type": "boolean",
                    "description": "Indicates if this finding has been manually suppressed or hidden in the Panorays dashboard (true = hidden)"
                },
                {
                    "name": "metadata",
                    "type": "dynamic",
                    "description": "A JSON object containing additional context specific to the finding type (e.g., specific port numbers, certificate details)"
                },
                {
                    "name": "previously_disputed",
                    "type": "boolean",
                    "description": "Flag indicating if this finding was previously marked as a false positive or disputed by an analyst."
                },
                {
                    "name": "segments",
                    "type": "dynamic",
                    "description": "A list of business units, tags, or asset groups within Panorays that this finding is associated with"
                },
                {
                    "name": "severity",
                    "type": "string",
                    "description": "The risk level assigned to this finding. Possible values: Critical, High, Medium, Low, Info."
                },
                {
                    "name": "status",
                    "type": "string",
                    "description": "The current lifecycle state of the finding. Possible values Open, Done, Closed."
                },
                {
                    "name": "status_update_ts",
                    "type": "string",
                    "description": "The timestamp (as a string) reflecting specifically when the status field last changed."
                },
                {
                    "name": "sub_category",
                    "type": "string",
                    "description": "A granular classification of the finding within the parent category (e.g., Exposed Services, Mail Server etc.)."
                },
                {
                    "name": "test_name",
                    "type": "string",
                    "description": "test name"
                },
                {
                    "name": "test_text",
                    "type": "string",
                    "description": "test text"
                },
                {
                    "name": "update_ts",
                    "type": "datetime",
                    "description": "The timestamp (UTC) when the record was last modified in the Panorays."
                },
                {
                    "name": "updated_by",
                    "type": "string",
                    "description": "The user or system process that performed the last update to this record."
                }
          ]
        }
      }
    },
    {
      "name": "PanoraysCompanyFindingsDCR",
      "apiVersion": "2022-06-01",
      "type": "Microsoft.Insights/dataCollectionRules",
      "location": "[parameters('workspace-location')]",
      "kind": "Direct",
      "properties": {
        "dataCollectionEndpointId": "[resourceId('Microsoft.Insights/dataCollectionEndpoints', 'PanoraysDCE')]",
        "streamDeclarations": {
          "Custom-PanoraysCompanyFindings_API": {
            "columns": [
              { "name": "status", "type": "string" },
              { "name": "FindingKey", "type": "string" },
              { "name": "metadata", "type": "dynamic" },
              { "name": "cves", "type": "dynamic" },
              { "name": "asset_name", "type": "string" },
              { "name": "category", "type": "string" },
              { "name": "sub_category", "type": "string" },
              { "name": "test_text", "type": "string" },
              { "name": "insert_ts", "type": "string" },
              { "name": "update_ts", "type": "string" },
              { "name": "test_name", "type": "string" },
              { "name": "segments", "type": "dynamic" }
            ]
          }
        },
        "destinations": {
          "logAnalytics": [
            {
              "workspaceResourceId": "[variables('workspaceResourceId')]",
              "name": "clv2ws1"
            }
          ]
        },
        "dataFlows": [
          {
            "streams": [ "Custom-PanoraysCompanyFindings_API" ],
            "destinations": [ "clv2ws1" ],
            "transformKql": "source | project TimeGenerated = todatetime(insert_ts), Status = status, FindingKey = FindingKey, Metadata = metadata, CVEs = cves, AssetName = asset_name, Category = category, SubCategory = sub_category, TestText = test_text, InsertTimestamp = insert_ts, UpdateTimestamp = update_ts, TestName = test_name, Segments = segments",
            "outputStream": "Custom-PanoraysCompanyFindingPOC_CL"
          }
        ]
      }
    },
    {
      "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/',variables('_dataConnectorContentIdConnectorDefinition1'))]",
      "apiVersion": "2022-09-01-preview",
      "type": "Microsoft.OperationalInsights/workspaces/providers/dataConnectorDefinitions",
      "location": "[parameters('workspace-location')]",
      "kind": "Customizable",
      "properties": {
        "connectorUiConfig": {
          "id": "[concat('ccpPanoraysCompanyFindingPOC')]",
          "title": "Panorays",
          "publisher": "Panorays",
          "descriptionMarkdown": "The [Panorays](https://panorays-papi-v2-documentation.redocly.app) data connector allows ingesting logs from the Panorays APIs into Microsoft Sentinel. The data connector is built on Microsoft Sentinel Codeless Connector Platform. It uses the Panorays API to fetch data from Panorays platform and it supports DCR-based [ingestion time transformations](https://docs.microsoft.com/azure/azure-monitor/logs/custom-logs-overview) that parses the received security data into a custom table so that queries don't need to parse it again, thus resulting in better performance.",
          "graphQueriesTableName": "PanoraysCompanyFindingPOC_CL",
          "graphQueries": [
            {
              "metricName": "Findings by Severity",
              "legend": "Severity",
              "baseQuery": "PanoraysCompanyFindingPOC_CL | summarize Count=count() by severity, bin(TimeGenerated, 1h)"
            }
          ],
          "sampleQueries": [
            {
              "description": "List Latest Findings",
              "query": "PanoraysCompanyFindingPOC_CL | sort by TimeGenerated desc | take 20"
            }
          ],
          "dataTypes": [
            {
              "name": "PanoraysCompanyFindingPOC_CL",
              "lastDataReceivedQuery": "PanoraysCompanyFindingPOC_CL | summarize Time = max(TimeGenerated) | where isnotempty(Time)"
            }
          ],
          "connectivityCriteria": [ { "type": "HasDataConnectors" } ],
          "permissions": {
            "resourceProvider": [
              {
                "provider": "Microsoft.OperationalInsights/workspaces",
                "permissionsDisplayText": "Read and Write permissions are required.",
                "providerDisplayName": "Workspace",
                "scope": "Workspace",
                "requiredPermissions": { "read": true, "write": true, "delete": true, "action": false }
              }
            ]
          },
          "instructionSteps": [
            {
              "instructions": [
                { "type": "Markdown", "parameters": { "content": "#### Configuration steps for the Panorays APIs " } },
                { "type": "Markdown", "parameters": { "content": "1. Log in to the **[Panorays Console](https://www.panoraysapp.com/)**.\n2. Navigate to **Company Settings** > **API Tokens**.\n3. Generate a new token and copy it.\nSee our full guide **[here](https://support.panorays.com/?category&sub-category=Account-Settings&article_num=000001665)**"}},
                { "parameters": { "label": "API Token", "placeholder": "API Token", "type": "password", "name": "apitoken" }, "type": "Textbox" },
                { "parameters": { "label": "toggle", "name": "toggle" }, "type": "ConnectionToggleButton" }
              ]
            }
          ]
        }
      }
    },
    {
      "type": "Microsoft.OperationalInsights/workspaces/providers/contentPackages",
      "apiVersion": "2023-04-01-preview",
      "location": "[parameters('workspace-location')]",
      "properties": {
        "version": "3.0.0",
        "kind": "Solution",
        "contentSchemaVersion": "3.0.0",
        "displayName": "Panorays",
        "publisherDisplayName": "Panorays",
        "descriptionHtml": "<p>Panorays Solution</p>",
        "contentKind": "Solution",
        "contentProductId": "[variables('_solutioncontentProductId')]",
        "id": "[variables('_solutioncontentProductId')]",
        "icon": "<img src=\"https://raw.githubusercontent.com/Azure/Azure-Sentinel/master/Logos/Azure_Sentinel.svg\" width=\"75px\" height=\"75px\">",
        "contentId": "[variables('_solutionId')]",
        "parentId": "[variables('_solutionId')]",
        "source": { "kind": "Solution", "name": "Panorays", "sourceId": "[variables('_solutionId')]" },
        "author": { "name": "Panorays", "email": "[variables('_email')]" },
        "support": { "name": "Panorays", "email": "support@panorays.com", "tier": "Partner", "link": "https://www.panorays.com" },
        "dependencies": {
          "operator": "AND",
          "criteria": [
            { "kind": "DataConnector", "contentId": "[variables('_dataConnectorContentIdConnections1')]", "version": "[variables('dataConnectorCCPVersion')]" }
          ]
        },
        "providers": [ "Panorays" ],
        "categories": { "domains": [ "Security - Vulnerability Management" ] }
      },
      "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/', variables('_solutionId'))]"
    },
    {
      "type": "Microsoft.OperationalInsights/workspaces/providers/dataConnectors",
      "apiVersion": "2023-02-01-preview",
      "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/', 'Panorays_Company_Findings_', uniqueString(resourceGroup().id))]",
      "location": "[parameters('workspace-location')]",
      "kind": "RestApiPoller",
      "dependsOn": [
        "[resourceId('Microsoft.Insights/dataCollectionRules', 'PanoraysCompanyFindingsDCR')]",
        "[resourceId('Microsoft.Insights/dataCollectionEndpoints', 'PanoraysDCE')]",
        "[resourceId('Microsoft.OperationalInsights/workspaces/providers/dataConnectorDefinitions', parameters('workspace'), 'Microsoft.SecurityInsights', variables('_dataConnectorContentIdConnectorDefinition1'))]"
      ],
      "properties": {
        "connectorDefinitionName": "ccpPanoraysCompanyFindingPOC",
        "dataType": "Custom-PanoraysCompanyFindingPOC_CL",
        "dcrConfig": {
          "streamName": "Custom-PanoraysCompanyFindings_API",
          "dataCollectionEndpoint": "[reference(resourceId('Microsoft.Insights/dataCollectionEndpoints', 'PanoraysDCE'), '2021-09-01-preview').logsIngestion.endpoint]",
          "dataCollectionRuleImmutableId": "[reference(resourceId('Microsoft.Insights/dataCollectionRules', 'PanoraysCompanyFindingsDCR'), '2022-06-01').immutableId]"
        },
        "auth": {
          "type": "APIKey",
          "ApiKey": "[parameters('apitoken')]",
          "ApiKeyName": "Authorization",
          "ApiKeyIdentifier": "Bearer"
        },
        "request": {
          "apiEndpoint": "[concat(parameters('panoraysAPIBaseUrl'), '/v2/findings')]",
          "rateLimitQPS": 10,
          "queryWindowInMin": 720,
          "httpMethod": "GET",
          "headers": {
            "Accept": "application/json",
            "User-Agent": "PanoraysIntegration/1.0"
          }
        },
        "paging": {
          "pagingType": "NextPageToken",
          "PageSize": 100,
          "PageSizeParameterName": "limit",
          "NextPageTokenJsonPath": "$.pagination.nextCursor",
          "NextPageParaName": "cursor"
        },
        "response": {
          "eventsJsonPaths": [
            "$.data"
          ]
        }
      }
    }
  ],
  "outputs": {}
}