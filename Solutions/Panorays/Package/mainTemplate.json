{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "author": "Panorays - support@panorays.com"
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]"
    },
    "workspace-location": {
      "type": "string",
      "defaultValue": ""
    },
    "workspace": {
      "type": "string",
      "defaultValue": ""
    },
    "panoraysAPIBaseUrl": {
      "type": "string",
      "defaultValue": "https://api.panoraysapp.com"
    },
    "apitoken": {
      "type": "securestring"
    }
  },
  "variables": {
    "solutionId": "panorays.azure-sentinel-solution-panorays",
    "defName": "ccpPanoraysCompanyFindingPOC",
    "connName": "Panorays_Poller",
    "productId": "panorays-sentinel-solution-3-0-0",
    "workspaceResourceId": "[resourceId('Microsoft.OperationalInsights/workspaces', parameters('workspace'))]",
    "dceResourceId": "[resourceId('Microsoft.Insights/dataCollectionEndpoints', 'PanoraysDCE')]",
    "dcrResourceId": "[resourceId('Microsoft.Insights/dataCollectionRules', 'PanoraysCompanyFindingsDCR')]"
  },
  "resources": [
    {
      "type": "Microsoft.Insights/dataCollectionEndpoints",
      "apiVersion": "2021-09-01-preview",
      "name": "PanoraysDCE",
      "location": "[parameters('workspace-location')]",
      "properties": {
        "networkAcls": {
          "publicNetworkAccess": "Enabled"
        }
      }
    },
    {
      "type": "Microsoft.OperationalInsights/workspaces/tables",
      "apiVersion": "2022-10-01",
      "name": "[concat(parameters('workspace'), '/PanoraysCompanyFindingPOC_CL')]",
      "location": "[parameters('workspace-location')]",
      "properties": {
        "schema": {
          "name": "PanoraysCompanyFindingPOC_CL",
          "columns": [
            { "name": "TimeGenerated", "type": "datetime" },
            { "name": "asset_name", "type": "string" },
            { "name": "status", "type": "string" },
            { "name": "FindingKey", "type": "string" }
          ]
        }
      }
    },
    {
      "type": "Microsoft.Insights/dataCollectionRules",
      "apiVersion": "2022-06-01",
      "name": "PanoraysCompanyFindingsDCR",
      "location": "[parameters('workspace-location')]",
      "kind": "Direct",
      "dependsOn": [
        "PanoraysDCE"
      ],
      "properties": {
        "dataCollectionEndpointId": "[resourceId('Microsoft.Insights/dataCollectionEndpoints', 'PanoraysDCE')]",
        "streamDeclarations": {
          "Custom-PanoraysCompanyFindings_API": {
            "columns": [
              { "name": "status", "type": "string" },
              { "name": "FindingKey", "type": "string" },
              { "name": "insert_ts", "type": "string" }
            ]
          }
        },
        "destinations": {
          "logAnalytics": [
            {
              "workspaceResourceId": "[variables('workspaceResourceId')]",
              "name": "clv2ws1"
            }
          ]
        },
        "dataFlows": [
          {
            "streams": [ "Custom-PanoraysCompanyFindings_API" ],
            "destinations": [ "clv2ws1" ],
            "transformKql": "source | project TimeGenerated = todatetime(insert_ts), status = status, FindingKey = FindingKey",
            "outputStream": "Custom-PanoraysCompanyFindingPOC_CL"
          }
        ]
      }
    },
    {
      "type": "Microsoft.OperationalInsights/workspaces/providers/dataConnectorDefinitions",
      "apiVersion": "2022-09-01-preview",
      "name": "[concat(parameters('workspace'), '/Microsoft.SecurityInsights/ccpPanoraysCompanyFindingPOC')]",
      "location": "[parameters('workspace-location')]",
      "kind": "Customizable",
      "properties": {
        "connectorUiConfig": {
          "id": "ccpPanoraysCompanyFindingPOC",
          "title": "Panorays",
          "publisher": "Panorays",
          "descriptionMarkdown": "Panorays findings connector.",
          "graphQueriesTableName": "PanoraysCompanyFindingPOC_CL",
          "graphQueries": [ { "metricName": "Total findings", "legend": "Findings", "baseQuery": "PanoraysCompanyFindingPOC_CL" } ],
          "sampleQueries": [ { "description": "Samples", "query": "PanoraysCompanyFindingPOC_CL | take 10" } ],
          "dataTypes": [ { "name": "PanoraysCompanyFindingPOC_CL", "lastDataReceivedQuery": "PanoraysCompanyFindingPOC_CL | summarize max(TimeGenerated)" } ],
          "connectivityCriteria": [ { "type": "HasDataConnectors" } ],
          "availability": { "status": 1, "isPreview": false },
          "permissions": {
            "resourceProvider": [
              {
                "provider": "Microsoft.OperationalInsights/workspaces",
                "ProviderDisplayName": "Log Analytics Workspace",
                "scope": "ResourceGroup",
                "permissionsDisplayText": "Read/Write required.",
                "requiredPermissions": { "read": true, "write": true, "delete": true, "action": false }
              }
            ]
          },
          "instructionSteps": [ { "instructions": [ { "type": "Markdown", "parameters": { "content": "Connect Panorays." } }, { "type": "Textbox", "parameters": { "label": "API Token", "name": "apitoken" } }, { "type": "ConnectionToggleButton", "parameters": { "label": "toggle", "name": "toggle" } } ] } ]
        }
      }
    },
    {
      "type": "Microsoft.OperationalInsights/workspaces/providers/contentPackages",
      "apiVersion": "2023-04-01-preview",
      "name": "[concat(parameters('workspace'), '/Microsoft.SecurityInsights/', variables('solutionId'))]",
      "location": "[parameters('workspace-location')]",
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces/providers/dataConnectorDefinitions', parameters('workspace'), 'Microsoft.SecurityInsights', 'ccpPanoraysCompanyFindingPOC')]"
      ],
      "properties": {
        "contentProductId": "[variables('productId')]",
        "contentId": "[variables('solutionId')]",
        "version": "3.0.0",
        "kind": "Solution",
        "contentSchemaVersion": "3.0.0",
        "displayName": "Panorays",
        "publisherDisplayName": "Panorays",
        "contentKind": "Solution",
        "source": { "kind": "Solution", "name": "Panorays", "sourceId": "[variables('solutionId')]" },
        "author": { "name": "Panorays", "email": "support@panorays.com" },
        "support": { "name": "Panorays", "email": "support@panorays.com", "link": "https://support.panoraysapp.com/" },
        "dependencies": {
          "operator": "AND",
          "criteria": [ { "kind": "DataConnector", "contentId": "ccpPanoraysCompanyFindingPOC", "version": "3.0.0" } ]
        },
        "firstPublishDate": "2026-03-26",
        "providers": [ "Panorays" ],
        "categories": { "domains": [ "Security - Other" ] }
      }
    },
    {
      "type": "Microsoft.OperationalInsights/workspaces/providers/dataConnectors",
      "apiVersion": "2023-02-01-preview",
      "name": "[concat(parameters('workspace'), '/Microsoft.SecurityInsights/Panorays_Poller')]",
      "location": "[parameters('workspace-location')]",
      "kind": "RestApiPoller",
      "dependsOn": [
        "PanoraysCompanyFindingsDCR",
        "PanoraysDCE",
        "[resourceId('Microsoft.OperationalInsights/workspaces/providers/dataConnectorDefinitions', parameters('workspace'), 'Microsoft.SecurityInsights', 'ccpPanoraysCompanyFindingPOC')]"
      ],
      "properties": {
        "connectorDefinitionName": "ccpPanoraysCompanyFindingPOC",
        "dataType": "PanoraysCompanyFindingPOC_CL",
        "contentProductId": "[variables('productId')]",
        "dcrConfig": {
          "streamName": "Custom-PanoraysCompanyFindings_API",
          "dataCollectionEndpoint": "[reference(resourceId('Microsoft.Insights/dataCollectionEndpoints', 'PanoraysDCE'), '2021-09-01-preview').logsIngestion.endpoint]",
          "dataCollectionRuleImmutableId": "[reference(resourceId('Microsoft.Insights/dataCollectionRules', 'PanoraysCompanyFindingsDCR'), '2022-06-01').immutableId]"
        },
        "auth": {
          "type": "APIKey",
          "ApiKey": "[parameters('apitoken')]",
          "ApiKeyName": "Authorization",
          "ApiKeyIdentifier": "Bearer"
        },
        "request": {
          "apiEndpoint": "https://api.panoraysapp.com/v2/findings",
          "headers": {
            "Accept": "application/json"
          },
          "rateLimitQPS": 10,
          "httpMethod": "GET"
        },
        "paging": {
          "pagingType": "NextPageToken",
          "NextPageTokenJsonPath": "$.pagination.nextCursor",
          "NextPageParaName": "cursor"
        },
        "response": { "eventsJsonPaths": [ "$.data" ] }
      }
    }
  ],
  "outputs": {}
}