{
  "$schema": "https://schema.management.azure.com/schemas/0.1.2-preview/CreateUIDefinition.MultiVm.json#",
  "handler": "Microsoft.Azure.Sentinel.Main",
  "version": "1.0.0",
  "parameters": {
    "config": { "isPaaS": "true" },
    "basics": [{}],
    "steps": [
      {
        "name": "apitokenStep",
        "label": "Panorays Configuration",
        "elements": [
          {
            "name": "apitokenControl",
            "type": "Microsoft.Common.TextBox",
            "label": "API Token",
            "constraints": { "required": true }
          },
          {
            "name": "baseUrlControl",
            "type": "Microsoft.Common.TextBox",
            "label": "API Base URL",
            "defaultValue": "https://api.panoraysapp.com",
            "constraints": { "required": true }
          }
        ]
      }
    ],
    "outputs": {
      "apitoken": "[steps('apitokenStep').apitokenControl]",
      "panoraysAPIBaseUrl": "[steps('apitokenStep').baseUrlControl]",
      "workspace": "[environment().name]",
      "location": "[deployment().location]"
    }
  }
}