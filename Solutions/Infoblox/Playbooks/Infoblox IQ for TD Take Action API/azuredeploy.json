                        },
                        {
                            "name": "threat_actors",
                            "type": "dynamic"
                        },
                        {
                            "name": "overview",
                            "type": "dynamic"
                        },
                        {
                            "name": "key_recommendations",
                            "type": "dynamic"
                        },
                        {
                            "name": "InsightDetail",
                            "type": "boolean"
                        },
                        {
                            "name": "DataObservedVia",
                            "type": "string"
                        },
                        {
                            "name": "InfobloxInsightLogType",
                            "type": "string"
                        },
                        {
