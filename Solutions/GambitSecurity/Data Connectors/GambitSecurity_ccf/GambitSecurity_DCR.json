{
    "name": "GambitSecurityCustomDCR",
    "apiVersion": "2021-09-01-preview",
    "type": "Microsoft.Insights/dataCollectionRules",
    "location": "[parameters('workspace-location')]",
    "properties": {
        "streamDeclarations": {
            "Custom-GambitPoliciesIssues": {
                "columns": [
                    {
                        "name": "TimeGenerated",
                        "type": "datetime"
                    },
                    {
                        "name": "IssueId",
                        "type": "string"
                    },
                    {
                        "name": "State",
                        "type": "string"
                    },
                    {
                        "name": "IssueStatus",
                        "type": "string"
                    },
                    {
                        "name": "ResourceDisplayId",
                        "type": "string"
                    },
                    {
                        "name": "HostPlatform",
                        "type": "string"
                    },
                    {
                        "name": "ResourceType",
                        "type": "string"
                    },
                    {
                        "name": "Environment",
                        "type": "string"
                    },
                    {
                        "name": "AffectedSystems",
                        "type": "dynamic"
                    },
                    {
                        "name": "PolicyId",
                        "type": "string"
                    },
                    {
                        "name": "PolicyName",
                        "type": "string"
                    },
                    {
                        "name": "PolicyDescription",
                        "type": "string"
                    },
                    {
                        "name": "PolicyCategories",
                        "type": "dynamic"
                    },
                    {
                        "name": "Severity",
                        "type": "string"
                    },
                    {
                        "name": "BusinessImpacts",
                        "type": "dynamic"
                    },
                    {
                        "name": "RemediationSteps",
                        "type": "string"
                    },
                    {
                        "name": "CreatedAt",
                        "type": "datetime"
                    },
                    {
                        "name": "LastEvaluationTime",
                        "type": "datetime"
                    }
                ]
            }
        },
        "destinations": {
            "logAnalytics": [
                {
                    "workspaceResourceId": "[variables('workspaceResourceId')]",
                    "name": "clv2ws1"
                }
            ]
        },
        "dataFlows": [
            {
                "streams": [
                    "Custom-GambitPoliciesIssues"
                ],
                "destinations": [
                    "clv2ws1"
                ],
                "transformKql": "source",
                "outputStream": "Custom-GambitPoliciesIssues_CL"
            }
        ],
        "dataCollectionEndpointId": "[concat('/subscriptions/',parameters('subscription'),'/resourceGroups/',parameters('resourceGroupName'),'/providers/Microsoft.Insights/dataCollectionEndpoints/',parameters('workspace'))]"
    }
}
