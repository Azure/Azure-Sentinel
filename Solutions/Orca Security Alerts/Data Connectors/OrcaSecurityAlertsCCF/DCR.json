{
  "name": "OrcaSecurityAlertsCustomDCR",
  "apiVersion": "2021-09-01-preview",
  "type": "Microsoft.Insights/dataCollectionRules",
  "location": "[parameters('workspace-location')]",
  "properties": {
    "streamDeclarations": {
      "Custom-OrcaSecurityAlerts": {
        "columns": [
          {
            "name": "time",
            "type": "datetime"
          },
          {
            "name": "alert_id",
            "type": "string"
          },
          {
            "name": "alert_type",
            "type": "string"
          },
          {
            "name": "alert_labels",
            "type": "string"
          },
          {
            "name": "status",
            "type": "string"
          },
          {
            "name": "risk_level",
            "type": "string"
          },
          {
            "name": "orca_score",
            "type": "dynamic"
          },
          {
            "name": "description",
            "type": "string"
          },
          {
            "name": "details",
            "type": "string"
          },
          {
            "name": "recommendation",
            "type": "string"
          },
          {
            "name": "source",
            "type": "string"
          },
          {
            "name": "account_name",
            "type": "string"
          },
          {
            "name": "cloud_provider_id",
            "type": "string"
          },
          {
            "name": "cloud_vendor_id",
            "type": "string"
          },
          {
            "name": "asset_unique_id",
            "type": "string"
          },
          {
            "name": "asset_name",
            "type": "string"
          },
          {
            "name": "asset_hostname",
            "type": "string"
          },
          {
            "name": "asset_type",
            "type": "string"
          },
          {
            "name": "asset_state",
            "type": "string"
          },
          {
            "name": "vm_id",
            "type": "string"
          },
          {
            "name": "cluster_name",
            "type": "string"
          },
          {
            "name": "cluster_type",
            "type": "string"
          },
          {
            "name": "cve_list",
            "type": "dynamic"
          },
          {
            "name": "asset_tags_info_list",
            "type": "dynamic"
          },
          {
            "name": "findings",
            "type": "string"
          }
        ]
      }
    },
    "destinations": {
      "logAnalytics": [
        {
          "workspaceResourceId": "[variables('workspaceResourceId')]",
          "name": "clv2ws1"
        }
      ]
    },
    "dataFlows": [
      {
        "streams": [
          "Custom-OrcaSecurityAlerts"
        ],
        "destinations": [
          "clv2ws1"
        ],
        "transformKql": "source\n| extend TimeGenerated = iif(isnotnull(todatetime(['time'])), todatetime(['time']), now())\n| extend orca_score = toreal(orca_score)\n| project-away ['time']",
        "outputStream": "Custom-OrcaAlerts_CL"
      }
    ],
    "dataCollectionEndpointId": "[concat('/subscriptions/',parameters('subscription'),'/resourceGroups/',parameters('resourceGroupName'),'/providers/Microsoft.Insights/dataCollectionEndpoints/',parameters('workspace'))]"
  }
}
