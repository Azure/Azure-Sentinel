[
  {
    "name": "SailPointIdentityNowEvents",
    "apiVersion": "2023-02-01-preview",
    "type": "Microsoft.SecurityInsights/dataConnectors",
    "location": "{{location}}",
    "kind": "RestApiPoller",
    "properties": {
      "connectorDefinitionName": "SailPointIdentityNowDefinition",
      "dataType": "SailPointIDNEvents_CL",
      "auth": {
        "type": "OAuth2",
        "GrantType": "client_credentials",
        "ClientId": "{{ClientId}}",
        "ClientSecret": "{{ClientSecret}}",
        "TokenEndpoint": "https://{{TenantId}}.api.identitynow.com/oauth/token"
      },
      "request": {
        "apiEndpoint": "https://{{TenantId}}.api.identitynow.com/v2025/search/events",
        "httpMethod": "POST",
        "queryTimeFormat": "yyyy-MM-ddTHH:mm:ss.fffZ",
        "startTimeAttributeName": "startTime",
        "endTimeAttributeName": "endTime",
        "queryWindowInMin": 5,
        "rateLimitQPS": 1,
        "retryCount": 3,
        "timeoutInSeconds": 120,
        "headers": {
          "Content-Type": "application/json"
        },
        "queryParameters": {
          "count": "true",
          "offset": "0",
          "limit": "250"
        },
        "isPostPayloadJson": true,
        "queryParametersTemplate": "{\"queryType\":\"SAILPOINT\",\"query\":{\"query\":\"created:>{_QueryWindowStartTime} AND created:<{_QueryWindowEndTime}\"},\"queryResultFilter\":{},\"sort\":[\"created\"],\"searchAfter\":[]}"
      },
      "response": {
        "eventsJsonPaths": [
          "$"
        ],
        "format": "json"
      },
      "paging": {
        "pagingType": "Offset",
        "offsetParaName": "offset",
        "pageSizeParameterName": "limit",
        "pageSize": 250
      },
      "dcrConfig": {
        "dataCollectionEndpoint": "{{dataCollectionEndpoint}}",
        "dataCollectionRuleImmutableId": "{{dataCollectionRuleImmutableId}}",
        "streamName": "Custom-SailPointIDNEvents_CL"
      }
    }
  }
]