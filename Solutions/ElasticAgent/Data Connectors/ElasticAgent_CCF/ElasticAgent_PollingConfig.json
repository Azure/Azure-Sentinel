{
  "type": "Microsoft.SecurityInsights/dataConnectors",
  "apiVersion": "2024-09-01",
  "name": "[[concat('parameters('workspace')', '/Microsoft.SecurityInsights/','ElasticAgentLogsV2' , uniqueString(parameters('friendlyName')) )]",
  "location": "{{location}}",
  "kind": "RestApiPoller",
  "properties": {
    "auth": {
      "type": "APIKey",
      "ApiKey": "[[parameters('apiKey')]",
      "ApiKeyName": "Authorization",
      "ApiKeyIdentifier": "ApiKey"
    },
    "request": {
      "apiEndpoint": "[[concat(parameters('elasticsearchUrl'), '/metrics-system.cpu-*,metrics-system.memory-*,metrics-system.process-*,metrics-system.filesystem-*,metrics-system.network-*,metrics-system.load-*,metrics-system.uptime-*,metrics-elastic_agent.*,logs-elastic_agent-*/_search')]",
      "httpMethod": "POST",
      "rateLimitQPS": 10,
      "paginatedCallsPerSecond": 5.0,
      "queryWindowInMin": 5,
      "queryWindowDelayInMin": 30,
      "queryTimeFormat": "yyyy-MM-ddTHH:mm:ssZ",
      "retryCount": 3,
      "timeoutInSeconds": 30,
      "isPostPayloadJson": true,
      "headers": {
        "Content-Type": "application/json",
        "Accept": "application/json"
      },
      "queryParametersTemplate": "\r\n        {\r\n            \"sort\": [\r\n                { \"@timestamp\": { \"order\": \"asc\" } }\r\n            ],\r\n            \"query\": {\r\n                \"bool\": {\r\n                    \"filter\": [\r\n                        {\r\n                            \"range\": {\r\n                                \"@timestamp\": {\r\n                                    \"gte\": \"{_QueryWindowStartTime}\",\r\n                                    \"lt\": \"{_QueryWindowEndTime}\"\r\n                                }\r\n                            }\r\n                        }\r\n                    ]\r\n                }\r\n            }\r\n        }"
    },
    "response": {
      "eventsJsonPaths": [
        "$.hits.hits[*]"
      ],
      "format": "json"
    },
    "paging": {
      "pagingType": "Offset",
      "offsetParaName": "from",
      "pageSize": 100,
      "pageSizeParameterName": "size",
      "pagingInfoPlacement": "RequestBody"
    },
    "connectorDefinitionName": "ElasticAgentConnector",
    "dataType": "ElasticAgentLogsV2",
    "dcrConfig": {
      "streamName": "Custom-ElasticAgentLogsV2_CL",
      "dataCollectionEndpoint": "{{dataCollectionEndpoint}}",
      "dataCollectionRuleImmutableId": "{{dataCollectionRuleImmutableId}}"
    },
    "addOnAttributes": {
      "friendlyName": "[[parameters('friendlyName')]"
    }
  }
}