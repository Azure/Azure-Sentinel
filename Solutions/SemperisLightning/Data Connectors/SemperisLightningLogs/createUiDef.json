{
  "$schema": "https://schema.management.azure.com/schemas/2021-09-09/uiFormDefinition.schema.json",
  "view": {
    "kind": "Form",
    "properties": {
      "title": "Semperis Lightning Connector",
      "steps": [
        {
          "name": "basics",
          "label": "Basics",
          "elements": [
            {
              "name": "resourceScope",
              "type": "Microsoft.Common.ResourceScope",
              "location": {
                "metadata": {
                  "hidden": "Hiding location, we get it from the log analytics workspace"
                },
                "visible": false
              }
            },
            {
              "name": "LogAnalyticsWorkspaceResourceID",
              "type": "Microsoft.Common.TextBox",
              "label": "Log Analytics Workspace Resource ID",
              "placeholder": "/subscriptions/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx/resourcegroups/myRG/providers/microsoft.operationalinsights/workspaces/myWorkspace",
              "toolTip": "Azure Resource ID of the existing Log Analytics Workspace where Semperis Lightning data will be ingested. Find this in your workspace's JSON View.",
              "constraints": {
                "required": true,
                "regex": "^/subscriptions/[a-f0-9\\-]+/resourcegroups/[a-zA-Z0-9\\-._]+/providers/microsoft.operationalinsights/workspaces/[a-zA-Z0-9\\-._]+$",
                "validationMessage": "Please enter a valid Log Analytics Workspace Resource ID"
              }
            }
          ]
        },
        {
          "name": "semperis",
          "label": "Semperis Configuration",
          "elements": [
            {
              "name": "configText",
              "type": "Microsoft.Common.TextBlock",
              "options": {
                "text": "Configure your Semperis Lightning API credentials and region",
                "link": {
                  "label": "Learn more about Semperis Lightning",
                  "uri": "https://www.semperis.com/platform/"
                }
              }
            },
            {
              "name": "SemperisZone",
              "type": "Microsoft.Common.DropDown",
              "label": "Semperis Zone",
              "defaultValue": "na",
              "toolTip": "Select your Semperis region (North America or Europe)",
              "constraints": {
                "allowedValues": [
                  {
                    "label": "North America (na)",
                    "value": "na"
                  },
                  {
                    "label": "Europe (eu)",
                    "value": "eu"
                  }
                ],
                "required": true
              }
            },
            {
              "name": "SemperisApiKey",
              "type": "Microsoft.Common.PasswordBox",
              "label": "Semperis API Key",
              "toolTip": "Your Semperis Lightning API key for authentication",
              "constraints": {
                "required": true,
                "regex": "^[A-Za-z0-9+/=]{32,}$",
                "validationMessage": "Please enter a valid Semperis API key"
              },
              "options": {
                "hideConfirmation": false
              }
            }
          ]
        },
        {
          "name": "schedule",
          "label": "Schedule",
          "elements": [
            {
              "name": "scheduleText",
              "type": "Microsoft.Common.TextBlock",
              "options": {
                "text": "Configure how often the connector will ingest Semperis Lightning data into Log Analytics",
                "link": {
                  "label": "Learn more about cron expressions",
                  "uri": "https://learn.microsoft.com/en-us/azure/azure-functions/functions-bindings-timer?tabs=python-v2%2Cisolated-process%2Cnodejs-v4&pivots=programming-language-csharp#ncrontab-expressions"
                }
              }
            },
            {
              "name": "ConnectorSchedule",
              "type": "Microsoft.Common.TextBox",
              "label": "Connector Schedule (CRON)",
              "defaultValue": "0 * * * *",
              "placeholder": "0 * * * * (every 1 hour)",
              "toolTip": "CRON expression for ingestion frequency. Default: every 1 hour. Format: 'minute hour day month dayOfWeek'",
              "constraints": {
                "required": true,
                "regex": "^\\d{1,2} \\d{1,2} \\d{1,2} \\d{1,2} \\d{1,2}$",
                "validationMessage": "Please enter a valid CRON expression (e.g., '0 * * * *')"
              }
            }
          ]
        }
      ],
      "outputs": {
        "resourceGroupId": "[steps('basics').resourceScope.resourceGroup.id]",
        "location": "[steps('basics').resourceScope.location.displayName]",
        "LogAnalyticsWorkspaceResourceID": "[steps('basics').LogAnalyticsWorkspaceResourceID]",
        "SemperisZone": "[steps('semperis').SemperisZone]",
        "SemperisApiKey": "[steps('semperis').SemperisApiKey]",
        "ConnectorSchedule": "[steps('schedule').ConnectorSchedule]"
      }
    }
  }
}
