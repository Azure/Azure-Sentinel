{
  "name": "42CrunchAPIProtectionDCR",
  "apiVersion": "2022-06-01",
  "type": "Microsoft.Insights/dataCollectionRules",
  "location": "{{location}}",
  "properties": {
    "dataCollectionEndpointId": "[resourceId('Microsoft.Insights/dataCollectionEndpoints', '42CrunchAPIProtection-DCE')]",
    "streamDeclarations": {
      "Custom-FortyTwoCrunchAPIProtectionV2_CL": {
        "columns": [
          {
            "name": "Uuid",
            "type": "string"
          },
          {
            "name": "Timestamp",
            "type": "datetime"
          },
          {
            "name": "InstanceName",
            "type": "string"
          },
          {
            "name": "Hostname",
            "type": "string"
          },
          {
            "name": "SourceIp",
            "type": "string"
          },
          {
            "name": "SourcePort",
            "type": "int"
          },
          {
            "name": "DestinationPort",
            "type": "int"
          },
          {
            "name": "UriPath",
            "type": "string"
          },
          {
            "name": "Query",
            "type": "string"
          },
          {
            "name": "Status",
            "type": "int"
          },
          {
            "name": "ErrorMessage",
            "type": "string"
          },
          {
            "name": "Errors",
            "type": "string"
          },
          {
            "name": "RequestHeader",
            "type": "string"
          },
          {
            "name": "ResponseHeader",
            "type": "string"
          },
          {
            "name": "ApiId",
            "type": "string"
          },
          {
            "name": "NonBlockingMode",
            "type": "boolean"
          },
          {
            "name": "EventType",
            "type": "string"
          }
        ]
      }
    },
    "destinations": {
      "logAnalytics": [
        {
          "workspaceResourceId": "{{workspaceResourceId}}",
          "name": "clv2ws1"
        }
      ]
    },
    "dataFlows": [
      {
        "streams": [
          "Custom-FortyTwoCrunchAPIProtectionV2_CL"
        ],
        "destinations": [
          "clv2ws1"
        ],
        "outputStream": "Custom-FortyTwoCrunchAPIProtectionV2_CL",
        "transformKql": "source | extend TimeGenerated = iff(isnull(Timestamp) or Timestamp < ago(2d), now(), Timestamp) | project TimeGenerated , Uuid , Timestamp , InstanceName , Hostname , SourceIp , SourcePort , DestinationPort , UriPath , Query , Status , ErrorMessage , Errors , RequestHeader , ResponseHeader , ApiId , NonBlockingMode , EventType"
      }
    ]
  }
}