      "kind": "GenericUI",
      "properties": {
        "connectorUiConfig": {
          "title": "Agent 365",
          "publisher": "Microsoft",
          "descriptionMarkdown": "Agent 365 data connector gives richer insights into AI agent activity by bringing AI agent telemetry from Agent 365, AI Foundry, and Copilot in the Microsoft Sentinel data lake to investigate agent behavior, tool usage, and execution with hunting, graph, and MCP workflows. Data from this connector is used to investigate AI agent behavior, tool usage, and execution in Microsoft Sentinel. If you have enabled these workflows, deactivating this connector will prevent those investigations from being performed.",
