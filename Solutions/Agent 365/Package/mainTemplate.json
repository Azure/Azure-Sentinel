          "sampleQueries": "[variables('TemplateEmptyArray')]",
          "availability": {
            "status": 2,
            "isPreview": false
          },
          "permissions": {
            "tenant": [
              "GlobalAdmin"
            ]
          },
          "instructionSteps": [
            {
              "instructions": [
                {
                  "parameters": {
                    "type": "A365",
                    "description": "1. Connect Agent 365 assets to ingest into Microsoft Sentinel Lake.",
                    "items": [
                      {
                        "label": "UnifiedAgentObservability"
                      }
                    ]
                  },
                  "type": "MSG"
                }
              ]
            }
          ],
          "id": "[variables('_uiConfigId1')]"
        }
