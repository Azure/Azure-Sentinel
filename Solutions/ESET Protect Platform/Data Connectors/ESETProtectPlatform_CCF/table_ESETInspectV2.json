{
  "name": "ESETInspectV2_CL",
  "type": "Microsoft.OperationalInsights/workspaces/tables",
  "apiVersion": "2022-10-01",
  "tags": {
    "StreamName": "Custom-ESETInspectV2_CL",
    "DataSource": "ESETConnect",
    "Category": "SecurityEvents",
    "CreatedFrom": "DCR-StreamDeclaration"
  },
  "properties": {
    "retentionInDays": 180,
    "schema": {
      "name": "ESETInspectV2_CL",
      "description": "ESET Connect security data",
      "columns": [
        {
          "name": "TimeGenerated",
          "type": "datetime",
          "description": "The time when the log entry was generated",
          "isDefaultDisplay": true
        },
        {
          "name": "Id",
          "type": "int",
          "description": "Unique detection ID"
        },
        {
          "name": "Uuid",
          "type": "string",
          "description": "UUID of the detection"
        },
        {
          "name": "DetectionType",
          "type": "int",
          "description": "Type of detection (numeric: 0=UnknownAlarm, 1=RuleActivated, 2=MalwareFoundOnDisk, 3=MalwareFoundInMemory, 4=ExploitDetected, 5=FirewallDetection, 7=BlockedAddress, 8=CryptoBlockerDetection)"
        },
        {
          "name": "DetectionTypeDescription",
          "type": "string",
          "description": "Human-readable description of the detection type (enriched from DetectionType field)"
        },
        {
          "name": "CreationTime",
          "type": "datetime",
          "description": "Timestamp when the detection was created"
        },
        {
          "name": "ComputerId",
          "type": "string",
          "description": "Computer identifier"
        },
        {
          "name": "ComputerName",
          "type": "string",
          "description": "Name of the computer where detection occurred"
        },
        {
          "name": "ComputerUuid",
          "type": "string",
          "description": "UUID of the computer"
        },
        {
          "name": "Severity",
          "type": "string",
          "description": "Severity level of the detection"
        },
        {
          "name": "SeverityScore",
          "type": "int",
          "description": "Numeric severity score"
        },
        {
          "name": "Priority",
          "type": "string",
          "description": "Priority level of the detection"
        },
        {
          "name": "Handled",
          "type": "boolean",
          "description": "Whether the detection has been handled"
        },
        {
          "name": "Resolved",
          "type": "boolean",
          "description": "Whether the detection has been resolved"
        },
        {
          "name": "Note",
          "type": "string",
          "description": "Additional notes about the detection"
        },
        {
          "name": "RuleName",
          "type": "string",
          "description": "Name of the detection rule"
        },
        {
          "name": "RuleId",
          "type": "string",
          "description": "ID of the detection rule"
        },
        {
          "name": "RuleUuid",
          "type": "string",
          "description": "UUID of the detection rule"
        },
        {
          "name": "ThreatName",
          "type": "string",
          "description": "Name of the detected threat"
        },
        {
          "name": "ThreatUri",
          "type": "string",
          "description": "URI reference for the threat"
        },
        {
          "name": "ModuleId",
          "type": "string",
          "description": "Module identifier"
        },
        {
          "name": "ModuleName",
          "type": "string",
          "description": "Name of the module/file"
        },
        {
          "name": "ModuleSha1",
          "type": "string",
          "description": "SHA1 hash of the module"
        },
        {
          "name": "ModuleSignatureType",
          "type": "int",
          "description": "Module signature type (90=Trusted, 80=Valid, 75=AdHoc, 70=None, 60=Invalid, 0=Unknown)"
        },
        {
          "name": "ModuleSignatureTypeDescription",
          "type": "string",
          "description": "Human-readable description of module signature type (enriched from ModuleSignatureType field)"
        },
        {
          "name": "ModuleSigner",
          "type": "string",
          "description": "Signer of the module"
        },
        {
          "name": "ModuleFirstSeenLocally",
          "type": "datetime",
          "description": "When the module was first seen locally"
        },
        {
          "name": "ModuleLastExecutedLocally",
          "type": "datetime",
          "description": "When the module was last executed locally"
        },
        {
          "name": "ModuleLgAge",
          "type": "int",
          "description": "LiveGrid age of the module"
        },
        {
          "name": "ModuleLgPopularity",
          "type": "int",
          "description": "LiveGrid popularity of the module"
        },
        {
          "name": "ModuleLgReputation",
          "type": "int",
          "description": "LiveGrid reputation of the module"
        },
        {
          "name": "ProcessId",
          "type": "string",
          "description": "Process identifier"
        },
        {
          "name": "ProcessPath",
          "type": "string",
          "description": "Path of the process involved"
        },
        {
          "name": "ProcessCommandLine",
          "type": "string",
          "description": "Process command line arguments"
        },
        {
          "name": "ProcessUser",
          "type": "string",
          "description": "User account associated with the process"
        },
        {
          "name": "ConnectorName",
          "type": "string",
          "description": "Connector Friendly Name assigned during connector setup"
        },
        {
          "name": "ProductIds",
          "type": "string",
          "description": "ESET product selected for this connector instance (EP, EI, or ECOS)"
        },
        {
          "name": "BaseUrl",
          "type": "string",
          "description": "Base URL of the ESET Inspect server (enriched from connector configuration)"
        },
        {
          "name": "DeepLink",
          "type": "string",
          "description": "Deep link URL to view this detection in ESET Inspect console"
        }
      ]
    }
  }
}