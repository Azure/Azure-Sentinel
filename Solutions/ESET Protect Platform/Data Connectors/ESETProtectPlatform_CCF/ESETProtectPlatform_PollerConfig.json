[
  {
    "type": "Microsoft.SecurityInsights/dataConnectors",
    "apiVersion": "2025-03-01",
    "name": "[[concat('parameters('workspace')', '/Microsoft.SecurityInsights/','IntegrationTableV2_CL' , uniqueString(parameters('friendlyName')) )]",
    "location": "{{location}}",
    "kind": "RestApiPoller",
    "properties": {
      "auth": {
        "type": "OAuth2",
        "ClientId": "[[parameters('clientId')]",
        "ClientSecret": "[[parameters('clientSecret')]",
        "UserName": "[[parameters('username')]",
        "Password": "[[parameters('password')]",
        "GrantType": "password",
        "TokenEndpoint": "[[concat(parameters('tokenEndpoint'), '/oauth/token')]"
      },
      "request": {
        "apiEndpoint": "[[concat(parameters('esetBaseUrl'), '/v1/detections')]",
        "httpMethod": "GET",
        "rateLimitQPS": 10,
        "queryWindowInMin": 15,
        "queryTimeFormat": "yyyy-MM-ddTHH:mm:ss'Z'",
        "retryCount": 3,
        "timeoutInSeconds": 120,
        "headers": {
          "Content-Type": "application/json",
          "Accept": "application/json",
          "User-Agent": "MS-Sentinel-CCF-ESET"
        },
        "queryParameters": {
          "startTime": "{_QueryWindowStartTime}",
          "endTime": "{_QueryWindowEndTime}"
        }
      },
      "response": {
        "eventsJsonPaths": [
          "$.detections[*]"
        ],
        "format": "json"
      },
      "paging": {
        "pagingType": "NextPageToken",
        "nextPageTokenJsonPath": "$.nextPageToken",
        "NextPageParaName": "pageToken",
        "pageSize": 1000,
        "pageSizeParameterName": "pageSize"
      },
      "connectorDefinitionName": "ESETConnectConnector",
      "dataType": "IntegrationTableV2_CL",
      "dcrConfig": {
        "streamName": "Custom-IntegrationTableV2_CL",
        "dataCollectionEndpoint": "{{dataCollectionEndpoint}}",
        "dataCollectionRuleImmutableId": "{{dataCollectionRuleImmutableId}}"
      },
      "addOnAttributes": {
        "friendlyName": "[[parameters('friendlyName')]",
        "productIds": "[[parameters('productIds')[0]]"
      }
    },
    "condition": "[[or(contains(parameters('productIds'), 'EP'), and(contains(parameters('productIds'), 'EI'), equals(parameters('deploymentMode'), 'Cloud')))]"
  },
  {
    "type": "Microsoft.SecurityInsights/dataConnectors",
    "apiVersion": "2025-03-01",
    "name": "[[concat('parameters('workspace')', '/Microsoft.SecurityInsights/','IntegrationTableV2_CL' , uniqueString(parameters('friendlyName')) )]",
    "location": "{{location}}",
    "kind": "RestApiPoller",
    "properties": {
      "auth": {
        "type": "OAuth2",
        "ClientId": "[[parameters('clientId')]",
        "ClientSecret": "[[parameters('clientSecret')]",
        "UserName": "[[parameters('username')]",
        "Password": "[[parameters('password')]",
        "GrantType": "password",
        "TokenEndpoint": "[[concat(parameters('tokenEndpoint'), '/oauth/token')]"
      },
      "request": {
        "apiEndpoint": "[[concat(parameters('esetBaseUrl'), '/v2/detections')]",
        "httpMethod": "GET",
        "rateLimitQPS": 10,
        "queryWindowInMin": 15,
        "queryTimeFormat": "yyyy-MM-ddTHH:mm:ss'Z'",
        "retryCount": 3,
        "timeoutInSeconds": 120,
        "headers": {
          "Content-Type": "application/json",
          "Accept": "application/json",
          "User-Agent": "MS-Sentinel-CCF-ESET"
        },
        "queryParameters": {
          "startTime": "{_QueryWindowStartTime}",
          "endTime": "{_QueryWindowEndTime}"
        }
      },
      "response": {
        "eventsJsonPaths": [
          "$.detections[*]"
        ],
        "format": "json"
      },
      "paging": {
        "pagingType": "NextPageToken",
        "nextPageTokenJsonPath": "$.nextPageToken",
        "NextPageParaName": "pageToken",
        "pageSize": 1000,
        "pageSizeParameterName": "pageSize"
      },
      "connectorDefinitionName": "ESETConnectConnector",
      "dataType": "IntegrationTableV2_CL",
      "dcrConfig": {
        "streamName": "Custom-IntegrationTableV2_CL",
        "dataCollectionEndpoint": "{{dataCollectionEndpoint}}",
        "dataCollectionRuleImmutableId": "{{dataCollectionRuleImmutableId}}"
      },
      "addOnAttributes": {
        "friendlyName": "[[parameters('friendlyName')]",
        "productIds": "[[parameters('productIds')[0]]"
      }
    },
    "condition": "[[contains(parameters('productIds'), 'ECOS')]"
  },
  {
    "type": "Microsoft.SecurityInsights/dataConnectors",
    "apiVersion": "2025-03-01",
    "name": "[[concat('parameters('workspace')', '/Microsoft.SecurityInsights/','IntegrationTableIncidentsV2_CL' , uniqueString(parameters('friendlyName')) )]",
    "location": "{{location}}",
    "kind": "RestApiPoller",
    "properties": {
      "auth": {
        "type": "OAuth2",
        "ClientId": "[[parameters('clientId')]",
        "ClientSecret": "[[parameters('clientSecret')]",
        "UserName": "[[parameters('username')]",
        "Password": "[[parameters('password')]",
        "GrantType": "password",
        "TokenEndpoint": "[[concat(parameters('tokenEndpoint'), '/oauth/token')]"
      },
      "request": {
        "apiEndpoint": "[[concat(parameters('esetBaseUrl'), '/v2/incidents')]",
        "httpMethod": "GET",
        "rateLimitQPS": 10,
        "queryWindowInMin": 15,
        "queryTimeFormat": "yyyy-MM-ddTHH:mm:ss'Z'",
        "retryCount": 3,
        "timeoutInSeconds": 120,
        "headers": {
          "Content-Type": "application/json",
          "Accept": "application/json",
          "User-Agent": "MS-Sentinel-CCF-ESET"
        },
        "queryParameters": {
          "filter": "incident.create_time >= timestamp(\"{_QueryWindowStartTime}\") AND incident.create_time < timestamp(\"{_QueryWindowEndTime}\")",
          "orderBy": "create_time desc",
          "pageSize": "1000"
        }
      },
      "response": {
        "eventsJsonPaths": [
          "$.incidents[*]"
        ],
        "format": "json"
      },
      "paging": {
        "pagingType": "NextPageToken",
        "nextPageTokenJsonPath": "$.nextPageToken",
        "NextPageParaName": "pageToken",
        "pageSize": 1000,
        "pageSizeParameterName": "pageSize"
      },
      "connectorDefinitionName": "ESETConnectConnector",
      "dataType": "IntegrationTableIncidentsV2_CL",
      "dcrConfig": {
        "streamName": "Custom-IntegrationTableIncidentsV2_CL",
        "dataCollectionEndpoint": "{{dataCollectionEndpoint}}",
        "dataCollectionRuleImmutableId": "{{dataCollectionRuleImmutableId}}"
      },
      "addOnAttributes": {
        "friendlyName": "[[parameters('friendlyName')]",
        "productIds": "[[parameters('productIds')[0]]"
      }
    },
    "condition": "[[and(contains(parameters('productIds'), 'EI'), equals(parameters('deploymentMode'), 'Cloud'))]"
  },
  {
    "type": "Microsoft.SecurityInsights/dataConnectors",
    "apiVersion": "2025-03-01",
    "name": "[[concat('parameters('workspace')', '/Microsoft.SecurityInsights/','ESETInspectV2_CL' , uniqueString(parameters('friendlyName')) )]",
    "location": "{{location}}",
    "kind": "RestApiPoller",
    "properties": {
      "auth": {
        "type": "OAuth2",
        "ClientId": "[[parameters('clientId')]",
        "ClientSecret": "[[parameters('clientSecret')]",
        "UserName": "[[parameters('username')]",
        "Password": "[[parameters('password')]",
        "GrantType": "password",
        "TokenEndpoint": "[[concat(parameters('tokenEndpoint'), '/oauth/token')]"
      },
      "request": {
        "apiEndpoint": "[[concat(parameters('esetBaseUrl'),'/api/v1/detections')]",
        "httpMethod": "GET",
        "rateLimitQPS": 1,
        "queryWindowInMin": 15,
        "queryTimeFormat": "yyyy-MM-ddTHH:mm:ssZ",
        "retryCount": 3,
        "timeoutInSeconds": 60,
        "headers": {
          "Content-Type": "application/json",
          "Accept": "application/json"
        },
        "queryParameters": {
          "$orderBy": "id asc",
          "$filter": "[[concat('id ge ', if(equals(parameters('startFromDetectionId'), 'startFromDetectionId'), '0', parameters('startFromDetectionId')))]",
          "$count": "1"
        }
      },
      "response": {
        "eventsJsonPaths": [
          "$"
        ],
        "format": "json"
      },
      "paging": {
        "pagingType": "Offset",
        "offsetParaName": "$skip",
        "pageSize": 100,
        "pageSizeParameterName": "$top"
      },
      "stepInfo": {
        "stepType": "Nested",
        "nextSteps": [
          {
            "stepId": "detection_details",
            "stepPlaceholdersParsingKql": "source | project res = parse_json(data) | project detections = res['value'] | mvexpand detections | project id = detections['id']"
          }
        ]
      },
      "stepCollectorConfigs": {
        "detection_details": {
          "shouldJoinNestedData": false,
          "request": {
            "apiEndpoint": "[[concat(parameters('esetBaseUrl'),'/api/v1/detections/$id$')]",
            "httpMethod": "GET",
            "rateLimitQPS": 1,
            "queryWindowInMin": 5,
            "retryCount": 3,
            "timeoutInSeconds": 60,
            "headers": {
              "Content-Type": "application/json",
              "Accept": "application/json"
            }
          },
          "response": {
            "eventsJsonPaths": [
              "$.DETECTION"
            ],
            "format": "json"
          }
        }
      },
      "connectorDefinitionName": "ESETConnectConnector",
      "dataType": "ESETInspectV2_CL",
      "dcrConfig": {
        "streamName": "Custom-ESETInspectV2_CL",
        "dataCollectionEndpoint": "{{dataCollectionEndpoint}}",
        "dataCollectionRuleImmutableId": "{{dataCollectionRuleImmutableId}}"
      },
      "addOnAttributes": {
        "esetBaseUrl": "[[parameters('esetBaseUrl')]",
        "friendlyName": "[[parameters('friendlyName')]",
        "productIds": "[[parameters('productIds')[0]]"
      }
    },
    "condition": "[[and(contains(parameters('productIds'), 'EI'), equals(parameters('deploymentMode'), 'On-Premise'))]"
  }
]