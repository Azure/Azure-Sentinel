        "queryWindowInMin": 60,
        "headers": {
          "Accept": "application/json",
          "User-Agent": "spycloud_microsoftccf/1.0.0"
        },
        "queryParameters": {
          "since_modification_date": "{_QueryWindowStartTime}",
          "until_modification_date": "{_QueryWindowStartTime}",
          "severity": "{{severity}}"
        },
        "retryCount": 3,
        "timeoutInSeconds": 60
      },
      "response": {
        "eventsJsonPaths": [
