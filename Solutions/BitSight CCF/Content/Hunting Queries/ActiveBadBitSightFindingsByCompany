id: cea0dea5-6448-4ea5-91c2-38d719448eb9
name: Active BAD BitSight findings by company
description: |
  Shows the latest active BAD BitSight findings summarized by company.
requiredDataConnectors:
  - connectorId: bitsight-risk-findings-ccf
    dataTypes:
      - BitsightRiskFindings_CL
tactics:
  - Impact
query: |
  BitsightRiskFindings_CL
  | summarize arg_max(TimeGenerated, *) by finding_uid
  | where normalized_risk_state == "bad"
  | summarize BadFindings=count(), RiskVectors=make_set(risk_vector_label, 20) by company_name, company_guid
  | order by BadFindings desc
