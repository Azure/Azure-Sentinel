  "contentVersion": "1.0.0.0",
  "parameters": {
    "workspaceName": {
      "value": "<log-analytics-workspace-name>"
    },
    "location": {
      "value": "<workspace-region>"
    },
    "connectorDefinitionName": {
      "value": "bitsight-full-ccf"
    },
    "createDce": {
      "value": true
    },
    "existingDceResourceId": {
      "value": ""
    },
    "tableNames": {
      "value": {
        "portfolioCompanies": "BitsightPortfolio_Companies",
        "companyDetails": "BitsightCompany_details",
        "companyRatingDetails": "BitsightCompany_rating_details",
        "alerts": "BitsightAlerts_data",
        "graph": "BitsightGraph_data",
        "diligenceHistorical": "BitsightDiligence_historical_statistics",
