        "findings": "BitsightFindings_data",
        "findingsSummary": "BitsightFindings_summary",
        "breaches": "BitsightBreaches_data"
      }
    },
    "portfolioCompaniesConfig": {
      "value": {
        "request": {
          "apiEndpoint": "https://api.bitsighttech.com/<replace>/portfolio-companies",
          "httpMethod": "Get",
          "queryWindowInMin": 30,
          "retryCount": 3,
          "timeoutInSeconds": 60,
          "rateLimitQPS": 2,
          "headers": {
            "Accept": "application/json"
          },
          "queryParameters": {
            "limit": "100"
          }
        },
        "response": {
          "eventsJsonPaths": [
            "$.results[*]"
          ],
          "format": "json"
        },
        "paging": {
          "pagingType": "Offset",
          "offsetParaName": "offset",
          "pageSize": 100,
          "pageSizeParameterName": "limit",
          "pagingInfoPlacement": "QueryString",
          "pagingQueryParamOnly": false
        }
      }
    },
