{
  "name": "D3SOARConnectorDefinition",
  "apiVersion": "2022-09-01-preview",
  "type": "Microsoft.SecurityInsights/dataConnectorDefinitions",
  "location": "{{location}}",
  "kind": "Customizable",
  "properties": {
    "connectorUiConfig": {
      "id": "D3SOARConnectorDefinition",
      "title": "D3 SOAR Incidents",
      "publisher": "D3 Security",
      "descriptionMarkdown": "The D3SOAR data connector pulls incidents from D3 SOAR into Microsoft Sentinel using the D3 codeless REST API command endpoint.",
      "graphQueries": [
        {
          "metricName": "Total incidents received",
          "legend": "D3 SOAR Incidents",
          "baseQuery": "D3SOARIncidents_CL"
        }
      ],
      "sampleQueries": [
        {
          "description": "Get sample D3 SOAR incidents",
          "query": "D3SOARIncidents_CL | take 10"
        }
      ],
      "dataTypes": [
        {
          "name": "D3SOARIncidents_CL",
          "lastDataReceivedQuery": "D3SOARIncidents_CL | where TimeGenerated > ago(12h) | summarize Time=max(TimeGenerated) | where isnotempty(Time)"
        }
      ],
      "connectivityCriteria": [
        {
          "type": "HasDataConnectors"
        }
      ],
      "availability": {
        "status": 1,
        "isPreview": false
      },
      "permissions": {
        "resourceProvider": [
          {
            "provider": "Microsoft.OperationalInsights/workspaces",
            "permissionsDisplayText": "Read and Write permissions are required.",
            "providerDisplayName": "Workspace",
            "scope": "Workspace",
            "requiredPermissions": {
              "read": true,
              "write": true,
              "delete": true,
              "action": false
            }
          }
        ]
      },
      "instructionSteps": [
        {
          "instructions": [
            {
              "type": "Textbox",
              "parameters": {
                "label": "Base URL",
                "placeholder": "https://poc.bemimo.com",
                "type": "text",
                "name": "BaseUrl"
              }
            },
            {
              "type": "Textbox",
              "parameters": {
                "label": "Username",
                "placeholder": "admin",
                "type": "text",
                "name": "Username"
              }
            },
            {
              "type": "Textbox",
              "parameters": {
                "label": "Site",
                "placeholder": "Security Operations",
                "type": "text",
                "name": "Site"
              }
            },
            {
              "type": "Textbox",
              "parameters": {
                "label": "D3 JWT",
                "placeholder": "ey...",
                "type": "password",
                "name": "D3Jwt"
              }
            },
            {
              "type": "ConnectionToggleButton",
              "parameters": {
                "label": "toggle",
                "name": "toggle"
              }
            }
          ]
        }
      ]
    }
  }
}
