{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "author": "D3 Security - support@d3security.com",
    "comments": "Starter solution template for D3SOAR"
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Not used directly. Workspace location is derived from selected Log Analytics workspace."
      }
    },
    "workspace-location": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Region to deploy solution resources."
      }
    },
    "workspace": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Workspace name for Log Analytics where Microsoft Sentinel is enabled."
      }
    }
  },
  "variables": {
    "_solutionName": "D3SOAR",
    "_solutionVersion": "3.0.0",
    "solutionId": "d3security.azure-sentinel-solution-d3soar",
    "_solutionId": "[variables('solutionId')]",
    "_solutioncontentProductId": "[concat(take(variables('_solutionId'),50),'-','sl','-', uniqueString(concat(variables('_solutionId'),'-','Solution','-',variables('_solutionId'),'-', variables('_solutionVersion'))))]"
  },
  "resources": [
    {
      "type": "Microsoft.OperationalInsights/workspaces/providers/contentPackages",
      "apiVersion": "2023-04-01-preview",
      "location": "[parameters('workspace-location')]",
      "properties": {
        "version": "3.0.0",
        "kind": "Solution",
        "contentSchemaVersion": "3.0.0",
        "displayName": "D3SOAR",
        "publisherDisplayName": "D3 Security",
        "descriptionHtml": "<p>The D3SOAR solution installs content for Microsoft Sentinel.</p>",
        "contentKind": "Solution",
        "contentProductId": "[variables('_solutioncontentProductId')]",
        "id": "[variables('_solutioncontentProductId')]",
        "icon": "<img src=\"https://raw.githubusercontent.com/Azure/Azure-Sentinel/master/Logos/D3SOAR.svg\" width=\"75px\" height=\"75px\">",
        "contentId": "[variables('_solutionId')]",
        "parentId": "[variables('_solutionId')]",
        "source": {
          "kind": "Solution",
          "name": "D3SOAR",
          "sourceId": "[variables('_solutionId')]"
        },
        "author": {
          "name": "D3 Security",
          "email": "support@d3security.com"
        },
        "support": {
          "name": "D3 Security",
          "email": "support@d3security.com",
          "tier": "Partner",
          "link": "https://d3security.com/support"
        },
        "firstPublishDate": "2026-02-18",
        "providers": [
          "D3 Security"
        ],
        "categories": {
          "domains": [
            "Security - Threat Protection"
          ]
        }
      },
      "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/', variables('_solutionId'))]"
    }
  ],
  "outputs": {}
}