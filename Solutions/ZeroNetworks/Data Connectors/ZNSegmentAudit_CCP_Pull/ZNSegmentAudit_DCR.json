[
    {
        "name": "ZNSegmentAuditDCR",
        "apiVersion": "2021-09-01-preview",
        "type": "Microsoft.Insights/dataCollectionRules",
        "location": "{{location}}",
        "properties": {
            "dataCollectionEndpointId": "{{dataCollectionEndpointId}}",
            "streamDeclarations": {
                "Custom-ZNSegmentAuditNativePoller": {
                    "columns": [
                        { "name": "timestamp", "type": "long" },
                        { "name": "isoTimestamp", "type": "string" },
                        { "name": "auditType", "type": "int" },
                        { "name": "enforcementSource", "type": "int" },
                        { "name": "userRole", "type": "int" },
                        { "name": "destinationEntitiesList", "type": "dynamic" },
                        { "name": "details", "type": "string" },
                        { "name": "parentObjectId", "type": "string" },
                        { "name": "reportedObjectId", "type": "string" },
                        { "name": "reportedObjectGeneration", "type": "long" },
                        { "name": "performedBy", "type": "dynamic" },
                        { "name": "onBehalfOfEmail", "type": "string" }
                    ]
                }
            },
            "destinations": {
                "logAnalytics": [
                    {
                        "workspaceResourceId": "{{workspaceResourceId}}",
                        "name": "clv2ws1"
                    }
                ]
            },
            "dataFlows": [
                {
                    "streams": [
                        "Custom-ZNSegmentAuditNativePoller"
                    ],
                    "destinations": [
                        "clv2ws1"
                    ],
                    "transformKql": "source | extend TimeGenerated = todatetime(isoTimestamp) | project TimeGenerated, timestamp, isoTimestamp, auditType, enforcementSource, userRole, destinationEntitiesList, details, parentObjectId, reportedObjectId, reportedObjectGeneration, performedBy, onBehalfOfEmail",
                    "outputStream": "Custom-ZNSegmentAuditNativePoller_CL"
                }
            ]
        }
    }
]
