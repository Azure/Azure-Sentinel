[
    {
        "type": "Microsoft.SecurityInsights/dataConnectors",
        "apiVersion": "2022-10-01-preview",
        "name": "ZNSegmentAudit",
        "kind": "RestApiPoller",
        "properties": {
            "connectorDefinitionName": "ZNSegmentAuditCCPDefinition",
            "dataType": "ZNSegmentAuditNativePoller_CL",
            "dcrConfig": {
                "streamName": "Custom-ZNSegmentAuditNativePoller",
                "dataCollectionEndpoint": "{{dataCollectionEndpoint}}",
                "dataCollectionRuleImmutableId": "{{dataCollectionRuleImmutableId}}"
            },
            "auth": {
                "type": "APIKey",
                "ApiKey": "{{apikey}}",
                "ApiKeyName": "Authorization"
            },
            "request": {
                "apiEndpoint": "https://{{baseUrl}}/api/v1/audit",
                "httpMethod": "GET",
                "queryTimeFormat": "UnixTimestampInMills",
                "queryWindowInMin": 5,
                "startTimeAttributeName": "from",
                "endTimeAttributeName": "to",
                "queryParameters": {
                    "order": "desc"
                },
                "headers": {
                    "Accept": "application/json"
                },
                "retryCount": 3,
                "timeoutInSeconds": 60
            },
            "response": {
                "eventsJsonPaths": [
                    "$.items"
                ]
            },
            "paging": {
                "pagingType": "NextPageToken",
                "nextPageParaName": "_cursor",
                "nextPageTokenJsonPath": "..scrollCursor",
                "pageSize": 400,
                "pageSizeParaName": "_limit"
            }
        }
    }
]
