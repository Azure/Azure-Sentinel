[
    {
        "name": "ZNSegmentPushDCR",
        "apiVersion": "2021-09-01-preview",
        "type": "Microsoft.Insights/dataCollectionRules",
        "location": "{{location}}",
        "properties": {
            "dataCollectionEndpointId": "{{dataCollectionEndpointId}}",
            "streamDeclarations": {
                "Custom-ZNAudit": {
                    "columns": [
                        { "name": "TimestampEpoch", "type": "long" },
                        { "name": "TimestampIso8601", "type": "string" },
                        { "name": "AuditType", "type": "string" },
                        { "name": "Platform", "type": "string" },
                        { "name": "InitiatedBy", "type": "dynamic" },
                        { "name": "AffectedEntity", "type": "dynamic" },
                        { "name": "Details", "type": "string" },
                        { "name": "ReportedObjectId", "type": "string" },
                        { "name": "ParentObjectId", "type": "string" }
                    ]
                },
                "Custom-ZNNetworkActivity": {
                    "columns": [
                        { "name": "TimestampEpoch", "type": "long" },
                        { "name": "TimestampIso8601", "type": "string" },
                        { "name": "ProtocolType", "type": "int" },
                        { "name": "ConnectionStatus", "type": "string" },
                        { "name": "TrafficType", "type": "string" },
                        { "name": "InboundRuleIds", "type": "dynamic" },
                        { "name": "OutboundRuleIds", "type": "dynamic" },
                        { "name": "Src", "type": "dynamic" },
                        { "name": "Dst", "type": "dynamic" }
                    ]
                },
                "Custom-ZNIdentityActivity": {
                    "columns": [
                        { "name": "TimestampEpoch", "type": "long" },
                        { "name": "TimestampIso8601", "type": "string" },
                        { "name": "LogonStatus", "type": "string" },
                        { "name": "LogonType", "type": "string" },
                        { "name": "FailureReason", "type": "string" },
                        { "name": "AuthenticationPackageName", "type": "string" },
                        { "name": "LogonProvider", "type": "string" },
                        { "name": "ImpersonationLevel", "type": "int" },
                        { "name": "EventRecordID", "type": "long" },
                        { "name": "LmPackageName", "type": "string" },
                        { "name": "RuleIds", "type": "dynamic" },
                        { "name": "Src", "type": "dynamic" },
                        { "name": "Dst", "type": "dynamic" },
                        { "name": "SubjectUser", "type": "dynamic" },
                        { "name": "TargetUser", "type": "dynamic" }
                    ]
                },
                "Custom-ZNRPCActivity": {
                    "columns": [
                        { "name": "TimestampEpoch", "type": "long" },
                        { "name": "TimestampIso8601", "type": "string" },
                        { "name": "Status", "type": "string" },
                        { "name": "TrafficType", "type": "int" },
                        { "name": "ProtocolType", "type": "int" },
                        { "name": "Interface", "type": "dynamic" },
                        { "name": "Operation", "type": "dynamic" },
                        { "name": "User", "type": "dynamic" },
                        { "name": "RuleIDs", "type": "dynamic" },
                        { "name": "Src", "type": "dynamic" },
                        { "name": "Dst", "type": "dynamic" }
                    ]
                }
            },
            "destinations": {
                "logAnalytics": [
                    { "workspaceResourceId": "{{workspaceResourceId}}", "name": "clv2ws1" }
                ]
            },
            "dataFlows": [
                {
                    "streams": ["Custom-ZNAudit"],
                    "destinations": ["clv2ws1"],
                    "transformKql": "source | extend TimeGenerated = todatetime(TimestampIso8601) | project TimeGenerated, TimestampEpoch, TimestampIso8601, AuditType, Platform, InitiatedBy, AffectedEntity, Details, ReportedObjectId, ParentObjectId",
                    "outputStream": "Custom-ZNAudit_CL"
                },
                {
                    "streams": ["Custom-ZNNetworkActivity"],
                    "destinations": ["clv2ws1"],
                    "transformKql": "source | extend TimeGenerated = todatetime(TimestampIso8601) | project TimeGenerated, TimestampEpoch, TimestampIso8601, ProtocolType, ConnectionStatus, TrafficType, InboundRuleIds, OutboundRuleIds, Src, Dst",
                    "outputStream": "Custom-ZNNetworkActivity_CL"
                },
                {
                    "streams": ["Custom-ZNIdentityActivity"],
                    "destinations": ["clv2ws1"],
                    "transformKql": "source | extend TimeGenerated = todatetime(TimestampIso8601) | project TimeGenerated, TimestampEpoch, TimestampIso8601, LogonStatus, LogonType, FailureReason, AuthenticationPackageName, LogonProvider, ImpersonationLevel, EventRecordID, LmPackageName, RuleIds, Src, Dst, SubjectUser, TargetUser",
                    "outputStream": "Custom-ZNIdentityActivity_CL"
                },
                {
                    "streams": ["Custom-ZNRPCActivity"],
                    "destinations": ["clv2ws1"],
                    "transformKql": "source | extend TimeGenerated = todatetime(TimestampIso8601) | project TimeGenerated, TimestampEpoch, TimestampIso8601, Status, TrafficType, ProtocolType, Interface, Operation, User, RuleIDs, Src, Dst",
                    "outputStream": "Custom-ZNRPCActivity_CL"
                }
            ]
        }
    }
]
