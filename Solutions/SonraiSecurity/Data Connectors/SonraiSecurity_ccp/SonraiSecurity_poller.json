{
    "id": "a7e3b5c2-d8f1-4e6a-9b0c-2d4f6e8a1b3c",
    "name": "SonraiSecurityPushConnectorPolling",
    "apiVersion": "2023-02-01-preview",
    "type": "Microsoft.SecurityInsights/dataConnectors",
    "kind": "Push",
    "properties": {
        "connectorDefinitionName": "SonraiSecurityPush",
        "dcrConfig": {
            "streamName": "Custom-SonraiSecurityTickets",
            "dataCollectionEndpoint": "{{dataCollectionEndpoint}}",
            "dataCollectionRuleImmutableId": "{{dataCollectionRuleImmutableId}}"
        },
        "auth": {
            "type": "Push",
            "AppId": "{{appId}}",
            "ServicePrincipalId": "{{servicePrincipalId}}"
        },
        "request": {
            "RetryCount": 1
        },
        "response": {
            "eventsJsonPaths": [
                "$.tickets"
            ]
        }
    }
}
