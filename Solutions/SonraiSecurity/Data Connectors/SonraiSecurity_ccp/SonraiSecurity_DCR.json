{
    "name": "SonraiSecurityTickets_DCR",
    "apiVersion": "2023-02-01-preview",
    "type": "Microsoft.Insights/dataCollectionRules",
    "location": "{{location}}",
    "properties": {
        "dataCollectionEndpointId": "{{dataCollectionEndpointId}}",
        "streamDeclarations": {
            "Custom-SonraiSecurityTickets": {
                "columns": [
                    {
                        "name": "TimeGenerated",
                        "type": "datetime"
                    },
                    {
                        "name": "action",
                        "type": "int"
                    },
                    {
                        "name": "digest_title",
                        "type": "string"
                    },
                    {
                        "name": "digest_status",
                        "type": "string"
                    },
                    {
                        "name": "digest_severityCategory",
                        "type": "string"
                    },
                    {
                        "name": "digest_resourceLabel",
                        "type": "string"
                    },
                    {
                        "name": "digest_resourceType",
                        "type": "string"
                    },
                    {
                        "name": "digest_criticalResourceName",
                        "type": "string"
                    },
                    {
                        "name": "digest_org",
                        "type": "string"
                    },
                    {
                        "name": "digest_ticketSrn",
                        "type": "string"
                    },
                    {
                        "name": "digest_ticketKeyName",
                        "type": "string"
                    },
                    {
                        "name": "digest_ticketKeyDescription",
                        "type": "string"
                    },
                    {
                        "name": "digest_assignedTo",
                        "type": "string"
                    }
                ]
            }
        },
        "destinations": {
            "logAnalytics": [
                {
                    "workspaceResourceId": "{{workspaceResourceId}}",
                    "name": "clv2ws1"
                }
            ]
        },
        "dataFlows": [
            {
                "streams": [
                    "Custom-SonraiSecurityTickets"
                ],
                "destinations": [
                    "clv2ws1"
                ],
                "transformKql": "source | extend TimeGenerated = now()",
                "outputStream": "Custom-SonraiSecurityTickets_CL"
            }
        ]
    }
}
