{
    "$schema": "https://schema.management.azure.com/schemas/2021-09-09/uiFormDefinition.schema.json",
    "view": {
        "kind": "Form",
        "properties": {
            "title": "Upwind Logs Loader",
            "steps": [
                {
                    "name": "basics",
                    "label": "Basics",
                    "elements": [
                        {
                            "name": "resourceScope",
                            "type": "Microsoft.Common.ResourceScope",
                            "location": {
                                "metadata": {
                                    "hidden": "Hiding location, we get it from the log analytics workspace"
                                },
                                "visible": false
                            }
                        },
                        {
                            "name": "WorkspaceName",
                            "type": "Microsoft.Common.TextBox",
                            "label": "Log Analytics Workspace Name",
                            "toolTip": "Name of the Log Analytics / Microsoft Sentinel workspace where the custom log table will be created.",
                            "constraints": {
                                "required": true,
                                "regex": "^[a-zA-Z0-9][a-zA-Z0-9-]{2,62}$",
                                "validationMessage": "Workspace name must be 3-63 characters, start with a letter or number, and contain only letters, numbers, and hyphens."
                            }
                        },
                        {
                            "name": "AppInsightsWorkspaceResourceID",
                            "type": "Microsoft.Common.TextBox",
                            "label": "Log Analytics Workspace Resource ID",
                            "placeholder": "/subscriptions/.../resourceGroups/.../providers/Microsoft.OperationalInsights/workspaces/...",
                            "toolTip": "Full Azure Resource ID of the Log Analytics workspace for Application Insights. Find this by clicking 'JSON View' on the workspace Overview page.",
                            "constraints": {
                                "required": true,
                                "regex": "^/subscriptions/[^/]+/resourceGroups/[^/]+/providers/Microsoft\\.OperationalInsights/workspaces/[^/]+$",
                                "validationMessage": "Please enter a valid Log Analytics workspace Resource ID (e.g. /subscriptions/.../resourceGroups/.../providers/Microsoft.OperationalInsights/workspaces/...)."
                            }
                        }
                    ]
                },
                {
                    "name": "upwind",
                    "label": "Upwind Connection",
                    "elements": [
                        {
                            "name": "upwind-text",
                            "type": "Microsoft.Common.TextBlock",
                            "options": {
                                "text": "Configure the credentials used to connect to the Upwind API. Obtain these from your Upwind platform under Settings.",
                                "link": {
                                    "label": "Learn more about Upwind",
                                    "uri": "https://upwind.io"
                                }
                            }
                        },
                        {
                            "name": "UpwindOrgId",
                            "type": "Microsoft.Common.TextBox",
                            "label": "Upwind Organization ID",
                            "toolTip": "Your Upwind Organization ID. Find it in the Upwind platform under Settings → Organization.",
                            "constraints": {
                                "required": true,
                                "validationMessage": "Please enter your Upwind Organization ID."
                            }
                        },
                        {
                            "name": "UpwindClientId",
                            "type": "Microsoft.Common.TextBox",
                            "label": "Upwind API Client ID",
                            "toolTip": "Upwind API client ID from Settings → API Keys.",
                            "constraints": {
                                "required": true,
                                "validationMessage": "Please enter your Upwind API Client ID."
                            }
                        },
                        {
                            "name": "authMethod",
                            "type": "Microsoft.Common.OptionsGroup",
                            "label": "Authentication Method",
                            "defaultValue": "Client Secret",
                            "toolTip": "Choose how to provide the Upwind client secret",
                            "constraints": {
                                "allowedValues": [
                                    {
                                        "label": "Client Secret",
                                        "value": "secret"
                                    },
                                    {
                                        "label": "Key Vault",
                                        "value": "keyvault"
                                    }
                                ],
                                "required": true
                            }
                        },
                        {
                            "name": "UpwindClientSecret",
                            "type": "Microsoft.Common.PasswordBox",
                            "label": {
                                "password": "Upwind API Client Secret"
                            },
                            "toolTip": "Upwind API client secret from Settings → API Keys.",
                            "constraints": {
                                "required": "[equals(steps('upwind').authMethod, 'secret')]"
                            },
                            "options": {
                                "hideConfirmation": true
                            },
                            "visible": "[equals(steps('upwind').authMethod, 'secret')]"
                        },
                        {
                            "name": "keyVaultName",
                            "type": "Microsoft.Common.TextBox",
                            "label": "Key Vault Name",
                            "defaultValue": "",
                            "toolTip": "Name of existing Key Vault containing the Upwind client secret. The secret must be named 'upwind-client-secret'.",
                            "constraints": {
                                "required": "[equals(steps('upwind').authMethod, 'keyvault')]",
                                "regex": "^[a-zA-Z0-9-]{3,24}$",
                                "validationMessage": "Key Vault name must be 3-24 characters and contain only letters, numbers, and hyphens."
                            },
                            "visible": "[equals(steps('upwind').authMethod, 'keyvault')]"
                        },
                        {
                            "name": "UpwindAuthUrl",
                            "type": "Microsoft.Common.TextBox",
                            "label": "Upwind Auth URL",
                            "defaultValue": "https://auth.upwind.io/oauth/token",
                            "toolTip": "Upwind OAuth2 token endpoint. Override only if using a custom Upwind environment.",
                            "constraints": {
                                "required": true,
                                "regex": "^https://.+",
                                "validationMessage": "Please enter a valid HTTPS URL."
                            }
                        },
                        {
                            "name": "UpwindApiBaseUrl",
                            "type": "Microsoft.Common.TextBox",
                            "label": "Upwind API Base URL",
                            "defaultValue": "https://api.upwind.io",
                            "toolTip": "Upwind API base URL. Override only if using a custom Upwind environment.",
                            "constraints": {
                                "required": true,
                                "regex": "^https://.+",
                                "validationMessage": "Please enter a valid HTTPS URL."
                            }
                        }
                    ]
                },
                {
                    "name": "schedule",
                    "label": "Schedule & Advanced",
                    "elements": [
                        {
                            "name": "schedule-text",
                            "type": "Microsoft.Common.TextBlock",
                            "options": {
                                "text": "Configure the polling schedule and advanced settings for the connector.",
                                "link": {
                                    "label": "Learn about CRON expressions",
                                    "uri": "https://learn.microsoft.com/en-us/azure/azure-functions/functions-bindings-timer?tabs=python-v2%2Cisolated-process%2Cnodejs-v4&pivots=programming-language-csharp#ncrontab-expressions"
                                }
                            }
                        },
                        {
                            "name": "UpwindLogsSchedule",
                            "type": "Microsoft.Common.TextBox",
                            "label": "Timer Schedule (CRON)",
                            "defaultValue": "0 0 * * * *",
                            "toolTip": "CRON expression for the Function App timer trigger. Default runs at the top of every hour.",
                            "constraints": {
                                "required": true,
                                "validationMessage": "Please enter a valid 6-field CRON expression (e.g. 0 0 * * * *)."
                            }
                        },
                        {
                            "name": "FunctionName",
                            "type": "Microsoft.Common.TextBox",
                            "label": "Function App Base Name",
                            "defaultValue": "UpwindLogs",
                            "toolTip": "Base name for all created resources (storage account, function app). A unique suffix is appended automatically.",
                            "constraints": {
                                "required": true,
                                "regex": "^[a-zA-Z][a-zA-Z0-9]{1,19}$",
                                "validationMessage": "Must be 2-20 characters, start with a letter, and contain only letters and numbers."
                            }
                        },
                        {
                            "name": "advanced-text",
                            "type": "Microsoft.Common.TextBlock",
                            "options": {
                                "text": "The settings below control pagination and retry behaviour. The defaults are recommended for most deployments."
                            }
                        },
                        {
                            "name": "UpwindPageSize",
                            "type": "Microsoft.Common.Slider",
                            "label": "Page Size",
                            "subLabel": "assets per page",
                            "defaultValue": 100,
                            "toolTip": "Number of assets to request per API page.",
                            "min": 10,
                            "max": 500,
                            "showStepMarkers": false,
                            "constraints": {
                                "required": false
                            }
                        },
                        {
                            "name": "UpwindMaxRetries",
                            "type": "Microsoft.Common.Slider",
                            "label": "Max Retries",
                            "subLabel": "retries",
                            "defaultValue": 4,
                            "toolTip": "Maximum number of retries on transient errors (429, 502, 503, 504).",
                            "min": 0,
                            "max": 10,
                            "showStepMarkers": true,
                            "constraints": {
                                "required": false
                            }
                        },
                        {
                            "name": "UpwindInitialBackoffSeconds",
                            "type": "Microsoft.Common.Slider",
                            "label": "Initial Backoff",
                            "subLabel": "seconds",
                            "defaultValue": 1,
                            "toolTip": "Initial backoff duration in seconds for exponential retry.",
                            "min": 1,
                            "max": 30,
                            "showStepMarkers": false,
                            "constraints": {
                                "required": false
                            }
                        },
                        {
                            "name": "UpwindMaxBackoffSeconds",
                            "type": "Microsoft.Common.Slider",
                            "label": "Max Backoff",
                            "subLabel": "seconds",
                            "defaultValue": 60,
                            "toolTip": "Maximum backoff duration in seconds for exponential retry.",
                            "min": 10,
                            "max": 300,
                            "showStepMarkers": false,
                            "constraints": {
                                "required": false
                            }
                        }
                    ]
                }
            ]
        },
        "outputs": {
            "kind": "ResourceGroup",
            "location": "[steps('basics').resourceScope.location.name]",
            "resourceGroupId": "[steps('basics').resourceScope.resourceGroup.id]",
            "parameters": {
                "FunctionName": "[steps('schedule').FunctionName]",
                "WorkspaceName": "[steps('basics').WorkspaceName]",
                "AppInsightsWorkspaceResourceID": "[steps('basics').AppInsightsWorkspaceResourceID]",
                "UpwindOrgId": "[steps('upwind').UpwindOrgId]",
                "UpwindClientId": "[steps('upwind').UpwindClientId]",
                "UpwindClientSecret": "[if(equals(steps('upwind').authMethod, 'secret'), steps('upwind').UpwindClientSecret, '')]",
                "keyVaultName": "[if(equals(steps('upwind').authMethod, 'keyvault'), steps('upwind').keyVaultName, '')]",
                "UpwindAuthUrl": "[steps('upwind').UpwindAuthUrl]",
                "UpwindApiBaseUrl": "[steps('upwind').UpwindApiBaseUrl]",
                "UpwindPageSize": "[steps('schedule').UpwindPageSize]",
                "UpwindMaxRetries": "[steps('schedule').UpwindMaxRetries]",
                "UpwindInitialBackoffSeconds": "[steps('schedule').UpwindInitialBackoffSeconds]",
                "UpwindMaxBackoffSeconds": "[steps('schedule').UpwindMaxBackoffSeconds]",
                "UpwindLogsSchedule": "[steps('schedule').UpwindLogsSchedule]"
            }
        }
    }
}
