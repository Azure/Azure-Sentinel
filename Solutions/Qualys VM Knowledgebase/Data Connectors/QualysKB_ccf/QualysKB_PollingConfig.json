{
  "type": "Microsoft.SecurityInsights/dataConnectors",
  "apiVersion": "2025-03-01",
  "name": "QualysKBLogsCCP",
  "location": "{{location}}",
  "kind": "RestApiPoller",
  "properties": {
    "auth": {
      "type": "Basic",
      "UserName": "[[parameters('username')]",
      "Password": "[[parameters('password')]"
    },
    "request": {
      "apiEndpoint": "[[concat(parameters('apiServerUrl'),'/api/2.0/fo/knowledge_base/vuln/')]",
      "httpMethod": "GET",
      "rateLimitQPS": 1,
      "queryWindowInMin": 10,
      "queryWindowDelayInMin": 600,
      "queryTimeFormat": "yyyy-MM-ddTHH:mm:ssZ",
      "retryCount": 3,
      "timeoutInSeconds": 60,
      "headers": {
        "X-Requested-With": "XMLHttpRequest",
        "User-Agent": "Scuba"
      },
      "queryParameters": {
        "action": "list",
        "published_after": "{_QueryWindowStartTime}",
        "published_before": "{_QueryWindowEndTime}",
        "details": "All",
        "show_disabled_flag": "0",
        "show_qid_change_log": "[[concat('0',if(and(not(equals(trim(parameters('isPatchable')[0]), '2')), not(equals(trim(parameters('isPatchable')[0]), ''))), concat('&is_patchable=',parameters('isPatchable')[0]), ''),if(and(not(equals(trim(parameters('discoveryMethod')[0]), 'All')), not(equals(trim(parameters('discoveryMethod')[0]), ''))), concat('&discovery_method=',parameters('discoveryMethod')[0]), ''),if(and(not(equals(trim(parameters('discoveryAuthTypes')), 'discoveryAuthTypes')), not(equals(trim(parameters('discoveryAuthTypes')), ''))), concat('&discovery_auth_types=',parameters('discoveryAuthTypes')), ''))]"
      }
    },
    "response": {
      "eventsJsonPaths": [
        "$.KNOWLEDGE_BASE_VULN_LIST_OUTPUT.RESPONSE.VULN_LIST.VULN"
      ],
      "format": "xml"
    },
    "connectorDefinitionName": "QualysKbConnector",
    "dataType": "QualysKnowledgeBase",
    "dcrConfig": {
      "streamName": "SENTINEL_QUALYSKNOWLEDGEBASE",
      "dataCollectionEndpoint": "{{dataCollectionEndpoint}}",
      "dataCollectionRuleImmutableId": "{{dataCollectionRuleImmutableId}}"
    },
    "extra": {
      "transformName": "/ASI/Qualys/QualysKbTransformer"
    }
  }
}