{
  "type": "Microsoft.SecurityInsights/dataConnectors",
  "apiVersion": "2022-10-01-preview",
  "name": "illumioInsightsGraphPoller",
  "location": "{{location}}",
  "kind": "RestApiPoller",
  "properties": {
    "connectorDefinitionName": "SentinelIllumioInsightsGraphCCP",
    "dataType": "IllumioInsightsGraph_CL",
    "auth": {
      "type": "APIKey",
      "ApiKey": "[[parameters('apiToken')]",
      "ApiKeyName": "X-api-secret"
    },
    "request": {
      "apiEndpoint": "https://gw.console.illum.io/api/v1/resource-insights",
      "queryWindowInMin": 15,
      "queryTimeFormat": "UnixTimestampInMills",
      "httpMethod": "GET",
      "timeoutInSeconds": 60,
      "rateLimitQPS": 10,
      "headers": {
        "Accept": "application/json",
        "User-Agent": "MS-Sentinel-CCP-IllumioInsightsGraph",
        "x-illumio-tenant-id": "[[parameters('illumioTenantId')]",
        "X-api-key": "[[parameters('apiKey')]"
      },
      "queryParameters": {
        "after": "{_QueryWindowEndTime}",
        "expand": "graph"
      }
    },
    "response": {
      "eventsJsonPaths": [
        "$"
      ],
      "format": "json"
    },
    "dcrConfig": {
      "streamName": "Custom-IllumioInsightsGraph",
      "dataCollectionEndpoint": "{{dataCollectionEndpoint}}",
      "dataCollectionRuleImmutableId": "{{dataCollectionRuleImmutableId}}"
    }
  }
}