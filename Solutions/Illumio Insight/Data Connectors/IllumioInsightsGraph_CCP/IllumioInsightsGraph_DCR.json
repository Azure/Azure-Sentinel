{
  "name": "IllumioInsightsGraphDCR",
  "apiVersion": "2021-09-01-preview",
  "type": "Microsoft.Insights/dataCollectionRules",
  "location": "{{location}}",
  "properties": {
    "dataCollectionEndpointId": "{{DataCollectionEndpointId}}",
    "streamDeclarations": {
      "Custom-IllumioInsightsGraph": {
        "columns": [
          {
            "name": "TenantId",
            "type": "string"
          },
          {
            "name": "TimeGenerated",
            "type": "string"
          },
          {
            "name": "Name",
            "type": "string"
          },
          {
            "name": "SrcResId",
            "type": "string"
          },
          {
            "name": "SrcIP",
            "type": "string"
          },
          {
            "name": "DestResId",
            "type": "string"
          },
          {
            "name": "DestIP",
            "type": "string"
          },
          {
            "name": "ResourceInternalId",
            "type": "string"
          },
          {
            "name": "IllumioTenantId",
            "type": "string"
          },
          {
            "name": "ResourceTenantId",
            "type": "string"
          },
          {
            "name": "ResourceSubId",
            "type": "string"
          },
          {
            "name": "ResourceRegion",
            "type": "string"
          },
          {
            "name": "ResourceVnetId",
            "type": "string"
          },
          {
            "name": "IllumioUrl",
            "type": "string"
          },
          {
            "name": "Service",
            "type": "string"
          },
          {
            "name": "Port",
            "type": "long"
          },
          {
            "name": "Proto",
            "type": "string"
          },
          {
            "name": "SrcLabel",
            "type": "string"
          },
          {
            "name": "DestLabel",
            "type": "string"
          },
          {
            "name": "TotalSentBytes",
            "type": "long"
          },
          {
            "name": "TotalReceivedBytes",
            "type": "string"
          },
          {
            "name": "SrcThreatLevel",
            "type": "long"
          },
          {
            "name": "SrcCity",
            "type": "string"
          },
          {
            "name": "SrcCountry",
            "type": "string"
          },
          {
            "name": "DestThreatLevel",
            "type": "long"
          },
          {
            "name": "DestCity",
            "type": "string"
          },
          {
            "name": "DestCountry",
            "type": "string"
          },
          {
            "name": "SrcPort",
            "type": "long"
          },
          {
            "name": "DestPort",
            "type": "long"
          },
          {
            "name": "SrcIsWellKnown",
            "type": "string"
          },
          {
            "name": "DestIsWellKnown",
            "type": "boolean"
          },
          {
            "name": "FlowCount",
            "type": "long"
          },
          {
            "name": "CvssSeverity",
            "type": "string"
          },
          {
            "name": "UniqueId",
            "type": "string"
          },
          {
            "name": "Status",
            "type": "string"
          },
          {
            "name": "SourceSystem",
            "type": "string"
          }
        ]
      }
    },
    "destinations": {
      "logAnalytics": [
        {
          "workspaceResourceId": "{{workspaceResourceId}}",
          "name": "clv2ws1"
        }
      ]
    },
    "dataFlows": [
      {
        "streams": [
          "Custom-IllumioInsightsGraph"
        ],
        "destinations": [
          "clv2ws1"
        ],
        "outputStream": "Custom-IllumioInsightsGraph",
        "transformKql": "source | extend TimeGenerated = iff(isempty(CreatedAt), now(), datetime_add('millisecond', tolong(CreatedAt), datetime(1970-01-01))) , ReportPayload = todynamic(ReportPayload) | project TimeGenerated , ReportId , SummaryStartDate , SummaryEndDate , ComparisonStartDate , ComparisonEndDate , CreatedAt , Persona , DataSources , ReportPayload , IllumioTenantId , Tags"
      }
    ]
  }
}