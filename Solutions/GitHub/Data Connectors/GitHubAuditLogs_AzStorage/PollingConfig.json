{
  "type": "Microsoft.SecurityInsights/dataConnectors",
  "apiVersion": "2024-09-01",
  "name": "GitHubAuditLogsBlob",
  "location": "{{location}}",
  "kind": "StorageAccountBlobContainer",
  "eventGridAdvancedFilters": [
    {
      "operatorType": "StringNotContains",
      "key": "subject",
      "values": [
        "/_check"
      ]
    }
  ],
  "properties": {
    "auth": {
      "type": "ServicePrincipal"
    },
    "request": {
      "QueueUri": "[[concat('https://', variables('storageAccountName'), '.queue.core.windows.net/', variables('queueName'))]",
      "DlqUri": "[[concat('https://', variables('storageAccountName'), '.queue.core.windows.net/', variables('dlqName'))]"
    },
    "response": {
      "eventsJsonPaths": [
        "$"
      ],
      "format": "json",
      "isGzipCompressed": true
    },
    "connectorDefinitionName": "GitHubAuditBlobConnector",
    "dataType": "GitHubAuditLogsV2_CL",
    "dcrConfig": {
      "streamName": "Custom-GitHubAuditLogs",
      "dataCollectionEndpoint": "{{dataCollectionEndpoint}}",
      "dataCollectionRuleImmutableId": "{{dataCollectionRuleImmutableId}}"
    }
  }
}