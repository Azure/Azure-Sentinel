{
  "name": "CheckPointEmailSecuritySpamExceptions_CL",
  "type": "Microsoft.OperationalInsights/workspaces/tables",
  "apiVersion": "2022-10-01",
  "tags": {
    "StreamName": "Custom-CheckPointEmailSecuritySpamExceptions_CL",
    "Category": "Security",
    "DataSource": "CheckPointEmailSecurity"
  },
  "properties": {
    "retentionInDays": 180,
    "schema": {
      "name": "CheckPointEmailSecuritySpamExceptions_CL",
      "description": "The CheckPointEmailSecuritySpamExceptions table contains spam whitelist and exception rules from Check Point Email Security that have been ingested into Microsoft Sentinel.",
      "columns": [
        {
          "name": "TimeGenerated",
          "type": "datetime",
          "description": "The timestamp (in UTC) when the log entry was generated.",
          "isDefaultDisplay": true
        },
        {
          "name": "EntityId",
          "type": "string",
          "description": "Unique identifier for the spam exception."
        },
        {
          "name": "AttachmentMd5",
          "type": "string",
          "description": "MD5 hash of the attachment."
        },
        {
          "name": "SenderEmail",
          "type": "string",
          "description": "Email address of the sender."
        },
        {
          "name": "SenderName",
          "type": "string",
          "description": "Name of the sender."
        },
        {
          "name": "Recipient",
          "type": "string",
          "description": "Recipient email address."
        },
        {
          "name": "SenderClientIp",
          "type": "string",
          "description": "Client IP address of the sender.",
          "dataTypeHint": "IP"
        },
        {
          "name": "SenderDomain",
          "type": "string",
          "description": "Domain of the sender."
        },
        {
          "name": "SenderIp",
          "type": "string",
          "description": "IP address of the sender.",
          "dataTypeHint": "IP"
        },
        {
          "name": "LinkDomains",
          "type": "string",
          "description": "Domains contained in email links."
        },
        {
          "name": "Subject",
          "type": "string",
          "description": "Email subject line."
        },
        {
          "name": "Comment",
          "type": "string",
          "description": "Comment associated with the exception."
        },
        {
          "name": "ActionNeeded",
          "type": "string",
          "description": "Action required for the exception."
        },
        {
          "name": "MatchOnlyFuture",
          "type": "string",
          "description": "Indicates if the exception applies only to future emails."
        },
        {
          "name": "QuarantineAll",
          "type": "string",
          "description": "Indicates if all matching emails should be quarantined."
        },
        {
          "name": "IgnoringSpfCheck",
          "type": "boolean",
          "description": "Indicates if SPF check is ignored."
        },
        {
          "name": "SubjectMatching",
          "type": "string",
          "description": "Subject matching criteria (e.g., contains, equals)."
        },
        {
          "name": "LinkDomainMatching",
          "type": "string",
          "description": "Link domain matching criteria."
        },
        {
          "name": "SenderNameMatching",
          "type": "string",
          "description": "Sender name matching criteria."
        },
        {
          "name": "SenderDomainMatching",
          "type": "string",
          "description": "Sender domain matching criteria."
        },
        {
          "name": "SenderEmailMatching",
          "type": "string",
          "description": "Sender email matching criteria."
        },
        {
          "name": "RecipientMatching",
          "type": "string",
          "description": "Recipient matching criteria."
        },
        {
          "name": "AddedBy",
          "type": "string",
          "description": "User ID who added the exception."
        },
        {
          "name": "EditedBy",
          "type": "string",
          "description": "User ID who last edited the exception."
        },
        {
          "name": "UpdateTime",
          "type": "datetime",
          "description": "Timestamp when the exception was last updated."
        }
      ]
    }
  }
}