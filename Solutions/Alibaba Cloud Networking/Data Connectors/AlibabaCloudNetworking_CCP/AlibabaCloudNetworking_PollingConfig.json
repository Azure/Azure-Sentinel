[
  {
    "type": "Microsoft.SecurityInsights/dataConnectors",
    "apiVersion": "2022-10-01-preview",
    "name": "[[concat('parameters('workspace')','/Microsoft.SecurityInsights/', base64(concat( parameters('dataStream')[0], parameters('logRegion'), parameters('logStore'), parameters('logProject') )) )]",
    "location": "{{location}}",
    "kind": "RestApiPoller",
    "properties": {
      "auth": {
        "type": "AliCloudSlsV1",
        "AccessKeyId": "[[parameters('accessKeyId')]",
        "AccessKeySecret": "[[parameters('accessKeySecret')]"
      },
      "request": {
        "apiEndpoint": "[[concat('https://', parameters('logProject'), '.', parameters('logRegion'), '.log.aliyuncs.com/logstores/', parameters('logStore') ) ]",
        "httpMethod": "GET",
        "rateLimitQPS": 2,
        "queryWindowInMin": 5,
        "queryTimeFormat": "UnixTimestamp",
        "retryCount": 3,
        "timeoutInSeconds": 60,
        "headers": {
          "Accept": "application/json",
          "x-log-apiversion": "0.6.0"
        },
        "queryParameters": {
          "type": "log",
          "project": "[[parameters('logProject')]"
        },
        "startTimeAttributeName": "from",
        "endTimeAttributeName": "to"
      },
      "response": {
        "eventsJsonPaths": [
          "$[*]"
        ],
        "format": "json"
      },
      "paging": {
        "pagingType": "Offset",
        "offsetParaName": "offset",
        "pageSize": 200,
        "pageSizeParameterName": "line"
      },
      "connectorDefinitionName": "AlibabaCloudNetworkingConnector",
      "dataType": "AlibabaCloudVPCFlowLogs",
      "dcrConfig": {
        "streamName": "SENTINEL_ALIBABACLOUDVPCFLOWLOGS",
        "dataCollectionEndpoint": "{{dataCollectionEndpoint}}",
        "dataCollectionRuleImmutableId": "{{dataCollectionRuleImmutableId}}"
      },
      "addOnAttributes": {
        "logStore": "[[parameters('logStore')]",
        "logProject": "[[parameters('logProject')]",
        "logRegion": "[[parameters('logRegion')]"
      }
    },
    "condition": "[[equals(parameters('dataStream')[0], 'AlibabaCloudVPCFlowLogs')]"
  },
