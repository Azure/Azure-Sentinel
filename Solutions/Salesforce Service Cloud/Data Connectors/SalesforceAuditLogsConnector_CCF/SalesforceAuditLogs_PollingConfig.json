[
  {
    "type": "Microsoft.SecurityInsights/dataConnectors",
    "apiVersion": "2024-09-01",
    "name": "SalesforceAuditTrailPoller",
    "location": "[parameters('workspace-location')]",
    "kind": "RestApiPoller",
    "properties": {
      "auth": {
        "type": "OAuth2",
        "ClientId": "[[parameters('clientId')]",
        "ClientSecret": "[[parameters('clientSecret')]",
        "UserName": "[[if(equals(parameters('salesforceGrantType'), 'password'), parameters('username'), '')]",
        "Password": "[[if(equals(parameters('salesforceGrantType'), 'password'), parameters('password'), '')]",
        "GrantType": "[[parameters('salesforceGrantType')]",
        "TokenEndpoint": "[[concat(parameters('salesforceBaseUrl'),'/services/oauth2/token')]",
        "TokenEndpointHeaders": {
          "Accept": "application/json",
          "Content-Type": "application/x-www-form-urlencoded"
        },
        "TokenEndpointQueryParameters": {}
      },
      "request": {
        "apiEndpoint": "[[concat(parameters('salesforceBaseUrl'),'/services/data/v66.0/query')]",
        "httpMethod": "GET",
        "rateLimitQPS": 10,
        "queryWindowInMin": 10,
        "queryTimeFormat": "yyyy-MM-ddTHH:mm:ssZ",
        "retryCount": 3,
        "timeoutInSeconds": 30,
        "headers": {
          "Accept": "application/json",
          "User-Agent": "Scuba"
        },
        "queryParameters": {
          "q": "SELECT Id,Action,Section,Display,CreatedDate,CreatedById,CreatedBy.Name,CreatedBy.Email,CreatedBy.Username,DelegateUser FROM SetupAuditTrail WHERE CreatedDate > {_QueryWindowStartTime} AND CreatedDate < {_QueryWindowEndTime}"
        }
      },
      "response": {
        "eventsJsonPaths": [
          "$.records[*]"
        ],
        "format": "json"
      },
      "paging": {
        "pagingType": "NextPageUrl",
        "nextPageUrl": "[[parameters('salesforceBaseUrl')]",
        "nextPageTokenJsonPath": "$.nextRecordsUrl",
        "isNextPageTokenRelativeUrl": true
      },
      "connectorDefinitionName": "SalesforceAuditLogsConnector",
      "dataType": "SalesforceAuditTrail",
      "dcrConfig": {
        "streamName": "SENTINEL_SALESFORCEAUDITTRAIL",
        "dataCollectionEndpoint": "{{dataCollectionEndpoint}}",
        "dataCollectionRuleImmutableId": "{{dataCollectionRuleImmutableId}}"
      },
      "addOnAttributes": {
        "friendlyName": "[[parameters('friendlyName')]",
        "grantType": "[[if(equals(parameters('salesforceGrantType'), 'client_credentials'), 'Client Credentials', 'Password')]",
        "apiUrl": "[[parameters('salesforceBaseUrl')]",
        "dataType": "SalesforceAuditTrail"
      }
    },
    "condition": "[[contains(parameters('selectedDataTypes'), 'setupAuditTrail')]"
  },
  {
    "type": "Microsoft.SecurityInsights/dataConnectors",
    "apiVersion": "2024-09-01",
    "name": "SalesforceLoginHistoryPoller",
    "location": "[parameters('workspace-location')]",
    "kind": "RestApiPoller",
    "properties": {
      "auth": {
        "type": "OAuth2",
        "ClientId": "[[parameters('clientId')]",
        "ClientSecret": "[[parameters('clientSecret')]",
        "UserName": "[[if(equals(parameters('salesforceGrantType'), 'password'), parameters('username'), '')]",
        "Password": "[[if(equals(parameters('salesforceGrantType'), 'password'), parameters('password'), '')]",
        "GrantType": "[[parameters('salesforceGrantType')]",
        "TokenEndpoint": "[[concat(parameters('salesforceBaseUrl'),'/services/oauth2/token')]",
        "TokenEndpointHeaders": {
          "Accept": "application/json",
          "Content-Type": "application/x-www-form-urlencoded"
        },
        "TokenEndpointQueryParameters": {}
      },
      "request": {
        "apiEndpoint": "[[concat(parameters('salesforceBaseUrl'),'/services/data/v66.0/query')]",
        "httpMethod": "GET",
        "rateLimitQPS": 10,
        "queryWindowInMin": 10,
        "queryTimeFormat": "yyyy-MM-ddTHH:mm:ssZ",
        "retryCount": 3,
        "timeoutInSeconds": 30,
        "headers": {
          "Accept": "application/json",
          "User-Agent": "Scuba"
        },
        "queryParameters": {
          "q": "SELECT ApiType,ApiVersion,Application,AuthMethodReference,AuthenticationServiceId,Browser,CipherSuite,ClientVersion,CountryIso,ForwardedForIp,LoginGeoId,LoginSubType,LoginTime,LoginType,LoginUrl,OptionsIsGet,OptionsIsPost,Platform,SourceIp,Status,TlsProtocol,UserId FROM LoginHistory WHERE LoginTime > {_QueryWindowStartTime} AND LoginTime < {_QueryWindowEndTime}"
        }
      },
      "response": {
        "eventsJsonPaths": [
          "$.records[*]"
        ],
        "format": "json"
      },
      "paging": {
        "pagingType": "NextPageUrl",
        "nextPageUrl": "[[parameters('salesforceBaseUrl')]",
        "nextPageTokenJsonPath": "$.nextRecordsUrl",
        "isNextPageTokenRelativeUrl": true
      },
      "connectorDefinitionName": "SalesforceAuditLogsConnector",
      "dataType": "SalesforceLoginHistory",
      "dcrConfig": {
        "streamName": "SENTINEL_SALESFORCELOGINHISTORY",
        "dataCollectionEndpoint": "{{dataCollectionEndpoint}}",
        "dataCollectionRuleImmutableId": "{{dataCollectionRuleImmutableId}}"
      },
      "addOnAttributes": {
        "friendlyName": "[[parameters('friendlyName')]",
        "grantType": "[[if(equals(parameters('salesforceGrantType'), 'client_credentials'), 'Client Credentials', 'Password')]",
        "apiUrl": "[[parameters('salesforceBaseUrl')]",
        "dataType": "SalesforceLoginHistory"
      }
    },
    "condition": "[[contains(parameters('selectedDataTypes'), 'loginHistory')]"
  }
]