{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "title": "Whisper Security - Discover Co-Hosted Domains",
    "description": "Microsoft Sentinel playbook that extracts IP entities from an incident and queries the Whisper Security knowledge graph to discover domains co-hosted on the same infrastructure. Results are posted as an incident comment with a domain list and count.",
    "prerequisites": [
      "Microsoft Sentinel workspace",
      "Whisper API key stored in Azure Key Vault",
      "Key Vault secret URI for the Whisper API key",
      "Whisper Security custom connector deployed (WhisperSecurityConnector)"
    ],
    "lastUpdateTime": "2026-07-13T00:00:00.000Z",
    "support": {
      "tier": "partner"
    },
    "version": "1.0.0",
    "author": {
      "name": "Whisper Security"
    }
  },
  "parameters": {
    "workspace": {
      "type": "string",
      "metadata": {
        "description": "Log Analytics workspace name"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Location for all resources"
      }
    },
    "keyVaultSecretUri": {
      "type": "securestring",
      "metadata": {
        "description": "Full secret URI for the Whisper API key in Key Vault"
      }
    },
    "PlaybookName": {
      "type": "string",
      "defaultValue": "Whisper-DiscoverCoHosted",
      "metadata": {
        "description": "Name of the Logic App playbook"
      }
    },
    "keyVaultName": {
      "type": "string",
      "defaultValue": "[first(split(split(parameters('keyVaultSecretUri'), '/')[2], '.'))]",
      "metadata": {
        "description": "Key Vault name (extracted from keyVaultSecretUri)"
      }
    }
  },
  "variables": {
    "azureSentinelConnectionName": "[concat('azuresentinel-', parameters('PlaybookName'))]",
    "keyvaultConnectionName": "[concat('keyvault-', parameters('PlaybookName'))]"
  },
  "resources": [
    {
      "type": "Microsoft.Web/connections",
      "apiVersion": "2016-06-01",
      "name": "[variables('azureSentinelConnectionName')]",
      "location": "[parameters('location')]",
      "kind": "V1",
      "properties": {
        "displayName": "[variables('azureSentinelConnectionName')]",
        "parameterValueType": "Alternative",
        "api": {
          "id": "[subscriptionResourceId('Microsoft.Web/locations/managedApis', parameters('location'), 'azuresentinel')]"
        }
      }
    },
    {
      "type": "Microsoft.Web/connections",
      "apiVersion": "2018-07-01-preview",
      "name": "[variables('keyvaultConnectionName')]",
      "location": "[parameters('location')]",
      "tags": {
        "hidden-SentinelWorkspaceId": "[parameters('workspace')]"
      },
      "properties": {
        "displayName": "Key Vault - Whisper API Key",
        "api": {
          "id": "[subscriptionResourceId('Microsoft.Web/locations/managedApis', parameters('location'), 'keyvault')]"
        },
        "parameterValueType": "Alternative",
        "alternativeParameterValues": {
          "vaultName": "[parameters('keyVaultName')]"
        }
      }
    },
    {
      "type": "Microsoft.Logic/workflows",
      "apiVersion": "2019-05-01",
      "name": "[parameters('PlaybookName')]",
      "location": "[resourceGroup().location]",
      "tags": {
        "hidden-SentinelTemplateName": "Whisper-DiscoverCoHosted",
        "hidden-SentinelTemplateVersion": "1.0.0",
        "hidden-SentinelWorkspaceId": "[parameters('workspace')]"
      },
      "identity": {
        "type": "SystemAssigned"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/connections', variables('azureSentinelConnectionName'))]",
        "[resourceId('Microsoft.Web/connections', variables('keyvaultConnectionName'))]"
      ],
      "properties": {
        "state": "Enabled",
        "definition": {
          "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
          "contentVersion": "1.0.0.0",
          "parameters": {
            "$connections": {
              "type": "Object"
            },
            "keyVaultSecretUri": {
              "type": "securestring",
              "defaultValue": "[parameters('keyVaultSecretUri')]"
            }
          },
          "triggers": {
            "Microsoft_Sentinel_incident": {
              "type": "ApiConnectionWebhook",
              "inputs": {
                "host": {
                  "connection": {
                    "name": "@parameters('$connections')['azuresentinel']['connectionId']"
                  }
                },
                "body": {
                  "callback_url": "@{listCallbackUrl()}"
                },
                "path": "/incident-creation"
              }
            }
          },
          "actions": {
            "Entities_-_Get_IPs": {
              "type": "ApiConnection",
              "inputs": {
                "host": {
                  "connection": {
                    "name": "@parameters('$connections')['azuresentinel']['connectionId']"
                  }
                },
                "method": "post",
                "body": "@triggerBody()?['object']?['properties']?['relatedEntities']",
                "path": "/entities/ip"
              },
              "runAfter": {}
            },
            "Filter_IP_Entities": {
              "type": "Query",
              "inputs": {
                "from": "@body('Entities_-_Get_IPs')?['IPs']",
                "where": "@not(empty(item()?['Address']))"
              },
              "runAfter": {
                "Entities_-_Get_IPs": [
                  "Succeeded"
                ]
              }
            },
            "Initialize_Comment_Body": {
              "type": "InitializeVariable",
              "inputs": {
                "variables": [
                  {
                    "name": "commentBody",
                    "type": "string",
                    "value": ""
                  }
                ]
              },
              "runAfter": {}
            },
            "For_Each_IP": {
              "type": "Foreach",
              "foreach": "@body('Filter_IP_Entities')",
              "actions": {
                "Validate_Input": {
                  "type": "Compose",
                  "inputs": "@if(or(contains(toUpper(items('For_Each_IP')?['Address']), 'MATCH'), contains(toUpper(items('For_Each_IP')?['Address']), 'RETURN'), contains(toUpper(items('For_Each_IP')?['Address']), 'DELETE'), contains(toUpper(items('For_Each_IP')?['Address']), 'MERGE'), contains(toUpper(items('For_Each_IP')?['Address']), 'CREATE'), contains(toUpper(items('For_Each_IP')?['Address']), 'SET'), contains(toUpper(items('For_Each_IP')?['Address']), 'REMOVE'), contains(toUpper(items('For_Each_IP')?['Address']), 'DETACH')), 'BLOCKED', 'SAFE')",
                  "runAfter": {}
                },
                "Check_Input_Safe": {
                  "type": "If",
                  "expression": {
                    "and": [
                      {
                        "equals": [
                          "@outputs('Validate_Input')",
                          "SAFE"
                        ]
                      }
                    ]
                  },
                  "actions": {
                    "Enrich_Scope": {
                      "type": "Scope",
                      "actions": {
                        "Call_Whisper_DiscoverCoHosted": {
                          "type": "Http",
                          "inputs": {
                            "method": "POST",
                            "uri": "https://graph.whisper.security/api/query",
                            "headers": {
                              "Content-Type": "application/json",
                              "X-API-Key": "@body('Get_API_Key')?['value']"
                            },
                            "body": {
                              "query": "MATCH (ip:IPV4 {name: \"@{items('For_Each_IP')?['Address']}\"})<-[:RESOLVES_TO]-(h:HOSTNAME) RETURN h.name AS hostname, count(h) AS total"
                            },
                            "retryPolicy": {
                              "type": "exponential",
                              "count": 3,
                              "interval": "PT10S",
                              "maximumInterval": "PT1M"
                            }
                          },
                          "runAfter": {
                            "Get_API_Key": [
                              "Succeeded"
                            ]
                          },
                          "runtimeConfiguration": {
                            "secureData": {
                              "properties": [
                                "inputs"
                              ]
                            }
                          }
                        },
                        "Parse_CoHosted_Response": {
                          "type": "ParseJson",
                          "inputs": {
                            "content": "@body('Call_Whisper_DiscoverCoHosted')",
                            "schema": {
                              "type": "object",
                              "properties": {
                                "columns": {
                                  "type": "array",
                                  "items": {
                                    "type": "string"
                                  }
                                },
                                "rows": {
                                  "type": "array",
                                  "items": {
                                    "type": "object"
                                  }
                                }
                              }
                            }
                          },
                          "runAfter": {
                            "Call_Whisper_DiscoverCoHosted": [
                              "Succeeded"
                            ]
                          }
                        },
                        "Format_CoHosted_Comment": {
                          "type": "Compose",
                          "inputs": "@concat('## Whisper Security - Co-Hosted Domain Discovery\n\n**IP Address:** ', items('For_Each_IP')?['Address'], '\n**Co-Hosted Domain Count:** ', string(length(body('Parse_CoHosted_Response')?['rows'])), '\n\n### Domains Found\n\n', if(equals(length(body('Parse_CoHosted_Response')?['rows']), 0), '_No co-hosted domains found._', join(body('Parse_CoHosted_Response')?['rows'], '\n')))",
                          "runAfter": {
                            "Parse_CoHosted_Response": [
                              "Succeeded"
                            ]
                          }
                        },
                        "Append_To_Comment": {
                          "type": "AppendToStringVariable",
                          "inputs": {
                            "name": "commentBody",
                            "value": "@{outputs('Format_CoHosted_Comment')}\n\n---\n\n"
                          },
                          "runAfter": {
                            "Format_CoHosted_Comment": [
                              "Succeeded"
                            ]
                          }
                        },
                        "Get_API_Key": {
                          "type": "ApiConnection",
                          "inputs": {
                            "host": {
                              "connection": {
                                "name": "@parameters('$connections')['keyvault']['connectionId']"
                              }
                            },
                            "method": "get",
                            "path": "/secrets/@{encodeURIComponent(last(split(parameters('keyVaultSecretUri'), '/')))}/value"
                          },
                          "runAfter": {},
                          "runtimeConfiguration": {
                            "secureData": {
                              "properties": [
                                "outputs"
                              ]
                            }
                          }
                        }
                      }
                    }
                  },
                  "else": {
                    "actions": {
                      "Log_Blocked_Input": {
                        "type": "Compose",
                        "inputs": "Cypher injection attempt blocked for IP: @{items('For_Each_IP')?['Address']}"
                      }
                    }
                  },
                  "runAfter": {
                    "Validate_Input": [
                      "Succeeded"
                    ]
                  }
                },
                "Handle_Error": {
                  "type": "Scope",
                  "actions": {
                    "Compose_Error": {
                      "type": "Compose",
                      "inputs": {
                        "message": "Whisper API call failed for co-hosted discovery",
                        "ip": "@items('For_Each_IP')?['Address']",
                        "error": "@result('Enrich_Scope')"
                      }
                    },
                    "Append_Error_Comment": {
                      "type": "AppendToStringVariable",
                      "inputs": {
                        "name": "commentBody",
                        "value": "## Whisper Security - Co-Hosted Discovery Error\n\n**IP Address:** @{items('For_Each_IP')?['Address']}\n**Status:** API call failed. Check playbook run history for details.\n\n---\n\n"
                      },
                      "runAfter": {
                        "Compose_Error": [
                          "Succeeded"
                        ]
                      }
                    }
                  },
                  "runAfter": {
                    "Check_Input_Safe": [
                      "Failed",
                      "TimedOut"
                    ]
                  }
                }
              },
              "runAfter": {
                "Filter_IP_Entities": [
                  "Succeeded"
                ],
                "Initialize_Comment_Body": [
                  "Succeeded"
                ]
              },
              "runtimeConfiguration": {
                "concurrency": {
                  "repetitions": 1
                }
              }
            },
            "Add_Incident_Comment": {
              "type": "ApiConnection",
              "inputs": {
                "host": {
                  "connection": {
                    "name": "@parameters('$connections')['azuresentinel']['connectionId']"
                  }
                },
                "method": "post",
                "body": {
                  "incidentArmId": "@triggerBody()?['object']?['id']",
                  "message": "<p>@{variables('commentBody')}</p>"
                },
                "path": "/Incidents/Comment"
              },
              "runAfter": {
                "For_Each_IP": [
                  "Succeeded",
                  "Failed"
                ]
              }
            }
          },
          "outputs": {}
        },
        "parameters": {
          "$connections": {
            "value": {
              "azuresentinel": {
                "connectionId": "[resourceId('Microsoft.Web/connections', variables('azureSentinelConnectionName'))]",
                "connectionName": "[variables('azureSentinelConnectionName')]",
                "id": "[subscriptionResourceId('Microsoft.Web/locations/managedApis', parameters('location'), 'azuresentinel')]",
                "connectionProperties": {
                  "authentication": {
                    "type": "ManagedServiceIdentity"
                  }
                }
              },
              "keyvault": {
                "connectionId": "[resourceId('Microsoft.Web/connections', variables('keyvaultConnectionName'))]",
                "connectionName": "[variables('keyvaultConnectionName')]",
                "id": "[subscriptionResourceId('Microsoft.Web/locations/managedApis', parameters('location'), 'keyvault')]",
                "connectionProperties": {
                  "authentication": {
                    "type": "ManagedServiceIdentity"
                  }
                }
              }
            }
          }
        }
      }
    }
  ],
  "outputs": {
    "logicAppResourceId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Logic/workflows', parameters('PlaybookName'))]"
    },
    "logicAppName": {
      "type": "string",
      "value": "[parameters('PlaybookName')]"
    },
    "logicAppManagedIdentityPrincipalId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Logic/workflows', parameters('PlaybookName')), '2019-05-01', 'full').identity.principalId]"
    }
  }
}