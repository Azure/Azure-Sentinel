{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "title": "Whisper Security - Logic Apps Custom Connector",
    "description": "Deploys a Logic Apps custom connector and managed API connection for the Whisper Security knowledge graph API. Provides 10 enrichment actions: ExplainIP, ExplainDomain, ExplainASN, ExplainNetwork, DiscoverCoHosted, GetInfraChain, GetWHOISHistory, GetBGPHistory, BatchEnrichment, and CheckASNReputation.",
    "prerequisites": [
      "Azure Sentinel workspace",
      "Whisper API key stored in Azure Key Vault",
      "Key Vault secret URI for the Whisper API key"
    ],
    "version": "1.0.0",
    "author": {
      "name": "Whisper Security"
    }
  },
  "parameters": {
    "workspace": {
      "type": "string",
      "metadata": {
        "description": "Log Analytics workspace name"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Location for all resources"
      }
    },
    "keyVaultSecretUri": {
      "type": "string",
      "metadata": {
        "description": "Full secret URI for the Whisper API key in Key Vault (e.g., https://myvault.vault.azure.net/secrets/whisper-api-key)"
      }
    },
    "connectorName": {
      "type": "string",
      "defaultValue": "WhisperSecurity",
      "metadata": {
        "description": "Name for the custom API connector"
      }
    }
  },
  "variables": {
    "customApiName": "[parameters('connectorName')]",
    "connectionName": "[concat(parameters('connectorName'), '-connection')]",
    "keyVaultApiKeyReference": "[concat('@Microsoft.KeyVault(SecretUri=', parameters('keyVaultSecretUri'), ')')]",
    "_operationQuerySchema": {
      "type": "object",
      "required": [
        "query"
      ],
      "properties": {
        "query": {
          "type": "string",
          "description": "Cypher query",
          "x-ms-summary": "Cypher Query"
        }
      }
    },
    "_operationResponseSchema": {
      "type": "object",
      "properties": {
        "columns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "rows": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "statistics": {
          "type": "object",
          "properties": {
            "rowCount": { "type": "integer" },
            "executionTimeMs": { "type": "integer" }
          }
        }
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.Web/customApis",
      "apiVersion": "2016-06-01",
      "name": "[parameters('connectorName')]",
      "location": "[parameters('location')]",
      "tags": {
        "hidden-SentinelWorkspaceId": "[parameters('workspace')]"
      },
      "properties": {
        "displayName": "Whisper Security",
        "description": "Connect to the Whisper Security knowledge graph for threat intelligence enrichment, infrastructure context, WHOIS/BGP history, and ASN reputation data.",
        "iconUri": "https://graph.whisper.security/favicon.ico",
        "brandColor": "#1a1a2e",
        "capabilities": [
          "actions"
        ],
        "connectionParameters": {
          "api_key": {
            "type": "securestring",
            "uiDefinition": {
              "displayName": "Whisper API Key",
              "description": "The API key for authenticating with the Whisper Security API",
              "tooltip": "Enter your Whisper Security API key",
              "constraints": {
                "required": "true",
                "tabIndex": 1
              }
            }
          }
        },
        "backendService": {
          "serviceUrl": "https://graph.whisper.security"
        },
        "swagger": {
          "swagger": "2.0",
          "info": {
            "title": "Whisper Security",
            "description": "Whisper Security knowledge graph API for threat intelligence enrichment",
            "version": "1.0.0"
          },
          "host": "graph.whisper.security",
          "basePath": "/",
          "schemes": [
            "https"
          ],
          "consumes": [
            "application/json"
          ],
          "produces": [
            "application/json"
          ],
          "securityDefinitions": {
            "api_key": {
              "type": "apiKey",
              "in": "header",
              "name": "X-API-Key"
            }
          },
          "paths": {
            "/api/query": {
              "post": {
                "x-ms-operation": "ExplainIP",
                "summary": "Explain IP Address",
                "description": "Get threat assessment and reputation score for an IP address using CALL explain(ip)",
                "parameters": [
                  {
                    "name": "body",
                    "in": "body",
                    "required": true,
                    "schema": "[variables('_operationQuerySchema')]"
                  }
                ],
                "responses": {
                  "200": {
                    "description": "Threat assessment result",
                    "schema": "[variables('_operationResponseSchema')]"
                  }
                }
              }
            },
            "/api/query#ExplainDomain": {
              "post": {
                "x-ms-operation": "ExplainDomain",
                "summary": "Explain Domain",
                "description": "Get threat assessment and reputation score for a domain using CALL explain(domain)",
                "parameters": [
                  {
                    "name": "body",
                    "in": "body",
                    "required": true,
                    "schema": "[variables('_operationQuerySchema')]"
                  }
                ],
                "responses": {
                  "200": {
                    "description": "Threat assessment result",
                    "schema": "[variables('_operationResponseSchema')]"
                  }
                }
              }
            },
            "/api/query#ExplainASN": {
              "post": {
                "x-ms-operation": "ExplainASN",
                "summary": "Explain ASN",
                "description": "Get threat assessment and reputation score for an ASN using CALL explain(asn)",
                "parameters": [
                  {
                    "name": "body",
                    "in": "body",
                    "required": true,
                    "schema": "[variables('_operationQuerySchema')]"
                  }
                ],
                "responses": {
                  "200": {
                    "description": "ASN threat assessment result",
                    "schema": "[variables('_operationResponseSchema')]"
                  }
                }
              }
            },
            "/api/query#ExplainNetwork": {
              "post": {
                "x-ms-operation": "ExplainNetwork",
                "summary": "Explain Network CIDR",
                "description": "Get threat assessment for a network CIDR block using CALL explain(cidr)",
                "parameters": [
                  {
                    "name": "body",
                    "in": "body",
                    "required": true,
                    "schema": "[variables('_operationQuerySchema')]"
                  }
                ],
                "responses": {
                  "200": {
                    "description": "Network threat assessment result",
                    "schema": "[variables('_operationResponseSchema')]"
                  }
                }
              }
            },
            "/api/query#DiscoverCoHosted": {
              "post": {
                "x-ms-operation": "DiscoverCoHosted",
                "summary": "Discover Co-Hosted Domains",
                "description": "Find domains co-hosted on the same infrastructure using a Cypher traversal query",
                "parameters": [
                  {
                    "name": "body",
                    "in": "body",
                    "required": true,
                    "schema": "[variables('_operationQuerySchema')]"
                  }
                ],
                "responses": {
                  "200": {
                    "description": "Co-hosted domain results",
                    "schema": "[variables('_operationResponseSchema')]"
                  }
                }
              }
            },
            "/api/query#GetInfraChain": {
              "post": {
                "x-ms-operation": "GetInfraChain",
                "summary": "Get Infrastructure Chain",
                "description": "Traverse the infrastructure chain for a domain or IP using a Cypher graph traversal query",
                "parameters": [
                  {
                    "name": "body",
                    "in": "body",
                    "required": true,
                    "schema": "[variables('_operationQuerySchema')]"
                  }
                ],
                "responses": {
                  "200": {
                    "description": "Infrastructure chain result",
                    "schema": "[variables('_operationResponseSchema')]"
                  }
                }
              }
            },
            "/api/query#GetWHOISHistory": {
              "post": {
                "x-ms-operation": "GetWHOISHistory",
                "summary": "Get WHOIS History",
                "description": "Retrieve historical WHOIS snapshots for a domain using CALL whisper.history(domain)",
                "parameters": [
                  {
                    "name": "body",
                    "in": "body",
                    "required": true,
                    "schema": "[variables('_operationQuerySchema')]"
                  }
                ],
                "responses": {
                  "200": {
                    "description": "WHOIS history snapshots",
                    "schema": "[variables('_operationResponseSchema')]"
                  }
                }
              }
            },
            "/api/query#GetBGPHistory": {
              "post": {
                "x-ms-operation": "GetBGPHistory",
                "summary": "Get BGP History",
                "description": "Retrieve BGP routing history for an IP address using CALL whisper.history(ip)",
                "parameters": [
                  {
                    "name": "body",
                    "in": "body",
                    "required": true,
                    "schema": "[variables('_operationQuerySchema')]"
                  }
                ],
                "responses": {
                  "200": {
                    "description": "BGP routing history",
                    "schema": "[variables('_operationResponseSchema')]"
                  }
                }
              }
            },
            "/api/query#BatchEnrichment": {
              "post": {
                "x-ms-operation": "BatchEnrichment",
                "summary": "Batch Indicator Enrichment",
                "description": "Enrich multiple indicators in a single request using the UNWIND batch pattern for O(1) per-item processing",
                "parameters": [
                  {
                    "name": "body",
                    "in": "body",
                    "required": true,
                    "schema": "[variables('_operationQuerySchema')]"
                  }
                ],
                "responses": {
                  "200": {
                    "description": "Batch enrichment results",
                    "schema": "[variables('_operationResponseSchema')]"
                  }
                }
              }
            },
            "/api/query#CheckASNReputation": {
              "post": {
                "x-ms-operation": "CheckASNReputation",
                "summary": "Check ASN Reputation",
                "description": "Assess the reputation of an Autonomous System Number using CALL explain(asn) with reputation-focused analysis",
                "parameters": [
                  {
                    "name": "body",
                    "in": "body",
                    "required": true,
                    "schema": "[variables('_operationQuerySchema')]"
                  }
                ],
                "responses": {
                  "200": {
                    "description": "ASN reputation assessment result",
                    "schema": "[variables('_operationResponseSchema')]"
                  }
                }
              }
            }
          }
        }
      }
    },
    {
      "type": "Microsoft.Web/connections",
      "apiVersion": "2016-06-01",
      "name": "[variables('connectionName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Web/customApis', variables('customApiName'))]"
      ],
      "properties": {
        "displayName": "Whisper Security Connection",
        "customParameterValues": {
          "api_key": "[variables('keyVaultApiKeyReference')]"
        },
        "api": {
          "id": "[resourceId('Microsoft.Web/customApis', variables('customApiName'))]"
        }
      }
    }
  ],
  "outputs": {
    "customApiId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Web/customApis', variables('customApiName'))]"
    },
    "connectionId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Web/connections', variables('connectionName'))]"
    },
    "connectionName": {
      "type": "string",
      "value": "[variables('connectionName')]"
    }
  }
}