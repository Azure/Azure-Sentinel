{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "title": "Whisper Security - Check ASN Reputation",
    "description": "Sentinel incident trigger playbook that extracts IP entities from an incident, determines ASN context, and calls the Whisper Security explain(asn) API for ASN reputation assessment. Results are posted as an incident comment with reputation score, level, max/avg threat scores, and prefix count.",
    "prerequisites": [
      "Azure Sentinel workspace",
      "Whisper API key stored in Azure Key Vault",
      "Key Vault secret URI for the Whisper API key"
    ],
    "version": "1.0.0",
    "author": {
      "name": "Whisper Security"
    }
  },
  "parameters": {
    "workspace": {
      "type": "string",
      "metadata": {
        "description": "Log Analytics workspace name"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Location for all resources"
      }
    },
    "PlaybookName": {
      "type": "string",
      "defaultValue": "Whisper-CheckAsnReputation",
      "metadata": {
        "description": "Name of the Logic App playbook"
      }
    },
    "keyVaultName": {
      "type": "string",
      "metadata": {
        "description": "Name of the Key Vault that holds the Whisper API key"
      }
    },
    "keyVaultSecretUri": {
      "type": "securestring",
      "metadata": {
        "description": "Full Key Vault secret URI for the Whisper API key (e.g., https://myvault.vault.azure.net/secrets/whisper-api-key)"
      }
    }
  },
  "variables": {
    "sentinelConnectionName": "azuresentinel-checkasnrep",
    "keyvaultConnectionName": "keyvault-checkasnrep"
  },
  "resources": [
    {
      "type": "Microsoft.Web/connections",
      "apiVersion": "2018-07-01-preview",
      "name": "[variables('sentinelConnectionName')]",
      "location": "[parameters('location')]",
      "tags": {
        "hidden-SentinelWorkspaceId": "[parameters('workspace')]"
      },
      "properties": {
        "displayName": "Azure Sentinel - Check ASN Reputation",
        "api": {
          "id": "[subscriptionResourceId('Microsoft.Web/locations/managedApis', parameters('location'), 'azuresentinel')]"
        },
        "parameterValueType": "Alternative"
      }
    },
    {
      "type": "Microsoft.Web/connections",
      "apiVersion": "2018-07-01-preview",
      "name": "[variables('keyvaultConnectionName')]",
      "location": "[parameters('location')]",
      "tags": {
        "hidden-SentinelWorkspaceId": "[parameters('workspace')]"
      },
      "properties": {
        "displayName": "Key Vault - Whisper API Key",
        "api": {
          "id": "[subscriptionResourceId('Microsoft.Web/locations/managedApis', parameters('location'), 'keyvault')]"
        },
        "parameterValueType": "Alternative",
        "alternativeParameterValues": {
          "vaultName": "[parameters('keyVaultName')]"
        }
      }
    },
    {
      "type": "Microsoft.Logic/workflows",
      "apiVersion": "2019-05-01",
      "name": "[parameters('PlaybookName')]",
      "location": "[parameters('location')]",
      "tags": {
        "LogicAppsCategory": "security",
        "hidden-SentinelTemplateName": "Whisper-CheckAsnReputation",
        "hidden-SentinelTemplateVersion": "1.0.0",
        "hidden-SentinelWorkspaceId": "[parameters('workspace')]"
      },
      "identity": {
        "type": "SystemAssigned"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/connections', variables('sentinelConnectionName'))]",
        "[resourceId('Microsoft.Web/connections', variables('keyvaultConnectionName'))]"
      ],
      "properties": {
        "state": "Enabled",
        "definition": {
          "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
          "contentVersion": "1.0.0.0",
          "parameters": {
            "$connections": {
              "type": "Object"
            },
            "keyVaultSecretUri": {
              "type": "SecureString"
            }
          },
          "triggers": {
            "Microsoft_Sentinel_incident": {
              "type": "ApiConnectionWebhook",
              "inputs": {
                "host": {
                  "connection": {
                    "name": "@parameters('$connections')['azuresentinel']['connectionId']"
                  }
                },
                "body": {
                  "callback_url": "@{listCallbackUrl()}"
                },
                "path": "/incident-creation"
              }
            }
          },
          "actions": {
            "Entities_-_Get_IPs": {
              "type": "ApiConnection",
              "inputs": {
                "host": {
                  "connection": {
                    "name": "@parameters('$connections')['azuresentinel']['connectionId']"
                  }
                },
                "method": "post",
                "body": "@triggerBody()?['object']?['properties']?['relatedEntities']",
                "path": "/entities/ip"
              },
              "runAfter": {}
            },
            "For_Each_IP": {
              "type": "Foreach",
              "foreach": "@body('Entities_-_Get_IPs')?['IPs']",
              "actions": {
                "Compose_IP_Value": {
                  "type": "Compose",
                  "inputs": "@items('For_Each_IP')?['Address']",
                  "runAfter": {}
                },
                "Validate_IP_Input": {
                  "type": "If",
                  "expression": {
                    "and": [
                      {
                        "not": {
                          "contains": [
                            "@toUpper(string(outputs('Compose_IP_Value')))",
                            "MATCH"
                          ]
                        }
                      },
                      {
                        "not": {
                          "contains": [
                            "@toUpper(string(outputs('Compose_IP_Value')))",
                            "RETURN"
                          ]
                        }
                      },
                      {
                        "not": {
                          "contains": [
                            "@toUpper(string(outputs('Compose_IP_Value')))",
                            "DELETE"
                          ]
                        }
                      },
                      {
                        "not": {
                          "contains": [
                            "@toUpper(string(outputs('Compose_IP_Value')))",
                            "MERGE"
                          ]
                        }
                      },
                      {
                        "not": {
                          "contains": [
                            "@toUpper(string(outputs('Compose_IP_Value')))",
                            "CREATE"
                          ]
                        }
                      },
                      {
                        "not": {
                          "contains": [
                            "@toUpper(string(outputs('Compose_IP_Value')))",
                            "SET "
                          ]
                        }
                      },
                      {
                        "not": {
                          "contains": [
                            "@toUpper(string(outputs('Compose_IP_Value')))",
                            "REMOVE"
                          ]
                        }
                      },
                      {
                        "not": {
                          "contains": [
                            "@toUpper(string(outputs('Compose_IP_Value')))",
                            "DETACH"
                          ]
                        }
                      },
                      {
                        "not": {
                          "equals": [
                            "@length(string(outputs('Compose_IP_Value')))",
                            0
                          ]
                        }
                      }
                    ]
                  },
                  "actions": {
                    "Enrich_ASN_Scope": {
                      "type": "Scope",
                      "actions": {
                        "Get_API_Key": {
                          "type": "ApiConnection",
                          "inputs": {
                            "host": {
                              "connection": {
                                "name": "@parameters('$connections')['keyvault']['connectionId']"
                              }
                            },
                            "method": "get",
                            "path": "/secrets/@{encodeURIComponent(last(split(parameters('keyVaultSecretUri'), '/')))}/value"
                          },
                          "runAfter": {},
                          "runtimeConfiguration": {
                            "secureData": {
                              "properties": [
                                "outputs"
                              ]
                            }
                          }
                        },
                        "Resolve_IP_Infrastructure": {
                          "type": "Http",
                          "inputs": {
                            "method": "POST",
                            "uri": "https://graph.whisper.security/api/query",
                            "headers": {
                              "Content-Type": "application/json",
                              "X-API-Key": "@body('Get_API_Key')?['value']"
                            },
                            "body": {
                              "query": "CALL explain(\"@{outputs('Compose_IP_Value')}\")"
                            },
                            "retryPolicy": {
                              "type": "exponential",
                              "count": 3,
                              "interval": "PT10S",
                              "maximumInterval": "PT1M"
                            }
                          },
                          "runAfter": {
                            "Get_API_Key": [
                              "Succeeded"
                            ]
                          },
                          "runtimeConfiguration": {
                            "secureData": {
                              "properties": [
                                "inputs"
                              ]
                            }
                          }
                        },
                        "Parse_IP_Response": {
                          "type": "ParseJson",
                          "inputs": {
                            "content": "@body('Resolve_IP_Infrastructure')",
                            "schema": {
                              "type": "object",
                              "properties": {
                                "columns": {
                                  "type": "array",
                                  "items": {
                                    "type": "string"
                                  }
                                },
                                "rows": {
                                  "type": "array",
                                  "items": {
                                    "type": "object",
                                    "properties": {
                                      "indicator": { "type": "string" },
                                      "type": { "type": "string" },
                                      "available": { "type": "boolean" },
                                      "cached": { "type": "boolean" },
                                      "found": { "type": "boolean" },
                                      "score": { "type": "number" },
                                      "level": { "type": "string" },
                                      "explanation": { "type": "string" },
                                      "factors": {
                                        "type": "array",
                                        "items": { "type": "string" }
                                      },
                                      "sources": { "type": "array" }
                                    }
                                  }
                                },
                                "statistics": {
                                  "type": "object",
                                  "properties": {
                                    "rowCount": { "type": "integer" },
                                    "executionTimeMs": { "type": "integer" }
                                  }
                                }
                              }
                            }
                          },
                          "runAfter": {
                            "Resolve_IP_Infrastructure": [
                              "Succeeded"
                            ]
                          }
                        },
                        "Compose_ASN_Enrichment": {
                          "type": "Compose",
                          "inputs": {
                            "indicator": "@outputs('Compose_IP_Value')",
                            "type": "ip-asn",
                            "found": "@body('Parse_IP_Response')?['rows']?[0]?['found']",
                            "score": "@body('Parse_IP_Response')?['rows']?[0]?['score']",
                            "level": "@{body('Parse_IP_Response')?['rows']?[0]?['level']}",
                            "explanation": "@{body('Parse_IP_Response')?['rows']?[0]?['explanation']}",
                            "factors": "@{string(body('Parse_IP_Response')?['rows']?[0]?['factors'])}",
                            "sources": "@body('Parse_IP_Response')?['rows']?[0]?['sources']"
                          },
                          "runAfter": {
                            "Parse_IP_Response": [
                              "Succeeded"
                            ]
                          }
                        },
                        "Format_Incident_Comment": {
                          "type": "Compose",
                          "inputs": "<h3>Whisper Security - ASN Reputation Assessment</h3><table><tr><th>Field</th><th>Value</th></tr><tr><td>IP Address</td><td>@{outputs('Compose_IP_Value')}</td></tr><tr><td>Reputation Score</td><td>@{outputs('Compose_ASN_Enrichment')?['score']}</td></tr><tr><td>Reputation Level</td><td>@{outputs('Compose_ASN_Enrichment')?['level']}</td></tr><tr><td>Explanation</td><td>@{outputs('Compose_ASN_Enrichment')?['explanation']}</td></tr><tr><td>Factors</td><td>@{outputs('Compose_ASN_Enrichment')?['factors']}</td></tr></table><p>ASN reputation data including score, level, max/avg threat scores, and prefix count.</p><p><em>Enriched by Whisper Security at @{utcNow()}</em></p>",
                          "runAfter": {
                            "Compose_ASN_Enrichment": [
                              "Succeeded"
                            ]
                          }
                        },
                        "Add_Incident_Comment_Success": {
                          "type": "ApiConnection",
                          "inputs": {
                            "host": {
                              "connection": {
                                "name": "@parameters('$connections')['azuresentinel']['connectionId']"
                              }
                            },
                            "method": "post",
                            "body": {
                              "incidentArmId": "@triggerBody()?['object']?['id']",
                              "message": "<p>@{outputs('Format_Incident_Comment')}</p>"
                            },
                            "path": "/Incidents/Comment"
                          },
                          "runAfter": {
                            "Format_Incident_Comment": [
                              "Succeeded"
                            ]
                          }
                        }
                      }
                    },
                    "Handle_Error_Scope": {
                      "type": "Scope",
                      "runAfter": {
                        "Enrich_ASN_Scope": [
                          "Failed",
                          "TimedOut"
                        ]
                      },
                      "actions": {
                        "Log_Error_Details": {
                          "type": "Compose",
                          "inputs": {
                            "status": "error",
                            "indicator": "@outputs('Compose_IP_Value')",
                            "error": "@{result('Enrich_ASN_Scope')}",
                            "timestamp": "@{utcNow()}"
                          },
                          "runAfter": {}
                        },
                        "Add_Incident_Comment_Error": {
                          "type": "ApiConnection",
                          "inputs": {
                            "host": {
                              "connection": {
                                "name": "@parameters('$connections')['azuresentinel']['connectionId']"
                              }
                            },
                            "method": "post",
                            "body": {
                              "incidentArmId": "@triggerBody()?['object']?['id']",
                              "message": "<p>Whisper Security ASN reputation check failed for IP: @{outputs('Compose_IP_Value')}. Check playbook run history for details.</p>"
                            },
                            "path": "/Incidents/Comment"
                          },
                          "runAfter": {
                            "Log_Error_Details": [
                              "Succeeded"
                            ]
                          }
                        }
                      }
                    }
                  },
                  "else": {
                    "actions": {
                      "Log_Blocked_IP_Input": {
                        "type": "Compose",
                        "inputs": {
                          "status": "blocked",
                          "reason": "Cypher injection keyword detected or empty indicator",
                          "indicator": "@outputs('Compose_IP_Value')",
                          "timestamp": "@{utcNow()}"
                        },
                        "runAfter": {}
                      }
                    }
                  },
                  "runAfter": {
                    "Compose_IP_Value": [
                      "Succeeded"
                    ]
                  }
                }
              },
              "runAfter": {
                "Entities_-_Get_IPs": [
                  "Succeeded"
                ]
              },
              "runtimeConfiguration": {
                "concurrency": {
                  "repetitions": 1
                }
              }
            }
          },
          "outputs": {}
        },
        "parameters": {
          "$connections": {
            "value": {
              "azuresentinel": {
                "connectionId": "[resourceId('Microsoft.Web/connections', variables('sentinelConnectionName'))]",
                "connectionName": "[variables('sentinelConnectionName')]",
                "id": "[subscriptionResourceId('Microsoft.Web/locations/managedApis', parameters('location'), 'azuresentinel')]",
                "connectionProperties": {
                  "authentication": {
                    "type": "ManagedServiceIdentity"
                  }
                }
              },
              "keyvault": {
                "connectionId": "[resourceId('Microsoft.Web/connections', variables('keyvaultConnectionName'))]",
                "connectionName": "[variables('keyvaultConnectionName')]",
                "id": "[subscriptionResourceId('Microsoft.Web/locations/managedApis', parameters('location'), 'keyvault')]",
                "connectionProperties": {
                  "authentication": {
                    "type": "ManagedServiceIdentity"
                  }
                }
              }
            }
          },
          "keyVaultSecretUri": {
            "value": "[parameters('keyVaultSecretUri')]"
          }
        }
      }
    }
  ],
  "outputs": {
    "logicAppResourceId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Logic/workflows', parameters('PlaybookName'))]"
    },
    "logicAppManagedIdentityPrincipalId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Logic/workflows', parameters('PlaybookName')), '2019-05-01', 'full').identity.principalId]"
    }
  }
}
