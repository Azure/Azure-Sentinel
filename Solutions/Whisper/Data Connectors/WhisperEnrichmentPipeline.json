{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "title": "Whisper Security - Enrichment Pipeline",
    "description": "Deploys a Logic App workflow that calls the Whisper Security explain() API to enrich Microsoft Sentinel incident indicators, applying Cypher injection protection and source attribution, then ingests enrichment data into WhisperThreatIntel_CL via DCR.",
    "prerequisites": [
      "Microsoft Sentinel workspace",
      "Whisper API key in Key Vault",
      "WhisperThreatIntel_CL table deployed (WhisperThreatIntel_CL.json)",
      "Data Collection Endpoint and Rule for WhisperThreatIntel_CL"
    ],
    "version": "1.0.0",
    "author": {
      "name": "Whisper Security"
    }
  },
  "parameters": {
    "workspace": {
      "type": "string",
      "metadata": {
        "description": "Log Analytics workspace name"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Location for all resources"
      }
    },
    "playbook-name": {
      "type": "string",
      "defaultValue": "Whisper-EnrichmentPipeline",
      "metadata": {
        "description": "Name of the Logic App playbook"
      }
    },
    "keyVaultSecretUri": {
      "type": "securestring",
      "metadata": {
        "description": "Key Vault secret URI for the Whisper API key (e.g. https://myvault.vault.azure.net/secrets/whisper-api-key)"
      }
    },
    "dceEndpoint": {
      "type": "string",
      "metadata": {
        "description": "Data Collection Endpoint logs ingestion URI"
      }
    },
    "dcrImmutableId": {
      "type": "string",
      "metadata": {
        "description": "Immutable ID of the Data Collection Rule for WhisperThreatIntel_CL"
      }
    },
    "keyVaultName": {
      "type": "string",
      "metadata": {
        "description": "Name of the Key Vault that holds the Whisper API key"
      }
    }
  },
  "variables": {
    "sentinelConnectionName": "azuresentinel",
    "keyvaultConnectionName": "keyvault"
  },
  "resources": [
    {
      "type": "Microsoft.Web/connections",
      "apiVersion": "2018-07-01-preview",
      "name": "[variables('sentinelConnectionName')]",
      "location": "[parameters('location')]",
      "properties": {
        "displayName": "Microsoft Sentinel",
        "api": {
          "id": "[subscriptionResourceId('Microsoft.Web/locations/managedApis', parameters('location'), 'azuresentinel')]"
        },
        "parameterValueType": "Alternative"
      }
    },
    {
      "type": "Microsoft.Web/connections",
      "apiVersion": "2018-07-01-preview",
      "name": "[variables('keyvaultConnectionName')]",
      "location": "[parameters('location')]",
      "properties": {
        "displayName": "Key Vault - Whisper API Key",
        "api": {
          "id": "[subscriptionResourceId('Microsoft.Web/locations/managedApis', parameters('location'), 'keyvault')]"
        },
        "parameterValueType": "Alternative",
        "alternativeParameterValues": {
          "vaultName": "[parameters('keyVaultName')]"
        }
      }
    },
    {
      "type": "Microsoft.Logic/workflows",
      "apiVersion": "2019-05-01",
      "name": "[parameters('playbook-name')]",
      "location": "[parameters('location')]",
      "tags": {
        "LogicAppsCategory": "security",
        "hidden-SentinelTemplateName": "Whisper-EnrichmentPipeline",
        "hidden-SentinelTemplateVersion": "1.0.0",
        "hidden-SentinelWorkspaceId": "[parameters('workspace')]"
      },
      "identity": {
        "type": "SystemAssigned"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/connections', variables('sentinelConnectionName'))]",
        "[resourceId('Microsoft.Web/connections', variables('keyvaultConnectionName'))]"
      ],
      "properties": {
        "state": "Enabled",
        "definition": {
          "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
          "contentVersion": "1.0.0.0",
          "parameters": {
            "$connections": {
              "type": "Object",
              "defaultValue": {}
            },
            "keyVaultSecretUri": {
              "type": "SecureString"
            },
            "dceEndpoint": {
              "type": "String"
            },
            "dcrImmutableId": {
              "type": "String"
            }
          },
          "triggers": {
            "Microsoft_Sentinel_incident": {
              "type": "ApiConnectionWebhook",
              "inputs": {
                "host": {
                  "connection": {
                    "name": "@parameters('$connections')['azuresentinel']['connectionId']"
                  }
                },
                "body": {
                  "callback_url": "@{listCallbackUrl()}"
                },
                "path": "/incident-creation"
              }
            }
          },
          "actions": {
            "Initialize_Indicator": {
              "type": "InitializeVariable",
              "inputs": {
                "variables": [
                  {
                    "name": "indicator",
                    "type": "string",
                    "value": ""
                  }
                ]
              },
              "runAfter": {}
            },
            "Extract_Entities": {
              "type": "Compose",
              "inputs": "@triggerBody()?['object']?['properties']?['relatedEntities']",
              "runAfter": {
                "Initialize_Indicator": [
                  "Succeeded"
                ]
              }
            },
            "For_Each_Entity": {
              "type": "Foreach",
              "foreach": "@outputs('Extract_Entities')",
              "actions": {
                "Set_Indicator_Value": {
                  "type": "SetVariable",
                  "inputs": {
                    "name": "indicator",
                    "value": "@{coalesce(items('For_Each_Entity')?['properties']?['address'], items('For_Each_Entity')?['properties']?['domainName'], items('For_Each_Entity')?['properties']?['friendlyName'], '')}"
                  },
                  "runAfter": {}
                },
                "Validate_Input": {
                  "type": "If",
                  "expression": {
                    "and": [
                      {
                        "not": {
                          "contains": [
                            "@toUpper(variables('indicator'))",
                            "MATCH"
                          ]
                        }
                      },
                      {
                        "not": {
                          "contains": [
                            "@toUpper(variables('indicator'))",
                            "RETURN"
                          ]
                        }
                      },
                      {
                        "not": {
                          "contains": [
                            "@toUpper(variables('indicator'))",
                            "DELETE"
                          ]
                        }
                      },
                      {
                        "not": {
                          "contains": [
                            "@toUpper(variables('indicator'))",
                            "MERGE"
                          ]
                        }
                      },
                      {
                        "not": {
                          "contains": [
                            "@toUpper(variables('indicator'))",
                            "CREATE"
                          ]
                        }
                      },
                      {
                        "not": {
                          "contains": [
                            "@toUpper(variables('indicator'))",
                            "SET"
                          ]
                        }
                      },
                      {
                        "not": {
                          "contains": [
                            "@toUpper(variables('indicator'))",
                            "REMOVE"
                          ]
                        }
                      },
                      {
                        "not": {
                          "contains": [
                            "@toUpper(variables('indicator'))",
                            "DETACH"
                          ]
                        }
                      },
                      {
                        "not": {
                          "equals": [
                            "@length(variables('indicator'))",
                            0
                          ]
                        }
                      }
                    ]
                  },
                  "actions": {
                    "Enrich_Indicator": {
                      "type": "Scope",
                      "actions": {
                        "Get_API_Key": {
                          "type": "ApiConnection",
                          "inputs": {
                            "host": {
                              "connection": {
                                "name": "@parameters('$connections')['keyvault']['connectionId']"
                              }
                            },
                            "method": "get",
                            "path": "/secrets/@{encodeURIComponent(last(split(parameters('keyVaultSecretUri'), '/')))}/value"
                          },
                          "runAfter": {},
                          "runtimeConfiguration": {
                            "secureData": {
                              "properties": [
                                "outputs"
                              ]
                            }
                          }
                        },
                        "Call_Whisper_Explain": {
                          "type": "Http",
                          "inputs": {
                            "method": "POST",
                            "uri": "https://graph.whisper.security/api/query",
                            "headers": {
                              "Content-Type": "application/json",
                              "X-API-Key": "@body('Get_API_Key')?['value']"
                            },
                            "body": {
                              "query": "CALL explain(\"@{variables('indicator')}\") YIELD score, level, explanation, factors, sources\nWITH score, level, explanation, factors, sources\nOPTIONAL MATCH (n) WHERE (n:IPV4 OR n:HOSTNAME OR n:IPV6) AND n.name = \"@{variables('indicator')}\"\nRETURN coalesce(score, 0.0) AS threatScore,\n       coalesce(level, \"NONE\") AS threatLevel,\n       coalesce(n.isThreat, false) AS isThreat,\n       coalesce(n.isC2, false) AS isC2,\n       coalesce(n.isMalware, false) AS isMalware,\n       coalesce(n.isPhishing, false) AS isPhishing,\n       coalesce(n.isTor, false) AS isTor,\n       false AS isAnonymizer,\n       false AS isSpam,\n       false AS isBruteforce,\n       false AS isScanner,\n       coalesce(explanation, \"\") AS explanation,\n       coalesce(factors, []) AS factors,\n       size(coalesce(sources, [])) AS threatSources,\n       [s IN coalesce(sources, []) | s.feedId] AS feedNames"
                            },
                            "retryPolicy": {
                              "type": "exponential",
                              "count": 3,
                              "interval": "PT10S",
                              "maximumInterval": "PT1M"
                            }
                          },
                          "runAfter": {
                            "Get_API_Key": [
                              "Succeeded"
                            ]
                          },
                          "runtimeConfiguration": {
                            "secureData": {
                              "properties": [
                                "inputs"
                              ]
                            }
                          }
                        },
                        "Parse_Explain_Response": {
                          "type": "ParseJson",
                          "inputs": {
                            "content": "@body('Call_Whisper_Explain')",
                            "schema": {
                              "type": "object",
                              "properties": {
                                "columns": {
                                  "type": "array",
                                  "items": {
                                    "type": "string"
                                  }
                                },
                                "rows": {
                                  "type": "array",
                                  "items": {
                                    "type": "object",
                                    "properties": {
                                      "threatScore": {
                                        "type": "number"
                                      },
                                      "threatLevel": {
                                        "type": "string"
                                      },
                                      "isThreat": {
                                        "type": "boolean"
                                      },
                                      "isC2": {
                                        "type": "boolean"
                                      },
                                      "isMalware": {
                                        "type": "boolean"
                                      },
                                      "isPhishing": {
                                        "type": "boolean"
                                      },
                                      "isTor": {
                                        "type": "boolean"
                                      },
                                      "isAnonymizer": {
                                        "type": "boolean"
                                      },
                                      "isSpam": {
                                        "type": "boolean"
                                      },
                                      "isBruteforce": {
                                        "type": "boolean"
                                      },
                                      "isScanner": {
                                        "type": "boolean"
                                      },
                                      "explanation": {
                                        "type": "string"
                                      },
                                      "factors": {
                                        "type": "array"
                                      },
                                      "threatSources": {
                                        "type": "integer"
                                      },
                                      "feedNames": {
                                        "type": "array"
                                      }
                                    }
                                  }
                                }
                              }
                            }
                          },
                          "runAfter": {
                            "Call_Whisper_Explain": [
                              "Succeeded"
                            ]
                          }
                        },
                        "Map_Response_Fields": {
                          "type": "Compose",
                          "inputs": {
                            "indicator": "@variables('indicator')",
                            "indicatorType": "@{if(contains(variables('indicator'), '.'), 'domain', 'ip')}",
                            "threatScore": "@body('Parse_Explain_Response')?['rows']?[0]?['threatScore']",
                            "threatLevel": "@{body('Parse_Explain_Response')?['rows']?[0]?['threatLevel']}",
                            "isThreat": "@body('Parse_Explain_Response')?['rows']?[0]?['isThreat']",
                            "isC2": "@body('Parse_Explain_Response')?['rows']?[0]?['isC2']",
                            "isMalware": "@body('Parse_Explain_Response')?['rows']?[0]?['isMalware']",
                            "isPhishing": "@body('Parse_Explain_Response')?['rows']?[0]?['isPhishing']",
                            "isTor": "@body('Parse_Explain_Response')?['rows']?[0]?['isTor']",
                            "isAnonymizer": "@body('Parse_Explain_Response')?['rows']?[0]?['isAnonymizer']",
                            "isSpam": "@body('Parse_Explain_Response')?['rows']?[0]?['isSpam']",
                            "isBruteforce": "@body('Parse_Explain_Response')?['rows']?[0]?['isBruteforce']",
                            "isScanner": "@body('Parse_Explain_Response')?['rows']?[0]?['isScanner']",
                            "threatSources": "@body('Parse_Explain_Response')?['rows']?[0]?['threatSources']",
                            "feedNames": "@{join(body('Parse_Explain_Response')?['rows']?[0]?['feedNames'], ',')}",
                            "explanation": "@{body('Parse_Explain_Response')?['rows']?[0]?['explanation']}",
                            "factors": "@{string(body('Parse_Explain_Response')?['rows']?[0]?['factors'])}",
                            "lastSeen": "@{utcNow()}",
                            "TimeGenerated": "@{utcNow()}"
                          },
                          "runAfter": {
                            "Parse_Explain_Response": [
                              "Succeeded"
                            ]
                          }
                        },
                        "Ingest_To_DCR": {
                          "type": "Http",
                          "inputs": {
                            "method": "POST",
                            "uri": "@{parameters('dceEndpoint')}/dataCollectionRules/@{parameters('dcrImmutableId')}/streams/Custom-WhisperThreatIntel_CL?api-version=2023-01-01",
                            "headers": {
                              "Content-Type": "application/json"
                            },
                            "body": [
                              "@outputs('Map_Response_Fields')"
                            ],
                            "authentication": {
                              "type": "ManagedServiceIdentity",
                              "audience": "https://monitor.azure.com"
                            },
                            "retryPolicy": {
                              "type": "exponential",
                              "count": 3,
                              "interval": "PT10S",
                              "maximumInterval": "PT1M"
                            }
                          },
                          "runAfter": {
                            "Map_Response_Fields": [
                              "Succeeded"
                            ]
                          }
                        },
                        "Log_Success": {
                          "type": "Compose",
                          "inputs": {
                            "status": "success",
                            "indicator": "@variables('indicator')",
                            "threatScore": "@outputs('Map_Response_Fields')?['threatScore']",
                            "timestamp": "@{utcNow()}"
                          },
                          "runAfter": {
                            "Ingest_To_DCR": [
                              "Succeeded"
                            ]
                          }
                        }
                      }
                    },
                    "Handle_Error": {
                      "type": "Scope",
                      "runAfter": {
                        "Enrich_Indicator": [
                          "Failed",
                          "TimedOut"
                        ]
                      },
                      "actions": {
                        "Log_Error": {
                          "type": "Compose",
                          "inputs": {
                            "status": "error",
                            "indicator": "@variables('indicator')",
                            "error": "@{result('Enrich_Indicator')}",
                            "timestamp": "@{utcNow()}"
                          },
                          "runAfter": {}
                        },
                        "Add_Incident_Comment_Error": {
                          "type": "ApiConnection",
                          "inputs": {
                            "host": {
                              "connection": {
                                "name": "@parameters('$connections')['azuresentinel']['connectionId']"
                              }
                            },
                            "method": "post",
                            "body": {
                              "incidentArmId": "@triggerBody()?['object']?['id']",
                              "message": "<p>Whisper enrichment failed for indicator: @{variables('indicator')}. Error: @{result('Enrich_Indicator')}</p>"
                            },
                            "path": "/Incidents/Comment"
                          },
                          "runAfter": {
                            "Log_Error": [
                              "Succeeded"
                            ]
                          }
                        }
                      }
                    }
                  },
                  "else": {
                    "actions": {
                      "Log_Blocked_Input": {
                        "type": "Compose",
                        "inputs": {
                          "status": "blocked",
                          "reason": "Cypher injection keyword detected or empty indicator",
                          "indicator": "@variables('indicator')",
                          "timestamp": "@{utcNow()}"
                        },
                        "runAfter": {}
                      }
                    }
                  },
                  "runAfter": {
                    "Set_Indicator_Value": [
                      "Succeeded"
                    ]
                  }
                }
              },
              "runAfter": {
                "Extract_Entities": [
                  "Succeeded"
                ]
              },
              "runtimeConfiguration": {
                "concurrency": {
                  "repetitions": 1
                }
              }
            }
          },
          "outputs": {}
        },
        "parameters": {
          "$connections": {
            "value": {
              "azuresentinel": {
                "connectionId": "[resourceId('Microsoft.Web/connections', variables('sentinelConnectionName'))]",
                "connectionName": "[variables('sentinelConnectionName')]",
                "id": "[subscriptionResourceId('Microsoft.Web/locations/managedApis', parameters('location'), 'azuresentinel')]",
                "connectionProperties": {
                  "authentication": {
                    "type": "ManagedServiceIdentity"
                  }
                }
              },
              "keyvault": {
                "connectionId": "[resourceId('Microsoft.Web/connections', variables('keyvaultConnectionName'))]",
                "connectionName": "[variables('keyvaultConnectionName')]",
                "id": "[subscriptionResourceId('Microsoft.Web/locations/managedApis', parameters('location'), 'keyvault')]",
                "connectionProperties": {
                  "authentication": {
                    "type": "ManagedServiceIdentity"
                  }
                }
              }
            }
          },
          "keyVaultSecretUri": {
            "value": "[parameters('keyVaultSecretUri')]"
          },
          "dceEndpoint": {
            "value": "[parameters('dceEndpoint')]"
          },
          "dcrImmutableId": {
            "value": "[parameters('dcrImmutableId')]"
          }
        }
      }
    }
  ],
  "outputs": {
    "logicAppResourceId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Logic/workflows', parameters('playbook-name'))]"
    },
    "logicAppManagedIdentityPrincipalId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Logic/workflows', parameters('playbook-name')), '2019-05-01', 'full').identity.principalId]"
    }
  }
}
