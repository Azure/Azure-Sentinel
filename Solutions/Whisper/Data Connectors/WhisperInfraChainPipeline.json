{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "title": "Whisper Security - Infrastructure Chain Pipeline",
    "description": "Deploys a Logic App workflow that performs graph traversal of the Whisper Security knowledge graph to resolve infrastructure chains (HOSTNAME -> IP -> PREFIX -> ASN) and co-hosted domain counts, then ingests the results into the WhisperInfraContext_CL custom table via DCR.",
    "prerequisites": [
      "Microsoft Sentinel workspace",
      "Whisper API key in Key Vault",
      "WhisperInfraContext_CL table deployed",
      "Data Collection Endpoint and Rule for WhisperInfraContext_CL"
    ],
    "version": "1.0.0",
    "author": {
      "name": "Whisper Security"
    }
  },
  "parameters": {
    "workspace": {
      "type": "string",
      "metadata": {
        "description": "Log Analytics workspace name"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Location for all resources"
      }
    },
    "keyVaultSecretUri": {
      "type": "securestring",
      "metadata": {
        "description": "Key Vault secret URI for the Whisper API key (e.g. https://myvault.vault.azure.net/secrets/whisper-api-key)"
      }
    },
    "dceEndpoint": {
      "type": "string",
      "metadata": {
        "description": "Data Collection Endpoint logs ingestion URI for WhisperInfraContext_CL"
      }
    },
    "dcrImmutableId": {
      "type": "string",
      "metadata": {
        "description": "Immutable ID of the Data Collection Rule for WhisperInfraContext_CL"
      }
    },
    "keyVaultName": {
      "type": "string",
      "metadata": {
        "description": "Name of the Key Vault that holds the Whisper API key"
      }
    }
  },
  "variables": {
    "logicAppName": "Whisper-InfraChainPipeline",
    "keyVaultConnectionName": "keyvault-whisper",
    "sentinelConnectionName": "azuresentinel-whisper",
    "injectionKeywords": "MATCH,RETURN,DELETE,MERGE,CREATE,SET,REMOVE,DETACH"
  },
  "resources": [
    {
      "type": "Microsoft.Web/connections",
      "apiVersion": "2018-07-01-preview",
      "name": "[variables('keyVaultConnectionName')]",
      "location": "[parameters('location')]",
      "properties": {
        "displayName": "Whisper API Key Vault",
        "api": {
          "id": "[subscriptionResourceId('Microsoft.Web/locations/managedApis', parameters('location'), 'keyvault')]"
        },
        "parameterValueType": "Alternative",
        "alternativeParameterValues": {
          "vaultName": "[parameters('keyVaultName')]"
        }
      }
    },
    {
      "type": "Microsoft.Web/connections",
      "apiVersion": "2018-07-01-preview",
      "name": "[variables('sentinelConnectionName')]",
      "location": "[parameters('location')]",
      "properties": {
        "displayName": "Microsoft Sentinel Connection",
        "api": {
          "id": "[subscriptionResourceId('Microsoft.Web/locations/managedApis', parameters('location'), 'azuresentinel')]"
        },
        "parameterValueType": "Alternative"
      }
    },
    {
      "type": "Microsoft.Logic/workflows",
      "apiVersion": "2019-05-01",
      "name": "[variables('logicAppName')]",
      "location": "[parameters('location')]",
      "tags": {
        "LogicAppsCategory": "security",
        "hidden-SentinelTemplateName": "Whisper-InfraChainPipeline",
        "hidden-SentinelTemplateVersion": "1.0.0",
        "hidden-SentinelWorkspaceId": "[parameters('workspace')]"
      },
      "identity": {
        "type": "SystemAssigned"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/connections', variables('keyVaultConnectionName'))]",
        "[resourceId('Microsoft.Web/connections', variables('sentinelConnectionName'))]"
      ],
      "properties": {
        "state": "Enabled",
        "definition": {
          "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
          "contentVersion": "1.0.0.0",
          "parameters": {
            "$connections": {
              "defaultValue": {},
              "type": "Object"
            },
            "keyVaultSecretUri": {
              "type": "SecureString"
            },
            "dceEndpoint": {
              "type": "String"
            },
            "dcrImmutableId": {
              "type": "String"
            },
            "injectionKeywords": {
              "type": "String"
            }
          },
          "triggers": {
            "Microsoft_Sentinel_incident": {
              "type": "ApiConnectionWebhook",
              "inputs": {
                "host": {
                  "connection": {
                    "name": "@parameters('$connections')['azuresentinel']['connectionId']"
                  }
                },
                "body": {
                  "callback_url": "@{listCallbackUrl()}"
                },
                "path": "/incident-creation"
              }
            }
          },
          "actions": {
            "Extract_Indicator": {
              "type": "Compose",
              "runAfter": {},
              "inputs": "@triggerBody()?['object']?['properties']?['relatedEntities']?[0]?['properties']?['friendlyName']"
            },
            "Detect_Indicator_Type": {
              "type": "Compose",
              "runAfter": {
                "Extract_Indicator": [
                  "Succeeded"
                ]
              },
              "inputs": "@if(contains(outputs('Extract_Indicator'), '.'), if(equals(indexOf(outputs('Extract_Indicator'), ':'), -1), if(greater(indexOf(outputs('Extract_Indicator'), '.0'), -1), 'ip', if(less(length(split(outputs('Extract_Indicator'), '.')), 4), 'domain', if(and(greater(length(split(outputs('Extract_Indicator'), '.')), 3), lessOrEquals(length(split(outputs('Extract_Indicator'), '.')), 4)), 'ip', 'domain'))), 'ip'), 'unknown')"
            },
            "Validate_Input": {
              "type": "Compose",
              "runAfter": {
                "Detect_Indicator_Type": [
                  "Succeeded"
                ]
              },
              "inputs": "@not(or(contains(toUpper(string(outputs('Extract_Indicator'))), 'MATCH'), contains(toUpper(string(outputs('Extract_Indicator'))), 'RETURN'), contains(toUpper(string(outputs('Extract_Indicator'))), 'DELETE'), contains(toUpper(string(outputs('Extract_Indicator'))), 'MERGE'), contains(toUpper(string(outputs('Extract_Indicator'))), 'CREATE'), contains(toUpper(string(outputs('Extract_Indicator'))), ' SET '), contains(toUpper(string(outputs('Extract_Indicator'))), 'REMOVE'), contains(toUpper(string(outputs('Extract_Indicator'))), 'DETACH')))"
            },
            "Check_Input_Valid": {
              "type": "If",
              "runAfter": {
                "Validate_Input": [
                  "Succeeded"
                ]
              },
              "expression": {
                "and": [
                  {
                    "equals": [
                      "@outputs('Validate_Input')",
                      true
                    ]
                  }
                ]
              },
              "actions": {
                "Get_API_Key": {
                  "type": "ApiConnection",
                  "inputs": {
                    "host": {
                      "connection": {
                        "name": "@parameters('$connections')['keyvault']['connectionId']"
                      }
                    },
                    "method": "get",
                    "path": "/secrets/@{encodeURIComponent(last(split(parameters('keyVaultSecretUri'), '/')))}/value"
                  },
                  "runAfter": {},
                  "runtimeConfiguration": {
                    "secureData": {
                      "properties": [
                        "outputs"
                      ]
                    }
                  }
                },
                "Enrich_Infrastructure": {
                  "type": "Scope",
                  "runAfter": {
                    "Get_API_Key": [
                      "Succeeded"
                    ]
                  },
                  "actions": {
                    "Query_Infra_Chain": {
                      "type": "Http",
                      "runAfter": {},
                      "inputs": {
                        "method": "POST",
                        "uri": "https://graph.whisper.security/api/query",
                        "headers": {
                          "Content-Type": "application/json",
                          "X-API-Key": "@{body('Get_API_Key')?['value']}"
                        },
                        "body": {
                          "query": "MATCH (h:HOSTNAME {name: \"@{outputs('Extract_Indicator')}\"})-[:RESOLVES_TO]->(ip:IPV4)-[:BELONGS_TO]->(p:PREFIX)<-[:ROUTES]-(a:ASN)-[:HAS_NAME]->(n:ASN_NAME) OPTIONAL MATCH (ip)-[:LOCATED_IN]->(c:CITY)-[:HAS_COUNTRY]->(co:COUNTRY) RETURN ip.name AS ipAddress, p.name AS prefix, a.name AS asn, n.name AS asnName, c.name AS city, co.name AS country"
                        },
                        "retryPolicy": {
                          "type": "exponential",
                          "count": 3,
                          "interval": "PT10S",
                          "maximumInterval": "PT1M"
                        }
                      },
                      "runtimeConfiguration": {
                        "secureData": {
                          "properties": [
                            "inputs"
                          ]
                        }
                      }
                    },
                    "Parse_Infra_Response": {
                      "type": "ParseJson",
                      "runAfter": {
                        "Query_Infra_Chain": [
                          "Succeeded"
                        ]
                      },
                      "inputs": {
                        "content": "@body('Query_Infra_Chain')",
                        "schema": {
                          "type": "object",
                          "properties": {
                            "columns": {
                              "type": "array",
                              "items": {
                                "type": "string"
                              }
                            },
                            "rows": {
                              "type": "array",
                              "items": {
                                "type": "object",
                                "properties": {
                                  "indicator": {
                                    "type": "string"
                                  },
                                  "type": {
                                    "type": "string"
                                  },
                                  "available": {
                                    "type": "boolean"
                                  },
                                  "cached": {
                                    "type": "boolean"
                                  },
                                  "found": {
                                    "type": "boolean"
                                  },
                                  "score": {
                                    "type": "number"
                                  },
                                  "level": {
                                    "type": "string"
                                  },
                                  "explanation": {
                                    "type": "string"
                                  },
                                  "factors": {
                                    "type": "array"
                                  },
                                  "sources": {
                                    "type": "array"
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    },
                    "Extract_First_IP": {
                      "type": "Compose",
                      "runAfter": {
                        "Parse_Infra_Response": [
                          "Succeeded"
                        ]
                      },
                      "inputs": "@if(greater(length(body('Parse_Infra_Response')?['rows']), 0), body('Parse_Infra_Response')?['rows']?[0]?['ipAddress'], '')"
                    },
                    "Query_Cohosted_Count": {
                      "type": "Http",
                      "runAfter": {
                        "Extract_First_IP": [
                          "Succeeded"
                        ]
                      },
                      "inputs": {
                        "method": "POST",
                        "uri": "https://graph.whisper.security/api/query",
                        "headers": {
                          "Content-Type": "application/json",
                          "X-API-Key": "@{body('Get_API_Key')?['value']}"
                        },
                        "body": {
                          "query": "MATCH (ip:IPV4 {name: \"@{outputs('Extract_First_IP')}\"})<-[:RESOLVES_TO]-(h:HOSTNAME) RETURN count(h) AS cohostedCount"
                        },
                        "retryPolicy": {
                          "type": "exponential",
                          "count": 3,
                          "interval": "PT10S",
                          "maximumInterval": "PT1M"
                        }
                      },
                      "runtimeConfiguration": {
                        "secureData": {
                          "properties": [
                            "inputs"
                          ]
                        }
                      }
                    },
                    "Parse_Cohosted_Response": {
                      "type": "ParseJson",
                      "runAfter": {
                        "Query_Cohosted_Count": [
                          "Succeeded"
                        ]
                      },
                      "inputs": {
                        "content": "@body('Query_Cohosted_Count')",
                        "schema": {
                          "type": "object",
                          "properties": {
                            "columns": {
                              "type": "array",
                              "items": {
                                "type": "string"
                              }
                            },
                            "rows": {
                              "type": "array",
                              "items": {
                                "type": "object",
                                "properties": {
                                  "indicator": {
                                    "type": "string"
                                  },
                                  "type": {
                                    "type": "string"
                                  },
                                  "available": {
                                    "type": "boolean"
                                  },
                                  "cached": {
                                    "type": "boolean"
                                  },
                                  "found": {
                                    "type": "boolean"
                                  },
                                  "score": {
                                    "type": "number"
                                  },
                                  "level": {
                                    "type": "string"
                                  },
                                  "explanation": {
                                    "type": "string"
                                  },
                                  "factors": {
                                    "type": "array"
                                  },
                                  "sources": {
                                    "type": "array"
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    },
                    "Query_Domain_Metadata": {
                      "type": "Http",
                      "runAfter": {
                        "Parse_Cohosted_Response": [
                          "Succeeded"
                        ]
                      },
                      "inputs": {
                        "method": "POST",
                        "uri": "https://graph.whisper.security/api/query",
                        "headers": {
                          "Content-Type": "application/json",
                          "X-API-Key": "@{body('Get_API_Key')?['value']}"
                        },
                        "body": {
                          "query": "MATCH (h:HOSTNAME {name: \"@{outputs('Extract_Indicator')}\"})\nOPTIONAL MATCH (h)-[:HAS_REGISTRAR]->(r:REGISTRAR)\nOPTIONAL MATCH (h)-[:HAS_EMAIL]->(e:EMAIL)\nOPTIONAL MATCH (ns:HOSTNAME)-[:NAMESERVER_FOR]->(h)\nWITH h, r, e, collect(distinct ns.name) AS nsList\nRETURN coalesce(r.name, \"\")           AS registrar,\n       coalesce(e.name, \"\")           AS registrant,\n       reduce(s = \"\", n IN nsList | s + CASE WHEN s = \"\" THEN \"\" ELSE \",\" END + n) AS nameservers"
                        },
                        "retryPolicy": {
                          "type": "exponential",
                          "count": 3,
                          "interval": "PT10S",
                          "maximumInterval": "PT1M"
                        }
                      },
                      "runtimeConfiguration": {
                        "secureData": {
                          "properties": [
                            "inputs"
                          ]
                        }
                      }
                    },
                    "Calculate_Domain_Age": {
                      "type": "Compose",
                      "runAfter": {
                        "Query_Domain_Metadata": [
                          "Succeeded"
                        ]
                      },
                      "inputs": "@int(-1)"
                    },
                    "Build_InfraContext_Record": {
                      "type": "Compose",
                      "runAfter": {
                        "Aggregate_IPs": [
                          "Succeeded"
                        ],
                        "Aggregate_Prefixes": [
                          "Succeeded"
                        ],
                        "Aggregate_ASNs": [
                          "Succeeded"
                        ],
                        "Aggregate_ASNNames": [
                          "Succeeded"
                        ],
                        "Aggregate_Cities": [
                          "Succeeded"
                        ],
                        "Aggregate_Countries": [
                          "Succeeded"
                        ],
                        "Parse_Cohosted_Response": [
                          "Succeeded"
                        ],
                        "Calculate_Domain_Age": [
                          "Succeeded"
                        ]
                      },
                      "inputs": [
                        {
                          "indicator": "@{outputs('Extract_Indicator')}",
                          "indicatorType": "@{outputs('Detect_Indicator_Type')}",
                          "ipAddresses": "@{join(union(body('Aggregate_IPs'), body('Aggregate_IPs')), ',')}",
                          "prefixes": "@{join(union(body('Aggregate_Prefixes'), body('Aggregate_Prefixes')), ',')}",
                          "asns": "@{join(union(body('Aggregate_ASNs'), body('Aggregate_ASNs')), ',')}",
                          "asnNames": "@{join(union(body('Aggregate_ASNNames'), body('Aggregate_ASNNames')), ',')}",
                          "cities": "@{join(union(body('Aggregate_Cities'), body('Aggregate_Cities')), ',')}",
                          "countries": "@{join(union(body('Aggregate_Countries'), body('Aggregate_Countries')), ',')}",
                          "registrar": "@{coalesce(body('Query_Domain_Metadata')?['rows']?[0]?['registrar'], '')}",
                          "registrant": "@{coalesce(body('Query_Domain_Metadata')?['rows']?[0]?['registrant'], '')}",
                          "nameservers": "@{coalesce(body('Query_Domain_Metadata')?['rows']?[0]?['nameservers'], '')}",
                          "domainAge": "@int(outputs('Calculate_Domain_Age'))",
                          "cohostedCount": "@if(greater(length(body('Parse_Cohosted_Response')?['rows']), 0), int(body('Parse_Cohosted_Response')?['rows']?[0]?['cohostedCount']), 0)",
                          "bgpStatus": "active",
                          "TimeGenerated": "@{utcNow()}"
                        }
                      ]
                    },
                    "Ingest_Via_DCR": {
                      "type": "Http",
                      "runAfter": {
                        "Build_InfraContext_Record": [
                          "Succeeded"
                        ]
                      },
                      "inputs": {
                        "method": "POST",
                        "uri": "@{parameters('dceEndpoint')}/dataCollectionRules/@{parameters('dcrImmutableId')}/streams/Custom-WhisperInfraContext_CL?api-version=2023-01-01",
                        "headers": {
                          "Content-Type": "application/json"
                        },
                        "body": "@outputs('Build_InfraContext_Record')",
                        "authentication": {
                          "type": "ManagedServiceIdentity",
                          "audience": "https://monitor.azure.com"
                        },
                        "retryPolicy": {
                          "type": "exponential",
                          "count": 3,
                          "interval": "PT10S",
                          "maximumInterval": "PT1M"
                        }
                      }
                    },
                    "Log_Success": {
                      "type": "Compose",
                      "runAfter": {
                        "Ingest_Via_DCR": [
                          "Succeeded"
                        ]
                      },
                      "inputs": {
                        "status": "success",
                        "indicator": "@outputs('Extract_Indicator')",
                        "timestamp": "@utcNow()",
                        "cohostedCount": "@if(greater(length(body('Parse_Cohosted_Response')?['rows']), 0), body('Parse_Cohosted_Response')?['rows']?[0]?['cohostedCount'], 0)",
                        "domainAge": "@outputs('Calculate_Domain_Age')"
                      }
                    },
                    "Aggregate_IPs": {
                      "type": "Select",
                      "runAfter": {
                        "Parse_Infra_Response": [
                          "Succeeded"
                        ]
                      },
                      "inputs": {
                        "from": "@body('Parse_Infra_Response')?['rows']",
                        "select": "@item()?['ipAddress']"
                      }
                    },
                    "Aggregate_Prefixes": {
                      "type": "Select",
                      "runAfter": {
                        "Parse_Infra_Response": [
                          "Succeeded"
                        ]
                      },
                      "inputs": {
                        "from": "@body('Parse_Infra_Response')?['rows']",
                        "select": "@item()?['prefix']"
                      }
                    },
                    "Aggregate_ASNs": {
                      "type": "Select",
                      "runAfter": {
                        "Parse_Infra_Response": [
                          "Succeeded"
                        ]
                      },
                      "inputs": {
                        "from": "@body('Parse_Infra_Response')?['rows']",
                        "select": "@item()?['asn']"
                      }
                    },
                    "Aggregate_ASNNames": {
                      "type": "Select",
                      "runAfter": {
                        "Parse_Infra_Response": [
                          "Succeeded"
                        ]
                      },
                      "inputs": {
                        "from": "@body('Parse_Infra_Response')?['rows']",
                        "select": "@item()?['asnName']"
                      }
                    },
                    "Aggregate_Cities": {
                      "type": "Select",
                      "runAfter": {
                        "Parse_Infra_Response": [
                          "Succeeded"
                        ]
                      },
                      "inputs": {
                        "from": "@body('Parse_Infra_Response')?['rows']",
                        "select": "@item()?['city']"
                      }
                    },
                    "Aggregate_Countries": {
                      "type": "Select",
                      "runAfter": {
                        "Parse_Infra_Response": [
                          "Succeeded"
                        ]
                      },
                      "inputs": {
                        "from": "@body('Parse_Infra_Response')?['rows']",
                        "select": "@item()?['country']"
                      }
                    }
                  }
                },
                "Handle_Enrichment_Error": {
                  "type": "Scope",
                  "runAfter": {
                    "Enrich_Infrastructure": [
                      "Failed",
                      "TimedOut"
                    ]
                  },
                  "actions": {
                    "Log_Error_Details": {
                      "type": "Compose",
                      "runAfter": {},
                      "inputs": {
                        "status": "failed",
                        "indicator": "@outputs('Extract_Indicator')",
                        "timestamp": "@utcNow()",
                        "error": "@result('Enrich_Infrastructure')"
                      }
                    }
                  }
                }
              },
              "else": {
                "actions": {
                  "Log_Injection_Blocked": {
                    "type": "Compose",
                    "runAfter": {},
                    "inputs": {
                      "status": "blocked",
                      "reason": "Input failed Cypher injection validation",
                      "indicator": "@outputs('Extract_Indicator')",
                      "timestamp": "@utcNow()"
                    }
                  }
                }
              }
            }
          },
          "outputs": {}
        },
        "parameters": {
          "$connections": {
            "value": {
              "keyvault": {
                "connectionId": "[resourceId('Microsoft.Web/connections', variables('keyVaultConnectionName'))]",
                "connectionName": "[variables('keyVaultConnectionName')]",
                "connectionProperties": {
                  "authentication": {
                    "type": "ManagedServiceIdentity"
                  }
                },
                "id": "[subscriptionResourceId('Microsoft.Web/locations/managedApis', parameters('location'), 'keyvault')]"
              },
              "azuresentinel": {
                "connectionId": "[resourceId('Microsoft.Web/connections', variables('sentinelConnectionName'))]",
                "connectionName": "[variables('sentinelConnectionName')]",
                "connectionProperties": {
                  "authentication": {
                    "type": "ManagedServiceIdentity"
                  }
                },
                "id": "[subscriptionResourceId('Microsoft.Web/locations/managedApis', parameters('location'), 'azuresentinel')]"
              }
            }
          },
          "keyVaultSecretUri": {
            "value": "[parameters('keyVaultSecretUri')]"
          },
          "dceEndpoint": {
            "value": "[parameters('dceEndpoint')]"
          },
          "dcrImmutableId": {
            "value": "[parameters('dcrImmutableId')]"
          },
          "injectionKeywords": {
            "value": "[variables('injectionKeywords')]"
          }
        }
      }
    }
  ],
  "outputs": {
    "logicAppResourceId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Logic/workflows', variables('logicAppName'))]"
    },
    "logicAppManagedIdentityPrincipalId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Logic/workflows', variables('logicAppName')), '2019-05-01', 'full').identity.principalId]"
    }
  }
}
