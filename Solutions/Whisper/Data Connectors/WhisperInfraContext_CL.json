{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "title": "Whisper Security - Infrastructure Context Table",
    "description": "Deploys the WhisperInfraContext_CL custom table, Data Collection Endpoint, and Data Collection Rule for ingesting infrastructure context data including DNS, WHOIS, and BGP information from the Whisper Security knowledge graph.",
    "prerequisites": [
      "Azure Sentinel workspace",
      "Whisper API key in Key Vault"
    ],
    "version": "1.0.0",
    "author": {
      "name": "Whisper Security"
    }
  },
  "parameters": {
    "workspace": {
      "type": "string",
      "metadata": {
        "description": "Log Analytics workspace name"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Location for all resources"
      }
    }
  },
  "variables": {
    "tableName": "WhisperInfraContext_CL",
    "dceName": "dce-whisper-infra-context",
    "dcrName": "dcr-whisper-infra-context",
    "customStreamName": "Custom-WhisperInfraContext_CL",
    "workspaceResourceId": "[resourceId('Microsoft.OperationalInsights/workspaces', parameters('workspace'))]"
  },
  "resources": [
    {
      "type": "Microsoft.OperationalInsights/workspaces/tables",
      "apiVersion": "2025-02-01",
      "name": "[concat(parameters('workspace'), '/', variables('tableName'))]",
      "properties": {
        "schema": {
          "name": "[variables('tableName')]",
          "columns": [
            {
              "name": "indicator",
              "type": "string",
              "description": "The IP address or domain being described"
            },
            {
              "name": "indicatorType",
              "type": "string",
              "description": "Indicator type (ip, domain)"
            },
            {
              "name": "ipAddresses",
              "type": "string",
              "description": "Resolved IP addresses (comma-separated)"
            },
            {
              "name": "prefixes",
              "type": "string",
              "description": "BGP prefixes containing the IP (comma-separated)"
            },
            {
              "name": "asns",
              "type": "string",
              "description": "Autonomous System Numbers (comma-separated)"
            },
            {
              "name": "asnNames",
              "type": "string",
              "description": "AS organization names (comma-separated)"
            },
            {
              "name": "cities",
              "type": "string",
              "description": "Geolocated cities (comma-separated)"
            },
            {
              "name": "countries",
              "type": "string",
              "description": "Geolocated countries (comma-separated)"
            },
            {
              "name": "registrar",
              "type": "string",
              "description": "Domain registrar name"
            },
            {
              "name": "registrant",
              "type": "string",
              "description": "Domain registrant organization"
            },
            {
              "name": "nameservers",
              "type": "string",
              "description": "Authoritative nameservers (comma-separated)"
            },
            {
              "name": "domainAge",
              "type": "int",
              "description": "Domain age in days since creation"
            },
            {
              "name": "dnssecAlgorithm",
              "type": "string",
              "description": "DNSSEC signing algorithm if present"
            },
            {
              "name": "cohostedCount",
              "type": "int",
              "description": "Number of domains co-hosted on the same IP"
            },
            {
              "name": "spfIncludes",
              "type": "string",
              "description": "SPF include directives (comma-separated)"
            },
            {
              "name": "bgpStatus",
              "type": "string",
              "description": "Current BGP routing status"
            },
            {
              "name": "TimeGenerated",
              "type": "dateTime",
              "description": "Event generation timestamp"
            }
          ]
        }
      }
    },
    {
      "type": "Microsoft.Insights/dataCollectionEndpoints",
      "apiVersion": "2024-03-11",
      "name": "[variables('dceName')]",
      "location": "[parameters('location')]",
      "properties": {
        "networkAcls": {
          "publicNetworkAccess": "Enabled"
        }
      }
    },
    {
      "type": "Microsoft.Insights/dataCollectionRules",
      "apiVersion": "2024-03-11",
      "name": "[variables('dcrName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces/tables', parameters('workspace'), variables('tableName'))]",
        "[resourceId('Microsoft.Insights/dataCollectionEndpoints', variables('dceName'))]"
      ],
      "properties": {
        "dataCollectionEndpointId": "[resourceId('Microsoft.Insights/dataCollectionEndpoints', variables('dceName'))]",
        "streamDeclarations": {
          "[variables('customStreamName')]": {
            "columns": [
              {
                "name": "indicator",
                "type": "string"
              },
              {
                "name": "indicatorType",
                "type": "string"
              },
              {
                "name": "ipAddresses",
                "type": "string"
              },
              {
                "name": "prefixes",
                "type": "string"
              },
              {
                "name": "asns",
                "type": "string"
              },
              {
                "name": "asnNames",
                "type": "string"
              },
              {
                "name": "cities",
                "type": "string"
              },
              {
                "name": "countries",
                "type": "string"
              },
              {
                "name": "registrar",
                "type": "string"
              },
              {
                "name": "registrant",
                "type": "string"
              },
              {
                "name": "nameservers",
                "type": "string"
              },
              {
                "name": "domainAge",
                "type": "int"
              },
              {
                "name": "dnssecAlgorithm",
                "type": "string"
              },
              {
                "name": "cohostedCount",
                "type": "int"
              },
              {
                "name": "spfIncludes",
                "type": "string"
              },
              {
                "name": "bgpStatus",
                "type": "string"
              },
              {
                "name": "TimeGenerated",
                "type": "datetime"
              }
            ]
          }
        },
        "destinations": {
          "logAnalytics": [
            {
              "workspaceResourceId": "[variables('workspaceResourceId')]",
              "name": "whisperWorkspace"
            }
          ]
        },
        "dataFlows": [
          {
            "streams": [
              "[variables('customStreamName')]"
            ],
            "destinations": [
              "whisperWorkspace"
            ],
            "transformKql": "source",
            "outputStream": "[variables('customStreamName')]"
          }
        ]
      }
    }
  ],
  "outputs": {
    "tableResourceId": {
      "type": "string",
      "value": "[resourceId('Microsoft.OperationalInsights/workspaces/tables', parameters('workspace'), variables('tableName'))]"
    },
    "dceResourceId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Insights/dataCollectionEndpoints', variables('dceName'))]"
    },
    "dcrResourceId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Insights/dataCollectionRules', variables('dcrName'))]"
    },
    "dceLogsIngestionEndpoint": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Insights/dataCollectionEndpoints', variables('dceName'))).logsIngestion.endpoint]"
    },
    "dcrImmutableId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Insights/dataCollectionRules', variables('dcrName'))).immutableId]"
    }
  }
}