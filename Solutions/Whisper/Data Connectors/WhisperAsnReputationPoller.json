{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "title": "Whisper Security - ASN Reputation Poller",
    "description": "Deploys a Logic App workflow that polls the Whisper Security explain() API every hour for a configurable list of ASNs, mapping reputation data into WhisperASNReputation_CL via DCR. Each poll appends new rows to enable time-series trend analysis of ASN reputation changes.",
    "prerequisites": [
      "Azure Sentinel workspace",
      "Whisper API key in Key Vault",
      "WhisperASNReputation_CL table deployed",
      "Data Collection Endpoint and Rule for WhisperASNReputation_CL"
    ],
    "version": "1.0.0",
    "author": {
      "name": "Whisper Security"
    }
  },
  "parameters": {
    "workspace": {
      "type": "string",
      "metadata": {
        "description": "Log Analytics workspace name"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Location for all resources"
      }
    },
    "playbook-name": {
      "type": "string",
      "defaultValue": "Whisper-AsnReputationPoller",
      "metadata": {
        "description": "Name of the Logic App playbook"
      }
    },
    "keyVaultSecretUri": {
      "type": "securestring",
      "metadata": {
        "description": "Key Vault secret URI for the Whisper API key (e.g. https://myvault.vault.azure.net/secrets/whisper-api-key)"
      }
    },
    "dceEndpoint": {
      "type": "string",
      "metadata": {
        "description": "Data Collection Endpoint logs ingestion URI"
      }
    },
    "dcrImmutableId": {
      "type": "string",
      "metadata": {
        "description": "Immutable ID of the Data Collection Rule for WhisperASNReputation_CL"
      }
    },
    "monitoredAsns": {
      "type": "string",
      "metadata": {
        "description": "Comma-separated list of ASNs to monitor, e.g., AS13335,AS15169"
      }
    },
    "keyVaultName": {
      "type": "string",
      "metadata": {
        "description": "Name of the Key Vault that holds the Whisper API key"
      }
    }
  },
  "variables": {
    "keyvaultConnectionName": "keyvault"
  },
  "resources": [
    {
      "type": "Microsoft.Web/connections",
      "apiVersion": "2018-07-01-preview",
      "name": "[variables('keyvaultConnectionName')]",
      "location": "[parameters('location')]",
      "properties": {
        "displayName": "Key Vault - Whisper API Key",
        "api": {
          "id": "[subscriptionResourceId('Microsoft.Web/locations/managedApis', parameters('location'), 'keyvault')]"
        },
        "parameterValueType": "Alternative",
        "alternativeParameterValues": {
          "vaultName": "[parameters('keyVaultName')]"
        }
      }
    },
    {
      "type": "Microsoft.Logic/workflows",
      "apiVersion": "2019-05-01",
      "name": "[parameters('playbook-name')]",
      "location": "[parameters('location')]",
      "tags": {
        "LogicAppsCategory": "security",
        "hidden-SentinelTemplateName": "Whisper-AsnReputationPoller",
        "hidden-SentinelTemplateVersion": "1.0.0",
        "hidden-SentinelWorkspaceId": "[parameters('workspace')]"
      },
      "identity": {
        "type": "SystemAssigned"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/connections', variables('keyvaultConnectionName'))]"
      ],
      "properties": {
        "state": "Enabled",
        "definition": {
          "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
          "contentVersion": "1.0.0.0",
          "parameters": {
            "$connections": {
              "type": "Object",
              "defaultValue": {}
            },
            "keyVaultSecretUri": {
              "type": "SecureString"
            },
            "dceEndpoint": {
              "type": "String"
            },
            "dcrImmutableId": {
              "type": "String"
            },
            "monitoredAsns": {
              "type": "String"
            }
          },
          "triggers": {
            "Recurrence": {
              "type": "Recurrence",
              "recurrence": {
                "frequency": "Hour",
                "interval": 1
              }
            }
          },
          "actions": {
            "Initialize_ASNs": {
              "type": "InitializeVariable",
              "inputs": {
                "variables": [
                  {
                    "name": "asnList",
                    "type": "array",
                    "value": "@split(parameters('monitoredAsns'), ',')"
                  }
                ]
              },
              "runAfter": {}
            },
            "Get_API_Key": {
              "type": "ApiConnection",
              "inputs": {
                "host": {
                  "connection": {
                    "name": "@parameters('$connections')['keyvault']['connectionId']"
                  }
                },
                "method": "get",
                "path": "/secrets/@{encodeURIComponent(last(split(parameters('keyVaultSecretUri'), '/')))}/value"
              },
              "runAfter": {
                "Initialize_ASNs": [
                  "Succeeded"
                ]
              },
              "runtimeConfiguration": {
                "secureData": {
                  "properties": [
                    "outputs"
                  ]
                }
              }
            },
            "For_Each_ASN": {
              "type": "Foreach",
              "foreach": "@variables('asnList')",
              "actions": {
                "Validate_Input": {
                  "type": "If",
                  "expression": {
                    "and": [
                      {
                        "not": {
                          "contains": [
                            "@toUpper(outputs('Compose_Indicator'))",
                            "MATCH"
                          ]
                        }
                      },
                      {
                        "not": {
                          "contains": [
                            "@toUpper(outputs('Compose_Indicator'))",
                            "RETURN"
                          ]
                        }
                      },
                      {
                        "not": {
                          "contains": [
                            "@toUpper(outputs('Compose_Indicator'))",
                            "DELETE"
                          ]
                        }
                      },
                      {
                        "not": {
                          "contains": [
                            "@toUpper(outputs('Compose_Indicator'))",
                            "MERGE"
                          ]
                        }
                      },
                      {
                        "not": {
                          "contains": [
                            "@toUpper(outputs('Compose_Indicator'))",
                            "CREATE"
                          ]
                        }
                      },
                      {
                        "not": {
                          "contains": [
                            "@toUpper(outputs('Compose_Indicator'))",
                            "SET"
                          ]
                        }
                      },
                      {
                        "not": {
                          "contains": [
                            "@toUpper(outputs('Compose_Indicator'))",
                            "REMOVE"
                          ]
                        }
                      },
                      {
                        "not": {
                          "contains": [
                            "@toUpper(outputs('Compose_Indicator'))",
                            "DETACH"
                          ]
                        }
                      },
                      {
                        "not": {
                          "equals": [
                            "@length(outputs('Compose_Indicator'))",
                            0
                          ]
                        }
                      }
                    ]
                  },
                  "actions": {
                    "Enrich_Scope": {
                      "type": "Scope",
                      "actions": {
                        "Call_Whisper_Explain": {
                          "type": "Http",
                          "inputs": {
                            "method": "POST",
                            "uri": "https://graph.whisper.security/api/query",
                            "headers": {
                              "Content-Type": "application/json",
                              "X-API-Key": "@body('Get_API_Key')?['value']"
                            },
                            "body": {
                              "query": "MATCH (a:ASN {name: \"AS@{outputs('Compose_Indicator')}\"})\nOPTIONAL MATCH (a)-[:HAS_NAME]->(an:ASN_NAME)\nOPTIONAL MATCH (a)-[:HAS_COUNTRY]->(c:COUNTRY)\nOPTIONAL MATCH (a)-[:ROUTES]->(p:PREFIX)\nWITH a, an, c, collect(distinct p) AS prefixes\nOPTIONAL MATCH (a)-[:PEERS_WITH]-(peer:ASN)\nWITH a, an, c, prefixes, count(distinct peer) AS peerCount\nUNWIND prefixes AS p\nOPTIONAL MATCH (p)<-[:BELONGS_TO]-(ip:IPV4) WHERE ip.isThreat = true\nWITH a, an, c, peerCount, size(prefixes) AS prefixCount,\n     coalesce(max(ip.threatScore), 0.0) AS maxThreatScore,\n     coalesce(avg(ip.threatScore), 0.0) AS avgThreatScore,\n     count(ip) AS threatIpCount\nRETURN coalesce(toFloat(a.threatScore), 0.0) AS reputationScore,\n       an.name AS asnName,\n       coalesce(a.threatLevel, \"NONE\") AS reputationLevel,\n       maxThreatScore,\n       avgThreatScore,\n       (threatIpCount > 0) AS hasThreateningPrefixes,\n       c.name AS country,\n       prefixCount,\n       peerCount"
                            },
                            "retryPolicy": {
                              "type": "exponential",
                              "count": 3,
                              "interval": "PT10S",
                              "maximumInterval": "PT1M"
                            }
                          },
                          "runAfter": {},
                          "runtimeConfiguration": {
                            "secureData": {
                              "properties": [
                                "inputs"
                              ]
                            }
                          }
                        },
                        "Parse_Explain_Response": {
                          "type": "ParseJson",
                          "inputs": {
                            "content": "@body('Call_Whisper_Explain')",
                            "schema": {
                              "type": "object",
                              "properties": {
                                "columns": {
                                  "type": "array",
                                  "items": {
                                    "type": "string"
                                  }
                                },
                                "rows": {
                                  "type": "array",
                                  "items": {
                                    "type": "object",
                                    "properties": {
                                      "reputationScore": {
                                        "type": "number"
                                      },
                                      "asnName": {
                                        "type": [
                                          "string",
                                          "null"
                                        ]
                                      },
                                      "reputationLevel": {
                                        "type": "string"
                                      },
                                      "maxThreatScore": {
                                        "type": "number"
                                      },
                                      "avgThreatScore": {
                                        "type": "number"
                                      },
                                      "hasThreateningPrefixes": {
                                        "type": "boolean"
                                      },
                                      "country": {
                                        "type": [
                                          "string",
                                          "null"
                                        ]
                                      },
                                      "prefixCount": {
                                        "type": "integer"
                                      },
                                      "peerCount": {
                                        "type": "integer"
                                      }
                                    }
                                  }
                                }
                              }
                            }
                          },
                          "runAfter": {
                            "Call_Whisper_Explain": [
                              "Succeeded"
                            ]
                          }
                        },
                        "Map_Reputation_Fields": {
                          "type": "Compose",
                          "inputs": {
                            "TimeGenerated": "@{utcNow()}",
                            "asn": "@outputs('Compose_Indicator')",
                            "reputationScore": "@body('Parse_Explain_Response')?['rows']?[0]?['reputationScore']",
                            "asnName": "@{body('Parse_Explain_Response')?['rows']?[0]?['asnName']}",
                            "reputationLevel": "@{body('Parse_Explain_Response')?['rows']?[0]?['reputationLevel']}",
                            "maxThreatScore": "@body('Parse_Explain_Response')?['rows']?[0]?['maxThreatScore']",
                            "avgThreatScore": "@body('Parse_Explain_Response')?['rows']?[0]?['avgThreatScore']",
                            "hasThreateningPrefixes": "@body('Parse_Explain_Response')?['rows']?[0]?['hasThreateningPrefixes']",
                            "country": "@{body('Parse_Explain_Response')?['rows']?[0]?['country']}",
                            "prefixCount": "@body('Parse_Explain_Response')?['rows']?[0]?['prefixCount']",
                            "peerCount": "@body('Parse_Explain_Response')?['rows']?[0]?['peerCount']"
                          },
                          "runAfter": {
                            "Parse_Explain_Response": [
                              "Succeeded"
                            ]
                          }
                        },
                        "Ingest_To_DCR": {
                          "type": "Http",
                          "inputs": {
                            "method": "POST",
                            "uri": "@{parameters('dceEndpoint')}/dataCollectionRules/@{parameters('dcrImmutableId')}/streams/Custom-WhisperASNReputation_CL?api-version=2023-01-01",
                            "headers": {
                              "Content-Type": "application/json"
                            },
                            "body": [
                              "@outputs('Map_Reputation_Fields')"
                            ],
                            "authentication": {
                              "type": "ManagedServiceIdentity",
                              "audience": "https://monitor.azure.com"
                            },
                            "retryPolicy": {
                              "type": "exponential",
                              "count": 3,
                              "interval": "PT10S",
                              "maximumInterval": "PT1M"
                            }
                          },
                          "runAfter": {
                            "Map_Reputation_Fields": [
                              "Succeeded"
                            ]
                          }
                        }
                      }
                    },
                    "Handle_Error": {
                      "type": "Scope",
                      "runAfter": {
                        "Enrich_Scope": [
                          "Failed",
                          "TimedOut"
                        ]
                      },
                      "actions": {
                        "Log_Error": {
                          "type": "Compose",
                          "inputs": {
                            "status": "error",
                            "asn": "@outputs('Compose_Indicator')",
                            "error": "@{result('Enrich_Scope')}",
                            "message": "Skipping ASN due to enrichment failure, continuing with remaining ASNs",
                            "timestamp": "@{utcNow()}"
                          },
                          "runAfter": {}
                        }
                      }
                    }
                  },
                  "else": {
                    "actions": {
                      "Log_Blocked_Input": {
                        "type": "Compose",
                        "inputs": {
                          "status": "blocked",
                          "reason": "Cypher injection keyword detected or empty indicator",
                          "asn": "@outputs('Compose_Indicator')",
                          "timestamp": "@{utcNow()}"
                        },
                        "runAfter": {}
                      }
                    }
                  },
                  "runAfter": {
                    "Compose_Indicator": [
                      "Succeeded"
                    ]
                  }
                },
                "Compose_Indicator": {
                  "type": "Compose",
                  "inputs": "@{trim(items('For_Each_ASN'))}",
                  "runAfter": {}
                }
              },
              "runAfter": {
                "Get_API_Key": [
                  "Succeeded"
                ]
              },
              "runtimeConfiguration": {
                "concurrency": {
                  "repetitions": 5
                }
              }
            }
          },
          "outputs": {}
        },
        "parameters": {
          "$connections": {
            "value": {
              "keyvault": {
                "connectionId": "[resourceId('Microsoft.Web/connections', variables('keyvaultConnectionName'))]",
                "connectionName": "[variables('keyvaultConnectionName')]",
                "id": "[subscriptionResourceId('Microsoft.Web/locations/managedApis', parameters('location'), 'keyvault')]",
                "connectionProperties": {
                  "authentication": {
                    "type": "ManagedServiceIdentity"
                  }
                }
              }
            }
          },
          "keyVaultSecretUri": {
            "value": "[parameters('keyVaultSecretUri')]"
          },
          "dceEndpoint": {
            "value": "[parameters('dceEndpoint')]"
          },
          "dcrImmutableId": {
            "value": "[parameters('dcrImmutableId')]"
          },
          "monitoredAsns": {
            "value": "[parameters('monitoredAsns')]"
          }
        }
      }
    }
  ],
  "outputs": {
    "logicAppResourceId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Logic/workflows', parameters('playbook-name'))]"
    },
    "logicAppManagedIdentityPrincipalId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Logic/workflows', parameters('playbook-name')), '2019-05-01', 'full').identity.principalId]"
    }
  }
}
