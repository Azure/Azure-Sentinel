{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "workspaceName": {
      "type": "string",
      "metadata": {
        "description": "Workspace name for Log Analytics where Sentinel is setup"
      }
    },
    "watchlistdescription": {
      "type": "string",
      "defaultValue": "Designated security champions per application team. Used to route alert notifications and escalations to the correct engineering contact.",
      "metadata": {
        "description": "Designated security champions per application team. Used to route alert notifications and escalations to the correct engineering contact."
      }
    }
  },
  "resources": [
    {
      "name": "[concat(parameters('workspaceName'), '/Microsoft.SecurityInsights/SecurityChampions')]",
      "type": "Microsoft.OperationalInsights/workspaces/providers/Watchlists",
      "apiVersion": "2022-08-01",
      "kind": "",
      "properties": {
        "displayName": "Security Champions",
        "source": "SecurityChampions.csv",
        "description": "[parameters('watchlistdescription')]",
        "provider": "Soluciones Etech Corp",
        "isDeleted": false,
        "labels": [],
        "defaultDuration": "P1000Y",
        "contentType": "Text/Csv",
        "numberOfLinesToSkip": 0,
        "itemsSearchKey": "ApplicationId",
        "rawContent": "ApplicationId,ChampionEmail,ChampionName,TeamSlack\nPLACEHOLDER_APP_001,champion@example.com,John Doe,#security-champions"
      }
    }
  ]
}
