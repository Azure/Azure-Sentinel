{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "workspaceName": {
      "type": "string",
      "metadata": {
        "description": "Workspace name for Log Analytics where Sentinel is setup"
      }
    },
    "watchlistdescription": {
      "type": "string",
      "defaultValue": "List of applications in scope for PCI-DSS compliance. Used by StratoSecure rule S11 (audit window open findings).",
      "metadata": {
        "description": "List of applications in scope for PCI-DSS compliance. Used by StratoSecure rule S11 (audit window open findings)."
      }
    }
  },
  "resources": [
    {
      "name": "[concat(parameters('workspaceName'), '/Microsoft.SecurityInsights/PCIApplications')]",
      "type": "Microsoft.OperationalInsights/workspaces/providers/Watchlists",
      "apiVersion": "2022-08-01",
      "kind": "",
      "properties": {
        "displayName": "PCI Scoped Applications",
        "source": "PCIApplications.csv",
        "description": "[parameters('watchlistdescription')]",
        "provider": "Soluciones Etech Corp",
        "isDeleted": false,
        "defaultDuration": "P1000Y",
        "contentType": "Text/Csv",
        "numberOfLinesToSkip": 0,
        "itemsSearchKey": "ApplicationId",
        "rawContent": "ApplicationId,AppName,PCIScope,Owner,AuditDate,CardholderData\nPLACEHOLDER_APP_001,Example App,in-scope,security@example.com,2026-12-01,yes"
      }
    }
  ]
}
