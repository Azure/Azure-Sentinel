{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "workspaceName": {
      "type": "string",
      "metadata": {
        "description": "Workspace name for Log Analytics where Sentinel is setup"
      }
    },
    "watchlistdescription": {
      "type": "string",
      "defaultValue": "List of applications with public internet exposure. Used by StratoSecure rules S6 (overdue findings) and S9 (unauthenticated APIs).",
      "metadata": {
        "description": "List of applications with public internet exposure. Used by StratoSecure rules S6 (overdue findings) and S9 (unauthenticated APIs)."
      }
    }
  },
  "resources": [
    {
      "name": "[concat(parameters('workspaceName'), '/Microsoft.SecurityInsights/InternetFacingApps')]",
      "type": "Microsoft.OperationalInsights/workspaces/providers/Watchlists",
      "apiVersion": "2022-08-01",
      "kind": "",
      "properties": {
        "displayName": "Internet Facing Applications",
        "source": "InternetFacingApps.csv",
        "description": "[parameters('watchlistdescription')]",
        "provider": "Soluciones Etech Corp",
        "isDeleted": false,
        "labels": [],
        "defaultDuration": "P1000Y",
        "contentType": "Text/Csv",
        "numberOfLinesToSkip": 0,
        "itemsSearchKey": "ApplicationId",
        "rawContent": "ApplicationId,AppName,Environment,Owner,InternetExposure\nPLACEHOLDER_APP_001,Example App,Production,security@example.com,public"
      }
    }
  ]
}
