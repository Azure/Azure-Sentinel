{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "workspaceName": {
      "type": "string",
      "metadata": {
        "description": "Workspace name for Log Analytics where Sentinel is setup"
      }
    },
    "watchlistdescription": {
      "type": "string",
      "defaultValue": "Upcoming compliance audit dates per application and framework. Used by StratoSecure rule S11 to alert on open findings within the audit window.",
      "metadata": {
        "description": "Upcoming compliance audit dates per application and framework. Used by StratoSecure rule S11 to alert on open findings within the audit window."
      }
    }
  },
  "resources": [
    {
      "name": "[concat(parameters('workspaceName'), '/Microsoft.SecurityInsights/AuditCalendar')]",
      "type": "Microsoft.OperationalInsights/workspaces/providers/Watchlists",
      "apiVersion": "2022-08-01",
      "kind": "",
      "properties": {
        "displayName": "Audit Calendar",
        "source": "AuditCalendar.csv",
        "description": "[parameters('watchlistdescription')]",
        "provider": "Soluciones Etech Corp",
        "isDeleted": false,
        "defaultDuration": "P1000Y",
        "contentType": "Text/Csv",
        "numberOfLinesToSkip": 0,
        "itemsSearchKey": "ApplicationId",
        "rawContent": "ApplicationId,Framework,AuditDate,AuditType,ContactEmail\nPLACEHOLDER_APP_001,PCI-DSS,2026-12-01,External,auditor@example.com"
      }
    }
  ]
}
