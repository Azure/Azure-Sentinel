{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "workspaceName": {
      "type": "string",
      "metadata": {
        "description": "Workspace name for Log Analytics where Sentinel is setup"
      }
    },
    "watchlistdescription": {
      "type": "string",
      "defaultValue": "List of repositories classified as critical tier assets. Used to prioritize findings from high-value codebases.",
      "metadata": {
        "description": "List of repositories classified as critical tier assets. Used to prioritize findings from high-value codebases."
      }
    }
  },
  "resources": [
    {
      "name": "[concat(parameters('workspaceName'), '/Microsoft.SecurityInsights/CriticalRepos')]",
      "type": "Microsoft.OperationalInsights/workspaces/providers/Watchlists",
      "apiVersion": "2022-08-01",
      "kind": "",
      "properties": {
        "displayName": "Critical Repositories",
        "source": "CriticalRepos.csv",
        "description": "[parameters('watchlistdescription')]",
        "provider": "Soluciones Etech Corp",
        "isDeleted": false,
        "defaultDuration": "P1000Y",
        "contentType": "Text/Csv",
        "numberOfLinesToSkip": 0,
        "itemsSearchKey": "RepoName",
        "rawContent": "RepoName,ApplicationId,Tier,Owner\nexample-repo,PLACEHOLDER_APP_001,Tier1,security@example.com"
      }
    }
  ]
}
