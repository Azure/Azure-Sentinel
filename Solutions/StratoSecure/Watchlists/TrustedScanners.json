{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "workspaceName": {
      "type": "string",
      "metadata": {
        "description": "Workspace name for Log Analytics where Sentinel is setup"
      }
    },
    "watchlistdescription": {
      "type": "string",
      "defaultValue": "List of known trusted scanner identifiers used by StratoSecure. Used to filter out false-positive alerts triggered by authorized scanning activity.",
      "metadata": {
        "description": "List of known trusted scanner identifiers used by StratoSecure. Used to filter out false-positive alerts triggered by authorized scanning activity."
      }
    }
  },
  "resources": [
    {
      "name": "[concat(parameters('workspaceName'), '/Microsoft.SecurityInsights/TrustedScanners')]",
      "type": "Microsoft.OperationalInsights/workspaces/providers/Watchlists",
      "apiVersion": "2022-08-01",
      "kind": "",
      "properties": {
        "displayName": "Trusted Scanners",
        "source": "TrustedScanners.csv",
        "description": "[parameters('watchlistdescription')]",
        "provider": "Soluciones Etech Corp",
        "isDeleted": false,
        "labels": [],
        "defaultDuration": "P1000Y",
        "contentType": "Text/Csv",
        "numberOfLinesToSkip": 0,
        "itemsSearchKey": "ScanId",
        "rawContent": "ScanId,ScannerName,TrustedSince\nPLACEHOLDER_SCAN_001,StratoSecure-Primary,2026-01-01"
      }
    }
  ]
}
