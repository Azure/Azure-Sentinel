{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "workspaceName": {
      "type": "string",
      "metadata": {
        "description": "Workspace name for Log Analytics where Sentinel is setup"
      }
    },
    "watchlistdescription": {
      "type": "string",
      "defaultValue": "List of rule IDs and application combinations that have been formally exempted from alerting. Requires CISO approval and expiry date.",
      "metadata": {
        "description": "List of rule IDs and application combinations that have been formally exempted from alerting. Requires CISO approval and expiry date."
      }
    }
  },
  "resources": [
    {
      "name": "[concat(parameters('workspaceName'), '/Microsoft.SecurityInsights/ExemptedFindings')]",
      "type": "Microsoft.OperationalInsights/workspaces/providers/Watchlists",
      "apiVersion": "2022-08-01",
      "kind": "",
      "properties": {
        "displayName": "Exempted Findings",
        "source": "ExemptedFindings.csv",
        "description": "[parameters('watchlistdescription')]",
        "provider": "Soluciones Etech Corp",
        "isDeleted": false,
        "labels": [],
        "defaultDuration": "P1000Y",
        "contentType": "Text/Csv",
        "numberOfLinesToSkip": 0,
        "itemsSearchKey": "RuleId",
        "rawContent": "RuleId,ApplicationId,ExpiryDate,Justification,ApprovedBy\nCWE-79,PLACEHOLDER_APP_001,2026-12-31,Accepted risk approved by CISO,ciso@example.com"
      }
    }
  ]
}
