{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "workspaceName": {
      "type": "string",
      "metadata": {
        "description": "Workspace name for Log Analytics where Sentinel is setup"
      }
    },
    "watchlistdescription": {
      "type": "string",
      "defaultValue": "Applications and services classified as high-value assets based on data sensitivity and business criticality. Used for risk prioritization in alerting.",
      "metadata": {
        "description": "Applications and services classified as high-value assets based on data sensitivity and business criticality. Used for risk prioritization in alerting."
      }
    }
  },
  "resources": [
    {
      "name": "[concat(parameters('workspaceName'), '/Microsoft.SecurityInsights/HighValueAssets')]",
      "type": "Microsoft.OperationalInsights/workspaces/providers/Watchlists",
      "apiVersion": "2022-08-01",
      "kind": "",
      "properties": {
        "displayName": "High Value Assets",
        "source": "HighValueAssets.csv",
        "description": "[parameters('watchlistdescription')]",
        "provider": "Soluciones Etech Corp",
        "isDeleted": false,
        "labels": [],
        "defaultDuration": "P1000Y",
        "contentType": "Text/Csv",
        "numberOfLinesToSkip": 0,
        "itemsSearchKey": "ApplicationId",
        "rawContent": "ApplicationId,AssetTier,DataClass,BizOwner\nPLACEHOLDER_APP_001,Tier1,PII,owner@example.com"
      }
    }
  ]
}
