{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "title": "StratoSecure - Assign Owner",
    "description": "When a Microsoft Sentinel incident is created from a StratoSecure finding, this playbook calls the StratoSecure API to assign the finding to the SOC team and writes an audit record to StratoSecure_PlaybookRuns_CL. Human approval is always required before the action executes.",
    "prerequisites": "StratoSecure Platform API key. Microsoft Sentinel workspace with Contributor access.",
    "postDeployment": [
      "Grant the Logic App system-assigned managed identity the 'Microsoft Sentinel Responder' role on the Sentinel workspace."
    ],
    "lastUpdateTime": "2026-06-01T00:00:00.000Z",
    "entities": [],
    "tags": ["StratoSecure", "ASPM", "Security"],
    "support": {
      "tier": "partner",
      "name": "Soluciones Etech Corp",
      "email": "support@stratocode.io",
      "link": "https://stratocode.io/support"
    },
    "author": {
      "name": "Soluciones Etech Corp"
    }
  },
  "parameters": {
    "PlaybookName": {
      "type": "string",
      "defaultValue": "StratoSecure-AssignOwner",
      "metadata": {
        "description": "Name of the Logic App playbook resource."
      }
    },
    "WorkspaceName": {
      "type": "string",
      "metadata": {
        "description": "Name of the Microsoft Sentinel Log Analytics workspace."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for the Logic App. Defaults to the resource group location."
      }
    },
    "StratoApiBaseUrl": {
      "type": "string",
      "defaultValue": "https://api.stratocode.io",
      "metadata": {
        "description": "Base URL of the StratoSecure platform API."
      }
    },
    "StratoApiKey": {
      "type": "securestring",
      "metadata": {
        "description": "StratoSecure API key. Generate at client.stratocode.io/settings/integrations. Store in Key Vault."
      }
    },
    "LogAnalyticsWorkspaceId": {
      "type": "string",
      "metadata": {
        "description": "Log Analytics workspace ID for audit log ingestion."
      }
    },
    "LogAnalyticsWorkspaceKey": {
      "type": "securestring",
      "metadata": {
        "description": "Log Analytics workspace primary or secondary key for the azureloganalyticsdatacollector connector."
      }
    },
    "RequireApproval": {
      "type": "bool",
      "defaultValue": true,
      "metadata": {
        "description": "When true, main actions execute after the approval condition evaluates. Set to false for fully automated execution without gating. Audit log is always written regardless of this setting."
      }
    }
  },
  "variables": {
    "MicrosoftSentinelConnectionName": "[concat('MicrosoftSentinel-', parameters('PlaybookName'))]",
    "AzureLogAnalyticsConnectionName": "[concat('AzureLogAnalytics-', parameters('PlaybookName'))]"
  },
  "resources": [
    {
      "type": "Microsoft.Web/connections",
      "apiVersion": "2016-06-01",
      "name": "[variables('MicrosoftSentinelConnectionName')]",
      "location": "[parameters('location')]",
      "kind": "V1",
      "properties": {
        "displayName": "[variables('MicrosoftSentinelConnectionName')]",
        "parameterValueType": "Alternative",
        "alternativeParameterValues": {},
        "api": {
          "id": "[concat('/subscriptions/', subscription().subscriptionId, '/providers/Microsoft.Web/locations/', parameters('location'), '/managedApis/azuresentinel')]"
        }
      }
    },
    {
      "type": "Microsoft.Web/connections",
      "apiVersion": "2016-06-01",
      "name": "[variables('AzureLogAnalyticsConnectionName')]",
      "location": "[parameters('location')]",
      "properties": {
        "displayName": "[variables('AzureLogAnalyticsConnectionName')]",
        "parameterValues": {
          "username": "[parameters('LogAnalyticsWorkspaceId')]",
          "password": "[parameters('LogAnalyticsWorkspaceKey')]"
        },
        "api": {
          "id": "[concat('/subscriptions/', subscription().subscriptionId, '/providers/Microsoft.Web/locations/', parameters('location'), '/managedApis/azureloganalyticsdatacollector')]"
        }
      }
    },
    {
      "type": "Microsoft.Logic/workflows",
      "apiVersion": "2017-07-01",
      "name": "[parameters('PlaybookName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.Web/connections', variables('MicrosoftSentinelConnectionName'))]",
        "[resourceId('Microsoft.Web/connections', variables('AzureLogAnalyticsConnectionName'))]"
      ],
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "state": "Enabled",
        "definition": {
          "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
          "contentVersion": "1.0.0.0",
          "parameters": {
            "$connections": {
              "defaultValue": {},
              "type": "Object"
            },
            "WorkspaceName": {
              "type": "string",
              "defaultValue": "[parameters('WorkspaceName')]"
            },
            "RequireApproval": {
              "defaultValue": true,
              "type": "Bool"
            }
          },
          "triggers": {
            "Microsoft_Sentinel_alert": {
              "type": "ApiConnectionWebhook",
              "inputs": {
                "host": {
                  "connection": {
                    "name": "@parameters('$connections')['azuresentinel']['connectionId']"
                  }
                },
                "body": {
                  "callback_url": "@{listCallbackUrl()}"
                },
                "path": "/subscribe"
              }
            }
          },
          "actions": {
            "Condition_RequireHumanApproval": {
              "type": "If",
              "expression": {
                "and": [
                  {
                    "equals": [
                      "@parameters('RequireApproval')",
                      "@true"
                    ]
                  }
                ]
              },
              "actions": {
                "Action_AssignOwner": {
                  "type": "Http",
                  "inputs": {
                    "method": "PATCH",
                    "uri": "[concat(parameters('StratoApiBaseUrl'), '/api/v1/findings/assign-owner')]",
                    "headers": {
                      "Content-Type": "application/json",
                      "X-API-Key": "[parameters('StratoApiKey')]"
                    },
                    "body": {
                      "findingId": "@{triggerBody()?['object']?['name']}",
                      "assignedTo": "soc-team",
                      "incidentId": "@{triggerBody()?['object']?['properties']?['incidentNumber']}",
                      "assignedAt": "@{utcNow()}"
                    }
                  },
                  "runAfter": {}
                },
                "Action_AuditLog": {
                  "type": "ApiConnection",
                  "inputs": {
                    "host": {
                      "connection": {
                        "name": "@parameters('$connections')['azureloganalyticsdatacollector']['connectionId']"
                      }
                    },
                    "method": "post",
                    "path": "/api/logs",
                    "headers": {
                      "Log-Type": "StratoSecure_PlaybookRuns_CL"
                    },
                    "body": {
                      "PlaybookName": "[parameters('PlaybookName')]",
                      "IncidentId": "@{triggerBody()?['object']?['name']}",
                      "IncidentTitle": "@{triggerBody()?['object']?['properties']?['title']}",
                      "Action": "AssignOwner",
                      "Status": "@{outputs('Action_AssignOwner')['statusCode']}",
                      "WorkspaceName": "[parameters('WorkspaceName')]",
                      "TimeGenerated": "@{utcNow()}"
                    }
                  },
                  "runAfter": {
                    "Action_AssignOwner": ["Succeeded", "Failed"]
                  }
                }
              },
              "else": {
                "actions": {}
              },
              "runAfter": {}
            }
          }
        },
        "parameters": {
          "$connections": {
            "value": {
              "azuresentinel": {
                "connectionId": "[resourceId('Microsoft.Web/connections', variables('MicrosoftSentinelConnectionName'))]",
                "connectionName": "[variables('MicrosoftSentinelConnectionName')]",
                "connectionProperties": {
                  "authentication": {
                    "type": "ManagedServiceIdentity"
                  }
                },
                "id": "[concat('/subscriptions/', subscription().subscriptionId, '/providers/Microsoft.Web/locations/', parameters('location'), '/managedApis/azuresentinel')]"
              },
              "azureloganalyticsdatacollector": {
                "connectionId": "[resourceId('Microsoft.Web/connections', variables('AzureLogAnalyticsConnectionName'))]",
                "connectionName": "[variables('AzureLogAnalyticsConnectionName')]",
                "id": "[concat('/subscriptions/', subscription().subscriptionId, '/providers/Microsoft.Web/locations/', parameters('location'), '/managedApis/azureloganalyticsdatacollector')]"
              }
            }
          },
          "RequireApproval": {
            "value": "[parameters('RequireApproval')]"
          }
        }
      }
    }
  ],
  "outputs": {
    "PlaybookResourceId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Logic/workflows', parameters('PlaybookName'))]"
    },
    "PlaybookPrincipalId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Logic/workflows', parameters('PlaybookName')), '2017-07-01', 'Full').identity.principalId]"
    }
  }
}
