{
  "name": "StratoSecurePushConnector",
  "apiVersion": "2024-01-01-preview",
  "type": "Microsoft.SecurityInsights/dataConnectors",
  "location": "{{location}}",
  "kind": "Push",
  "properties": {
    "connectorDefinitionName": "StratoSecurePush",
    "dcrConfig": {
      "streamName": "Custom-StratoSecure_Findings_CL",
      "dataCollectionEndpoint": "{{dataCollectionEndpoint}}",
      "dataCollectionRuleImmutableId": "{{dataCollectionRuleImmutableId}}"
    },
    "auth": {
      "type": "Push",
      "appId": "{{appId}}",
      "servicePrincipalId": "{{servicePrincipalId}}"
    },
    "request": {
      "RetryCount": 1
    },
    "response": {
      "eventsJsonPaths": [
        "$.messages"
      ]
    }
  }
}