{
    "location": "<customer-region>",
    "kind": "Direct",
    "apiVersion": "2024-03-11",
    "properties": {
        "streamDeclarations": {
            "Custom-StratoSecure_Remediation_CL": {
                "columns": [
                    {"name": "TimeGenerated", "type": "datetime"},
                    {"name": "StraTenantId", "type": "string"},
                    {"name": "ScanId", "type": "string"},
                    {"name": "FindingId", "type": "string"},
                    {"name": "FindingFingerprint", "type": "string"},
                    {"name": "OldStatus", "type": "string"},
                    {"name": "NewStatus", "type": "string"},
                    {"name": "ChangedBy", "type": "string"},
                    {"name": "ChangeTimestamp", "type": "datetime"},
                    {"name": "JustificationRef", "type": "string"}
                ]
            }
        },
        "destinations": {
            "logAnalytics": [
                {
                    "workspaceResourceId": "<workspace-arm-resource-id>",
                    "name": "LogAnalyticsDest"
                }
            ]
        },
        "dataFlows": [
            {
                "streams": ["Custom-StratoSecure_Remediation_CL"],
                "destinations": ["LogAnalyticsDest"],
                "transformKql": "source",
                "outputStream": "Custom-StratoSecure_Remediation_CL"
            }
        ]
    }
}
