{
    "location": "<customer-region>",
    "kind": "Direct",
    "apiVersion": "2024-03-11",
    "properties": {
        "streamDeclarations": {
            "Custom-StratoSecure_ScanSummary_CL": {
                "columns": [
                    {"name": "TimeGenerated", "type": "datetime"},
                    {"name": "StraTenantId", "type": "string"},
                    {"name": "ScanId", "type": "string"},
                    {"name": "ProjectId", "type": "string"},
                    {"name": "FindingCount", "type": "int"},
                    {"name": "CriticalCount", "type": "int"},
                    {"name": "HighCount", "type": "int"},
                    {"name": "MediumCount", "type": "int"},
                    {"name": "LowCount", "type": "int"},
                    {"name": "NewFindings", "type": "int"},
                    {"name": "ResolvedFindings", "type": "int"},
                    {"name": "ScanDuration", "type": "real"},
                    {"name": "ScanStatus", "type": "string"}
                ]
            }
        },
        "destinations": {
            "logAnalytics": [
                {
                    "workspaceResourceId": "<workspace-arm-resource-id>",
                    "name": "LogAnalyticsDest"
                }
            ]
        },
        "dataFlows": [
            {
                "streams": ["Custom-StratoSecure_ScanSummary_CL"],
                "destinations": ["LogAnalyticsDest"],
                "transformKql": "source",
                "outputStream": "Custom-StratoSecure_ScanSummary_CL"
            }
        ]
    }
}
