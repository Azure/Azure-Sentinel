  "Description": "AWS Security Hub Solution for Microsoft Sentinel provides data connector to ingest AWS Security Hub findings into Microsoft Sentinel.",
  "Workbooks": [
      "Workbooks/AWSSecurityHubComplianceWorkbook.json"
