{
  "name": "FieldEffectARODCR",
  "apiVersion": "2022-06-01",
  "type": "Microsoft.Insights/dataCollectionRules",
  "location": "{{workspace-location}}",
  "properties": {
    "dataCollectionEndpointId": "{{dataCollectionEndpointId}}",
    "streamDeclarations": {
      "Custom-FieldEffectAROAlerts_CL": {
        "columns": [
          { "name": "ID", "type": "string" },
          { "name": "Severity", "type": "string" },
          { "name": "AROType", "type": "string" },
          { "name": "Title", "type": "string" },
          { "name": "Hostname", "type": "string" },
          { "name": "IPAddress", "type": "string" },
          { "name": "LastUser", "type": "string" },
          { "name": "DetailsMarkdown", "type": "string" },
          { "name": "DetailsRaw", "type": "string" },
          { "name": "PortalUrl", "type": "string" },
          { "name": "TimeGenerated", "type": "datetime" }
        ]
      }
    },
    "destinations": {
      "logAnalytics": [
        {
          "workspaceResourceId": "{{workspaceResourceId}}",
          "name": "clv2ws2"
        }
      ]
    },
    "dataFlows": [
      {
        "streams": [
          "Custom-FieldEffectAROAlerts_CL"
        ],
        "destinations": [
          "clv2ws2"
        ],
        "transformKql": "source\n| extend d = todynamic(data)\n| extend Agent = todynamic(d.agent_details)\n| project\n    ID = tostring(serial_id),\n    Severity = tostring(d.severity),\n    AROType = tostring(d.type),\n    Title = tostring(d.title),\n    Hostname = tostring(Agent.hostName),\n    IPAddress = tostring(Agent.ipAddress),\n    LastUser = tostring(Agent.lastSessionUser),\n    DetailsMarkdown = tostring(d.details_markdown),\n    DetailsRaw = tostring(d.details),\n    PortalUrl = tostring(d.display_url),\n    TimeGenerated = now()",
        "outputStream": "Custom-FieldEffectAROAlerts_CL"
      }
    ]
  }
}