[
  {
    "type": "Microsoft.SecurityInsights/dataConnectors",
    "apiVersion": "2023-04-01-preview",
    "name": "FieldEffectAROsPoller",
    "location": "{{location}}",
    "kind": "RestApiPoller",
    "properties": {
      "connectorDefinitionName": "FieldEffectCCF",
      "dataType": "FieldEffectARO",
      "dcrConfig": {
        "streamName": "Custom-FieldEffectAROAlerts_CL",
        "dataCollectionEndpoint": "{{dataCollectionEndpoint}}",
        "dataCollectionRuleImmutableId": "{{dataCollectionRuleImmutableId}}"
      },
      "auth": {
        "type": "APIKey",
        "apiKey": "{{bearerToken}}",
        "apiKeyName": "Authorization",
        "apiKeyIdentifier": "Bearer"
      },
      "request": {
        "httpMethod": "GET",
        "apiEndpoint": "https://services.fieldeffect.net/v1/aros",
        "headers": {
          "Accept": "application/json"
        },
        "queryParameters": {
          "organization_id": "{{organizationId}}",
          "limit": 20,
          "sort_by": "creation_time",
          "sort_order": "desc",
          "status": "Open",
          "resolution": "Unresolved",
          "released_time_since": "{_QueryWindowStartTime}"
        },
        "queryTimeFormat": "yyyy-MM-dd HH:mm:ss",
        "queryWindowInMin": 5,
        "timeoutInSeconds": 45,
        "retryCount": 3,
        "logResponseContent": true
      },
      "response": {
        "eventsJsonPaths": [
          "$.items"
        ]
      }
    }
  }
]
