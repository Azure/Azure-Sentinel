{
  "$schema": "https://schema.management.azure.com/schemas/0.1.2-preview/CreateUIDefinition.MultiVm.json#",
  "handler": "Microsoft.Azure.CreateUIDef",
  "version": "0.1.2-preview",
  "parameters": {
    "config": {
      "isWizard": false,
      "basics": {
        "description": "<img src=\"https://raw.githubusercontent.com/Azure/Azure-Sentinel/master/Logos/FieldEffect_Logo.svg\" width=\"75px\" height=\"75px\">\n\n**Note:** Please review the https://github.com/Azure/Azure-Sentinel/tree/master/Solutions/FieldEffectMDR/ReleaseNotes.md before installing.\n\nThe [Field Effect](https://fieldeffect.com/) solution for Microsoft Sentinel ingests Field Effect MDR ARO alerts into a Log Analytics custom table for hunting, correlation, and alerting.\n\n**Data Connectors:** 1, **Parsers:** 1, **Analytic Rules:** 1\n\n[Learn more about Microsoft Sentinel](https://aka.ms/azuresentinel)\n[Learn more about Solutions](https://aka.ms/azuresentinelsolutionsdoc)",
        "subscription": {
          "resourceProviders": [
            "Microsoft.OperationalInsights/workspaces",
            "Microsoft.SecurityInsights",
            "Microsoft.Insights"
          ]
        },
        "location": {
          "metadata": {
            "hidden": "Hiding location, we get it from the Log Analytics workspace"
          },
          "visible": false
        },
        "resourceGroup": {
          "allowExisting": true
        }
      }
    }
  },
  "basics": [
    {
      "name": "getLAWorkspace",
      "type": "Microsoft.Solutions.ArmApiControl",
      "toolTip": "Lists Log Analytics workspaces in the selected subscription.",
      "condition": "[greater(length(resourceGroup().name),0)]",
      "request": {
        "method": "GET",
        "path": "[concat(subscription().id,'/providers/Microsoft.OperationalInsights/workspaces?api-version=2020-08-01')]"
      }
    },
    {
      "name": "workspace",
      "type": "Microsoft.Common.DropDown",
      "label": "Workspace",
      "placeholder": "Select a workspace",
      "toolTip": "This dropdown lists workspaces that exist in the selected resource group.",
      "constraints": {
        "allowedValues": "[map(filter(basics('getLAWorkspace').value, (w) => contains(toLower(w.id), toLower(resourceGroup().name))), (item) => parse(concat('{\"label\":\"', item.name, '\",\"value\":\"', item.name, '\"}')))]",
        "required": true
      },
      "visible": true
    }
  ],
  "steps": [
    {
      "name": "connectorconfig",
      "label": "Connector Configuration",
      "bladeTitle": "Connector Configuration",
      "elements": [
        {
          "name": "apiKey",
          "type": "Microsoft.Common.TextBox",
          "label": "Field Effect API Key",
          "toolTip": "API key used as a Bearer token in the Authorization header.",
          "constraints": {
            "required": true
          },
          "options": {
            "isPassword": true
          }
        },
        {
          "name": "organizationId",
          "type": "Microsoft.Common.TextBox",
          "label": "Organization ID",
          "toolTip": "Your Field Effect Organization ID.",
          "constraints": {
            "required": true
          }
        }
      ]
    },
    {
      "name": "dataconnectors",
      "label": "Data Connectors",
      "bladeTitle": "Data Connectors",
      "elements": [
        {
          "name": "dataconnectors-text",
          "type": "Microsoft.Common.TextBlock",
          "options": {
            "text": "This solution installs the Field Effect MDR data connector (via the Codeless Connector Framework). After installing the solution, configure and enable the connector from the Manage solution view."
          }
        },
        {
          "name": "dataconnectors-link",
          "type": "Microsoft.Common.TextBlock",
          "options": {
            "link": {
              "label": "Learn more about connecting data sources",
              "uri": "https://docs.microsoft.com/azure/sentinel/connect-data-sources"
            }
          }
        }
      ]
    },
    {
      "name": "parsers",
      "label": "Parsers",
      "bladeTitle": "Parsers",
      "elements": [
        {
          "name": "parsers-text",
          "type": "Microsoft.Common.TextBlock",
          "options": {
            "text": "This solution installs a parser that maps Field Effect MDR ARO alert data to normalized fields for analysis and correlation."
          }
        },
        {
          "name": "parsers-link",
          "type": "Microsoft.Common.TextBlock",
          "options": {
            "link": {
              "label": "Learn more about parsers",
              "uri": "https://docs.microsoft.com/azure/sentinel/normalization-about-parsers"
            }
          }
        }
      ]
    },
    {
      "name": "analytics",
      "label": "Analytics",
      "bladeTitle": "Analytics",
      "elements": [
        {
          "name": "analytics-text",
          "type": "Microsoft.Common.TextBlock",
          "options": {
            "text": "This solution installs analytic rule templates. After installing the solution, create and enable analytic rules from the Manage solution view."
          }
        },
        {
          "name": "analytics-link",
          "type": "Microsoft.Common.TextBlock",
          "options": {
            "link": {
              "label": "Learn more",
              "uri": "https://docs.microsoft.com/azure/sentinel/tutorial-detect-threats-custom?WT.mc_id=Portal-Microsoft_Azure_CreateUIDef"
            }
          }
        }
      ]
    }
  ],
  "outputs": {
    "workspace-location": "[first(map(filter(basics('getLAWorkspace').value, (w) => and(contains(toLower(w.id), toLower(resourceGroup().name)), equals(w.name, basics('workspace')))), (item) => item.location))]",
    "workspaceResourceId": "[first(map(filter(basics('getLAWorkspace').value, (w) => and(contains(toLower(w.id), toLower(resourceGroup().name)), equals(w.name, basics('workspace')))), (item) => item.id))]",
    "location": "[location()]",
    "workspace": "[basics('workspace')]",
    "bearerToken": "[steps('connectorconfig').apiKey]",
    "organizationId": "[steps('connectorconfig').organizationId]"
  }
}
