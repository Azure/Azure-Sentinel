{
  "name": "CheckPointCyberintPremiumIOCDCR",
  "apiVersion": "2021-09-01-preview",
  "type": "Microsoft.Insights/dataCollectionRules",
  "location": "{{location}}",
  "properties": {
    "dataCollectionEndpointId": "{{dataCollectionEndpointId}}",
    "streamDeclarations": {
      "Custom-iocsentpremium_CL": {
        "columns": [
          {
            "name": "indicator_type",
            "type": "string"
          },
          {
            "name": "indicator_value",
            "type": "string"
          },
          {
            "name": "activity",
            "type": "string"
          },
          {
            "name": "confidence",
            "type": "int"
          },
          {
            "name": "severity",
            "type": "int"
          },
          {
            "name": "malicious",
            "type": "string"
          },
          {
            "name": "kill_chain_stage",
            "type": "string"
          },
          {
            "name": "first_seen",
            "type": "datetime"
          },
          {
            "name": "last_seen",
            "type": "datetime"
          },
          {
            "name": "added_to_feed",
            "type": "datetime"
          },
          {
            "name": "valid_until",
            "type": "datetime"
          },
          {
            "name": "is_blocking",
            "type": "boolean"
          },
          {
            "name": "is_unique",
            "type": "boolean"
          },
          {
            "name": "malware_types",
            "type": "dynamic"
          },
          {
            "name": "has_cve",
            "type": "boolean"
          },
          {
            "name": "has_campaign",
            "type": "boolean"
          }
        ]
      }
    },
    "dataSources": {},
    "destinations": {
      "logAnalytics": [
        {
          "workspaceResourceId": "{{workspaceResourceId}}",
          "name": "ioc-sent-premium"
        }
      ]
    },
    "dataFlows": [
      {
        "streams": [
          "Custom-iocsentpremium_CL"
        ],
        "destinations": [
          "ioc-sent-premium"
        ],
        "transformKql": "source\n| extend TimeGenerated = todatetime(added_to_feed)\n",
        "outputStream": "Custom-iocsentpremium_CL"
      }
    ]
  }
}
