{
  "name": "CyberintPremiumIOCPollingConfig",
  "apiVersion": "2022-12-01-preview",
  "type": "Microsoft.SecurityInsights/dataConnectors",
  "location": "{{location}}",
  "kind": "RestApiPoller",
  "properties": {
    "connectorDefinitionName": "CheckPointCyberintPremiumIOC",
    "dcrConfig": {
      "streamName": "Custom-iocsentpremium_CL",
      "dataCollectionEndpoint": "{{dataCollectionEndpoint}}",
      "dataCollectionRuleImmutableId": "{{dataCollectionRuleImmutableId}}"
    },
    "dataType": "iocsentpremium_CL",
    "auth": {
      "type": "APIKey",
      "ApiKey": "{{apikey}}",
      "ApiKeyName": "Cookie",
      "ApiKeyIdentifier": "access_token="
    },
    "request": {
      "apiEndpoint": "{{argosurl}}/ioc-intel/feed-api/v1/feed/jsonl",
      "rateLimitQPS": 10,
      "queryWindowInMin": 60,
      "httpMethod": "POST",
      "queryTimeFormat": "yyyy-MM-ddTHH:mm:ssZ",
      "retryCount": 3,
      "timeoutInSeconds": 120,
      "headers": {
        "Accept": "application/x-ndjson",
        "User-Agent": "Scuba",
        "X-Sender-Id": "0",
        "X-Integration-Type": "Azure Sentinel Premium IOC",
        "X-Integration-Instance-Name": "Default",
        "X-Integration-Instance-Id": "0",
        "X-Integration-Customer-Name": "Integration",
        "X-Integration-Version": "1.0"
      },
      "isPostPayloadJson": true,
      "queryParametersTemplate": "{ 'filters': { 'added_to_feed_after': '{_QueryWindowStartTime}' }, 'pagination': { 'limit': 100000, 'offset': 0 }, 'sort': { 'field': 'added_to_feed', 'direction': 'asc' } }"
    },
    "response": {
      "eventsJsonPaths": ["$"],
      "format": "jsonlines",
      "successStatusCodes": [200]
    }
  }
}
