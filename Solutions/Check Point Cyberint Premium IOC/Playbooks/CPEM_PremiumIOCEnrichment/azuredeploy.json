{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "title": "Check Point Exposure Management - Premium IOC Enrichment and Triage",
    "description": "When a new Microsoft Sentinel incident is created, this playbook enriches IOC entities (IPs, domains, file hashes, URLs) using the Check Point Exposure Management Premium IOC enrichment API and adds a structured enrichment comment to the incident. The Premium API returns malicious classification, confidence (0-100), severity (0-5), kill-chain stage, malware family, threat actors, CVEs, and type-specific enrichment (geo/whois/file).",
    "prerequisites": [
      "1. A valid Check Point Exposure Management API token and base Argos URL (e.g. https://your-company.cyberint.io).",
      "2. The Logic App Managed Identity must be granted Microsoft Sentinel Responder role on the resource group."
    ],
    "postDeployment": [
      "1. Grant the Logic App Managed Identity the **Microsoft Sentinel Responder** role.",
      "2. Configure an automation rule in Microsoft Sentinel to trigger this playbook on incident creation."
    ],
    "lastUpdateTime": "2026-04-26T00:00:00.000Z",
    "entities": [
      "IP",
      "FileHash",
      "DNS",
      "URL"
    ],
    "tags": [
      "Enrichment"
    ],
    "support": {
      "tier": "Partner",
      "name": "Check Point",
      "link": "https://cyberint.com/customer-support/"
    },
    "source": {
      "type": "solution",
      "name": "Check Point Cyberint Premium IOC"
    },
    "author": {
      "name": "Check Point"
    },
    "releaseNotes": [
      {
        "version": "1.0.0",
        "title": "Check Point Exposure Management - Premium IOC Enrichment and Triage",
        "notes": [
          "Initial version"
        ]
      }
    ]
  },
  "parameters": {
    "PlaybookName": {
      "type": "String",
      "defaultValue": "Check_Point_EM_PremiumIOCEnrichment",
      "metadata": {
        "description": "Name of the Logic App / Playbook"
      }
    },
    "API_Base_URL": {
      "type": "String",
      "metadata": {
        "description": "Base URL of the Check Point Exposure Management API (e.g. https://your-company.cyberint.io)"
      }
    },
    "API_Access_Token": {
      "type": "SecureString",
      "metadata": {
        "description": "API token for Check Point Exposure Management"
      }
    }
  },
  "variables": {
    "AzureSentinelConnectionName": "[concat('azuresentinel-', parameters('PlaybookName'))]",
    "workspace-location-inline": "[resourceGroup().location]"
  },
  "resources": [
    {
      "type": "Microsoft.Web/connections",
      "apiVersion": "2016-06-01",
      "name": "[variables('AzureSentinelConnectionName')]",
      "location": "[variables('workspace-location-inline')]",
      "kind": "V1",
      "properties": {
        "displayName": "[variables('AzureSentinelConnectionName')]",
        "parameterValueType": "Alternative",
        "api": {
          "id": "[concat('/subscriptions/', subscription().subscriptionId, '/providers/Microsoft.Web/locations/', resourceGroup().location, '/managedApis/azuresentinel')]"
        }
      }
    },
    {
      "type": "Microsoft.Logic/workflows",
      "apiVersion": "2017-07-01",
      "name": "[parameters('PlaybookName')]",
      "location": "[variables('workspace-location-inline')]",
      "identity": {
        "type": "SystemAssigned"
      },
      "tags": {
        "hidden-SentinelTemplateName": "Check_Point_EM_PremiumIOCEnrichment",
        "hidden-SentinelTemplateVersion": "1.0"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/connections', variables('AzureSentinelConnectionName'))]"
      ],
      "properties": {
        "state": "Enabled",
        "definition": {
          "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
          "contentVersion": "1.0.0.0",
          "parameters": {
            "$connections": {
              "type": "Object"
            },
            "API_Base_URL": {
              "defaultValue": "",
              "type": "String"
            },
            "API_Access_Token": {
              "defaultValue": "",
              "type": "SecureString"
            }
          },
          "triggers": {
            "Microsoft_Sentinel_incident": {
              "type": "ApiConnectionWebhook",
              "inputs": {
                "host": {
                  "connection": {
                    "name": "@parameters('$connections')['azuresentinel']['connectionId']"
                  }
                },
                "body": {
                  "callback_url": "@{listCallbackUrl()}"
                },
                "path": "/incident-creation"
              }
            }
          },
          "actions": {
            "Entities_-_Get_IPs": {
              "type": "ApiConnection",
              "inputs": {
                "host": {
                  "connection": {
                    "name": "@parameters('$connections')['azuresentinel']['connectionId']"
                  }
                },
                "method": "post",
                "body": "@triggerBody()?['object']?['properties']?['relatedEntities']",
                "path": "/entities/ip"
              },
              "runAfter": {}
            },
            "Entities_-_Get_FileHashes": {
              "type": "ApiConnection",
              "inputs": {
                "host": {
                  "connection": {
                    "name": "@parameters('$connections')['azuresentinel']['connectionId']"
                  }
                },
                "method": "post",
                "body": "@triggerBody()?['object']?['properties']?['relatedEntities']",
                "path": "/entities/filehash"
              },
              "runAfter": {}
            },
            "Entities_-_Get_DNS": {
              "type": "ApiConnection",
              "inputs": {
                "host": {
                  "connection": {
                    "name": "@parameters('$connections')['azuresentinel']['connectionId']"
                  }
                },
                "method": "post",
                "body": "@triggerBody()?['object']?['properties']?['relatedEntities']",
                "path": "/entities/dnsresolution"
              },
              "runAfter": {}
            },
            "Entities_-_Get_URLs": {
              "type": "ApiConnection",
              "inputs": {
                "host": {
                  "connection": {
                    "name": "@parameters('$connections')['azuresentinel']['connectionId']"
                  }
                },
                "method": "post",
                "body": "@triggerBody()?['object']?['properties']?['relatedEntities']",
                "path": "/entities/url"
              },
              "runAfter": {}
            },
            "Initialize_variable_-_EnrichmentComment": {
              "type": "InitializeVariable",
              "inputs": {
                "variables": [
                  {
                    "name": "EnrichmentComment",
                    "type": "string",
                    "value": ""
                  }
                ]
              },
              "runAfter": {
                "Entities_-_Get_IPs": ["Succeeded"],
                "Entities_-_Get_FileHashes": ["Succeeded"],
                "Entities_-_Get_DNS": ["Succeeded"],
                "Entities_-_Get_URLs": ["Succeeded"]
              }
            },
            "For_each_IP": {
              "type": "Foreach",
              "foreach": "@body('Entities_-_Get_IPs')?['IPs']",
              "actions": {
                "Enrich_IP": {
                  "type": "Http",
                  "inputs": {
                    "method": "POST",
                    "uri": "@{parameters('API_Base_URL')}/ioc-intel/enrichment-api/v1/enrichment",
                    "headers": {
                      "Accept": "application/json",
                      "Content-Type": "application/json",
                      "Cookie": "access_token=@{parameters('API_Access_Token')}",
                      "X-Integration-Type": "Azure Sentinel Premium IOC",
                      "X-Integration-Version": "1.0"
                    },
                    "body": {
                      "type": "ipv4",
                      "value": "@{items('For_each_IP')?['Address']}"
                    }
                  },
                  "runAfter": {}
                },
                "Append_IP_result": {
                  "type": "AppendToStringVariable",
                  "inputs": {
                    "name": "EnrichmentComment",
                    "value": "<br><strong>IP: @{items('For_each_IP')?['Address']}</strong> — Malicious: @{json(string(body('Enrich_IP')))?['malicious']} | Confidence: @{json(string(body('Enrich_IP')))?['confidence']} | Severity: @{json(string(body('Enrich_IP')))?['severity']} | Activity: @{json(string(body('Enrich_IP')))?['activity']} | Kill Chain: @{json(string(body('Enrich_IP')))?['kill_chain_stage']} | Malware Family: @{json(string(body('Enrich_IP')))?['malware_family']} | First Seen: @{json(string(body('Enrich_IP')))?['first_seen']}"
                  },
                  "runAfter": {
                    "Enrich_IP": ["Succeeded"]
                  }
                }
              },
              "runAfter": {
                "Initialize_variable_-_EnrichmentComment": ["Succeeded"]
              }
            },
            "For_each_FileHash": {
              "type": "Foreach",
              "foreach": "@body('Entities_-_Get_FileHashes')?['Filehashes']",
              "actions": {
                "Select_hash_type": {
                  "type": "Compose",
                  "inputs": "@if(equals(length(coalesce(items('For_each_FileHash')?['Value'], '')), 64), 'sha256', if(equals(length(coalesce(items('For_each_FileHash')?['Value'], '')), 40), 'sha1', if(equals(length(coalesce(items('For_each_FileHash')?['Value'], '')), 32), 'md5', 'sha256')))",
                  "runAfter": {}
                },
                "Enrich_FileHash": {
                  "type": "Http",
                  "inputs": {
                    "method": "POST",
                    "uri": "@{parameters('API_Base_URL')}/ioc-intel/enrichment-api/v1/enrichment",
                    "headers": {
                      "Accept": "application/json",
                      "Content-Type": "application/json",
                      "Cookie": "access_token=@{parameters('API_Access_Token')}",
                      "X-Integration-Type": "Azure Sentinel Premium IOC",
                      "X-Integration-Version": "1.0"
                    },
                    "body": {
                      "type": "@{outputs('Select_hash_type')}",
                      "value": "@{items('For_each_FileHash')?['Value']}"
                    }
                  },
                  "runAfter": {
                    "Select_hash_type": ["Succeeded"]
                  }
                },
                "Append_FileHash_result": {
                  "type": "AppendToStringVariable",
                  "inputs": {
                    "name": "EnrichmentComment",
                    "value": "<br><strong>Hash (@{outputs('Select_hash_type')}): @{items('For_each_FileHash')?['Value']}</strong> — Malicious: @{json(string(body('Enrich_FileHash')))?['malicious']} | Confidence: @{json(string(body('Enrich_FileHash')))?['confidence']} | Severity: @{json(string(body('Enrich_FileHash')))?['severity']} | Activity: @{json(string(body('Enrich_FileHash')))?['activity']} | Malware Family: @{json(string(body('Enrich_FileHash')))?['malware_family']} | Threat Actors: @{join(coalesce(json(string(body('Enrich_FileHash')))?['threat_actors'], json('[]')), ', ')} | CVEs: @{join(coalesce(json(string(body('Enrich_FileHash')))?['cves'], json('[]')), ', ')}"
                  },
                  "runAfter": {
                    "Enrich_FileHash": ["Succeeded"]
                  }
                }
              },
              "runAfter": {
                "For_each_IP": ["Succeeded"]
              }
            },
            "For_each_Domain": {
              "type": "Foreach",
              "foreach": "@body('Entities_-_Get_DNS')?['DNSresolutions']",
              "actions": {
                "Enrich_Domain": {
                  "type": "Http",
                  "inputs": {
                    "method": "POST",
                    "uri": "@{parameters('API_Base_URL')}/ioc-intel/enrichment-api/v1/enrichment",
                    "headers": {
                      "Accept": "application/json",
                      "Content-Type": "application/json",
                      "Cookie": "access_token=@{parameters('API_Access_Token')}",
                      "X-Integration-Type": "Azure Sentinel Premium IOC",
                      "X-Integration-Version": "1.0"
                    },
                    "body": {
                      "type": "domain",
                      "value": "@{items('For_each_Domain')?['DomainName']}"
                    }
                  },
                  "runAfter": {}
                },
                "Append_Domain_result": {
                  "type": "AppendToStringVariable",
                  "inputs": {
                    "name": "EnrichmentComment",
                    "value": "<br><strong>Domain: @{items('For_each_Domain')?['DomainName']}</strong> — Malicious: @{json(string(body('Enrich_Domain')))?['malicious']} | Confidence: @{json(string(body('Enrich_Domain')))?['confidence']} | Severity: @{json(string(body('Enrich_Domain')))?['severity']} | Activity: @{json(string(body('Enrich_Domain')))?['activity']} | Malware Family: @{json(string(body('Enrich_Domain')))?['malware_family']} | Threat Actors: @{join(coalesce(json(string(body('Enrich_Domain')))?['threat_actors'], json('[]')), ', ')}"
                  },
                  "runAfter": {
                    "Enrich_Domain": ["Succeeded"]
                  }
                }
              },
              "runAfter": {
                "For_each_FileHash": ["Succeeded"]
              }
            },
            "For_each_URL": {
              "type": "Foreach",
              "foreach": "@body('Entities_-_Get_URLs')?['URLs']",
              "actions": {
                "Enrich_URL": {
                  "type": "Http",
                  "inputs": {
                    "method": "POST",
                    "uri": "@{parameters('API_Base_URL')}/ioc-intel/enrichment-api/v1/enrichment",
                    "headers": {
                      "Accept": "application/json",
                      "Content-Type": "application/json",
                      "Cookie": "access_token=@{parameters('API_Access_Token')}",
                      "X-Integration-Type": "Azure Sentinel Premium IOC",
                      "X-Integration-Version": "1.0"
                    },
                    "body": {
                      "type": "url",
                      "value": "@{items('For_each_URL')?['Url']}"
                    }
                  },
                  "runAfter": {}
                },
                "Append_URL_result": {
                  "type": "AppendToStringVariable",
                  "inputs": {
                    "name": "EnrichmentComment",
                    "value": "<br><strong>URL: @{items('For_each_URL')?['Url']}</strong> — Malicious: @{json(string(body('Enrich_URL')))?['malicious']} | Confidence: @{json(string(body('Enrich_URL')))?['confidence']} | Severity: @{json(string(body('Enrich_URL')))?['severity']} | Activity: @{json(string(body('Enrich_URL')))?['activity']} | Kill Chain: @{json(string(body('Enrich_URL')))?['kill_chain_stage']} | Malware Family: @{json(string(body('Enrich_URL')))?['malware_family']}"
                  },
                  "runAfter": {
                    "Enrich_URL": ["Succeeded"]
                  }
                }
              },
              "runAfter": {
                "For_each_Domain": ["Succeeded"]
              }
            },
            "Add_comment_to_incident": {
              "type": "ApiConnection",
              "inputs": {
                "host": {
                  "connection": {
                    "name": "@parameters('$connections')['azuresentinel']['connectionId']"
                  }
                },
                "method": "post",
                "body": {
                  "incidentArmId": "@triggerBody()?['object']?['id']",
                  "message": "<p><strong>CPEM Premium IOC Enrichment Results:</strong><br>@{variables('EnrichmentComment')}</p>"
                },
                "path": "/Incidents/Comment"
              },
              "runAfter": {
                "For_each_URL": ["Succeeded"]
              }
            }
          }
        },
        "parameters": {
          "$connections": {
            "value": {
              "azuresentinel": {
                "connectionId": "[resourceId('Microsoft.Web/connections', variables('AzureSentinelConnectionName'))]",
                "connectionName": "[variables('AzureSentinelConnectionName')]",
                "id": "[concat('/subscriptions/', subscription().subscriptionId, '/providers/Microsoft.Web/locations/', resourceGroup().location, '/managedApis/azuresentinel')]",
                "connectionProperties": {
                  "authentication": {
                    "type": "ManagedServiceIdentity"
                  }
                }
              }
            }
          },
          "API_Base_URL": {
            "value": "[parameters('API_Base_URL')]"
          },
          "API_Access_Token": {
            "value": "[parameters('API_Access_Token')]"
          }
        }
      }
    }
  ],
  "outputs": {}
}
