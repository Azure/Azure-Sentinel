{
  "name": "TheHiveConnector",
  "apiVersion": "2022-09-01-preview",
  "type": "Microsoft.SecurityInsights/dataConnectorDefinitions",
  "location": "{{location}}",
  "kind": "Customizable",
  "properties": {
    "connectorUiConfig": {
      "id": "TheHiveConnector",
      "title": "TheHive (via Codeless Connector Framework)",
      "publisher": "TheHive",
      "descriptionMarkdown": "The TheHive data connector provides the capability to ingest [TheHive](https://thehive-project.org/) security incident response platform data into Microsoft Sentinel through the REST API. Refer to [API documentation](https://docs.thehive-project.org/thehive/legacy/thehive3/api/api-guide/) for more information. The connector provides the ability to get cases, tasks, and alerts from TheHive and visualize them in Azure Sentinel.",
      "graphQueriesTableName": "TheHiveData",
      "graphQueries": [
        {
          "metricName": "Total data received",
          "legend": "TheHiveData Events",
          "baseQuery": "{{graphQueriesTableName}}"
        },
        {
          "metricName": "Cases only",
          "legend": "TheHiveData Cases",
          "baseQuery": "{{graphQueriesTableName}} | where ObjectType == \"Case\""
        },
        {
          "metricName": "Alerts only",
          "legend": "TheHiveData Alerts",
          "baseQuery": "{{graphQueriesTableName}} | where ObjectType == \"Alert\""
        }
      ],
      "sampleQueries": [
        {
          "description": "All TheHive events",
          "query": "{{graphQueriesTableName}}\n| sort by TimeGenerated desc"
        },
        {
          "description": "Get sample of TheHive events",
          "query": "{{graphQueriesTableName}}\n| take 10"
        },
        {
          "description": "Summary by entity type",
          "query": "{{graphQueriesTableName}}\n| summarize count() by ObjectType"
        }
      ],
      "dataTypes": [
        {
          "name": "TheHiveData",
          "lastDataReceivedQuery": "TheHiveData\n| where TimeGenerated > ago(12h)\n| summarize Time = max(TimeGenerated)\n| where isnotempty(Time)"
        }
      ],
      "connectivityCriteria": [
        {
          "type": "HasDataConnectors"
        }
      ],
      "availability": {
        "isPreview": true,
        "status": 1
      },
      "permissions": {
        "resourceProvider": [
          {
            "provider": "Microsoft.OperationalInsights/workspaces",
            "permissionsDisplayText": "Read and Write permissions are required.",
            "providerDisplayName": "Workspace",
            "scope": "Workspace",
            "requiredPermissions": {
              "write": true,
              "read": true,
              "delete": true,
              "action": false
            }
          }
        ],
        "customs": [
          {
            "name": "TheHive API access",
            "description": "**TheHive API Version 4 and above** access is required for the TheHive API."
          }
        ]
      },
      "instructionSteps": [
        {
          "title": "1. Configuration",
          "description": "Follow the instructions to configure the TheHive connector.",
          "instructions": [
            {
              "type": "Textbox",
              "parameters": {
                "label": "TheHive Base URL",
                "placeholder": "TheHive instance base URL (e.g., https://thehive.example.com)",
                "type": "text",
                "name": "theHiveBaseUrl"
              }
            },
            {
              "type": "Markdown",
              "parameters": {
                "content": "> Get the api Key from your TheHive user profile settings. (or a dedicated user created for this purpose)"
              }
            },
            {
              "type": "Textbox",
              "parameters": {
                "label": "Api Key",
                "placeholder": "API key for TheHive API",
                "type": "password",
                "name": "apiKey"
              }
            }
          ]
        },
        {
          "title": "2. Connect",
          "description": "Enable the TheHive connector.",
          "instructions": [
            {
              "type": "ConnectionToggleButton",
              "parameters": {
                "connectLabel": "Connect",
                "disconnectLabel": "Disconnect",
                "name": "toggle"
              }
            }
          ]
        }
      ]
    }
  }
}