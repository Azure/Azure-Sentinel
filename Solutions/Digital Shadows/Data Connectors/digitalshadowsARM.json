{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "HighVariabilityClassifications": {
            "defaultValue": "exposed-credential,marked-document",
            "type": "string"
        },
        "DigitalShadowsAccountID": {
            "type": "securestring",
            "defaultValue": ""
        },
        "DigitalShadowsKey": {
            "type": "securestring",
            "defaultValue": ""
        },
        "DigitalShadowsSecret": {
            "type": "securestring",
            "defaultValue": ""
        },
        "DigitalShadowsURL": {
            "type": "string",
            "defaultValue": ""
        },
        "HistoricalDays": {
            "type": "int",
            "defaultValue": 10,
            "metadata": {
                "description": "Enter from how many days before should the historical poll get data from."
            }
        },
        "AppInsightsWorkspaceResourceID": {
            "type": "string",
            "metadata": {
                "description": "Migrate Classic Application Insights to Log Analytic Workspace which is retiring by 29 Febraury 2024. Use 'Log Analytic Workspace-->Properties' blade having 'Resource ID' property value. This is a fully qualified resourceId which is in format '/subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.OperationalInsights/workspaces/{workspaceName}'"
            }
        },
        "DcrWorkspaceResourceId": {
            "type": "string",
            "metadata": {
                "description": "Full resource ID of the customer's Log Analytics workspace where DigitalShadows_V2_CL will be created. Format: '/subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.OperationalInsights/workspaces/{workspaceName}'."
            }
        }
    },
	"variables":
		{
            "ConnectorName": "[concat('ds', uniqueString(resourceGroup().id))]",
			"FunctionName1": "[concat('include', uniqueString(resourceGroup().id))]",
            "StorageSuffix": "[environment().suffixes.storage]",
			"FunctionName2": "[concat('exclude', uniqueString(resourceGroup().id))]",
            "DceName":               "[concat('ds-dce-', uniqueString(resourceGroup().id))]",
            "DcrName":               "[concat('ds-dcr-', uniqueString(resourceGroup().id))]",
            "DcrStreamName":         "Custom-DigitalShadows_V2_CL",
            "DcrTableName":          "DigitalShadows_V2_CL",
            "DcrWorkspaceName":      "[last(split(parameters('DcrWorkspaceResourceId'), '/'))]",
            "MetricsPublisherRoleId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '3913510d-42f4-4e42-8a64-420c390055eb')]"
    },
    "resources": [
        {
            "type": "Microsoft.Insights/components",
            "apiVersion": "2020-02-02",
            "name": "[variables('FunctionName1')]",
            "location": "[resourceGroup().location]",
            "kind": "web",
            "properties": {
                "Application_Type": "web",
                "ApplicationId": "[variables('FunctionName1')]",
                "WorkspaceResourceId": "[parameters('AppInsightsWorkspaceResourceID')]"
            }
        },
        {
            "type": "Microsoft.Storage/storageAccounts",
            "apiVersion": "2022-09-01",
            "name": "[tolower(variables('ConnectorName'))]",
            "location": "[resourceGroup().location]",
            "sku": {
                "name": "Standard_LRS",
                "tier": "Standard"
            },
            "kind": "StorageV2",
            "properties": {
                "networkAcls": {
                    "bypass": "AzureServices",
                    "defaultAction": "Allow"
                },
                "supportsHttpsTrafficOnly": true,
                "encryption": {
                    "services": {
                        "file": {
                            "keyType": "Account",
                            "enabled": true
                        },
                        "blob": {
                            "keyType": "Account",
                            "enabled": true
                        }
                    },
                    "keySource": "Microsoft.Storage"
                }
            }
        },
        {
            "type": "Microsoft.Storage/storageAccounts/fileServices",
            "apiVersion": "2022-09-01",
            "name": "[concat(variables('ConnectorName'), '/default')]",
            "dependsOn": [
                "[resourceId('Microsoft.Storage/storageAccounts', tolower(variables('ConnectorName')))]"
            ],
            "sku": {
                "name": "Standard_LRS",
                "tier": "Standard"
            },
            "properties": {}
        },
        {
            "type": "Microsoft.Web/sites",
            "apiVersion": "2022-03-01",
            "name": "[variables('FunctionName1')]",
            "location": "[resourceGroup().location]",
            "dependsOn": [
                "[resourceId('Microsoft.Storage/storageAccounts', tolower(variables('ConnectorName')))]",
                "[resourceId('Microsoft.Insights/components', variables('FunctionName1'))]"
            ],
            "kind": "functionapp,linux",
            "identity": {
                "type": "SystemAssigned"
            },
            "properties": {
                "name": "[variables('FunctionName1')]",
                "httpsOnly": true,
                "clientAffinityEnabled": true,
                "alwaysOn": true,
                "reserved": true,
                "siteConfig": {
                    "linuxFxVersion": "python|3.11"
                }
            },
            "resources": [
                {
                    "apiVersion": "2022-03-01",
                    "type": "config",
                    "name": "appsettings",
                    "dependsOn": [
                        "[concat('Microsoft.Web/sites/', variables('FunctionName1'))]"
                    ],
                    "properties": {
                        "FUNCTION_NAME": "[variables('FunctionName1')]",
                        "FUNCTIONS_EXTENSION_VERSION": "~4",
                        "FUNCTIONS_WORKER_RUNTIME": "python",
                        "APPINSIGHTS_INSTRUMENTATIONKEY": "[reference(resourceId('Microsoft.insights/components', variables('FunctionName1')), '2020-02-02').InstrumentationKey]",
                        "APPLICATIONINSIGHTS_CONNECTION_STRING": "[reference(resourceId('microsoft.insights/components', variables('FunctionName1')), '2020-02-02').ConnectionString]",
                        "AzureWebJobsStorage": "[concat('DefaultEndpointsProtocol=https;AccountName=', toLower(variables('ConnectorName')),';AccountKey=',listKeys(resourceId('Microsoft.Storage/storageAccounts', toLower(variables('ConnectorName'))), '2022-09-01').keys[0].value, ';EndpointSuffix=',toLower(variables('StorageSuffix')))]",
                        "HighVariabilityClassifications": "[parameters('HighVariabilityClassifications')]",
                        "ClassificationFilterOperation": "include",
                        "DCE_URL":          "[reference(resourceId('Microsoft.Insights/dataCollectionEndpoints', variables('DceName')), '2022-06-01').logsIngestion.endpoint]",
                        "DCR_IMMUTABLE_ID": "[reference(resourceId('Microsoft.Insights/dataCollectionRules', variables('DcrName')), '2022-06-01').immutableId]",
                        "STREAM_NAME":      "[variables('DcrStreamName')]",
                        "DigitalShadowsAccountID": "[parameters('DigitalShadowsAccountID')]",
                        "HistoricalDays": "[parameters('HistoricalDays')]",
                        "DigitalShadowsKey": "[parameters('DigitalShadowsKey')]",
                        "DigitalShadowsSecret": "[parameters('DigitalShadowsSecret')]",
                        "DigitalShadowsURL": "[parameters('DigitalShadowsURL')]",
                        "WEBSITE_RUN_FROM_PACKAGE": "https://aka.ms/sentinel-DigitalShadows-functionapp"
                    }
                }
            ]
        },
        {
            "type": "Microsoft.Storage/storageAccounts/fileServices/shares",
            "apiVersion": "2022-09-01",
            "name": "[concat(variables('ConnectorName'), '/default/', tolower(variables('FunctionName1')))]",
            "dependsOn": [
                "[resourceId('Microsoft.Storage/storageAccounts/fileServices', variables('ConnectorName'), 'default')]",
                "[resourceId('Microsoft.Storage/storageAccounts', variables('ConnectorName'))]"
            ],
            "properties": {
                "shareQuota": 5120
            }
        },
		{
        "type": "Microsoft.Insights/components",
        "apiVersion": "2020-02-02",
        "name": "[variables('FunctionName2')]",
            "location": "[resourceGroup().location]",
            "kind": "web",
            "properties": {
                "Application_Type": "web",
            "ApplicationId": "[variables('FunctionName2')]",
            "WorkspaceResourceId": "[parameters('AppInsightsWorkspaceResourceID')]"
            }
        },
        {
            "type": "Microsoft.Web/sites",
            "apiVersion": "2022-03-01",
            "name": "[variables('FunctionName2')]",
            "location": "[resourceGroup().location]",
            "dependsOn": [
            "[resourceId('Microsoft.Storage/storageAccounts', tolower(variables('ConnectorName')))]",
            "[resourceId('Microsoft.Insights/components', variables('FunctionName2'))]"
            ],
            "kind": "functionapp,linux",
            "identity": {
                "type": "SystemAssigned"
            },
            "properties": {
            "name": "[variables('FunctionName2')]",
                "httpsOnly": true,
                "clientAffinityEnabled": true,
                "alwaysOn": true,
                "reserved": true,
                "siteConfig": {
                    "linuxFxVersion": "python|3.11"
                }
            },
            "resources": [
                {
                    "apiVersion": "2022-03-01",
                    "type": "config",
                    "name": "appsettings",
                    "dependsOn": [
                    "[concat('Microsoft.Web/sites/', variables('FunctionName2'))]"
                    ],
                    "properties": {
                        "FUNCTION_NAME": "[variables('FunctionName2')]",
                        "FUNCTIONS_EXTENSION_VERSION": "~4",
                        "FUNCTIONS_WORKER_RUNTIME": "python",
                        "APPINSIGHTS_INSTRUMENTATIONKEY": "[reference(resourceId('Microsoft.insights/components', variables('FunctionName2')), '2020-02-02').InstrumentationKey]",
                        "APPLICATIONINSIGHTS_CONNECTION_STRING": "[reference(resourceId('microsoft.insights/components', variables('FunctionName2')), '2020-02-02').ConnectionString]",
                        "AzureWebJobsStorage": "[concat('DefaultEndpointsProtocol=https;AccountName=', toLower(variables('ConnectorName')),';AccountKey=',listKeys(resourceId('Microsoft.Storage/storageAccounts', toLower(variables('ConnectorName'))), '2022-09-01').keys[0].value, ';EndpointSuffix=',toLower(variables('StorageSuffix')))]",
                        "HighVariabilityClassifications": "[parameters('HighVariabilityClassifications')]",
                        "ClassificationFilterOperation": "exclude",
                        "DCE_URL":          "[reference(resourceId('Microsoft.Insights/dataCollectionEndpoints', variables('DceName')), '2022-06-01').logsIngestion.endpoint]",
                        "DCR_IMMUTABLE_ID": "[reference(resourceId('Microsoft.Insights/dataCollectionRules', variables('DcrName')), '2022-06-01').immutableId]",
                        "STREAM_NAME":      "[variables('DcrStreamName')]",
                        "DigitalShadowsAccountID": "[parameters('DigitalShadowsAccountID')]",
                        "HistoricalDays": "[parameters('HistoricalDays')]",
                        "DigitalShadowsKey": "[parameters('DigitalShadowsKey')]",
                        "DigitalShadowsSecret": "[parameters('DigitalShadowsSecret')]",
                        "DigitalShadowsURL": "[parameters('DigitalShadowsURL')]",
                        "WEBSITE_RUN_FROM_PACKAGE": "https://aka.ms/sentinel-DigitalShadows-functionapp"
                    }
                }
            ]
        },
        {
            "type": "Microsoft.Storage/storageAccounts/fileServices/shares",
            "apiVersion": "2022-09-01",
            "name": "[concat(variables('ConnectorName'), '/default/', tolower(variables('FunctionName2')))]",
            "dependsOn": [
                "[resourceId('Microsoft.Storage/storageAccounts/fileServices', variables('ConnectorName'), 'default')]",
                "[resourceId('Microsoft.Storage/storageAccounts', variables('ConnectorName'))]"
            ],
            "properties": {
                "shareQuota": 5120
            }
        },
        {
            "type": "Microsoft.Insights/dataCollectionEndpoints",
            "apiVersion": "2022-06-01",
            "name": "[variables('DceName')]",
            "location": "[resourceGroup().location]",
            "properties": {
                "networkAcls": { "publicNetworkAccess": "Enabled" }
            }
        },
        {
            "type": "Microsoft.OperationalInsights/workspaces/tables",
            "apiVersion": "2022-10-01",
            "name": "[concat(variables('DcrWorkspaceName'), '/', variables('DcrTableName'))]",
            "properties": {
                "schema": {
                    "name": "[variables('DcrTableName')]",
                    "columns": [
                        { "name": "TimeGenerated",           "type": "datetime" },
                        { "name": "App",                     "type": "string"   },
                        { "name": "Title",                   "type": "string"   },
                        { "name": "TimeRaised",              "type": "datetime" },
                        { "name": "TimeUpdated",             "type": "datetime" },
                        { "name": "Classification",          "type": "string"   },
                        { "name": "RiskLevel",               "type": "string"   },
                        { "name": "RiskAssessmentRiskLevel", "type": "string"   },
                        { "name": "GreyMatterLink",          "type": "string"   },
                        { "name": "Assets",                  "type": "string"   },
                        { "name": "Description",             "type": "string"   },
                        { "name": "ImpactDescription",       "type": "string"   },
                        { "name": "Mitigation",              "type": "string"   },
                        { "name": "RiskFactors",             "type": "string"   },
                        { "name": "Comments",                "type": "string"   },
                        { "name": "PortalId",                "type": "string"   },
                        { "name": "IncidentId",              "type": "real"     },
                        { "name": "AlertId",                 "type": "string"   },
                        { "name": "Status",                  "type": "string"   },
                        { "name": "TriageId",                "type": "string"   },
                        { "name": "TriageRaisedTime",        "type": "datetime" },
                        { "name": "TriageUpdatedTime",       "type": "datetime" }
                    ]
                }
            }
        },
        {
            "type": "Microsoft.Insights/dataCollectionRules",
            "apiVersion": "2022-06-01",
            "name": "[variables('DcrName')]",
            "location": "[resourceGroup().location]",
            "dependsOn": [
                "[resourceId('Microsoft.Insights/dataCollectionEndpoints', variables('DceName'))]",
                "[resourceId('Microsoft.OperationalInsights/workspaces/tables', variables('DcrWorkspaceName'), variables('DcrTableName'))]"
            ],
            "properties": {
                "dataCollectionEndpointId": "[resourceId('Microsoft.Insights/dataCollectionEndpoints', variables('DceName'))]",
                "streamDeclarations": {
                    "Custom-DigitalShadows_V2_CL": {
                        "columns": [
                            { "name": "TimeGenerated",           "type": "datetime" },
                            { "name": "App",                     "type": "string"   },
                            { "name": "Title",                   "type": "string"   },
                            { "name": "TimeRaised",              "type": "datetime" },
                            { "name": "TimeUpdated",             "type": "datetime" },
                            { "name": "Classification",          "type": "string"   },
                            { "name": "RiskLevel",               "type": "string"   },
                            { "name": "RiskAssessmentRiskLevel", "type": "string"   },
                            { "name": "GreyMatterLink",          "type": "string"   },
                            { "name": "Assets",                  "type": "string"   },
                            { "name": "Description",             "type": "string"   },
                            { "name": "ImpactDescription",       "type": "string"   },
                            { "name": "Mitigation",              "type": "string"   },
                            { "name": "RiskFactors",             "type": "string"   },
                            { "name": "Comments",                "type": "string"   },
                            { "name": "PortalId",                "type": "string"   },
                            { "name": "IncidentId",              "type": "real"     },
                            { "name": "AlertId",                 "type": "string"   },
                            { "name": "Status",                  "type": "string"   },
                            { "name": "TriageId",                "type": "string"   },
                            { "name": "TriageRaisedTime",        "type": "datetime" },
                            { "name": "TriageUpdatedTime",       "type": "datetime" }
                        ]
                    }
                },
                "destinations": {
                    "logAnalytics": [
                        {
                            "workspaceResourceId": "[parameters('DcrWorkspaceResourceId')]",
                            "name": "logAnalyticsDest"
                        }
                    ]
                },
                "dataFlows": [
                    {
                        "streams":      [ "Custom-DigitalShadows_V2_CL" ],
                        "destinations": [ "logAnalyticsDest" ],
                        "outputStream": "Custom-DigitalShadows_V2_CL",
                        "transformKql": "source | project TimeGenerated, App, Title, TimeRaised, TimeUpdated, Classification, RiskLevel, RiskAssessmentRiskLevel, GreyMatterLink, Assets, Description, ImpactDescription, Mitigation, RiskFactors, Comments, PortalId, IncidentId, AlertId, Status, TriageId, TriageRaisedTime, TriageUpdatedTime"
                    }
                ]
            }
        },
        {
            "type": "Microsoft.Authorization/roleAssignments",
            "apiVersion": "2022-04-01",
            "name": "[guid(resourceId('Microsoft.Insights/dataCollectionRules', variables('DcrName')), variables('FunctionName1'), variables('MetricsPublisherRoleId'))]",
            "scope": "[concat('Microsoft.Insights/dataCollectionRules/', variables('DcrName'))]",
            "dependsOn": [
                "[resourceId('Microsoft.Insights/dataCollectionRules', variables('DcrName'))]",
                "[resourceId('Microsoft.Web/sites', variables('FunctionName1'))]"
            ],
            "properties": {
                "roleDefinitionId": "[variables('MetricsPublisherRoleId')]",
                "principalId":      "[reference(resourceId('Microsoft.Web/sites', variables('FunctionName1')), '2022-03-01', 'Full').identity.principalId]",
                "principalType":    "ServicePrincipal"
            }
        },
        {
            "type": "Microsoft.Authorization/roleAssignments",
            "apiVersion": "2022-04-01",
            "name": "[guid(resourceId('Microsoft.Insights/dataCollectionRules', variables('DcrName')), variables('FunctionName2'), variables('MetricsPublisherRoleId'))]",
            "scope": "[concat('Microsoft.Insights/dataCollectionRules/', variables('DcrName'))]",
            "dependsOn": [
                "[resourceId('Microsoft.Insights/dataCollectionRules', variables('DcrName'))]",
                "[resourceId('Microsoft.Web/sites', variables('FunctionName2'))]"
            ],
            "properties": {
                "roleDefinitionId": "[variables('MetricsPublisherRoleId')]",
                "principalId":      "[reference(resourceId('Microsoft.Web/sites', variables('FunctionName2')), '2022-03-01', 'Full').identity.principalId]",
                "principalType":    "ServicePrincipal"
            }
        }
    ]
}