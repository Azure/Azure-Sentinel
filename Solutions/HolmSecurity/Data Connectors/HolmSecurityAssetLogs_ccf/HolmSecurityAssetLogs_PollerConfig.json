[
    {
        "name": "HolmSecurityWebAssetsPoller",
        "apiVersion": "2022-12-01-preview",
        "type": "Microsoft.SecurityInsights/dataConnectors",
        "location": "{{location}}",
        "kind": "RestApiPoller",
        "properties": {
            "connectorDefinitionName": "HolmSecurityCCF",
            "dataType": "HolmSecurityWebAssets",
            "dcrConfig": {
                "streamName": "Custom-web_assets_CL"
            },
            "auth": {
                "type": "APIKey",
                "ApiKey": "{{apiKey}}",
                "ApiKeyName": "Authorization",
                "ApiKeyIdentifier": "Token"
            },
            "request": {
                "apiEndpoint": "{{holmSecurityBaseUrl}}/web-assets",
                "httpMethod": "GET",
                "rateLimitQPS": 10,
                "queryWindowInMin": 1440,
                "retryCount": 4,
                "timeoutInSeconds": 45,
                "headers": {
                    "Accept": "application/json"
                }
            },
            "response": {
                "eventsJsonPaths": [
                    "$.results[*]"
                ],
                "format": "json"
            },
            "paging": {
                "pagingType": "Offset",
                "offsetParaName": "offset",
                "pageSize": 600,
                "pageSizeParameterName": "limit"
            }
        }
    },
    {
        "name": "HolmSecurityNetAssetsPoller",
        "apiVersion": "2022-12-01-preview",
        "type": "Microsoft.SecurityInsights/dataConnectors",
        "location": "{{location}}",
        "kind": "RestApiPoller",
        "properties": {
            "connectorDefinitionName": "HolmSecurityCCF",
            "dataType": "HolmSecurityNetAssets",
            "dcrConfig": {
                "streamName": "Custom-net_assets_CL"
            },
            "auth": {
                "type": "APIKey",
                "ApiKey": "{{apiKey}}",
                "ApiKeyName": "Authorization",
                "ApiKeyIdentifier": "Token"
            },
            "request": {
                "apiEndpoint": "{{holmSecurityBaseUrl}}/net-assets",
                "httpMethod": "GET",
                "rateLimitQPS": 10,
                "queryWindowInMin": 1440,
                "retryCount": 4,
                "timeoutInSeconds": 45,
                "headers": {
                    "Accept": "application/json"
                }
            },
            "response": {
                "eventsJsonPaths": [
                    "$.results[*]"
                ],
                "format": "json"
            },
            "paging": {
                "pagingType": "Offset",
                "offsetParaName": "offset",
                "pageSize": 600,
                "pageSizeParameterName": "limit"
            }
        }
    }
]