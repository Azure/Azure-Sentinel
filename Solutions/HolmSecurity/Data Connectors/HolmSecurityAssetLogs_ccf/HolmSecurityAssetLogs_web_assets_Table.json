[
    {
        "name": "web_assets_CL",
        "type": "Microsoft.OperationalInsights/workspaces/tables",
        "apiVersion": "2021-03-01-privatepreview",
        "properties": {
            "retentionInDays": 180,
            "schema": {
                "name": "web_assets_CL",
                "description": "Holm Security web assets data",
                "columns": [
                    { "name": "TimeGenerated", "type": "datetime", "description": "Time the record was generated" },
                    { "name": "Name", "type": "string", "description": "Asset name" },
                    { "name": "Uuid", "type": "string", "description": "Unique identifier for the asset" },
                    { "name": "ObjectType", "type": "string", "description": "Object type" },
                    { "name": "Tags", "type": "dynamic", "description": "Asset tags" },
                    { "name": "Created", "type": "datetime", "description": "Asset creation date" },
                    { "name": "Uri", "type": "string", "description": "URL of the web asset" },
                    { "name": "VulnerabilitiesCount", "type": "int", "description": "Number of vulnerabilities" },
                    { "name": "LastDetected", "type": "datetime", "description": "Last detected date" }
                ]
            }
        }
    }
]