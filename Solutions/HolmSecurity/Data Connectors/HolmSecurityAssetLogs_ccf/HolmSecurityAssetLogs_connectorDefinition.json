{
    "type": "Microsoft.SecurityInsights/dataConnectorDefinitions",
    "apiVersion": "2022-09-01-preview",
    "name": "HolmSecurityCCF",
    "location": "{{location}}",
    "kind": "Customizable",
    "properties": {
        "connectorUiConfig": {
            "id": "HolmSecurityCCF",
            "title": "Holm Security Data Connector",
            "publisher": "Holm Security",
            "descriptionMarkdown": "The Holm Security data connector provides the capability to ingest [Holm Security](https://www.holmsecurity.com/) asset data into Microsoft Sentinel through the REST API. The connector provides the ability to get web and network assets data from Holm Security.",
            "graphQueriesTableName": "web_assets_CL",
            "graphQueries": [
                {
                    "metricName": "Total data received",
                    "legend": "Holm Security Asset Data",
                    "baseQuery": "{{graphQueriesTableName}}"
                }
            ],
            "sampleQueries": [
                {
                    "description": "All Holm Security web assets",
                    "query": "web_assets_CL\n| sort by TimeGenerated desc"
                },
                {
                    "description": "Get sample of network assets",
                    "query": "net_assets_CL\n| take 10"
                },
                {
                    "description": "Summary of network assets by object type",
                    "query": "net_assets_CL\n| summarize count() by ObjectType"
                }
            ],
            "dataTypes": [
                {
                    "name": "web_assets_CL",
                    "lastDataReceivedQuery": "web_assets_CL\n| where TimeGenerated > ago(12h)\n| summarize Time = max(TimeGenerated)\n| where isnotempty(Time)"
                },
                {
                    "name": "net_assets_CL",
                    "lastDataReceivedQuery": "net_assets_CL\n| where TimeGenerated > ago(12h)\n| summarize Time = max(TimeGenerated)\n| where isnotempty(Time)"
                }
            ],
            "connectivityCriteria": [
                {
                    "type": "HasDataConnectors"
                }
            ],
            "availability": {
                "isPreview": false,
                "status": 1
            },
            "permissions": {
                "resourceProvider": [
                    {
                        "provider": "Microsoft.OperationalInsights/workspaces",
                        "permissionsDisplayText": "Read and Write permissions are required.",
                        "providerDisplayName": "Workspace",
                        "scope": "Workspace",
                        "requiredPermissions": {
                            "write": true,
                            "read": true,
                            "delete": true
                        }
                    }
                ],
                "customs": [
                    {
                        "name": "Holm Security API access",
                        "description": "A Holm Security API token is required. [See how to set up an API token](https://support.holmsecurity.com/knowledge/how-do-i-set-up-an-api-token)."
                    }
                ]
            },
            "instructionSteps": [
                {
                    "title": "1. Configuration",
                    "description": "Acquire your token from your Holm Security user profile. For details, visit https://se-api.holmsecurity.com/docs/v2/#section/Authentication",
                    "instructions": [
                        {
                            "type": "Textbox",
                            "parameters": {
                                "label": "API Key",
                                "placeholder": "API key for authentication",
                                "type": "password",
                                "name": "apiKey",
                                "validations": {
                                    "required": true
                                }
                            }
                        },
                        {
                            "type": "Textbox",
                            "parameters": {
                                "label": "Holm Security API Base URL",
                                "placeholder": "e.g. https://se-api.holmsecurity.com/v2",
                                "type": "text",
                                "name": "holmSecurityBaseUrl",
                                "validations": {
                                    "required": true
                                }
                            }
                        }
                    ]
                },
                {
                    "title": "2. Connect",
                    "description": "Enable the Holm Security connector.",
                    "instructions": [
                        {
                            "type": "ConnectionToggleButton",
                            "parameters": {
                                "connectLabel": "Connect",
                                "disconnectLabel": "Disconnect",
                                "name": "toggle"
                            }
                        }
                    ]
                }
            ]
        }
    }
}