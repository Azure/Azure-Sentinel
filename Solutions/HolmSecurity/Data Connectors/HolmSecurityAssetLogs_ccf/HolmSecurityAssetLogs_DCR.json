[
    {
        "name": "HolmSecDCR",
        "apiVersion": "2021-09-01-preview",
        "type": "Microsoft.Insights/dataCollectionRules",
        "location": "{{location}}",
        "properties": {
            "dataCollectionEndpointId": "{{dataCollectionEndpointId}}",
            "streamDeclarations": {
                "Custom-web_assets_CL": {
                    "columns": [
                        { "name": "name", "type": "string" },
                        { "name": "uuid", "type": "string" },
                        { "name": "type", "type": "string" },
                        { "name": "tags", "type": "dynamic" },
                        { "name": "created", "type": "datetime" },
                        { "name": "uri", "type": "string" },
                        { "name": "vulnerabilities_count", "type": "int" },
                        { "name": "last_detected", "type": "datetime" }
                    ]
                },
                "Custom-net_assets_CL": {
                    "columns": [
                        { "name": "created", "type": "datetime" },
                        { "name": "name", "type": "string" },
                        { "name": "tags", "type": "dynamic" },
                        { "name": "type", "type": "string" },
                        { "name": "uuid", "type": "string" },
                        { "name": "operating_system", "type": "string" },
                        { "name": "vulnerabilities_count", "type": "int" },
                        { "name": "last_detected", "type": "datetime" },
                        { "name": "ip", "type": "string" },
                        { "name": "ip_range", "type": "string" },
                        { "name": "hostname", "type": "string" },
                        { "name": "details", "type": "string" },
                        { "name": "business_impact", "type": "string" },
                        { "name": "hosts_personal_data", "type": "boolean" },
                        { "name": "severity", "type": "dynamic" }
                    ]
                }
            },
            "destinations": {
                "logAnalytics": [
                    {
                        "workspaceResourceId": "{{workspaceResourceId}}",
                        "name": "clv2ws1"
                    }
                ]
            },
            "dataFlows": [
                {
                    "streams": [ "Custom-web_assets_CL" ],
                    "destinations": [ "clv2ws1" ],
                    "outputStream": "Custom-web_assets_CL",
                    "transformKql": "source | extend TimeGenerated = iff(isempty(created), now(), todatetime(created)) , Name = ['name'] , Uuid = ['uuid'] , ObjectType = ['type'] , Tags = ['tags'] , Created = ['created'] , Uri = ['uri'] , VulnerabilitiesCount = ['vulnerabilities_count'] , LastDetected = ['last_detected'] | project TimeGenerated , Name , Uuid , ObjectType , Tags , Created , Uri , VulnerabilitiesCount , LastDetected"
                },
                {
                    "streams": [ "Custom-net_assets_CL" ],
                    "destinations": [ "clv2ws1" ],
                    "outputStream": "Custom-net_assets_CL",
                    "transformKql": "source | extend TimeGenerated = iff(isempty(created), now(), todatetime(created)) , Created = ['created'] , Name = ['name'] , Tags = ['tags'] , ObjectType = ['type'] , Uuid = ['uuid'] , OperatingSystem = ['operating_system'] , VulnerabilitiesCount = ['vulnerabilities_count'] , LastDetected = ['last_detected'] , Ip = ['ip'] , IpRange = ['ip_range'] , HostName = ['hostname'] , Details = ['details'] , BusinessImpact = ['business_impact'] , HostsPersonalData = ['hosts_personal_data'] , Severity = ['severity'] | project TimeGenerated , Created , Name , Tags , ObjectType , Uuid , OperatingSystem , VulnerabilitiesCount , LastDetected , Ip , IpRange , HostName , Details , BusinessImpact , HostsPersonalData , Severity"
                }
            ]
        }
    }
]