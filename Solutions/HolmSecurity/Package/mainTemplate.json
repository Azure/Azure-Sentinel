{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "author": "Holm Security - support@holmsecurity.com",
    "comments": "Solution template for HolmSecurity"
  },
  "parameters": {
    "location": {
      "type": "string",
      "minLength": 1,
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Not used, but needed to pass arm-ttk test `Location-Should-Not-Be-Hardcoded`.  We instead use the `workspace-location` which is derived from the LA workspace"
      }
    },
    "workspace-location": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "[concat('Region to deploy solution resources -- separate from location selection',parameters('location'))]"
      }
    },
    "workspace": {
      "defaultValue": "",
      "type": "string",
      "metadata": {
        "description": "Workspace name for Log Analytics where Microsoft Sentinel is setup"
      }
    },
    "resourceGroupName": {
      "type": "string",
      "defaultValue": "[resourceGroup().name]",
      "metadata": {
        "description": "resource group name where Microsoft Sentinel is setup"
      }
    },
    "subscription": {
      "type": "string",
      "defaultValue": "[last(split(subscription().id, '/'))]",
      "metadata": {
        "description": "subscription id where Microsoft Sentinel is setup"
      }
    }
  },
  "variables": {
    "email": "support@holmsecurity.com",
    "_email": "[variables('email')]",
    "_solutionName": "HolmSecurity",
    "_solutionVersion": "3.0.2",
    "solutionId": "holmsecurity.azure-sentinel-solution-holmsecurity",
    "_solutionId": "[variables('solutionId')]",
    "workspaceResourceId": "[resourceId('microsoft.OperationalInsights/Workspaces', parameters('workspace'))]",
    "dataConnectorCCPVersion": "3.0.2",
    "_dataConnectorContentIdConnectorDefinition1": "HolmSecurityCCF",
    "dataConnectorTemplateNameConnectorDefinition1": "[concat(parameters('workspace'),'-dc-',uniquestring(variables('_dataConnectorContentIdConnectorDefinition1')))]",
    "_dataConnectorContentIdConnections1": "HolmSecurityCCFConnections",
    "dataConnectorTemplateNameConnections1": "[concat(parameters('workspace'),'-dc-',uniquestring(variables('_dataConnectorContentIdConnections1')))]",
    "dataCollectionEndpointId1": "[concat('/subscriptions/',parameters('subscription'),'/resourceGroups/',parameters('resourceGroupName'),'/providers/Microsoft.Insights/dataCollectionEndpoints/',parameters('workspace'))]",
    "blanks": "[replace('b', 'b', '')]",
    "_solutioncontentProductId": "[concat(take(variables('_solutionId'),50),'-','sl','-', uniqueString(concat(variables('_solutionId'),'-','Solution','-',variables('_solutionId'),'-', variables('_solutionVersion'))))]"
  },
  "resources": [
    {
      "type": "Microsoft.OperationalInsights/workspaces/providers/contentTemplates",
      "apiVersion": "2023-04-01-preview",
      "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/', variables('dataConnectorTemplateNameConnectorDefinition1'), variables('dataConnectorCCPVersion'))]",
      "location": "[parameters('workspace-location')]",
      "dependsOn": [
        "[extensionResourceId(resourceId('Microsoft.OperationalInsights/workspaces', parameters('workspace')), 'Microsoft.SecurityInsights/contentPackages', variables('_solutionId'))]"
      ],
      "properties": {
        "contentId": "[variables('_dataConnectorContentIdConnectorDefinition1')]",
        "displayName": "Holm Security Data Connector",
        "contentKind": "DataConnector",
        "mainTemplate": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "[variables('dataConnectorCCPVersion')]",
          "parameters": {},
          "variables": {},
          "resources": [
            {
              "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/',variables('_dataConnectorContentIdConnectorDefinition1'))]",
              "apiVersion": "2022-09-01-preview",
              "type": "Microsoft.OperationalInsights/workspaces/providers/dataConnectorDefinitions",
              "location": "[parameters('workspace-location')]",
              "kind": "Customizable",
              "properties": {
                "connectorUiConfig": {
                  "id": "HolmSecurityCCF",
                  "title": "Holm Security Data Connector",
                  "publisher": "Holm Security",
                  "descriptionMarkdown": "The Holm Security data connector provides the capability to ingest [Holm Security](https://www.holmsecurity.com/) asset data into Microsoft Sentinel through the REST API. The connector provides the ability to get web and network assets data from Holm Security.",
                  "graphQueriesTableName": "web_assets_CL",
                  "graphQueries": [
                    {
                      "metricName": "Total data received",
                      "legend": "Holm Security Asset Data",
                      "baseQuery": "{{graphQueriesTableName}}"
                    }
                  ],
                  "sampleQueries": [
                    {
                      "description": "All Holm Security web assets",
                      "query": "web_assets_CL\n| sort by TimeGenerated desc"
                    },
                    {
                      "description": "Get sample of network assets",
                      "query": "net_assets_CL\n| take 10"
                    },
                    {
                      "description": "Summary of network assets by object type",
                      "query": "net_assets_CL\n| summarize count() by ObjectType"
                    }
                  ],
                  "dataTypes": [
                    {
                      "name": "web_assets_CL",
                      "lastDataReceivedQuery": "web_assets_CL\n| where TimeGenerated > ago(12h)\n| summarize Time = max(TimeGenerated)\n| where isnotempty(Time)"
                    },
                    {
                      "name": "net_assets_CL",
                      "lastDataReceivedQuery": "net_assets_CL\n| where TimeGenerated > ago(12h)\n| summarize Time = max(TimeGenerated)\n| where isnotempty(Time)"
                    }
                  ],
                  "connectivityCriteria": [
                    {
                      "type": "HasDataConnectors"
                    }
                  ],
                  "availability": {
                    "isPreview": false,
                    "status": 1
                  },
                  "permissions": {
                    "resourceProvider": [
                      {
                        "provider": "Microsoft.OperationalInsights/workspaces",
                        "permissionsDisplayText": "Read and Write permissions are required.",
                        "providerDisplayName": "Workspace",
                        "scope": "Workspace",
                        "requiredPermissions": {
                          "write": true,
                          "read": true,
                          "delete": true
                        }
                      }
                    ],
                    "customs": [
                      {
                        "name": "Holm Security API access",
                        "description": "A Holm Security API token is required. [See how to set up an API token](https://support.holmsecurity.com/knowledge/how-do-i-set-up-an-api-token)."
                      }
                    ]
                  },
                  "instructionSteps": [
                    {
                      "title": "1. Configuration",
                      "description": "Acquire your token from your Holm Security user profile. For details, visit https://se-api.holmsecurity.com/docs/v2/#section/Authentication",
                      "instructions": [
                        {
                          "type": "Textbox",
                          "parameters": {
                            "label": "API Key",
                            "placeholder": "API key for authentication",
                            "type": "password",
                            "name": "apiKey",
                            "validations": {
                              "required": true
                            }
                          }
                        },
                        {
                          "type": "Textbox",
                          "parameters": {
                            "label": "Holm Security API Base URL",
                            "placeholder": "e.g. https://se-api.holmsecurity.com/v2",
                            "type": "text",
                            "name": "holmSecurityBaseUrl",
                            "validations": {
                              "required": true
                            }
                          }
                        }
                      ]
                    },
                    {
                      "title": "2. Connect",
                      "description": "Enable the Holm Security connector.",
                      "instructions": [
                        {
                          "type": "ConnectionToggleButton",
                          "parameters": {
                            "connectLabel": "Connect",
                            "disconnectLabel": "Disconnect",
                            "name": "toggle"
                          }
                        }
                      ]
                    }
                  ]
                }
              }
            },
            {
              "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/',concat('DataConnector-', variables('_dataConnectorContentIdConnectorDefinition1')))]",
              "apiVersion": "2022-01-01-preview",
              "type": "Microsoft.OperationalInsights/workspaces/providers/metadata",
              "properties": {
                "parentId": "[extensionResourceId(resourceId('Microsoft.OperationalInsights/workspaces', parameters('workspace')), 'Microsoft.SecurityInsights/dataConnectorDefinitions', variables('_dataConnectorContentIdConnectorDefinition1'))]",
                "contentId": "[variables('_dataConnectorContentIdConnectorDefinition1')]",
                "kind": "DataConnector",
                "version": "[variables('dataConnectorCCPVersion')]",
                "source": {
                  "sourceId": "[variables('_solutionId')]",
                  "name": "[variables('_solutionName')]",
                  "kind": "Solution"
                },
                "author": {
                  "name": "Holm Security",
                  "email": "[variables('_email')]"
                },
                "support": {
                  "name": "Holm Security",
                  "email": "support@holmsecurity.com",
                  "tier": "Partner",
                  "link": "https://support.holmsecurity.com/"
                },
                "dependencies": {
                  "criteria": [
                    {
                      "version": "[variables('dataConnectorCCPVersion')]",
                      "contentId": "[variables('_dataConnectorContentIdConnections1')]",
                      "kind": "ResourcesDataConnector"
                    }
                  ]
                }
              }
            },
            {
              "name": "HolmSecDCR",
              "apiVersion": "2022-06-01",
              "type": "Microsoft.Insights/dataCollectionRules",
              "location": "[parameters('workspace-location')]",
              "kind": "[variables('blanks')]",
              "properties": {
                "dataCollectionEndpointId": "[variables('dataCollectionEndpointId1')]",
                "streamDeclarations": {
                  "Custom-web_assets_CL": {
                    "columns": [
                      {
                        "name": "name",
                        "type": "string"
                      },
                      {
                        "name": "uuid",
                        "type": "string"
                      },
                      {
                        "name": "type",
                        "type": "string"
                      },
                      {
                        "name": "tags",
                        "type": "dynamic"
                      },
                      {
                        "name": "created",
                        "type": "datetime"
                      },
                      {
                        "name": "uri",
                        "type": "string"
                      },
                      {
                        "name": "vulnerabilities_count",
                        "type": "int"
                      },
                      {
                        "name": "last_detected",
                        "type": "datetime"
                      }
                    ]
                  },
                  "Custom-net_assets_CL": {
                    "columns": [
                      {
                        "name": "created",
                        "type": "datetime"
                      },
                      {
                        "name": "name",
                        "type": "string"
                      },
                      {
                        "name": "tags",
                        "type": "dynamic"
                      },
                      {
                        "name": "type",
                        "type": "string"
                      },
                      {
                        "name": "uuid",
                        "type": "string"
                      },
                      {
                        "name": "operating_system",
                        "type": "string"
                      },
                      {
                        "name": "vulnerabilities_count",
                        "type": "int"
                      },
                      {
                        "name": "last_detected",
                        "type": "datetime"
                      },
                      {
                        "name": "ip",
                        "type": "string"
                      },
                      {
                        "name": "ip_range",
                        "type": "string"
                      },
                      {
                        "name": "hostname",
                        "type": "string"
                      },
                      {
                        "name": "details",
                        "type": "string"
                      },
                      {
                        "name": "business_impact",
                        "type": "string"
                      },
                      {
                        "name": "hosts_personal_data",
                        "type": "boolean"
                      },
                      {
                        "name": "severity",
                        "type": "dynamic"
                      }
                    ]
                  }
                },
                "destinations": {
                  "logAnalytics": [
                    {
                      "workspaceResourceId": "[variables('workspaceResourceId')]",
                      "name": "clv2ws1"
                    }
                  ]
                },
                "dataFlows": [
                  {
                    "streams": [
                      "Custom-web_assets_CL"
                    ],
                    "destinations": [
                      "clv2ws1"
                    ],
                    "outputStream": "Custom-web_assets_CL",
                    "transformKql": "source | extend TimeGenerated = iff(isempty(created), now(), todatetime(created)) , Name = ['name'] , Uuid = ['uuid'] , ObjectType = ['type'] , Tags = ['tags'] , Created = ['created'] , Uri = ['uri'] , VulnerabilitiesCount = ['vulnerabilities_count'] , LastDetected = ['last_detected'] | project TimeGenerated , Name , Uuid , ObjectType , Tags , Created , Uri , VulnerabilitiesCount , LastDetected"
                  },
                  {
                    "streams": [
                      "Custom-net_assets_CL"
                    ],
                    "destinations": [
                      "clv2ws1"
                    ],
                    "outputStream": "Custom-net_assets_CL",
                    "transformKql": "source | extend TimeGenerated = iff(isempty(created), now(), todatetime(created)) , Created = ['created'] , Name = ['name'] , Tags = ['tags'] , ObjectType = ['type'] , Uuid = ['uuid'] , OperatingSystem = ['operating_system'] , VulnerabilitiesCount = ['vulnerabilities_count'] , LastDetected = ['last_detected'] , Ip = ['ip'] , IpRange = ['ip_range'] , HostName = ['hostname'] , Details = ['details'] , BusinessImpact = ['business_impact'] , HostsPersonalData = ['hosts_personal_data'] , Severity = ['severity'] | project TimeGenerated , Created , Name , Tags , ObjectType , Uuid , OperatingSystem , VulnerabilitiesCount , LastDetected , Ip , IpRange , HostName , Details , BusinessImpact , HostsPersonalData , Severity"
                  }
                ]
              }
            },
            {
              "name": "net_assets_CL",
              "apiVersion": "2022-10-01",
              "type": "Microsoft.OperationalInsights/workspaces/tables",
              "location": "[parameters('workspace-location')]",
              "kind": null,
              "properties": {
                "retentionInDays": 180,
                "schema": {
                  "name": "net_assets_CL",
                  "description": "Holm Security network assets data",
                  "columns": [
                    {
                      "name": "TimeGenerated",
                      "type": "datetime",
                      "description": "Time the record was generated"
                    },
                    {
                      "name": "Created",
                      "type": "datetime",
                      "description": "Asset creation date"
                    },
                    {
                      "name": "Name",
                      "type": "string",
                      "description": "Asset name"
                    },
                    {
                      "name": "Tags",
                      "type": "dynamic",
                      "description": "Asset tags"
                    },
                    {
                      "name": "ObjectType",
                      "type": "string",
                      "description": "Object type"
                    },
                    {
                      "name": "Uuid",
                      "type": "string",
                      "description": "Unique identifier for the asset"
                    },
                    {
                      "name": "OperatingSystem",
                      "type": "string",
                      "description": "Operating system"
                    },
                    {
                      "name": "VulnerabilitiesCount",
                      "type": "int",
                      "description": "Number of vulnerabilities"
                    },
                    {
                      "name": "LastDetected",
                      "type": "datetime",
                      "description": "Last detected date"
                    },
                    {
                      "name": "Ip",
                      "type": "string",
                      "description": "IP address of the network asset"
                    },
                    {
                      "name": "IpRange",
                      "type": "string",
                      "description": "IP range of the network asset"
                    },
                    {
                      "name": "HostName",
                      "type": "string",
                      "description": "Host name"
                    },
                    {
                      "name": "Details",
                      "type": "string",
                      "description": "Additional details"
                    },
                    {
                      "name": "BusinessImpact",
                      "type": "string",
                      "description": "Business impact"
                    },
                    {
                      "name": "HostsPersonalData",
                      "type": "boolean",
                      "description": "Whether the asset hosts personal data"
                    },
                    {
                      "name": "Severity",
                      "type": "dynamic",
                      "description": "Vulnerability severity breakdown"
                    }
                  ]
                }
              }
            },
            {
              "name": "web_assets_CL",
              "apiVersion": "2022-10-01",
              "type": "Microsoft.OperationalInsights/workspaces/tables",
              "location": "[parameters('workspace-location')]",
              "kind": null,
              "properties": {
                "retentionInDays": 180,
                "schema": {
                  "name": "web_assets_CL",
                  "description": "Holm Security web assets data",
                  "columns": [
                    {
                      "name": "TimeGenerated",
                      "type": "datetime",
                      "description": "Time the record was generated"
                    },
                    {
                      "name": "Name",
                      "type": "string",
                      "description": "Asset name"
                    },
                    {
                      "name": "Uuid",
                      "type": "string",
                      "description": "Unique identifier for the asset"
                    },
                    {
                      "name": "ObjectType",
                      "type": "string",
                      "description": "Object type"
                    },
                    {
                      "name": "Tags",
                      "type": "dynamic",
                      "description": "Asset tags"
                    },
                    {
                      "name": "Created",
                      "type": "datetime",
                      "description": "Asset creation date"
                    },
                    {
                      "name": "Uri",
                      "type": "string",
                      "description": "URL of the web asset"
                    },
                    {
                      "name": "VulnerabilitiesCount",
                      "type": "int",
                      "description": "Number of vulnerabilities"
                    },
                    {
                      "name": "LastDetected",
                      "type": "datetime",
                      "description": "Last detected date"
                    }
                  ]
                }
              }
            }
          ]
        },
        "packageKind": "Solution",
        "packageVersion": "[variables('_solutionVersion')]",
        "packageName": "[variables('_solutionName')]",
        "contentProductId": "[concat(take(variables('_solutionId'), 50),'-','dc','-', uniqueString(concat(variables('_solutionId'),'-','DataConnector','-',variables('_dataConnectorContentIdConnectorDefinition1'),'-', variables('dataConnectorCCPVersion'))))]",
        "packageId": "[variables('_solutionId')]",
        "contentSchemaVersion": "3.0.2",
        "version": "[variables('dataConnectorCCPVersion')]"
      }
    },
    {
      "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/',variables('_dataConnectorContentIdConnectorDefinition1'))]",
      "apiVersion": "2022-09-01-preview",
      "type": "Microsoft.OperationalInsights/workspaces/providers/dataConnectorDefinitions",
      "location": "[parameters('workspace-location')]",
      "kind": "Customizable",
      "properties": {
        "connectorUiConfig": {
          "id": "HolmSecurityCCF",
          "title": "Holm Security Data Connector",
          "publisher": "Holm Security",
          "descriptionMarkdown": "The Holm Security data connector provides the capability to ingest [Holm Security](https://www.holmsecurity.com/) asset data into Microsoft Sentinel through the REST API. The connector provides the ability to get web and network assets data from Holm Security.",
          "graphQueriesTableName": "web_assets_CL",
          "graphQueries": [
            {
              "metricName": "Total data received",
              "legend": "Holm Security Asset Data",
              "baseQuery": "{{graphQueriesTableName}}"
            }
          ],
          "sampleQueries": [
            {
              "description": "All Holm Security web assets",
              "query": "web_assets_CL\n| sort by TimeGenerated desc"
            },
            {
              "description": "Get sample of network assets",
              "query": "net_assets_CL\n| take 10"
            },
            {
              "description": "Summary of network assets by object type",
              "query": "net_assets_CL\n| summarize count() by ObjectType"
            }
          ],
          "dataTypes": [
            {
              "name": "web_assets_CL",
              "lastDataReceivedQuery": "web_assets_CL\n| where TimeGenerated > ago(12h)\n| summarize Time = max(TimeGenerated)\n| where isnotempty(Time)"
            },
            {
              "name": "net_assets_CL",
              "lastDataReceivedQuery": "net_assets_CL\n| where TimeGenerated > ago(12h)\n| summarize Time = max(TimeGenerated)\n| where isnotempty(Time)"
            }
          ],
          "connectivityCriteria": [
            {
              "type": "HasDataConnectors"
            }
          ],
          "availability": {
            "isPreview": false,
            "status": 1
          },
          "permissions": {
            "resourceProvider": [
              {
                "provider": "Microsoft.OperationalInsights/workspaces",
                "permissionsDisplayText": "Read and Write permissions are required.",
                "providerDisplayName": "Workspace",
                "scope": "Workspace",
                "requiredPermissions": {
                  "write": true,
                  "read": true,
                  "delete": true
                }
              }
            ],
            "customs": [
              {
                "name": "Holm Security API access",
                "description": "A Holm Security API token is required. [See how to set up an API token](https://support.holmsecurity.com/knowledge/how-do-i-set-up-an-api-token)."
              }
            ]
          },
          "instructionSteps": [
            {
              "title": "1. Configuration",
              "description": "Acquire your token from your Holm Security user profile. For details, visit https://se-api.holmsecurity.com/docs/v2/#section/Authentication",
              "instructions": [
                {
                  "type": "Textbox",
                  "parameters": {
                    "label": "API Key",
                    "placeholder": "API key for authentication",
                    "type": "password",
                    "name": "apiKey",
                    "validations": {
                      "required": true
                    }
                  }
                },
                {
                  "type": "Textbox",
                  "parameters": {
                    "label": "Holm Security API Base URL",
                    "placeholder": "e.g. https://se-api.holmsecurity.com/v2",
                    "type": "text",
                    "name": "holmSecurityBaseUrl",
                    "validations": {
                      "required": true
                    }
                  }
                }
              ]
            },
            {
              "title": "2. Connect",
              "description": "Enable the Holm Security connector.",
              "instructions": [
                {
                  "type": "ConnectionToggleButton",
                  "parameters": {
                    "connectLabel": "Connect",
                    "disconnectLabel": "Disconnect",
                    "name": "toggle"
                  }
                }
              ]
            }
          ]
        }
      }
    },
    {
      "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/',concat('DataConnector-', variables('_dataConnectorContentIdConnectorDefinition1')))]",
      "apiVersion": "2022-01-01-preview",
      "type": "Microsoft.OperationalInsights/workspaces/providers/metadata",
      "properties": {
        "parentId": "[extensionResourceId(resourceId('Microsoft.OperationalInsights/workspaces', parameters('workspace')), 'Microsoft.SecurityInsights/dataConnectorDefinitions', variables('_dataConnectorContentIdConnectorDefinition1'))]",
        "contentId": "[variables('_dataConnectorContentIdConnectorDefinition1')]",
        "kind": "DataConnector",
        "version": "[variables('dataConnectorCCPVersion')]",
        "source": {
          "sourceId": "[variables('_solutionId')]",
          "name": "[variables('_solutionName')]",
          "kind": "Solution"
        },
        "author": {
          "name": "Holm Security",
          "email": "[variables('_email')]"
        },
        "support": {
          "name": "Holm Security",
          "email": "support@holmsecurity.com",
          "tier": "Partner",
          "link": "https://support.holmsecurity.com/"
        },
        "dependencies": {
          "criteria": [
            {
              "version": "[variables('dataConnectorCCPVersion')]",
              "contentId": "[variables('_dataConnectorContentIdConnections1')]",
              "kind": "ResourcesDataConnector"
            }
          ]
        }
      }
    },
    {
      "type": "Microsoft.OperationalInsights/workspaces/providers/contentTemplates",
      "apiVersion": "2023-04-01-preview",
      "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/', variables('dataConnectorTemplateNameConnections1'), variables('dataConnectorCCPVersion'))]",
      "location": "[parameters('workspace-location')]",
      "dependsOn": [
        "[extensionResourceId(resourceId('Microsoft.OperationalInsights/workspaces', parameters('workspace')), 'Microsoft.SecurityInsights/contentPackages', variables('_solutionId'))]"
      ],
      "properties": {
        "contentId": "[variables('_dataConnectorContentIdConnections1')]",
        "displayName": "Holm Security Data Connector",
        "contentKind": "ResourcesDataConnector",
        "mainTemplate": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "[variables('dataConnectorCCPVersion')]",
          "parameters": {
            "guidValue": {
              "defaultValue": "[[newGuid()]",
              "type": "securestring"
            },
            "innerWorkspace": {
              "defaultValue": "[parameters('workspace')]",
              "type": "securestring"
            },
            "connectorDefinitionName": {
              "defaultValue": "Holm Security Data Connector",
              "type": "securestring",
              "minLength": 1
            },
            "workspace": {
              "defaultValue": "[parameters('workspace')]",
              "type": "securestring"
            },
            "dcrConfig": {
              "defaultValue": {
                "dataCollectionEndpoint": "data collection Endpoint",
                "dataCollectionRuleImmutableId": "data collection rule immutableId"
              },
              "type": "object"
            },
            "apiKey": {
              "defaultValue": "apiKey",
              "type": "securestring",
              "minLength": 1
            },
            "holmSecurityBaseUrl": {
              "defaultValue": "holmSecurityBaseUrl",
              "type": "securestring",
              "minLength": 1
            }
          },
          "variables": {
            "_dataConnectorContentIdConnections1": "[variables('_dataConnectorContentIdConnections1')]"
          },
          "resources": [
            {
              "name": "[concat(parameters('workspace'),'/Microsoft.SecurityInsights/',concat('DataConnector-', variables('_dataConnectorContentIdConnections1')))]",
              "apiVersion": "2022-01-01-preview",
