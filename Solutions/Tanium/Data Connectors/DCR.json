{
    "name": "TaniumConnectorDCR",
    "apiVersion": "2021-09-01-preview",
    "type": "Microsoft.Insights/dataCollectionRules",
    "location": "[workspace().location]",
    "properties": {
        "streamDeclarations": {
            "Custom-SentinelBasicInventory": {
                "columns": [
                    {
                        "name": "ComputerName",
                        "type": "string"
                    },
                    {
                        "name": "ComputerID",
                        "type": "string"
                    },
                    {
                        "name": "SystemUUID",
                        "type": "string"
                    },
                    {
                        "name": "Username",
                        "type": "string"
                    },
                    {
                        "name": "OSPlatform",
                        "type": "string"
                    },
                    {
                        "name": "OperatingSystem",
                        "type": "string"
                    },
                    {
                        "name": "ServicePack",
                        "type": "string"
                    },
                    {
                        "name": "ChassisType",
                        "type": "string"
                    },
                    {
                        "name": "Manufacturer",
                        "type": "string"
                    },
                    {
                        "name": "Model",
                        "type": "string"
                    },
                    {
                        "name": "ComputerSerialNumber",
                        "type": "string"
                    },
                    {
                        "name": "IPAddress",
                        "type": "string"
                    },
                    {
                        "name": "DomainName",
                        "type": "string"
                    },
                    {
                        "name": "Count",
                        "type": "real"
                    }
                ]
            },
            "Custom-TaniumComplyCompliance": {
                "columns": [
                    {
                        "name": "ComputerName",
                        "type": "string"
                    },
                    {
                        "name": "IPAddress",
                        "type": "string"
                    },
                    {
                        "name": "OperatingSystemGeneration",
                        "type": "string"
                    },
                    {
                        "name": "Rule",
                        "type": "string"
                    },
                    {
                        "name": "RuleID",
                        "type": "string"
                    },
                    {
                        "name": "Standard",
                        "type": "string"
                    },
                    {
                        "name": "Profile",
                        "type": "string"
                    },
                    {
                        "name": "Version",
                        "type": "string"
                    },
                    {
                        "name": "StatusCategory",
                        "type": "string"
                    }
                ]
            },
            "Custom-TaniumComplyVulnerabilities": {
                "columns": [
                    {
                        "name": "ComputerID",
                        "type": "string"
                    },
                    {
                        "name": "ComputerName",
                        "type": "string"
                    },
                    {
                        "name": "IpAddress",
                        "type": "string"
                    },
                    {
                        "name": "OperatingSystemGeneration",
                        "type": "string"
                    },
                    {
                        "name": "CVE",
                        "type": "string"
                    },
                    {
                        "name": "ScanType",
                        "type": "string"
                    },
                    {
                        "name": "CveYear",
                        "type": "string"
                    },
                    {
                        "name": "Title",
                        "type": "string"
                    },
                    {
                        "name": "Severity",
                        "type": "string"
                    },
                    {
                        "name": "CvssScore",
                        "type": "real"
                    },
                    {
                        "name": "CvssV3Score",
                        "type": "real"
                    },
                    {
                        "name": "CvssV3Severity",
                        "type": "string"
                    }
                ]
            }
        },
        "destinations": {
            "logAnalytics": [
                {
                    "workspaceResourceId": "[concat('/subscriptions/',parameters('subscription'),'/resourceGroups/',parameters('resourceGroupName'),'/providers/Microsoft.operationalinsights/workspaces/',parameters('workspace'))]",
                    "name": "[parameters('workspace')]"
                }
            ]
        },
        "dataFlows": [
            {
                "streams": [
                    "Custom-SentinelBasicInventory"
                ],
                "destinations": [
                    "[parameters('workspace')]"
                ],
                "transformKql": "source\n| project\n    TimeGenerated = now(),\n    Chassis_Type_s = ChassisType,\n    Computer_ID_s = ComputerID,\n    Computer_Name_s = ComputerName,\n    Computer_Serial_Number_s = ComputerSerialNumber,\n    Count_d = Count,\n    Domain_Name_s = DomainName,\n    IP_Address_s = IPAddress,\n    Manufacturer_s = Manufacturer,\n    Model_s = Model,\n    Operating_System_s = OperatingSystem,\n    OS_Platform_s = OSPlatform,\n    Service_Pack_s = ServicePack,\n    System_UUID_s = SystemUUID,\n    Username_s = Username",
                "outputStream": "Custom-TaniumMainAsset_CL"
            },
            {
                "streams": [
                    "Custom-TaniumComplyCompliance"
                ],
                "destinations": [
                    "[parameters('workspace')]"
                ],
                "transformKql": "source\n| project\n    TimeGenerated = now(),\n    Computer_Name_s = ComputerName,\n    IP_Address_s = IPAddress,\n    Operating_System_Generation_s = OperatingSystemGeneration,\n    Profile_s = Profile,\n    Rule_ID_s = Rule,\n    Rule_s = RuleID,\n    Standard_s = Standard,\n    Status_Category_s = StatusCategory,\n    Version_s = Version",
                "outputStream": "Custom-TaniumComplyCompliance_CL"
            },
            {
                "streams": [
                    "Custom-TaniumComplyVulnerabilities"
                ],
                "destinations": [
                    "[parameters('workspace')]"
                ],
                "transformKql": "source\n| project\n    TimeGenerated = now(),\n    Computer_ID_s = ComputerID,\n    Computer_Name_s = ComputerName,\n    CVE_s = CVE,\n    CVE_Year_s = CveYear,\n    CVSS_Score_d = CvssScore,\n    CVSS_v3_Score_d = CvssV3Score,\n    CVSS_v3_Severity_s = CvssV3Severity,\n    IP_Address_s = IpAddress,\n    Operating_System_Generation_s = OperatingSystemGeneration,\n    Scan_Type_s = ScanType,\n    Severity_s = Severity,\n    Title_s = Title",
                "outputStream": "Custom-TaniumComplyVulnerabilities_CL"
            }
        ],
        "dataCollectionEndpointId": "[concat('/subscriptions/',parameters('subscription'),'/resourceGroups/',parameters('resourceGroupName'),'/providers/Microsoft.Insights/dataCollectionEndpoints/',parameters('workspace'))]"
    }
}