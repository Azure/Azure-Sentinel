                "outputStream": "Custom-TaniumHighUptime_CL"
            },
            {
                "streams": [
                    "Custom-TaniumPatchCoverageStatus"
                ],
                "destinations": [
                    "[parameters('workspace')]"
                ],
                "transformKql": "source\n| project\n    TimeGenerated = now(),\n    Computer_Name_s = ComputerName,\n    Count_d = Count,\n    Detail_s = Detail,\n    IP_Address_s = IPAddress,\n    Patch_Is_Process_Running_s = ['Patch-IsProcessRunning'],\n    Status_s = Status",
                "outputStream": "Custom-TaniumPatchCoverageStatus_CL"
            },
            {
                "streams": [
                    "Custom-TaniumPatchListApplicability"
                ],
                "destinations": [
                    "[parameters('workspace')]"
                ],
                "transformKql": "source\n| project\n    TimeGenerated = now(),\n    Bulletins_s = Bulletins,\n    Classification_s = Classification,\n    Computer_ID_s = ComputerID,\n    Computer_Name_s = ComputerName,\n    Count_d = Count,\n    Custom_Field_s = CustomField,\n    CVE_IDs_s = CveIds,\n    Install_Status_s = InstallStatus,\n    KB_Articles_s = KbArticles,\n    Last_Logged_In_User_s = LastLoggedInUser,\n    Operating_System_s = OperatingSystem,\n    OS_Type_s = OsType,\n    Patch_List_Ids_s = PatchListIds,\n    Patch_Mean_Time_to_Patch_s = ['Patch-MeanTimeToPatch'],\n    Product_s = Product,\n    Release_Date_s = ReleaseDate,\n    Severity_s = Severity,\n    Size_in_Bytes_s = SizeInBytes,\n    Superseded_s = Superseded,\n    Title_s = Title,\n    Uninstallable_s = Uninstallable",
                "outputStream": "Custom-TaniumPatchListApplicability_CL"
            },
            {
                "streams": [
                    "Custom-TaniumPatchListCompliance"
                ],
                "destinations": [
                    "[parameters('workspace')]"
                ],
                "transformKql": "source\n| project\n    TimeGenerated = now(),\n    Compliance_Status_s = ComplianceStatus,\n    Computer_ID_s = ComputerID,\n    Computer_Name_s = ComputerName,\n    Count_d = Count,\n    Last_Logged_In_User_s = LastLoggedInUser,\n    Operating_System_s = OperatingSystem,\n    OS_Type_s = OSType,\n    Patch_List_Id_s = PatchListId,\n    Patch_List_Name_s = PatchListName",
                "outputStream": "Custom-TaniumPatchListCompliance_CL"
            }
        ],
        "dataCollectionEndpointId": "[concat('/subscriptions/',parameters('subscription'),'/resourceGroups/',parameters('resourceGroupName'),'/providers/Microsoft.Insights/dataCollectionEndpoints/',parameters('workspace'))]"
    }
}