        "destinations": {
            "logAnalytics": [
                {
                    "workspaceResourceId": "[concat('/subscriptions/',parameters('subscription'),'/resourceGroups/',parameters('resourceGroupName'),'/providers/Microsoft.operationalinsights/workspaces/',parameters('workspace'))]",
                    "name": "[parameters('workspace')]"
                }
            ]
        },
        "dataFlows": [
            {
                "streams": [
                    "Custom-SentinelBasicInventory"
                ],
                "destinations": [
                    "[parameters('workspace')]"
                ],
                "transformKql": "source\n| project\n    TimeGenerated = now(),\n    Chassis_Type_s = ChassisType,\n    Computer_ID_s = ComputerID,\n    Computer_Name_s = ComputerName,\n    Computer_Serial_Number_s = ComputerSerialNumber,\n    Count_d = Count,\n    Domain_Name_s = DomainName,\n    IP_Address_s = IPAddress,\n    Manufacturer_s = Manufacturer,\n    Model_s = Model,\n    Operating_System_s = OperatingSystem,\n    OS_Platform_s = OSPlatform,\n    Service_Pack_s = ServicePack,\n    System_UUID_s = SystemUUID,\n    Username_s = Username",
                "outputStream": "Custom-TaniumMainAsset_CL"
            },
            {
                "streams": [
                    "Custom-TaniumComplyCompliance"
                ],
                "destinations": [
                    "[parameters('workspace')]"
                ],
                "transformKql": "source\n| project\n    TimeGenerated = now(),\n    Computer_Name_s = ComputerName,\n    IP_Address_s = IPAddress,\n    Operating_System_Generation_s = OperatingSystemGeneration,\n    Profile_s = Profile,\n    Rule_ID_s = Rule,\n    Rule_s = RuleID,\n    Standard_s = Standard,\n    Status_Category_s = StatusCategory,\n    Version_s = Version",
                "outputStream": "Custom-TaniumComplyCompliance_CL"
            },
            {
                "streams": [
                    "Custom-TaniumComplyVulnerabilities"
                ],
                "destinations": [
                    "[parameters('workspace')]"
                ],
                "transformKql": "source\n| project\n    TimeGenerated = now(),\n    Computer_ID_s = ComputerID,\n    Computer_Name_s = ComputerName,\n    CVE_s = CVE,\n    CVE_Year_s = CveYear,\n    CVSS_Score_d = CvssScore,\n    CVSS_v3_Score_d = CvssV3Score,\n    CVSS_v3_Severity_s = CvssV3Severity,\n    IP_Address_s = IpAddress,\n    Operating_System_Generation_s = OperatingSystemGeneration,\n    Scan_Type_s = ScanType,\n    Severity_s = Severity,\n    Title_s = Title",
                "outputStream": "Custom-TaniumComplyVulnerabilities_CL"
            },
            {
                "streams": [
                    "Custom-TaniumDefenderHealth"
                ],
                "destinations": [
                    "[parameters('workspace')]"
                ],
                "transformKql": "source\n| project\n    TimeGenerated = now(),\n    AntiMalware_Engine_Version_s = AntiMalwareEngineVersion,\n    AntiMalware_Product_Version_s = AntiMalwareProductVersion,\n    AntiMalware_Service_State_s = AntiMalwareServiceState,\n    AntiSpyware_Signature_Days_Age_s = AntiSpywareSignatureDaysAge,\n    AntiSpyware_Signature_Update_Date_s = AntiSpywareSignatureUpdateDate,\n    AntiSpyware_Signature_Version_s = AntiSpywareSignatureVersion,\n    Computer_ID_s = ComputerID,\n    Computer_Name_s = ComputerName,\n    Count_d = Count,\n    Health_Issues_s = MicrosoftDefenderHealthIssues,\n    IP_Address_s = IPAddress,\n    Is_AntiMalware_Service_Enabled_s = IsAntiMalwareServiceEnabled,\n    Is_AntiSpyware_Service_Enabled_s = IsAntiSpywareServiceEnabled,\n    Is_Defender_Healthy_s = IsMicrosoftDefenderHealthy,\n    Is_Defender_Installed_s = IsDefenderInstalled,\n    OS_Platform_s = OSPlatform,\n    QuickScan_Age_s = QuickScanAge,\n    QuickScan_Overdue_s = IsQuickScanOverdue,\n    QuickScan_Signature_Version_s = QuickScanSignatureVersion,\n    QuickScan_Start_Time_s = QuickScanStartTime,\n    QuickScan_Stop_Time_s = QuickScanStopTime",
                "outputStream": "Custom-TaniumDefenderHealth_CL"
            },
            {
                "streams": [
                    "Custom-TaniumDiscoverUnmanagedAssets"
                ],
                "destinations": [
                    "[parameters('workspace')]"
                ],
                "transformKql": "source\n| project\n    TimeGenerated = now(),\n    Arp_b = Arp,\n    AwsApi_b = AwsApi,\n    CentralizedNmap_b = CentralizedNmap,\n    Connected_b = Connected,\n    CreatedAt_t = CreatedAt,\n    FirstManagedAt_t = FirstManagedAt,\n    HostName_s = HostName,\n    id_d = Id,\n    IPAddress = IpAddress,\n    Labels_s = Labels,\n    LastDiscoveredAt_t = LastDiscoveredAt,\n    LastManagedAt_t = LastManagedAt,\n    Locations_s = Locations,\n    MacAddress_s = MacAddress,\n    MacOrganization_s = MacOrganization,\n    Managed_b = Managed,\n    NatIpAddress_s = NatIpAddress,\n    Nmap_b = Nmap,\n    Os_s = Os,\n    OsGeneration_s = OsGeneration,\n    Ping_b = Ping,\n    Ports_s = Ports,\n    Profile_s = Profile,\n    SatelliteDecId_g = toguid(SatelliteDecId),\n    SatelliteName_s = SatelliteName,\n    SatelliteNmap_b = SatelliteNmap,\n    TaniumComputerId_d = TaniumComputerId,\n    Unmanageable_d = Unmanageable,\n    UpdatedAt_t = UpdatedAt",
