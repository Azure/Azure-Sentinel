                                    {
                                        "columnMatch": "Events",
                                        "formatter": 22,
                                        "formatOptions": {
                                            "compositeBarSettings": {
                                                "labelText": "",
                                                "columnSettings": [
                                                    {
                                                        "columnName": "CREATE",
                                                        "color": "green"
                                                    },
                                                    {
                                                        "columnName": "UPDATE",
                                                        "color": "blue"
                                                    },
                                                    {
