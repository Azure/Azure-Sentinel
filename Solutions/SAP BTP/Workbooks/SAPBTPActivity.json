                    {
                        "type": 1,
                        "content": {
                            "json": "# BTP Audit Coverage\r\n\r\nThis view identifies custom BTP applications that have user logins but no business audit trail. These applications may be missing audit log service bindings or `@AuditLog` annotations, creating security blind spots where user actions are invisible to monitoring."
                        },
                        "name": "text - audit-coverage"
