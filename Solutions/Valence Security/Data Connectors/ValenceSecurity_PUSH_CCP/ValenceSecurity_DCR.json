{
  "name": "Valence-DCR",
  "apiVersion": "2023-03-11",
  "type": "Microsoft.Insights/dataCollectionRules",
  "location": "{{location}}",
  "properties": {
    "dataCollectionEndpointId": "{{dataCollectionEndpointId}}",
    "streamDeclarations": {
      "Custom-ValenceAlerts": {
        "columns": [
          { "name": "alertType", "type": "string" },
          { "name": "summaryLine", "type": "string" },
          { "name": "status", "type": "string" },
          { "name": "severity", "type": "string" },
          { "name": "creationTimestamp", "type": "datetime" },
          { "name": "events", "type": "dynamic" }
        ]
      },
      "Custom-ValenceAuditLogs": {
        "columns": [
          { "name": "actor", "type": "string" },
          { "name": "action", "type": "string" },
          { "name": "success", "type": "boolean" },
          { "name": "details", "type": "string" },
          { "name": "ipAddress", "type": "string" },
          { "name": "timeEpoch", "type": "long" }
        ]
      }
    },
    "destinations": {
      "logAnalytics": [
        {
          "workspaceResourceId": "{{workspaceResourceId}}",
          "name": "clv2ws1"
        }
      ]
    },
    "dataFlows": [
      {
        "streams": ["Custom-ValenceAlerts"],
        "destinations": ["clv2ws1"],
        "transformKql": "source | extend TimeGenerated = todatetime(creationTimestamp)",
        "outputStream": "Custom-ValenceAlerts_CL"
      },
      {
        "streams": ["Custom-ValenceAuditLogs"],
        "destinations": ["clv2ws1"],
        "transformKql": "source | extend TimeGenerated = unixtime_milliseconds_todatetime(timeEpoch)",
        "outputStream": "Custom-ValenceAuditLogs_CL"
      }
    ]
  }
}
