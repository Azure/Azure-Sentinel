{
    "type": "Microsoft.SecurityInsights/dataConnectors",
    "apiVersion": "2021-10-01-preview",
    "name": "MajorBuildInvocationsPoller",
    "location": "{{location}}",
    "kind": "RestApiPoller",
    "properties": {
        "connectorDefinitionName": "MajorBuildInvocationsDefinition",
        "dataType": "MajorBuildInvocations_CL",
        "auth": {
            "type": "APIKey",
            "ApiKey": "[[parameters('apiKey')]",
            "ApiKeyName": "Authorization",
            "ApiKeyIdentifier": "Bearer"
        },
        "request": {
            "apiEndpoint": "https://api.prod.major.build/api/public/invocations",
            "httpMethod": "GET",
            "queryWindowInMin": 60,
            "rateLimitQPS": 5,
            "retryCount": 3,
            "timeoutInSeconds": 30,
            "headers": {
                "Accept": "application/json"
            },
            "queryParameters": {
                "limit": 100
            },
            "queryParametersTemplate": "{\"startTime\": \"{_QueryWindowStartTime}\", \"endTime\": \"{_QueryWindowEndTime}\"}"
        },
        "response": {
            "eventsJsonPaths": [
                "$.invocations"
            ],
            "format": "json"
        },
        "dcrConfig": {
            "streamName": "Custom-MajorBuildInvocations_CL",
            "dataCollectionEndpoint": "{{dataCollectionEndpoint}}",
            "dataCollectionRuleImmutableId": "{{dataCollectionRuleImmutableId}}"
        }
    }
}
