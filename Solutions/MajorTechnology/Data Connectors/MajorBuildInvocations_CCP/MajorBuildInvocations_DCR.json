[
    {
        "name": "MajorBuildInvocationsDCR",
        "apiVersion": "2022-06-01",
        "type": "Microsoft.Insights/dataCollectionRules",
        "location": "{{location}}",
        "kind": null,
        "properties": {
            "dataCollectionEndpointId": "{{dataCollectionEndpointId}}",
            "streamDeclarations": {
                "Custom-MajorBuildInvocations_CL": {
                    "columns": [
                        { "name": "invocationId", "type": "string" },
                        { "name": "time", "type": "string" },
                        { "name": "resourceName", "type": "string" },
                        { "name": "applicationName", "type": "string" },
                        { "name": "resourceType", "type": "string" },
                        { "name": "environment", "type": "string" },
                        { "name": "userName", "type": "string" },
                        { "name": "userEmail", "type": "string" },
                        { "name": "status", "type": "string" },
                        { "name": "payload", "type": "dynamic" }
                    ]
                }
            },
            "destinations": {
                "logAnalytics": [
                    {
                        "workspaceResourceId": "{{workspaceResourceId}}",
                        "name": "clv2ws1"
                    }
                ]
            },
            "dataFlows": [
                {
                    "streams": [ "Custom-MajorBuildInvocations_CL" ],
                    "destinations": [ "clv2ws1" ],
                    "outputStream": "Custom-MajorBuildInvocations_CL",
                    "transformKql": "source | extend TimeGenerated = todatetime(['time']), invocationTime = tostring(['time']), payloadSubtype = tostring(payload.subtype), payloadTimeoutMs = toint(payload.timeoutMs), payloadType = tostring(payload.type) | project TimeGenerated, invocationId, invocationTime, resourceName, applicationName, resourceType, environment, userName, userEmail, status, payload, payloadSubtype, payloadTimeoutMs, payloadType"
                }
            ]
        }
    }
]
