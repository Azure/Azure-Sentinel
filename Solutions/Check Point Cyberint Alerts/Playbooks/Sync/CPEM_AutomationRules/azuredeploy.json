{
    "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "metadata": {
        "title": "Check Point Exposure Management - Automation Rules for Bi-Directional Sync",
        "description": "Deploys automation rules that trigger the Exporter playbook when Microsoft Sentinel incident status changes. Includes tag-based loop prevention to avoid circular sync.",
        "prerequisites": [
            "1. Check_Point_EM_Exporter playbook must be deployed in the same resource group.",
            "2. Microsoft Sentinel must be enabled on the target Log Analytics workspace."
        ],
        "postDeployment": [
            "1. Verify the automation rules are visible in Microsoft Sentinel > Automation.",
            "2. Grant the Check_Point_EM_Exporter playbook Managed Identity the Microsoft Sentinel Responder role if not already done."
        ],
        "lastUpdateTime": "2026-02-17T00:00:00.000Z",
        "entities": [],
        "tags": [ "Sync", "Automation" ],
        "support": {
            "tier": "Partner",
            "name": "Check Point",
            "link": "https://cyberint.com/customer-support/"
        },
        "source": {
            "type": "solution",
            "name": "Check Point Exposure Management Alerts"
        },
        "author": {
            "name": "Check Point"
        },
        "releaseNotes": [
            {
                "version": "1.0.0",
                "title": "Check Point Exposure Management - Automation Rules",
                "notes": [ "Initial version" ]
            }
        ]
    },
    "parameters": {
        "Sentinel_Workspace_Resource_Id": {
            "type": "string",
            "metadata": {
                "description": "Full resource ID of the Log Analytics workspace with Microsoft Sentinel enabled (e.g., /subscriptions/.../resourceGroups/.../providers/Microsoft.OperationalInsights/workspaces/...)"
            }
        },
        "Exporter_PlaybookName": {
            "type": "string",
            "defaultValue": "Check_Point_EM_Exporter",
            "metadata": {
                "description": "Name of the Check_Point_EM_Exporter Logic App"
            }
        },
        "Automation_Rule_Order": {
            "type": "int",
            "defaultValue": 100,
            "metadata": {
                "description": "Execution order of the automation rule (lower = higher priority)"
            }
        }
    },
    "variables": {
        "outboundSyncRuleName": "[guid('CPEM-Exporter-Rule', parameters('Sentinel_Workspace_Resource_Id'))]"
    },
    "resources": [
        {
            "type": "Microsoft.SecurityInsights/automationRules",
            "name": "[variables('outboundSyncRuleName')]",
            "scope": "[parameters('Sentinel_Workspace_Resource_Id')]",
            "apiVersion": "2023-02-01-preview",
            "properties": {
                "displayName": "Check Point EM - Sync incident status to Argos on update",
                "order": "[parameters('Automation_Rule_Order')]",
                "triggeringLogic": {
                    "isEnabled": true,
                    "triggersOn": "Incidents",
                    "triggersWhen": "Updated",
                    "conditions": [
                        {
                            "conditionType": "PropertyChanged",
                            "conditionProperties": {
                                "propertyName": "IncidentStatus",
                                "changeType": "ChangedTo",
                                "operator": "Equals",
                                "propertyValues": [
                                    "Closed"
                                ]
                            }
                        }
                    ]
                },
                "actions": [
                    {
                        "order": 1,
                        "actionType": "RunPlaybook",
                        "actionConfiguration": {
                            "logicAppResourceId": "[resourceId('Microsoft.Logic/workflows', parameters('Exporter_PlaybookName'))]",
                            "tenantId": "[subscription().tenantId]"
                        }
                    }
                ]
            }
        }
    ],
    "outputs": {
        "automationRuleId": {
            "type": "string",
            "value": "[variables('outboundSyncRuleName')]"
        }
    }
}