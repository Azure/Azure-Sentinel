{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "title": "Check Point Exposure Management - Credential Leak Validation and Response",
    "description": "When a new Microsoft Sentinel incident is created for leaked credentials, this playbook queries the Check Point Exposure Management credential leak API for the affected domain, enriches the incident with exposed credential details, and adds results as an incident comment.",
    "prerequisites": [
      "1. A valid Check Point Exposure Management API token and base URL.",
      "2. The Logic App Managed Identity must be granted Microsoft Sentinel Responder role on the resource group."
    ],
    "postDeployment": [
      "1. Grant the Logic App Managed Identity the **Microsoft Sentinel Responder** role.",
      "2. Configure an automation rule in Microsoft Sentinel to trigger this playbook on credential leak incidents."
    ],
    "lastUpdateTime": "2026-02-25T00:00:00.000Z",
    "entities": [
      "Account"
    ],
    "tags": [
      "Enrichment",
      "Response"
    ],
    "support": {
      "tier": "Partner",
      "name": "Check Point",
      "link": "https://cyberint.com/customer-support/"
    },
    "source": {
      "type": "solution",
      "name": "Check Point Exposure Management Alerts"
    },
    "author": {
      "name": "Check Point"
    },
    "releaseNotes": [
      {
        "version": "1.0.0",
        "title": "Check Point Exposure Management - Credential Leak Validation and Response",
        "notes": [
          "Initial version"
        ]
      }
    ]
  },
  "parameters": {
    "PlaybookName": {
      "type": "String",
      "defaultValue": "Check_Point_EM_CredentialLeakResponse",
      "metadata": {
        "description": "Name of the Logic App / Playbook"
      }
    },
    "API_Base_URL": {
      "type": "String",
      "metadata": {
        "description": "Base URL of the Check Point Exposure Management API (e.g. https://app.cyberint.io)"
      }
    },
    "API_Access_Token": {
      "type": "SecureString",
      "metadata": {
        "description": "API token for Check Point Exposure Management"
      }
    },
    "Company_Domain": {
      "type": "String",
      "metadata": {
        "description": "Primary company domain to check for leaked credentials (e.g. example.com)"
      }
    }
  },
  "variables": {
    "AzureSentinelConnectionName": "[concat('azuresentinel-', parameters('PlaybookName'))]",
    "workspace-location-inline": "[resourceGroup().location]"
  },
  "resources": [
    {
      "type": "Microsoft.Web/connections",
      "apiVersion": "2016-06-01",
      "name": "[variables('AzureSentinelConnectionName')]",
      "location": "[variables('workspace-location-inline')]",
      "kind": "V1",
      "properties": {
        "displayName": "[variables('AzureSentinelConnectionName')]",
        "parameterValueType": "Alternative",
        "api": {
          "id": "[concat('/subscriptions/', subscription().subscriptionId, '/providers/Microsoft.Web/locations/', resourceGroup().location, '/managedApis/azuresentinel')]"
        }
      }
    },
    {
      "type": "Microsoft.Logic/workflows",
      "apiVersion": "2017-07-01",
      "name": "[parameters('PlaybookName')]",
      "location": "[variables('workspace-location-inline')]",
      "identity": {
        "type": "SystemAssigned"
      },
      "tags": {
        "hidden-SentinelTemplateName": "Check_Point_EM_CredentialLeakResponse",
        "hidden-SentinelTemplateVersion": "1.2"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/connections', variables('AzureSentinelConnectionName'))]"
      ],
      "properties": {
        "state": "Enabled",
        "definition": {
          "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
          "contentVersion": "1.0.0.0",
          "parameters": {
            "$connections": {
              "type": "Object"
            },
            "Company_Domain": {
              "defaultValue": "",
              "type": "String"
            },
            "API_Base_URL": {
              "defaultValue": "",
              "type": "String"
            },
            "API_Access_Token": {
              "defaultValue": "",
              "type": "SecureString"
            }
          },
          "triggers": {
            "Microsoft_Sentinel_incident": {
              "type": "ApiConnectionWebhook",
              "inputs": {
                "host": {
                  "connection": {
                    "name": "@parameters('$connections')['azuresentinel']['connectionId']"
                  }
                },
                "body": {
                  "callback_url": "@{listCallbackUrl()}"
                },
                "path": "/incident-creation"
              }
            }
          },
          "actions": {
            "Entities_-_Get_Accounts": {
              "type": "ApiConnection",
              "inputs": {
                "host": {
                  "connection": {
                    "name": "@parameters('$connections')['azuresentinel']['connectionId']"
                  }
                },
                "method": "post",
                "body": "@triggerBody()?['object']?['properties']?['relatedEntities']",
                "path": "/entities/account"
              },
              "runAfter": {}
            },
            "Initialize_variable_-_LeakComment": {
              "type": "InitializeVariable",
              "inputs": {
                "variables": [
                  {
                    "name": "LeakComment",
                    "type": "string",
                    "value": ""
                  }
                ]
              },
              "runAfter": {
                "Entities_-_Get_Accounts": [
                  "Succeeded"
                ]
              }
            },
            "Initialize_variable_-_LeakCount": {
              "type": "InitializeVariable",
              "inputs": {
                "variables": [
                  {
                    "name": "LeakCount",
                    "type": "integer",
                    "value": 0
                  }
                ]
              },
              "runAfter": {
                "Initialize_variable_-_LeakComment": [
                  "Succeeded"
                ]
              }
            },
            "Query_Leaked_Credentials": {
              "type": "Http",
              "inputs": {
                "method": "POST",
                "uri": "@{parameters('API_Base_URL')}/by_domain/",
                "headers": {
                  "Content-Type": "application/json",
                  "Accept": "application/json",
                  "Cookie": "access_token=@{parameters('API_Access_Token')}",
                  "X-Integration-Type": "Azure Sentinel",
                  "X-Integration-Version": "1.0"
                },
                "body": {
                  "domain": "@{parameters('Company_Domain')}"
                }
              },
              "runAfter": {
                "Initialize_variable_-_LeakCount": [
                  "Succeeded"
                ]
              }
            },
            "Parse_JSON_-_Leak_results": {
              "type": "ParseJson",
              "inputs": {
                "content": "@body('Query_Leaked_Credentials')",
                "schema": {
                  "type": "object",
                  "properties": {
                    "credentials": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "email": {
                            "type": "string"
                          },
                          "password": {
                            "type": "string"
                          },
                          "source": {
                            "type": "string"
                          },
                          "last_seen": {
                            "type": "string"
                          }
                        }
                      }
                    }
                  }
                }
              },
              "runAfter": {
                "Query_Leaked_Credentials": [
                  "Succeeded"
                ]
              }
            },
            "For_each_leaked_credential": {
              "type": "Foreach",
              "foreach": "@body('Parse_JSON_-_Leak_results')?['credentials']",
              "actions": {
                "Increment_LeakCount": {
                  "type": "IncrementVariable",
                  "inputs": {
                    "name": "LeakCount",
                    "value": 1
                  },
                  "runAfter": {}
                },
                "Append_leak_detail": {
                  "type": "AppendToStringVariable",
                  "inputs": {
                    "name": "LeakComment",
                    "value": "<br>\u2022 <strong>@{items('For_each_leaked_credential')?['email']}</strong> \u2014 Source: @{items('For_each_leaked_credential')?['source']} | Last Seen: @{items('For_each_leaked_credential')?['last_seen']}"
                  },
                  "runAfter": {
                    "Increment_LeakCount": [
                      "Succeeded"
                    ]
                  }
                }
              },
              "runAfter": {
                "Parse_JSON_-_Leak_results": [
                  "Succeeded"
                ]
              }
            },
            "Add_comment_to_incident": {
              "type": "ApiConnection",
              "inputs": {
                "host": {
                  "connection": {
                    "name": "@parameters('$connections')['azuresentinel']['connectionId']"
                  }
                },
                "method": "post",
                "body": {
                  "incidentArmId": "@triggerBody()?['object']?['id']",
                  "message": "<p><strong>CPEM Credential Leak Results for @{parameters('Company_Domain')}:</strong><br>Total exposed credentials found: @{variables('LeakCount')}@{variables('LeakComment')}</p>"
                },
                "path": "/Incidents/Comment"
              },
              "runAfter": {
                "For_each_leaked_credential": [
                  "Succeeded"
                ]
              }
            },
            "Condition_-_High_leak_count": {
              "type": "If",
              "expression": {
                "and": [
                  {
                    "greater": [
                      "@variables('LeakCount')",
                      10
                    ]
                  }
                ]
              },
              "actions": {
                "Update_incident_severity": {
                  "type": "ApiConnection",
                  "inputs": {
                    "host": {
                      "connection": {
                        "name": "@parameters('$connections')['azuresentinel']['connectionId']"
                      }
                    },
                    "method": "put",
                    "body": {
                      "incidentArmId": "@triggerBody()?['object']?['id']",
                      "severity": "High",
                      "tagsToAdd": {
                        "TagsToAdd": [
                          "credential-leak-high-volume"
                        ]
                      }
                    },
                    "path": "/Incidents"
                  },
                  "runAfter": {}
                }
              },
              "runAfter": {
                "Add_comment_to_incident": [
                  "Succeeded"
                ]
              }
            }
          }
        },
        "parameters": {
          "$connections": {
            "value": {
              "azuresentinel": {
                "connectionId": "[resourceId('Microsoft.Web/connections', variables('AzureSentinelConnectionName'))]",
                "connectionName": "[variables('AzureSentinelConnectionName')]",
                "id": "[concat('/subscriptions/', subscription().subscriptionId, '/providers/Microsoft.Web/locations/', resourceGroup().location, '/managedApis/azuresentinel')]",
                "connectionProperties": {
                  "authentication": {
                    "type": "ManagedServiceIdentity"
                  }
                }
              }
            }
          },
          "Company_Domain": {
            "value": "[parameters('Company_Domain')]"
          },
          "API_Base_URL": {
            "value": "[parameters('API_Base_URL')]"
          },
          "API_Access_Token": {
            "value": "[parameters('API_Access_Token')]"
          }
        }
      }
    }
  ],
  "outputs": {}
}
