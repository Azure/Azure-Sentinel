{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "title": "Check Point Exposure Management - Fetch Attachments On-Demand",
    "description": "On-demand playbook that fetches alert attachments and analysis report for a Sentinel incident, surfacing the results as an incident comment.",
    "prerequisites": [
      "1. A valid Check Point Exposure Management API token and base URL.",
      "2. The Logic App Managed Identity must be granted Microsoft Sentinel Responder role on the resource group."
    ],
    "postDeployment": [
      "1. Grant the Logic App Managed Identity the **Microsoft Sentinel Responder** role.",
      "2. Analysts can run this playbook from the Sentinel incident Actions menu."
    ],
    "lastUpdateTime": "2026-02-25T00:00:00.000Z",
    "entities": [],
    "tags": [
      "Enrichment",
      "Response"
    ],
    "support": {
      "tier": "Partner",
      "name": "Check Point",
      "link": "https://cyberint.com/customer-support/"
    },
    "source": {
      "type": "solution",
      "name": "Check Point Exposure Management Alerts"
    },
    "author": {
      "name": "Check Point"
    },
    "releaseNotes": [
      {
        "version": "1.0.0",
        "title": "Check Point Exposure Management - Fetch Attachments",
        "notes": [
          "Initial version"
        ]
      }
    ]
  },
  "parameters": {
    "PlaybookName": {
      "type": "String",
      "defaultValue": "Check_Point_EM_FetchAttachments",
      "metadata": {
        "description": "Name of the Logic App / Playbook"
      }
    },
    "API_Base_URL": {
      "type": "String",
      "metadata": {
        "description": "Base URL of the Check Point Exposure Management API (e.g. https://app.cyberint.io)"
      }
    },
    "API_Access_Token": {
      "type": "SecureString",
      "metadata": {
        "description": "API token for Check Point Exposure Management"
      }
    }
  },
  "variables": {
    "AzureSentinelConnectionName": "[concat('azuresentinel-', parameters('PlaybookName'))]",
    "workspace-location-inline": "[resourceGroup().location]"
  },
  "resources": [
    {
      "type": "Microsoft.Web/connections",
      "apiVersion": "2016-06-01",
      "name": "[variables('AzureSentinelConnectionName')]",
      "location": "[variables('workspace-location-inline')]",
      "kind": "V1",
      "properties": {
        "displayName": "[variables('AzureSentinelConnectionName')]",
        "parameterValueType": "Alternative",
        "api": {
          "id": "[concat('/subscriptions/', subscription().subscriptionId, '/providers/Microsoft.Web/locations/', resourceGroup().location, '/managedApis/azuresentinel')]"
        }
      }
    },
    {
      "type": "Microsoft.Logic/workflows",
      "apiVersion": "2017-07-01",
      "name": "[parameters('PlaybookName')]",
      "location": "[variables('workspace-location-inline')]",
      "identity": {
        "type": "SystemAssigned"
      },
      "tags": {
        "hidden-SentinelTemplateName": "Check_Point_EM_FetchAttachments",
        "hidden-SentinelTemplateVersion": "1.2"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/connections', variables('AzureSentinelConnectionName'))]"
      ],
      "properties": {
        "state": "Enabled",
        "definition": {
          "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
          "contentVersion": "1.0.0.0",
          "parameters": {
            "$connections": {
              "type": "Object"
            },
            "API_Base_URL": {
              "defaultValue": "",
              "type": "String"
            },
            "API_Access_Token": {
              "defaultValue": "",
              "type": "SecureString"
            }
          },
          "triggers": {
            "Microsoft_Sentinel_incident": {
              "type": "ApiConnectionWebhook",
              "inputs": {
                "host": {
                  "connection": {
                    "name": "@parameters('$connections')['azuresentinel']['connectionId']"
                  }
                },
                "body": {
                  "callback_url": "@{listCallbackUrl()}"
                },
                "path": "/incident-creation"
              }
            }
          },
          "actions": {
            "Initialize_variable_-_AttachmentResults": {
              "type": "InitializeVariable",
              "inputs": {
                "variables": [
                  {
                    "name": "AttachmentResults",
                    "type": "string",
                    "value": ""
                  }
                ]
              },
              "runAfter": {}
            },
            "Initialize_variable_-_AlertRefId": {
              "type": "InitializeVariable",
              "inputs": {
                "variables": [
                  {
                    "name": "AlertRefId",
                    "type": "string",
                    "value": ""
                  }
                ]
              },
              "runAfter": {
                "Initialize_variable_-_AttachmentResults": [
                  "Succeeded"
                ]
              }
            },
            "Initialize_variable_-_AnalysisReport": {
              "type": "InitializeVariable",
              "inputs": {
                "variables": [
                  {
                    "name": "AnalysisReport",
                    "type": "string",
                    "value": ""
                  }
                ]
              },
              "runAfter": {
                "Initialize_variable_-_AlertRefId": [
                  "Succeeded"
                ]
              }
            },
            "Parse_incident_alerts": {
              "type": "Compose",
              "inputs": "@triggerBody()?['object']?['properties']?['alerts']",
              "runAfter": {
                "Initialize_variable_-_AnalysisReport": [
                  "Succeeded"
                ]
              }
            },
            "For_each_alert": {
              "type": "Foreach",
              "foreach": "@outputs('Parse_incident_alerts')",
              "actions": {
                "Set_AlertRefId": {
                  "type": "SetVariable",
                  "inputs": {
                    "name": "AlertRefId",
                    "value": "@{items('For_each_alert')?['properties']?['additionalData']?['Custom Details']?['ref_id']}"
                  },
                  "runAfter": {}
                },
                "Get_Alert_Details": {
                  "type": "Http",
                  "inputs": {
                    "method": "GET",
                    "uri": "@{parameters('API_Base_URL')}/api/v1/alerts/@{encodeURIComponent(variables('AlertRefId'))}",
                    "headers": {
                      "Accept": "application/json",
                      "Cookie": "access_token=@{parameters('API_Access_Token')}",
                      "X-Integration-Type": "Azure Sentinel",
                      "X-Integration-Version": "1.0"
                    }
                  },
                  "runAfter": {
                    "Set_AlertRefId": [
                      "Succeeded"
                    ]
                  }
                },
                "Compose_attachments_list": {
                  "type": "Compose",
                  "inputs": "@coalesce(json(string(body('Get_Alert_Details')))?['attachments'], json('[]'))",
                  "runAfter": {
                    "Get_Alert_Details": [
                      "Succeeded"
                    ]
                  }
                },
                "For_each_attachment": {
                  "type": "Foreach",
                  "foreach": "@outputs('Compose_attachments_list')",
                  "actions": {
                    "Get_Attachment": {
                      "type": "Http",
                      "inputs": {
                        "method": "GET",
                        "uri": "@{parameters('API_Base_URL')}/api/v1/alerts/@{encodeURIComponent(variables('AlertRefId'))}/attachments/@{encodeURIComponent(items('For_each_attachment')?['id'])}",
                        "headers": {
                          "Accept": "application/json",
                          "Cookie": "access_token=@{parameters('API_Access_Token')}",
                          "X-Integration-Type": "Azure Sentinel",
                          "X-Integration-Version": "1.0"
                        }
                      },
                      "runAfter": {}
                    },
                    "Append_attachment_info": {
                      "type": "AppendToStringVariable",
                      "inputs": {
                        "name": "AttachmentResults",
                        "value": "- @{coalesce(items('For_each_attachment')?['name'], 'unnamed')} (type: @{coalesce(items('For_each_attachment')?['content_type'], 'unknown')}, id: @{items('For_each_attachment')?['id']}) \u2014 @{if(equals(outputs('Get_Attachment')?['statusCode'], 200), 'fetched', 'failed')}\n"
                      },
                      "runAfter": {
                        "Get_Attachment": [
                          "Succeeded",
                          "Failed"
                        ]
                      }
                    }
                  },
                  "runAfter": {
                    "Compose_attachments_list": [
                      "Succeeded"
                    ]
                  }
                },
                "Get_Analysis_Report": {
                  "type": "Http",
                  "inputs": {
                    "method": "GET",
                    "uri": "@{parameters('API_Base_URL')}/api/v1/alerts/@{encodeURIComponent(variables('AlertRefId'))}/analysis_report",
                    "headers": {
                      "Accept": "application/json",
                      "Cookie": "access_token=@{parameters('API_Access_Token')}",
                      "X-Integration-Type": "Azure Sentinel",
                      "X-Integration-Version": "1.0"
                    }
                  },
                  "runAfter": {
                    "For_each_attachment": [
                      "Succeeded",
                      "Failed"
                    ]
                  }
                },
                "Set_AnalysisReport": {
                  "type": "SetVariable",
                  "inputs": {
                    "name": "AnalysisReport",
                    "value": "@{coalesce(string(body('Get_Analysis_Report')), 'No analysis report available')}"
                  },
                  "runAfter": {
                    "Get_Analysis_Report": [
                      "Succeeded",
                      "Failed"
                    ]
                  }
                }
              },
              "runAfter": {
                "Parse_incident_alerts": [
                  "Succeeded"
                ]
              }
            },
            "Add_attachments_comment": {
              "type": "ApiConnection",
              "inputs": {
                "host": {
                  "connection": {
                    "name": "@parameters('$connections')['azuresentinel']['connectionId']"
                  }
                },
                "method": "post",
                "body": {
                  "incidentArmId": "@triggerBody()?['object']?['id']",
                  "message": "<p><strong>CPEM Attachments &amp; Analysis Report:</strong><br><br><strong>Attachments:</strong><br>@{if(equals(variables('AttachmentResults'), ''), 'No attachments found.', variables('AttachmentResults'))}<br><br><strong>Analysis Report:</strong><br>@{variables('AnalysisReport')}</p>"
                },
                "path": "/Incidents/Comment"
              },
              "runAfter": {
                "For_each_alert": [
                  "Succeeded",
                  "Failed"
                ]
              }
            },
            "Update_incident_tags": {
              "type": "ApiConnection",
              "inputs": {
                "host": {
                  "connection": {
                    "name": "@parameters('$connections')['azuresentinel']['connectionId']"
                  }
                },
                "method": "put",
                "body": {
                  "incidentArmId": "@triggerBody()?['object']?['id']",
                  "tagsToAdd": {
                    "TagsToAdd": [
                      "argos-attachments-fetched"
                    ]
                  }
                },
                "path": "/Incidents"
              },
              "runAfter": {
                "Add_attachments_comment": [
                  "Succeeded"
                ]
              }
            }
          }
        },
        "parameters": {
          "$connections": {
            "value": {
              "azuresentinel": {
                "connectionId": "[resourceId('Microsoft.Web/connections', variables('AzureSentinelConnectionName'))]",
                "connectionName": "[variables('AzureSentinelConnectionName')]",
                "id": "[concat('/subscriptions/', subscription().subscriptionId, '/providers/Microsoft.Web/locations/', resourceGroup().location, '/managedApis/azuresentinel')]",
                "connectionProperties": {
                  "authentication": {
                    "type": "ManagedServiceIdentity"
                  }
                }
              }
            }
          },
          "API_Base_URL": {
            "value": "[parameters('API_Base_URL')]"
          },
          "API_Access_Token": {
            "value": "[parameters('API_Access_Token')]"
          }
        }
      }
    }
  ],
  "outputs": {}
}
