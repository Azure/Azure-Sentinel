{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "title": "Check Point Exposure Management - IOC Enrichment and Triage",
    "description": "When a new Microsoft Sentinel incident is created, this playbook enriches IOC entities (IPs, domains, file hashes, URLs) using the Check Point Exposure Management threat intelligence API and adds enrichment results as an incident comment.",
    "prerequisites": [
      "1. A valid Check Point Exposure Management API token and base URL.",
      "2. The Logic App Managed Identity must be granted Microsoft Sentinel Responder role on the resource group."
    ],
    "postDeployment": [
      "1. Grant the Logic App Managed Identity the **Microsoft Sentinel Responder** role.",
      "2. Configure an automation rule in Microsoft Sentinel to trigger this playbook on incident creation."
    ],
    "lastUpdateTime": "2026-02-25T00:00:00.000Z",
    "entities": [
      "IP",
      "FileHash",
      "DNS",
      "URL"
    ],
    "tags": [
      "Enrichment"
    ],
    "support": {
      "tier": "Partner",
      "name": "Check Point",
      "link": "https://cyberint.com/customer-support/"
    },
    "source": {
      "type": "solution",
      "name": "Check Point Exposure Management Alerts"
    },
    "author": {
      "name": "Check Point"
    },
    "releaseNotes": [
      {
        "version": "1.0.0",
        "title": "Check Point Exposure Management - IOC Enrichment and Triage",
        "notes": [
          "Initial version"
        ]
      }
    ]
  },
  "parameters": {
    "PlaybookName": {
      "type": "String",
      "defaultValue": "Check_Point_EM_IOCEnrichment",
      "metadata": {
        "description": "Name of the Logic App / Playbook"
      }
    },
    "API_Base_URL": {
      "type": "String",
      "metadata": {
        "description": "Base URL of the Check Point Exposure Management API (e.g. https://app.cyberint.io)"
      }
    },
    "API_Access_Token": {
      "type": "SecureString",
      "metadata": {
        "description": "API token for Check Point Exposure Management"
      }
    }
  },
  "variables": {
    "AzureSentinelConnectionName": "[concat('azuresentinel-', parameters('PlaybookName'))]",
    "workspace-location-inline": "[resourceGroup().location]"
  },
  "resources": [
    {
      "type": "Microsoft.Web/connections",
      "apiVersion": "2016-06-01",
      "name": "[variables('AzureSentinelConnectionName')]",
      "location": "[variables('workspace-location-inline')]",
      "kind": "V1",
      "properties": {
        "displayName": "[variables('AzureSentinelConnectionName')]",
        "parameterValueType": "Alternative",
        "api": {
          "id": "[concat('/subscriptions/', subscription().subscriptionId, '/providers/Microsoft.Web/locations/', resourceGroup().location, '/managedApis/azuresentinel')]"
        }
      }
    },
    {
      "type": "Microsoft.Logic/workflows",
      "apiVersion": "2017-07-01",
      "name": "[parameters('PlaybookName')]",
      "location": "[variables('workspace-location-inline')]",
      "identity": {
        "type": "SystemAssigned"
      },
      "tags": {
        "hidden-SentinelTemplateName": "Check_Point_EM_IOCEnrichment",
        "hidden-SentinelTemplateVersion": "1.2"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/connections', variables('AzureSentinelConnectionName'))]"
      ],
      "properties": {
        "state": "Enabled",
        "definition": {
          "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
          "contentVersion": "1.0.0.0",
          "parameters": {
            "$connections": {
              "type": "Object"
            },
            "API_Base_URL": {
              "defaultValue": "",
              "type": "String"
            },
            "API_Access_Token": {
              "defaultValue": "",
              "type": "SecureString"
            }
          },
          "triggers": {
            "Microsoft_Sentinel_incident": {
              "type": "ApiConnectionWebhook",
              "inputs": {
                "host": {
                  "connection": {
                    "name": "@parameters('$connections')['azuresentinel']['connectionId']"
                  }
                },
                "body": {
                  "callback_url": "@{listCallbackUrl()}"
                },
                "path": "/incident-creation"
              }
            }
          },
          "actions": {
            "Entities_-_Get_IPs": {
              "type": "ApiConnection",
              "inputs": {
                "host": {
                  "connection": {
                    "name": "@parameters('$connections')['azuresentinel']['connectionId']"
                  }
                },
                "method": "post",
                "body": "@triggerBody()?['object']?['properties']?['relatedEntities']",
                "path": "/entities/ip"
              },
              "runAfter": {}
            },
            "Entities_-_Get_FileHashes": {
              "type": "ApiConnection",
              "inputs": {
                "host": {
                  "connection": {
                    "name": "@parameters('$connections')['azuresentinel']['connectionId']"
                  }
                },
                "method": "post",
                "body": "@triggerBody()?['object']?['properties']?['relatedEntities']",
                "path": "/entities/filehash"
              },
              "runAfter": {}
            },
            "Entities_-_Get_DNS": {
              "type": "ApiConnection",
              "inputs": {
                "host": {
                  "connection": {
                    "name": "@parameters('$connections')['azuresentinel']['connectionId']"
                  }
                },
                "method": "post",
                "body": "@triggerBody()?['object']?['properties']?['relatedEntities']",
                "path": "/entities/dnsresolution"
              },
              "runAfter": {}
            },
            "Entities_-_Get_URLs": {
              "type": "ApiConnection",
              "inputs": {
                "host": {
                  "connection": {
                    "name": "@parameters('$connections')['azuresentinel']['connectionId']"
                  }
                },
                "method": "post",
                "body": "@triggerBody()?['object']?['properties']?['relatedEntities']",
                "path": "/entities/url"
              },
              "runAfter": {}
            },
            "Initialize_variable_-_EnrichmentComment": {
              "type": "InitializeVariable",
              "inputs": {
                "variables": [
                  {
                    "name": "EnrichmentComment",
                    "type": "string",
                    "value": ""
                  }
                ]
              },
              "runAfter": {
                "Entities_-_Get_IPs": [
                  "Succeeded"
                ],
                "Entities_-_Get_FileHashes": [
                  "Succeeded"
                ],
                "Entities_-_Get_DNS": [
                  "Succeeded"
                ],
                "Entities_-_Get_URLs": [
                  "Succeeded"
                ]
              }
            },
            "For_each_IP": {
              "type": "Foreach",
              "foreach": "@body('Entities_-_Get_IPs')?['IPs']",
              "actions": {
                "Enrich_IP": {
                  "type": "Http",
                  "inputs": {
                    "method": "GET",
                    "uri": "@{parameters('API_Base_URL')}/api/v1/file/ipv4/@{encodeURIComponent(items('For_each_IP')?['Address'])}",
                    "headers": {
                      "Accept": "application/json",
                      "Cookie": "access_token=@{parameters('API_Access_Token')}",
                      "X-Integration-Type": "Azure Sentinel",
                      "X-Integration-Version": "1.0"
                    }
                  },
                  "runAfter": {}
                },
                "Append_IP_result": {
                  "type": "AppendToStringVariable",
                  "inputs": {
                    "name": "EnrichmentComment",
                    "value": "<br><strong>IP: @{items('For_each_IP')?['Address']}</strong> \u2014 Verdict: @{json(string(body('Enrich_IP')))?['verdict']} | Confidence: @{json(string(body('Enrich_IP')))?['confidence']} | Malware Family: @{json(string(body('Enrich_IP')))?['malware_family']} | First Seen: @{json(string(body('Enrich_IP')))?['first_seen']}"
                  },
                  "runAfter": {
                    "Enrich_IP": [
                      "Succeeded"
                    ]
                  }
                }
              },
              "runAfter": {
                "Initialize_variable_-_EnrichmentComment": [
                  "Succeeded"
                ]
              }
            },
            "For_each_FileHash": {
              "type": "Foreach",
              "foreach": "@body('Entities_-_Get_FileHashes')?['Filehashes']",
              "actions": {
                "Enrich_FileHash": {
                  "type": "Http",
                  "inputs": {
                    "method": "GET",
                    "uri": "@{parameters('API_Base_URL')}/api/v1/file/sha256/@{encodeURIComponent(items('For_each_FileHash')?['Value'])}",
                    "headers": {
                      "Accept": "application/json",
                      "Cookie": "access_token=@{parameters('API_Access_Token')}",
                      "X-Integration-Type": "Azure Sentinel",
                      "X-Integration-Version": "1.0"
                    }
                  },
                  "runAfter": {}
                },
                "Append_FileHash_result": {
                  "type": "AppendToStringVariable",
                  "inputs": {
                    "name": "EnrichmentComment",
                    "value": "<br><strong>Hash: @{items('For_each_FileHash')?['Value']}</strong> \u2014 Verdict: @{json(string(body('Enrich_FileHash')))?['verdict']} | Confidence: @{json(string(body('Enrich_FileHash')))?['confidence']} | Malware Family: @{json(string(body('Enrich_FileHash')))?['malware_family']} | Actor: @{json(string(body('Enrich_FileHash')))?['actor_attribution']}"
                  },
                  "runAfter": {
                    "Enrich_FileHash": [
                      "Succeeded"
                    ]
                  }
                }
              },
              "runAfter": {
                "For_each_IP": [
                  "Succeeded"
                ]
              }
            },
            "For_each_Domain": {
              "type": "Foreach",
              "foreach": "@body('Entities_-_Get_DNS')?['DNSresolutions']",
              "actions": {
                "Enrich_Domain": {
                  "type": "Http",
                  "inputs": {
                    "method": "GET",
                    "uri": "@{parameters('API_Base_URL')}/api/v1/file/domain/@{encodeURIComponent(items('For_each_Domain')?['DomainName'])}",
                    "headers": {
                      "Accept": "application/json",
                      "Cookie": "access_token=@{parameters('API_Access_Token')}",
                      "X-Integration-Type": "Azure Sentinel",
                      "X-Integration-Version": "1.0"
                    }
                  },
                  "runAfter": {}
                },
                "Append_Domain_result": {
                  "type": "AppendToStringVariable",
                  "inputs": {
                    "name": "EnrichmentComment",
                    "value": "<br><strong>Domain: @{items('For_each_Domain')?['DomainName']}</strong> \u2014 Verdict: @{json(string(body('Enrich_Domain')))?['verdict']} | Confidence: @{json(string(body('Enrich_Domain')))?['confidence']} | Malware Family: @{json(string(body('Enrich_Domain')))?['malware_family']}"
                  },
                  "runAfter": {
                    "Enrich_Domain": [
                      "Succeeded"
                    ]
                  }
                }
              },
              "runAfter": {
                "For_each_FileHash": [
                  "Succeeded"
                ]
              }
            },
            "For_each_URL": {
              "type": "Foreach",
              "foreach": "@body('Entities_-_Get_URLs')?['URLs']",
              "actions": {
                "Enrich_URL": {
                  "type": "Http",
                  "inputs": {
                    "method": "GET",
                    "uri": "@{parameters('API_Base_URL')}/api/v1/file/url",
                    "headers": {
                      "Accept": "application/json",
                      "Cookie": "access_token=@{parameters('API_Access_Token')}",
                      "X-Integration-Type": "Azure Sentinel",
                      "X-Integration-Version": "1.0"
                    },
                    "queries": {
                      "value": "@{items('For_each_URL')?['Url']}"
                    }
                  },
                  "runAfter": {}
                },
                "Append_URL_result": {
                  "type": "AppendToStringVariable",
                  "inputs": {
                    "name": "EnrichmentComment",
                    "value": "<br><strong>URL: @{items('For_each_URL')?['Url']}</strong> \u2014 Verdict: @{json(string(body('Enrich_URL')))?['verdict']} | Confidence: @{json(string(body('Enrich_URL')))?['confidence']} | Malware Family: @{json(string(body('Enrich_URL')))?['malware_family']}"
                  },
                  "runAfter": {
                    "Enrich_URL": [
                      "Succeeded"
                    ]
                  }
                }
              },
              "runAfter": {
                "For_each_Domain": [
                  "Succeeded"
                ]
              }
            },
            "Add_comment_to_incident": {
              "type": "ApiConnection",
              "inputs": {
                "host": {
                  "connection": {
                    "name": "@parameters('$connections')['azuresentinel']['connectionId']"
                  }
                },
                "method": "post",
                "body": {
                  "incidentArmId": "@triggerBody()?['object']?['id']",
                  "message": "<p><strong>CPEM IOC Enrichment Results:</strong><br>@{variables('EnrichmentComment')}</p>"
                },
                "path": "/Incidents/Comment"
              },
              "runAfter": {
                "For_each_URL": [
                  "Succeeded"
                ]
              }
            }
          }
        },
        "parameters": {
          "$connections": {
            "value": {
              "azuresentinel": {
                "connectionId": "[resourceId('Microsoft.Web/connections', variables('AzureSentinelConnectionName'))]",
                "connectionName": "[variables('AzureSentinelConnectionName')]",
                "id": "[concat('/subscriptions/', subscription().subscriptionId, '/providers/Microsoft.Web/locations/', resourceGroup().location, '/managedApis/azuresentinel')]",
                "connectionProperties": {
                  "authentication": {
                    "type": "ManagedServiceIdentity"
                  }
                }
              }
            }
          },
          "API_Base_URL": {
            "value": "[parameters('API_Base_URL')]"
          },
          "API_Access_Token": {
            "value": "[parameters('API_Access_Token')]"
          }
        }
      }
    }
  ],
  "outputs": {}
}
