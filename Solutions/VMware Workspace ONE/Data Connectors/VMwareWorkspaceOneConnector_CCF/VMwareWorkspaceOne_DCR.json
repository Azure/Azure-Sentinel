{
  "name": "VMwareWorkspaceOneDCR",
  "apiVersion": "2022-06-01",
  "type": "Microsoft.Insights/dataCollectionRules",
  "location": "{{location}}",
  "properties": {
    "dataCollectionEndpointId": "{{dataCollectionEndpointId}}",
    "streamDeclarations": {
      "Custom-VMwareWorkspaceOneDevices_CL": {
        "columns": [
          {
            "name": "Uuid",
            "type": "string"
          },
          {
            "name": "SerialNumber",
            "type": "string"
          },
          {
            "name": "MacAddress",
            "type": "string"
          },
          {
            "name": "Imei",
            "type": "string"
          },
          {
            "name": "AssetNumber",
            "type": "string"
          },
          {
            "name": "DeviceFriendlyName",
            "type": "string"
          },
          {
            "name": "Platform",
            "type": "string"
          },
          {
            "name": "OperatingSystem",
            "type": "string"
          },
          {
            "name": "PhoneNumber",
            "type": "string"
          },
          {
            "name": "EnrollmentStatus",
            "type": "string"
          },
          {
            "name": "ComplianceStatus",
            "type": "string"
          },
          {
            "name": "CompromisedStatus",
            "type": "boolean"
          },
          {
            "name": "LastSeen",
            "type": "datetime"
          },
          {
            "name": "LastEnrolledOn",
            "type": "datetime"
          },
          {
            "name": "LastComplianceCheck",
            "type": "datetime"
          },
          {
            "name": "UserEmailAddress",
            "type": "string"
          },
          {
            "name": "Ownership",
            "type": "string"
          },
          {
            "name": "DataProtectionStatus",
            "type": "int"
          },
          {
            "name": "TotalPhysicalMemory",
            "type": "long"
          },
          {
            "name": "AvailablePhysicalMemory",
            "type": "long"
          },
          {
            "name": "BatteryLevel",
            "type": "string"
          },
          {
            "name": "IsDeviceDNDEnabled",
            "type": "boolean"
          },
          {
            "name": "IsDeviceLocatorEnabled",
            "type": "boolean"
          },
          {
            "name": "WifiSsid",
            "type": "string"
          },
          {
            "name": "IsRoaming",
            "type": "boolean"
          },
          {
            "name": "Id",
            "type": "dynamic"
          },
          {
            "name": "ModelId",
            "type": "dynamic"
          },
          {
            "name": "OwnerId",
            "type": "dynamic"
          },
          {
            "name": "LocationGroupId",
            "type": "dynamic"
          }
        ]
      },
      "Custom-VMwareWorkspaceOneDeviceApps_CL": {
        "columns": [
          {
            "name": "device_id",
            "type": "string"
          },
          {
            "name": "name",
            "type": "string"
          },
          {
            "name": "installed_version",
            "type": "string"
          },
          {
            "name": "bundle_id",
            "type": "string"
          },
          {
            "name": "installed_status",
            "type": "string"
          },
          {
            "name": "assignment_status",
            "type": "string"
          },
          {
            "name": "latest_uem_action",
            "type": "string"
          },
          {
            "name": "latest_uem_action_time",
            "type": "datetime"
          },
          {
            "name": "size",
            "type": "long"
          }
        ]
      }
    },
    "destinations": {
      "logAnalytics": [
        {
          "workspaceResourceId": "{{workspaceResourceId}}",
          "name": "clv2ws1"
        }
      ]
    },
    "dataFlows": [
      {
        "streams": [
          "Custom-VMwareWorkspaceOneDevices_CL"
        ],
        "destinations": [
          "clv2ws1"
        ],
        "outputStream": "Custom-VMwareWorkspaceOneDevices_CL",
        "transformKql": "source  | project TimeGenerated=iff(isnull(['LastSeen']),now(),todatetime(['LastSeen'])),DeviceId=tostring(Id.Id),DeviceUuid=tostring(Uuid),SerialNumber=tostring(SerialNumber),MacAddress=tostring(MacAddress),Imei=tostring(Imei),AssetNumber=tostring(AssetNumber),DeviceFriendlyName=tostring(DeviceFriendlyName),Platform=tostring(Platform),Model=tostring(ModelId.Name),OperatingSystem=tostring(OperatingSystem),PhoneNumber=tostring(PhoneNumber),EnrollmentStatus=tostring(EnrollmentStatus),ComplianceStatus=tostring(ComplianceStatus),CompromisedStatus=tobool(CompromisedStatus),LastSeen=todatetime(LastSeen),LastEnrolledOn=todatetime(LastEnrolledOn),LastComplianceCheck=todatetime(LastComplianceCheck),OwnerName=tostring(OwnerId.Name),UserEmailAddress=tostring(UserEmailAddress),LocationGroupName=tostring(LocationGroupId.Name),Ownership=tostring(Ownership),DataProtectionStatus=toint(DataProtectionStatus),TotalPhysicalMemory=tolong(TotalPhysicalMemory),AvailablePhysicalMemory=tolong(AvailablePhysicalMemory),BatteryLevel=tostring(BatteryLevel),IsDeviceDNDEnabled=tobool(IsDeviceDNDEnabled),IsDeviceLocatorEnabled=tobool(IsDeviceLocatorEnabled),WifiSsid=tostring(WifiSsid),IsRoaming=tobool(IsRoaming)"
      },
      {
        "streams": [
          "Custom-VMwareWorkspaceOneDeviceApps_CL"
        ],
        "destinations": [
          "clv2ws1"
        ],
        "outputStream": "Custom-VMwareWorkspaceOneDeviceApps_CL",
        "transformKql": "source  | project TimeGenerated=iff(isnull(['latest_uem_action_time']),now(),todatetime(['latest_uem_action_time'])),DeviceId=tostring(device_id),ApplicationName=tostring(name),AppVersion=tostring(installed_version),BundleId=tostring(bundle_id),InstallStatus=tostring(installed_status),AssignmentStatus=tostring(assignment_status),LatestUemAction=tostring(latest_uem_action),LatestUemActionTime=todatetime(latest_uem_action_time),SizeInBytes=tolong(size)"
      }
    ]
  }
}