[
  {
    "type": "Microsoft.SecurityInsights/dataConnectors",
    "apiVersion": "2024-09-01",
    "name": "[[concat('parameters('workspace')', '/Microsoft.SecurityInsights/','VMwareWorkspaceOneDevices_CL' , uniqueString(parameters('friendlyName')) )]",
    "location": "[parameters('workspace-location')]",
    "kind": "RestApiPoller",
    "properties": {
      "auth": {
        "type": "OAuth2",
        "ClientId": "[[parameters('clientId')]",
        "ClientSecret": "[[parameters('clientSecret')]",
        "GrantType": "client_credentials",
        "TokenEndpoint": "[[concat(parameters('authUrl'), '/connect/token')]",
        "TokenEndpointHeaders": {
          "Authorization": "[[concat('Basic ', base64(concat(parameters('clientId'), ':', parameters('clientSecret'))))]",
          "Content-Type": "application/x-www-form-urlencoded"
        }
      },
      "request": {
        "apiEndpoint": "[[concat(parameters('instanceUrl'), '/api/mdm/devices/search')]",
        "httpMethod": "GET",
        "rateLimitQPS": 1,
        "queryWindowInMin": 1440,
        "retryCount": 3,
        "timeoutInSeconds": 30,
        "headers": {
          "Accept": "application/json;version=2",
          "Content-Type": "application/json"
        }
      },
      "response": {
        "eventsJsonPaths": [
          "$.Devices[*]"
        ],
        "format": "json"
      },
      "paging": {
        "pagingType": "CountBasedPaging",
        "pageNumberParaName": "page",
        "zeroBasedIndexing": true,
        "pageSize": 500
      },
      "connectorDefinitionName": "VMwareWorkspaceOneConnector",
      "dataType": "VMwareWorkspaceOneDevices_CL",
      "dcrConfig": {
        "streamName": "Custom-VMwareWorkspaceOneDevices_CL",
        "dataCollectionEndpoint": "{{dataCollectionEndpoint}}",
        "dataCollectionRuleImmutableId": "{{dataCollectionRuleImmutableId}}"
      },
      "addOnAttributes": {
        "friendlyName": "[[parameters('friendlyName')]",
        "instanceUrl": "[[parameters('instanceUrl')]"
      }
    }
  },
  {
    "type": "Microsoft.SecurityInsights/dataConnectors",
    "apiVersion": "2024-09-01",
    "name": "[[concat('parameters('workspace')', '/Microsoft.SecurityInsights/','VMwareWorkspaceOneDeviceApps_CL' , uniqueString(parameters('friendlyName')) )]",
    "location": "[parameters('workspace-location')]",
    "kind": "RestApiPoller",
    "properties": {
      "auth": {
        "type": "OAuth2",
        "ClientId": "[[parameters('clientId')]",
        "ClientSecret": "[[parameters('clientSecret')]",
        "GrantType": "client_credentials",
        "TokenEndpoint": "[[concat(parameters('authUrl'), '/connect/token')]",
        "TokenEndpointHeaders": {
          "Authorization": "[[concat('Basic ', base64(concat(parameters('clientId'), ':', parameters('clientSecret'))))]",
          "Content-Type": "application/x-www-form-urlencoded"
        }
      },
      "request": {
        "apiEndpoint": "[[concat(parameters('instanceUrl'), '/api/mdm/devices/search')]",
        "httpMethod": "GET",
        "rateLimitQPS": 1,
        "queryWindowInMin": 1440,
        "retryCount": 3,
        "timeoutInSeconds": 30,
        "headers": {
          "Accept": "application/json;version=2",
          "Content-Type": "application/json"
        }
      },
      "response": {
        "eventsJsonPaths": [
          "$"
        ],
        "format": "json"
      },
      "paging": {
        "pagingType": "CountBasedPaging",
        "pageNumberParaName": "page",
        "zeroBasedIndexing": true,
        "pageSize": 500
      },
      "stepInfo": {
        "stepType": "Nested",
        "nextSteps": [
          {
            "stepId": "fetchAppsForDevice",
            "stepPlaceholdersParsingKql": "source | project res = parse_json(data) | project devices = res['Devices'] | mvexpand devices | project device_id = tostring(devices['Uuid'])"
          }
        ]
      },
      "stepCollectorConfigs": {
        "fetchAppsForDevice": {
          "shouldJoinNestedData": false,
          "request": {
            "apiEndpoint": "[[concat(parameters('instanceUrl'), '/api/mdm/devices/$device_id$/apps/search')]",
            "httpMethod": "GET",
            "rateLimitQPS": 1,
            "queryWindowInMin": 5,
            "retryCount": 3,
            "timeoutInSeconds": 30,
            "headers": {
              "Accept": "application/json;version=2",
              "Content-Type": "application/json"
            },
            "queryParametersTemplate": "{'pagesize': '500', 'page': '0', 'type': 'All'}"
          },
          "response": {
            "eventsJsonPaths": [
              "$.app_items[*]"
            ],
            "format": "json"
          },
          "paging": {
            "pagingType": "CountBasedPaging",
            "pageNumberParaName": "page",
            "zeroBasedIndexing": true,
            "pageSize": 500
          }
        }
      },
      "connectorDefinitionName": "VMwareWorkspaceOneConnector",
      "dataType": "VMwareWorkspaceOneDeviceApps_CL",
      "dcrConfig": {
        "streamName": "Custom-VMwareWorkspaceOneDeviceApps_CL",
        "dataCollectionEndpoint": "{{dataCollectionEndpoint}}",
        "dataCollectionRuleImmutableId": "{{dataCollectionRuleImmutableId}}"
      },
      "addOnAttributes": {
        "friendlyName": "[[parameters('friendlyName')]",
        "instanceUrl": "[[parameters('instanceUrl')]",
        "device_id": "$device_id$"
      }
    },
    "condition": "[[contains(parameters('collectAppsDetails'), 'true')]"
  }
]