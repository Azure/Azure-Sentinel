{
  "name": "Unifi_Syslog_CL",
  "type": "Microsoft.OperationalInsights/workspaces/tables",
  "apiVersion": "2021-03-01-privatepreview",
  "tags": {},
  "properties": {
    "plan": "Analytics",
    "schema": {
      "name": "Unifi_Syslog_CL",
      "columns": [
        { "name": "TimeGenerated",        "type": "datetime", "description": "Event ingestion time" },
        { "name": "EventTime",            "type": "datetime", "description": "Original event timestamp parsed from the syslog header" },
        { "name": "Computer",             "type": "string",   "description": "Source host emitting the event" },
        { "name": "Facility",             "type": "string",   "description": "Syslog facility name (kern, daemon, auth, etc.)" },
        { "name": "SyslogSeverity",       "type": "string",   "description": "Syslog severity" },
        { "name": "ProcessName",          "type": "string",   "description": "Process or daemon name" },
        { "name": "SourceIP",             "type": "string",   "description": "Source IP extracted from the event payload" },
        { "name": "SourcePort",           "type": "int",      "description": "Source port" },
        { "name": "SourceUserName",       "type": "string",   "description": "Source user account name" },
        { "name": "DestinationIP",        "type": "string",   "description": "Destination IP" },
        { "name": "DestinationPort",      "type": "int",      "description": "Destination port" },
        { "name": "DestinationUserName",  "type": "string",   "description": "Destination user account name" },
        { "name": "Protocol",             "type": "string",   "description": "Transport protocol" },
        { "name": "DeviceAction",         "type": "string",   "description": "Action taken" },
        { "name": "DeviceEventCategory",  "type": "string",   "description": "Event category" },
        { "name": "Message",              "type": "string",   "description": "Original message payload" },
        { "name": "RawJson",              "type": "dynamic",  "description": "Forensic JSON dump of fields not promoted to columns" }
      ]
    },
    "retentionInDays": 90
  }
}
