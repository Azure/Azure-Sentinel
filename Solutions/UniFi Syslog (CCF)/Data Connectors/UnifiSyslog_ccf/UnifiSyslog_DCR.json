{
  "name": "UnifiSyslogDCR",
  "apiVersion": "2023-03-11",
  "type": "Microsoft.Insights/dataCollectionRules",
  "location": "{{location}}",
  "properties": {
    "dataCollectionEndpointId": "{{dataCollectionEndpointId}}",
    "streamDeclarations": {
      "Custom-Unifi_CL": {
        "columns": [
          {
            "name": "EventTime",
            "type": "datetime"
          },
          {
            "name": "Computer",
            "type": "string"
          },
          {
            "name": "Facility",
            "type": "string"
          },
          {
            "name": "SyslogSeverity",
            "type": "string"
          },
          {
            "name": "ProcessName",
            "type": "string"
          },
          {
            "name": "CEFVersion",
            "type": "string"
          },
          {
            "name": "DeviceVendor",
            "type": "string"
          },
          {
            "name": "DeviceProduct",
            "type": "string"
          },
          {
            "name": "DeviceVersion",
            "type": "string"
          },
          {
            "name": "DeviceEventClassID",
            "type": "string"
          },
          {
            "name": "Activity",
            "type": "string"
          },
          {
            "name": "LogSeverity",
            "type": "string"
          },
          {
            "name": "SourceIP",
            "type": "string"
          },
          {
            "name": "SourcePort",
            "type": "string"
          },
          {
            "name": "SourceUserName",
            "type": "string"
          },
          {
            "name": "SourceMACAddress",
            "type": "string"
          },
          {
            "name": "SourceHostName",
            "type": "string"
          },
          {
            "name": "DestinationIP",
            "type": "string"
          },
          {
            "name": "DestinationPort",
            "type": "string"
          },
          {
            "name": "DestinationMACAddress",
            "type": "string"
          },
          {
            "name": "DeviceMacAddress",
            "type": "string"
          },
          {
            "name": "DeviceAddress",
            "type": "string"
          },
          {
            "name": "DeviceName",
            "type": "string"
          },
          {
            "name": "DeviceInboundInterface",
            "type": "string"
          },
          {
            "name": "DeviceOutboundInterface",
            "type": "string"
          },
          {
            "name": "ApplicationProtocol",
            "type": "string"
          },
          {
            "name": "DestinationServiceName",
            "type": "string"
          },
          {
            "name": "DestinationUserName",
            "type": "string"
          },
          {
            "name": "Protocol",
            "type": "string"
          },
          {
            "name": "DeviceAction",
            "type": "string"
          },
          {
            "name": "DeviceEventCategory",
            "type": "string"
          },
          {
            "name": "Message",
            "type": "string"
          },
          {
            "name": "ReceiptTime",
            "type": "string"
          },
          {
            "name": "StartTime",
            "type": "string"
          },
          {
            "name": "EndTime",
            "type": "string"
          },
          {
            "name": "Outcome",
            "type": "string"
          },
          {
            "name": "ExternalID",
            "type": "string"
          },
          {
            "name": "DeviceCustomString1",
            "type": "string"
          },
          {
            "name": "DeviceCustomString2",
            "type": "string"
          },
          {
            "name": "DeviceCustomString3",
            "type": "string"
          },
          {
            "name": "DeviceCustomString4",
            "type": "string"
          },
          {
            "name": "DeviceCustomString5",
            "type": "string"
          },
          {
            "name": "DeviceCustomString6",
            "type": "string"
          },
          {
            "name": "DeviceCustomNumber1",
            "type": "string"
          },
          {
            "name": "MaliciousIP",
            "type": "string"
          },
          {
            "name": "ThreatSeverity",
            "type": "string"
          },
          {
            "name": "IndicatorThreatType",
            "type": "string"
          },
          {
            "name": "ThreatDescription",
            "type": "string"
          },
          {
            "name": "ThreatConfidence",
            "type": "string"
          },
          {
            "name": "ReportReferenceLink",
            "type": "string"
          },
          {
            "name": "MaliciousIPCountry",
            "type": "string"
          },
          {
            "name": "MaliciousIPLatitude",
            "type": "string"
          },
          {
            "name": "MaliciousIPLongitude",
            "type": "string"
          },
          {
            "name": "EventFormat",
            "type": "string"
          },
          {
            "name": "cef",
            "type": "dynamic"
          },
          {
            "name": "rawJson",
            "type": "dynamic"
          },
          {
            "name": "tags",
            "type": "dynamic"
          }
        ]
      }
    },
    "destinations": {
      "logAnalytics": [
        {
          "workspaceResourceId": "{{workspaceResourceId}}",
          "name": "sentinelWorkspace"
        }
      ]
    },
    "dataFlows": [
      {
        "streams": [
          "Custom-Unifi_CL"
        ],
        "destinations": [
          "sentinelWorkspace"
        ],
        "transformKql": "source | where EventFormat == 'cef' | extend TimeGenerated = iff(isnotnull(EventTime), todatetime(EventTime), now()) | extend AdditionalExtensions = tostring(cef) | project TimeGenerated, DeviceVendor, DeviceProduct, DeviceVersion, DeviceEventClassID, Activity, LogSeverity = tostring(LogSeverity), OriginalLogSeverity = case(toint(LogSeverity) >= 9, 'Very-High', toint(LogSeverity) >= 7, 'High', toint(LogSeverity) >= 4, 'Medium', isnotempty(LogSeverity), 'Low', ''), SourceIP, SourcePort = iff(isnotempty(SourcePort), toint(SourcePort), int(null)), SourceUserName, SourceMACAddress, SourceHostName, DestinationIP, DestinationPort = iff(isnotempty(DestinationPort), toint(DestinationPort), int(null)), DestinationUserName, DestinationMACAddress, DeviceMacAddress, DeviceAddress, DeviceName, DeviceInboundInterface, DeviceOutboundInterface, ApplicationProtocol, DestinationServiceName, Protocol, DeviceAction, DeviceEventCategory, Message, ReceiptTime, EventOutcome = Outcome, DeviceCustomString1, DeviceCustomString2, DeviceCustomString3, DeviceCustomString4, DeviceCustomString5, DeviceCustomString6, DeviceCustomNumber1 = iff(isnotempty(DeviceCustomNumber1), toint(DeviceCustomNumber1), int(null)), MaliciousIP, ThreatSeverity = iff(isnotempty(ThreatSeverity), toint(ThreatSeverity), int(null)), IndicatorThreatType, ThreatDescription, ThreatConfidence, ReportReferenceLink, MaliciousIPCountry, MaliciousIPLatitude = iff(isnotempty(MaliciousIPLatitude), toreal(MaliciousIPLatitude), real(null)), MaliciousIPLongitude = iff(isnotempty(MaliciousIPLongitude), toreal(MaliciousIPLongitude), real(null)), AdditionalExtensions, Computer",
        "outputStream": "Microsoft-CommonSecurityLog"
      },
      {
        "streams": [
          "Custom-Unifi_CL"
        ],
        "destinations": [
          "sentinelWorkspace"
        ],
        "transformKql": "source | where EventFormat != 'cef' or isnull(EventFormat) | extend TimeGenerated = iff(isnotnull(EventTime), todatetime(EventTime), now()) | extend RawJson = rawJson | project TimeGenerated, EventTime, Computer, Facility, SyslogSeverity, ProcessName, SourceIP, SourcePort = iff(isnotempty(SourcePort), toint(SourcePort), int(null)), SourceUserName, DestinationIP, DestinationPort = iff(isnotempty(DestinationPort), toint(DestinationPort), int(null)), DestinationUserName, Protocol, DeviceAction, DeviceEventCategory, Message, RawJson",
        "outputStream": "Custom-Unifi_Syslog_CL"
      }
    ]
  }
}