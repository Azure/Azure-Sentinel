{
  "id": "f7b1a3c2-9e8d-4b5a-bc6f-1a2b3c4d5e6f",
  "name": "UnifiSyslogPushConnectorPolling",
  "apiVersion": "2023-02-01-preview",
  "type": "Microsoft.SecurityInsights/dataConnectors",
  "kind": "Push",
  "properties": {
    "connectorDefinitionName": "UnifiSyslogCCF",
    "dcrConfig": {
      "streamName": "Custom-Unifi_CL",
      "dataCollectionEndpoint": "{{dataCollectionEndpoint}}",
      "dataCollectionRuleImmutableId": "{{dataCollectionRuleImmutableId}}"
    },
    "auth": {
      "type": "Push",
      "AppId": "{{appId}}",
      "ServicePrincipalId": "{{servicePrincipalId}}"
    },
    "request": {
      "RetryCount": 1
    },
    "response": {
      "eventsJsonPaths": [
        "$"
      ]
    }
  }
}
