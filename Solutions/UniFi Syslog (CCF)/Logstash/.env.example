# Example .env for the UniFi Syslog Logstash relay (CCF Push).
#
# How to populate:
# 1. Install the "UniFi Syslog (CCF)" Solution from Microsoft Sentinel Content Hub.
# 2. Open Sentinel -> Data Connectors -> UniFi Syslog (CCF Push) (Preview).
# 3. Click "Deploy UniFi Syslog Push connector resources". Sentinel auto-creates:
#      - Entra application + client secret
#      - Data Collection Endpoint (DCE)
#      - Data Collection Rule (DCR)
#      - Unifi_Syslog_CL custom log table
#      - Monitoring Metrics Publisher role assignment on the DCR
# 4. Five CopyableLabel fields populate on the connector page. Copy each into
#    the matching variable below. The Client Secret is shown ONLY ONCE -
#    capture it now.
# 5. Drop this file as `.env` next to docker-compose.yml on your Logstash host.
# 6. `docker compose build --no-cache && docker compose up -d`

SENTINEL_TENANT_ID=<your-entra-tenant-id>
SENTINEL_CLIENT_APP_ID=<auto-generated-app-id-from-deploy-push-button>
SENTINEL_CLIENT_APP_SECRET=<one-time-secret-from-the-connector-card>
SENTINEL_DCE_URL=https://<dce-name>-<suffix>.<region>.ingest.monitor.azure.com
SENTINEL_DCR_IMMUTABLE_ID=dcr-<hex-32-chars>
SENTINEL_DCR_STREAM_NAME=Custom-Unifi_CL

# Optional - MaxMind GeoLite2 license for ingest-time geo + ASN enrichment.
# Sign up free at https://www.maxmind.com/en/geolite2/signup
# Without these, MaliciousIPCountry / DeviceCustomString3 (geo) and
# DeviceCustomString4 / DeviceCustomNumber1 (ASN) columns stay empty.
MAXMIND_ACCOUNT_ID=<your-maxmind-account-id>
MAXMIND_LICENSE_KEY=<your-maxmind-license-key>

# Optional - dump every parsed event to `docker logs` for tuning / debugging.
# Set to "true" to enable. Leave OFF in production (100+ MB/hr log volume).
ENABLE_STDOUT_RUBYDEBUG=false
