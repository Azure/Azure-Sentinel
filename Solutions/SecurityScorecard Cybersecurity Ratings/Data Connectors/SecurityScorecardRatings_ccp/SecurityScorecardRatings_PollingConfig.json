[
    {
        "name": "SecurityScorecardRatingsPoller",
        "apiVersion": "2024-09-01",
        "type": "Microsoft.SecurityInsights/dataConnectors",
        "location": "{{location}}",
        "kind": "RestApiPoller",
        "properties": {
            "connectorDefinitionName": "SecurityScorecardRatingsCCPDefinition",
            "dataType": "SecurityScorecardRatingsHistory_CL",
            "addOnAttributes": {
                "portfolio_id": "$portfolio_id$",
                "portfolio_name": "$portfolio_name$"
            },
            "dcrConfig": {
                "streamName": "Custom-SecurityScorecardRatingsHistory_CL",
                "dataCollectionEndpoint": "{{dataCollectionEndpoint}}",
                "dataCollectionRuleImmutableId": "{{dataCollectionRuleImmutableId}}"
            },
            "auth": {
                "type": "APIKey",
                "ApiKey": "{{ApiToken}}",
                "ApiKeyName": "Authorization",
                "ApiKeyIdentifier": "Token"
            },
            "request": {
                "apiEndpoint": "{{BaseUrl}}/portfolios",
                "httpMethod": "GET",
                "rateLimitQPS": 1,
                "retryCount": 3,
                "timeoutInSeconds": 60,
                "logResponseContent": true,
                "headers": {
                    "Content-Type": "application/json",
                    "Accept": "application/json; charset=utf-8",
                    "X-SSC-Application-Name": "Microsoft Sentinel",
                    "X-SSC-Application-Version": "1.0"
                }
            },
            "response": {
                "format": "json",
                "eventsJsonPaths": [
                    "$.entries"
                ]
            },
            "stepInfo": {
                "stepType": "Nested",
                "nextSteps": [
                    {
                        "stepId": "portfolioCompanies",
                        "stepPlaceholdersParsingKql": "source | extend res = parse_json(data) | project portfolio_id = tostring(res['id']), portfolio_name = tostring(res['name'])"
                    }
                ]
            },
            "stepCollectorConfigs": {
                "portfolioCompanies": {
                    "request": {
                        "apiEndpoint": "{{BaseUrl}}/portfolios/$portfolio_id$/companies",
                        "httpMethod": "GET",
                        "rateLimitQPS": 1,
                        "retryCount": 3,
                        "timeoutInSeconds": 60,
                        "logResponseContent": true,
                        "headers": {
                            "Content-Type": "application/json",
                            "Accept": "application/json; charset=utf-8",
                            "X-SSC-Application-Name": "Microsoft Sentinel",
                            "X-SSC-Application-Version": "1.0"
                        }
                    },
                    "response": {
                        "format": "json",
                        "eventsJsonPaths": [
                            "$.entries"
                        ]
                    }
                }
            }
        }
    }
]
