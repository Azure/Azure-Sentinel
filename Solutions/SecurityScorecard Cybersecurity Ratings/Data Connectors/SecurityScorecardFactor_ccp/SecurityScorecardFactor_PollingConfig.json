[
    {
        "name": "SecurityScorecardFactorPoller",
        "apiVersion": "2024-09-01",
        "type": "Microsoft.SecurityInsights/dataConnectors",
        "location": "{{location}}",
        "kind": "RestApiPoller",
        "properties": {
            "connectorDefinitionName": "SecurityScorecardFactorCCPDefinition",
            "dataType": "SecurityScorecardFactorHistory_CL",
            "dcrConfig": {
                "streamName": "Custom-SecurityScorecardFactorHistory_CL",
                "dataCollectionEndpoint": "{{dataCollectionEndpoint}}",
                "dataCollectionRuleImmutableId": "{{dataCollectionRuleImmutableId}}"
            },
            "auth": {
                "type": "APIKey",
                "ApiKey": "{{ApiToken}}",
                "ApiKeyName": "Authorization",
                "ApiKeyIdentifier": "Token"
            },
            "request": {
                "apiEndpoint": "{{BaseUrl}}/portfolios",
                "httpMethod": "GET",
                "queryWindowInMin": 10080,
                "queryTimeFormat": "yyyy-MM-dd",
                "rateLimitQPS": 1,
                "retryCount": 3,
                "timeoutInSeconds": 60,
                "logResponseContent": true,
                "headers": {
                    "Content-Type": "application/json",
                    "Accept": "application/json; charset=utf-8",
                    "X-SSC-Application-Name": "Microsoft Sentinel",
                    "X-SSC-Application-Version": "1.0"
                }
            },
            "response": {
                "format": "json",
                "eventsJsonPaths": [
                    "$.entries"
                ]
            },
            "stepInfo": {
                "stepType": "Nested",
                "nextSteps": [
                    {
                        "stepId": "portfolioCompanies",
                        "stepPlaceholdersParsingKql": "source | extend res = parse_json(data) | project portfolio_id = tostring(res['id'])"
                    }
                ]
            },
            "stepCollectorConfigs": {
                "portfolioCompanies": {
                    "stepInfo": {
                        "stepType": "Nested",
                        "nextSteps": [
                            {
                                "stepId": "factorHistory",
                                "stepPlaceholdersParsingKql": "source | extend res = parse_json(data) | project company_domain = tostring(res['domain'])"
                            }
                        ]
                    },
                    "request": {
                        "apiEndpoint": "{{BaseUrl}}/portfolios/$portfolio_id$/companies",
                        "httpMethod": "GET",
                        "rateLimitQPS": 1,
                        "retryCount": 3,
                        "timeoutInSeconds": 60,
                        "logResponseContent": true,
                        "headers": {
                            "Content-Type": "application/json",
                            "Accept": "application/json; charset=utf-8",
                            "X-SSC-Application-Name": "Microsoft Sentinel",
                            "X-SSC-Application-Version": "1.0"
                        }
                    },
                    "response": {
                        "format": "json",
                        "eventsJsonPaths": [
                            "$.entries"
                        ]
                    }
                },
                "factorHistory": {
                    "request": {
                        "apiEndpoint": "{{BaseUrl}}/companies/$company_domain$/history/factors/score",
                        "httpMethod": "GET",
                        "queryWindowInMin": 10080,
                        "queryTimeFormat": "yyyy-MM-dd",
                        "rateLimitQPS": 1,
                        "retryCount": 3,
                        "timeoutInSeconds": 60,
                        "logResponseContent": true,
                        "headers": {
                            "Content-Type": "application/json",
                            "Accept": "application/json; charset=utf-8",
                            "X-SSC-Application-Name": "Microsoft Sentinel",
                            "X-SSC-Application-Version": "1.0"
                        },
                        "queryParameters": {
                            "from": "{_QueryWindowStartTime}",
                            "to": "{_QueryWindowEndTime}",
                            "timing": "daily"
                        }
                    },
                    "response": {
                        "format": "json",
                        "eventsJsonPaths": [
                            "$.entries"
                        ]
                    }
                }
            }
        }
    }
]
