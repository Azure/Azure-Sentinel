[
  {
    "name": "WithSecureElementsConnection",
    "apiVersion": "2022-12-01-preview",
    "type": "Microsoft.SecurityInsights/dataConnectors",
    "location": "{{location}}",
    "kind": "RestApiPoller",
    "properties": {
      "connectorDefinitionName": "WithSecureElementsCCF",
      "dataType": "WithSecure Elements security-events",
      "auth": {
        "type": "OAuth2",
        "ClientId": "{{ClientId}}",
        "ClientSecret": "{{ClientSecret}}",
        "GrantType": "client_credentials",
        "TokenEndpoint": "{{elementsApiUrl}}/as/token.oauth2",
        "TokenEndpointHeaders": {
          "Content-Type": "application/x-www-form-urlencoded",
          "Accept": "application/json",
          "Authorization": "[[concat('Basic ', base64(concat(parameters('ClientId'), ':', parameters('ClientSecret'))))]"
        },
        "Scope": "connect.api.read",
        "IsClientSecretInHeader": true
      },
      "request": {
        "apiEndpoint": "{{elementsApiUrl}}/security-events/v1/security-events",
        "httpMethod": "POST",
        "isPostPayloadJson": true,
        "queryWindowInMin": 5,
        "queryTimeFormat": "yyyy-MM-ddTHH:mm:ss.fffZ",
        "rateLimitQPS": 10,
        "retryCount": 3,
        "timeoutInSeconds": 60,
        "headers": {
          "Accept": "application/json",
          "User-Agent": "ccf-sentinel-connector"
        },
        "queryParametersTemplate": "[[concat('{\"limit\":100,\"order\":\"asc\",\"exclusiveStart\":true,\"persistenceTimestampStart\":\"{_QueryWindowStartTime}\",\"persistenceTimestampEnd\":\"{_QueryWindowEndTime}\",',if(or(empty(parameters('engine')),equals(parameters('engine'),'engine')),concat('\"engineGroup\":',string(split(if(or(empty(parameters('engineGroup')),equals(parameters('engineGroup'),'engineGroup')),'epp,edr,ecp,xm',parameters('engineGroup')),','))),concat('\"engine\":',string(split(parameters('engine'),',')))),'}')]"
      },
      "response": {
        "eventsJsonPaths": [
          "$.items"
        ],
        "format": "json"
      },
      "paging": {
        "pagingType": "NextPageToken",
        "nextPageTokenJsonPath": "$.nextAnchor",
        "nextPageParaName": "anchor"
      },
      "dcrConfig": {
        "dataCollectionEndpoint": "{{dataCollectionEndpoint}}",
        "dataCollectionRuleImmutableId": "{{dataCollectionRuleImmutableId}}",
        "streamName": "Custom-WsSecurityEventsRaw_CL"
      },
      "isActive": true
    }
  }
]
