{
  "name": "AWSELBConnectorDCR",
  "apiVersion": "2023-04-01-preview",
  "type": "Microsoft.Insights/dataCollectionRules",
  "location": "{{location}}",
  "properties": {
    "dataCollectionEndpointId": "{{dataCollectionEndpointId}}",
    "destinations": {
      "logAnalytics": [
        {
          "workspaceResourceId": "{{workspaceResourceId}}",
          "name": "clv2ws1"
        }
      ]
    },
    "dataFlows": [
      {
        "streams": [
          "Microsoft-AWSALBAccessLogs"
        ],
        "destinations": [
          "clv2ws1"
        ]
      },
      {
        "streams": [
          "Microsoft-AWSNLBAccessLogs"
        ],
        "destinations": [
          "clv2ws1"
        ]
      },
      {
        "streams": [
          "Microsoft-AWSNLBFlowLogsStream"
        ],
        "destinations": [
          "clv2ws1"
        ]
      },
      {
        "streams": [
          "Microsoft-AWSGLBFlowLogsStream"
        ],
        "destinations": [
          "clv2ws1"
        ]
      }
    ]
  }
}
