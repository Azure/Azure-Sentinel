<?xml version="1.0" encoding="utf-8"?>
<!--
  SECURITY: NuGet Package Source Mapping (NuGet 6.0+)
  
  Mitigates dependency-confusion / supply-chain attacks for private Veeam SDK packages.
  
  The packages below are NOT available on nuget.org:
    - Veeam.AC.VBR.ApiClient  (Veeam Backup & Replication API client SDK)
    - 00000000-94D5-4BF9-8A50-7BD9929A0850  (internal Veeam SDK package)
  
  Without this file NuGet would silently fall back to nuget.org for any unresolved
  package, allowing an attacker who registers either package name on the public registry
  to inject a malicious build-time payload.
  
  The <packageSourceMapping> block below explicitly restricts those packages to the
  "veeam-private" source, so NuGet will never look for them on nuget.org.
  
  BUILD CONFIGURATION:
  Before building this project, add the Veeam private NuGet feed to your environment.
  Options (choose one):
    a) Set the environment variable VEEAM_NUGET_FEED to the feed URL, then replace
       %VEEAM_NUGET_FEED% below with that value (do NOT commit credentials).
    b) Add the feed via the NuGet CLI:
         nuget sources add -Name veeam-private -Source <feed-url>
    c) Add the feed in your CI/CD pipeline's NuGet configuration or Service Connection.
-->
<configuration>
  <packageSources>
    <clear />
    <!-- Public feed – used only for packages explicitly mapped to it below -->
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <!-- Veeam private feed – required for Veeam.* and GUID-named internal packages.
         Replace the placeholder URL with the actual feed URL before building. -->
    <add key="veeam-private" value="%VEEAM_NUGET_FEED%" protocolVersion="3" />
  </packageSources>

  <!--
    Package Source Mapping: each pattern is bound to exactly one source.
    NuGet will NOT fall through to other sources if resolution fails.
    
    IMPORTANT: every package used by this solution must be listed here.
    Add new entries as new PackageReferences are introduced.
  -->
  <packageSourceMapping>
    <!-- Public packages resolved exclusively from nuget.org -->
    <packageSource key="nuget.org">
      <package pattern="Azure.*" />
      <package pattern="Microsoft.*" />
    </packageSource>

    <!-- Private Veeam SDK packages – NEVER resolved from nuget.org -->
    <packageSource key="veeam-private">
      <!-- Veeam Backup & Replication REST API client (referenced in Veeam.Sentinel.FunctionApp.csproj) -->
      <package pattern="Veeam.*" />
      <!-- Internal GUID-named Veeam SDK package (00000000-94D5-4BF9-8A50-7BD9929A0850) -->
      <package pattern="00000000-*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
