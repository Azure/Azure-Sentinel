[
  {
    "type": "Microsoft.SecurityInsights/dataConnectors",
    "apiVersion": "2022-10-01-preview",
    "name": "[[concat('parameters('workspace')', '/Microsoft.SecurityInsights/','OpenAIAuditLogs' , uniqueString(parameters('auditLogsFriendlyName')) )]",
    "location": "{{location}}",
    "kind": "RestApiPoller",
    "properties": {
      "auth": {
        "type": "APIKey",
        "ApiKey": "[[parameters('orgApiKey')]",
        "ApiKeyName": "Authorization",
        "ApiKeyIdentifier": "Bearer"
      },
      "request": {
        "apiEndpoint": "https://api.openai.com/v1/organization/audit_logs",
        "httpMethod": "GET",
        "rateLimitQPS": 5,
        "queryWindowInMin": 5,
        "queryTimeFormat": "UnixTimestamp",
        "retryCount": 3,
        "timeoutInSeconds": 45,
        "headers": {
          "Content-Type": "application/json",
          "Accept": "application/json"
        },
        "queryParameters": {
          "order": "asc",
          "effective_at[gte]": "{_QueryWindowStartTime}",
          "effective_at[lt]": "{_QueryWindowEndTime}"
        }
      },
      "response": {
        "eventsJsonPaths": [
          "$.data[*]"
        ],
        "format": "json"
      },
      "paging": {
        "pagingType": "NextPageToken",
        "nextPageTokenJsonPath": "$.last_id",
        "NextPageParaName": "after",
        "pageSize": 100,
        "pageSizeParameterName": "limit"
      },
      "connectorDefinitionName": "OpenAIConnector",
      "dataType": "OpenAIAuditLogs",
      "dcrConfig": {
        "streamName": "Custom-OpenAIAuditLogs_CL",
        "dataCollectionEndpoint": "{{dataCollectionEndpoint}}",
        "dataCollectionRuleImmutableId": "{{dataCollectionRuleImmutableId}}"
      },
      "extra": {
        "transformName": "/ASI/OpenAI/OpenAIAuditLogsTransformer"
      },
      "addOnAttributes": {
        "friendlyName": "[[parameters('auditLogsFriendlyName')]"
      }
    },
    "condition": "[[and(not(empty(parameters('orgApiKey'))), not(equals(parameters('orgApiKey'), 'orgApiKey')))]"
  },
  {
    "type": "Microsoft.SecurityInsights/dataConnectors",
    "apiVersion": "2022-10-01-preview",
    "name": "[[concat('parameters('workspace')', '/Microsoft.SecurityInsights/','OpenAIChatCompletions' , uniqueString(parameters('chatCompletionsFriendlyName')) )]",
    "location": "{{location}}",
    "kind": "RestApiPoller",
    "properties": {
      "auth": {
        "type": "APIKey",
        "ApiKey": "[[parameters('projApiKey')]",
        "ApiKeyName": "Authorization",
        "ApiKeyIdentifier": "Bearer"
      },
      "request": {
        "apiEndpoint": "https://api.openai.com/v1/chat/completions",
        "httpMethod": "GET",
        "rateLimitQPS": 5,
        "queryWindowInMin": 5,
        "queryTimeFormat": "UnixTimestamp",
        "retryCount": 3,
        "timeoutInSeconds": 45,
        "headers": {
          "Content-Type": "application/json",
          "Accept": "application/json"
        },
        "queryParameters": {
          "order": "asc"
        }
      },
      "response": {
        "eventsJsonPaths": [
          "$.data[*]"
        ],
        "format": "json"
      },
      "paging": {
        "pagingType": "PersistentToken",
        "nextPageTokenJsonPath": "$.last_id",
        "nextPageParaName": "after",
        "pageSize": 100,
        "pageSizeParameterName": "limit"
      },
      "connectorDefinitionName": "OpenAIConnector",
      "dataType": "OpenAIChatCompletions",
      "dcrConfig": {
        "streamName": "Custom-OpenAIChatCompletions_CL",
        "dataCollectionEndpoint": "{{dataCollectionEndpoint}}",
        "dataCollectionRuleImmutableId": "{{dataCollectionRuleImmutableId}}"
      },
      "addOnAttributes": {
        "friendlyName": "[[parameters('chatCompletionsFriendlyName')]"
      }
    },
    "condition": "[[and(not(empty(parameters('projApiKey'))), not(equals(parameters('projApiKey'), 'projApiKey')))]"
  }
]