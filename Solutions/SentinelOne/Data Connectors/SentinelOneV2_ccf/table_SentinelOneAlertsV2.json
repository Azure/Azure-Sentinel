{
  "name": "SentinelOneAlertsV2_CL",
  "type": "Microsoft.OperationalInsights/workspaces/tables",
  "apiVersion": "2022-10-01",
  "tags": {
    "StreamName": "Custom-SentinelOneAlertsV2_CL",
    "DataSource": "SentinelOneV2Connector",
    "Category": "SecurityEvents"
  },
  "properties": {
    "retentionInDays": 90,
    "schema": {
      "name": "SentinelOneAlertsV2_CL",
      "description": "SentinelOne Unified Alert Management alerts collected from the SentinelOne GraphQL API",
      "columns": [
        {
          "name": "TimeGenerated",
          "type": "datetime",
          "description": "The timestamp (in UTC) when the log entry was generated."
        },
        {
          "name": "AlertId",
          "type": "string",
          "description": "Unique identifier of the unified alert.",
          "dataTypeHint": "GUID"
        },
        {
          "name": "AlertName",
          "type": "string",
          "description": "Human-readable alert name."
        },
        {
          "name": "DetectedAt",
          "type": "datetime",
          "description": "Time the alert was detected."
        },
        {
          "name": "CreatedAt",
          "type": "datetime",
          "description": "Time the alert was created."
        },
        {
          "name": "UpdatedAt",
          "type": "datetime",
          "description": "Time the alert was last updated."
        },
        {
          "name": "Status",
          "type": "string",
          "description": "Current status of the alert."
        },
        {
          "name": "Severity",
          "type": "string",
          "description": "Severity of the alert."
        },
        {
          "name": "AnalystVerdict",
          "type": "string",
          "description": "Analyst verdict assigned to the alert."
        },
        {
          "name": "ExternalId",
          "type": "string",
          "description": "External identifier of the alert."
        },
        {
          "name": "StorylineId",
          "type": "string",
          "description": "Associated storyline identifier."
        },
        {
          "name": "AttackSurfaces",
          "type": "dynamic",
          "description": "Attack surfaces associated with the alert."
        },
        {
          "name": "ConfidenceLevel",
          "type": "string",
          "description": "Confidence level of the detection."
        },
        {
          "name": "Classification",
          "type": "string",
          "description": "Classification of the alert."
        },
        {
          "name": "Product",
          "type": "string",
          "description": "Detection source product."
        },
        {
          "name": "Vendor",
          "type": "string",
          "description": "Detection source vendor."
        },
        {
          "name": "AssigneeName",
          "type": "string",
          "description": "Full name of the assignee."
        },
        {
          "name": "AssigneeEmail",
          "type": "string",
          "description": "Email of the assignee."
        },
        {
          "name": "Assets",
          "type": "dynamic",
          "description": "Assets associated with the alert."
        },
        {
          "name": "DataSources",
          "type": "dynamic",
          "description": "Data sources associated with the alert."
        }
      ]
    }
  }
}