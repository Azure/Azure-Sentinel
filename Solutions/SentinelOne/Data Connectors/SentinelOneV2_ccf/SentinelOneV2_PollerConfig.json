    "apiVersion": "2022-10-01-preview",
    "name": "[[concat('parameters('workspace')', '/Microsoft.SecurityInsights/','SentinelOneAlertsV2_CL' , uniqueString(parameters('managementUrl')) )]",
    "location": "{{location}}",
    "kind": "RestApiPoller",
    "properties": {
      "auth": {
        "type": "APIKey",
        "ApiKey": "[[parameters('apitoken')]",
        "ApiKeyName": "Authorization",
        "ApiKeyIdentifier": "ApiToken"
      },
      "request": {
        "apiEndpoint": "[[concat(parameters('managementUrl'), '/web/api/','v2.1', '/', 'unifiedalerts/graphql')]",
        "httpMethod": "POST",
        "rateLimitQPS": 10,
        "queryWindowInMin": 5,
        "queryTimeFormat": "UnixTimestampInMills",
        "retryCount": 3,
        "timeoutInSeconds": 30,
        "isPostPayloadJson": true,
        "headers": {
          "Accept": "application/json",
          "Content-Type": "application/json",
          "User-Agent": "Scuba"
        },
        "queryParametersTemplate": "{\"query\":\"query listAlerts($filters:[FilterInput!],$sort:SortInput,$first:Int,$after:String){alerts(filters:$filters,sort:$sort,first:$first,after:$after){edges{cursor node{id name detectedAt createdAt updatedAt status severity analystVerdict externalId storylineId attackSurfaces confidenceLevel classification detectionSource{product vendor}assignee{fullName email}assets{id name agentUuid osType osVersion}dataSources}}pageInfo{hasNextPage hasPreviousPage startCursor endCursor}}}\",\"variables\":{\"filters\":[{\"fieldId\":\"detectedAt\",\"dateTimeRange\":{\"start\":{_QueryWindowStartTime},\"end\":{_QueryWindowEndTime}}}],\"sort\":{\"by\":\"detectedAt\",\"order\":\"DESC\"},\"first\":1000}}"
      },
      "response": {
        "eventsJsonPaths": [
          "$.data.alerts.edges[*].node"
        ],
        "format": "json"
      },
      "paging": {
        "pagingType": "NextPageToken",
        "nextPageTokenJsonPath": "$.data.alerts.pageInfo.endCursor",
        "NextPageParaName": "$.variables.after",
        "hasNextFlagJsonPath": "$.data.alerts.pageInfo.hasNextPage",
        "pageSize": 1000,
        "pagingInfoPlacement": "RequestBody"
      },
      "connectorDefinitionName": "SentinelOneV2Connector",
      "dataType": "SentinelOneAlertsV2_CL",
      "dcrConfig": {
        "streamName": "Custom-SentinelOneAlertsV2_CL",
        "dataCollectionEndpoint": "{{dataCollectionEndpoint}}",
        "dataCollectionRuleImmutableId": "{{dataCollectionRuleImmutableId}}"
      },
      "addOnAttributes": {
        "managementUrl": "[[parameters('managementUrl')]",
        "dataType": "Alerts (V2)"
      }
    }
  }
