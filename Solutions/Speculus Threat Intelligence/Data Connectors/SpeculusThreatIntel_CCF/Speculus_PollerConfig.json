[
    {
        "name": "SpeculusTaxiiIndicators",
        "apiVersion": "2025-09-01",
        "type": "Microsoft.SecurityInsights/dataConnectors",
        "location": "{{location}}",
        "kind": "RestApiPoller",
        "properties": {
            "connectorDefinitionName": "SpeculusThreatIntel",
            "dataType": "Speculus_Indicators_CL",
            "dcrConfig": {
                "streamName": "Custom-Speculus_Indicators_CL",
                "dataCollectionEndpoint": "{{dataCollectionEndpoint}}",
                "dataCollectionRuleImmutableId": "{{dataCollectionRuleImmutableId}}"
            },
            "auth": {
                "type": "APIKey",
                "ApiKeyName": "Authorization",
                "ApiKeyIdentifier": "Bearer",
                "ApiKey": "{{apiKey}}"
            },
            "request": {
                "apiEndpoint": "{{taxiiBaseUrl}}/collections/{{collectionId}}/objects/",
                "httpMethod": "GET",
                "queryParameters": {
                    "limit": 1000
                },
                "queryTimeFormat": "yyyy-MM-ddTHH:mm:ss.fffZ",
                "startTimeAttributeName": "added_after",
                "queryWindowInMin": 60,
                "rateLimitQps": 2,
                "retryCount": 3,
                "timeoutInSeconds": 60,
                "headers": {
                    "Accept": "application/taxii+json;version=2.1",
                    "User-Agent": "Microsoft-Sentinel-Speculus/1.0"
                }
            },
            "paging": {
                "pagingType": "NextPageToken",
                "nextPageTokenJsonPath": "$.next",
                "hasNextFlagJsonPath": "$.more",
                "nextPageParaName": "next"
            },
            "response": {
                "eventsJsonPaths": [
                    "$.objects"
                ]
            }
        }
    }
]
