{
    "$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "FunctionName": {
            "defaultValue": "GTIRSAlerts",
            "minLength": 1,
            "maxLength": 11,
            "type": "string",
            "metadata": {
                "description": "Enter a unique name for the Azure Function App (maximum 11 characters)"
            }
        },
        "Location": {
            "defaultValue": "[resourceGroup().location]",
            "type": "string",
            "metadata": {
                "description": "The location in which the Function App, data collection endpoint, and data collection rule will be deployed"
            }
        },
        "WorkspaceName": {
            "type": "string",
            "minLength": 1,
            "metadata": {
                "description": "Enter the Microsoft Sentinel Log Analytics workspace name"
            }
        },
        "AppInsightsWorkspaceResourceID": {
            "type": "string",
            "metadata": {
                "description": "Enter the fully qualified resource ID of the Log Analytics workspace for Application Insights. Format: /subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.OperationalInsights/workspaces/{workspaceName}"
            }
        },
        "AzureTenantID": {
            "type": "string",
            "minLength": 1,
            "metadata": {
                "description": "Enter the Azure Tenant ID of your Azure Active Directory"
            }
        },
        "AzureClientID": {
            "type": "string",
            "minLength": 1,
            "metadata": {
                "description": "Enter the Azure Client ID (Application ID) created during app registration for the Microsoft Sentinel connector"
            }
        },
        "AzureClientSecret": {
            "type": "securestring",
            "minLength": 1,
            "metadata": {
                "description": "Enter the Azure Client Secret created for the app registration"
            }
        },
        "AzureEntraObjectID": {
            "type": "string",
            "minLength": 1,
            "metadata": {
                "description": "Enter the Object ID of your Microsoft Entra app (from Enterprise Applications)"
            }
        },
        "GTIProjectId": {
            "type": "string",
            "minLength": 1,
            "metadata": {
                "description": "Enter the Google Threat Intelligence project ID"
            }
        },
        "GTIApiKey": {
            "type": "securestring",
            "minLength": 1,
            "metadata": {
                "description": "Enter the Google Threat Intelligence API key"
            }
        },
        "GTIRelevanceSystemAlertsTableName": {
            "type": "string",
            "defaultValue": "RelevanceSystemAlerts",
            "maxLength": 52,
            "metadata": {
                "description": "Enter the name of the custom table for GTI alerts. The _CL suffix will be appended automatically. Default is RelevanceSystemAlerts"
            }
        },
        "StartDate": {
            "defaultValue": "",
            "type": "string",
            "metadata": {
                "description": "Enter the start datetime in yyyy-mm-ddTHH:MM:SS[.fff]Z format. Example: 2026-05-20T15:43:51Z. Must be a past date. If not provided, data from the last 7 days will be fetched."
            }
        },
        "GTIFilterExpression": {
            "defaultValue": "",
            "type": "string",
            "metadata": {
                "description": "GTI API filter expression to narrow which alerts are ingested. Any audit.update_time condition will be automatically removed as the connector manages that filter internally."
            }
        },
        "Schedule": {
            "type": "string",
            "defaultValue": "0 */10 * * * *",
            "metadata": {
                "description": "Enter a valid Quartz Cron-Expression for the timer trigger schedule. Default is every 10 minutes: 0 */10 * * * *"
            }
        },
        "LogLevel": {
            "type": "string",
            "defaultValue": "Info",
            "allowedValues": [
                "Debug",
                "Info",
                "Warning",
                "Error"
            ],
            "metadata": {
                "description": "Set the log level for the Function App. Default is Info."
            }
        },
        "KeyVaultName": {
            "type": "string",
            "metadata": {
                "description": "Enter name of keyvault where tokens will be stored"
            }
        }
    },
    "variables": {
        "FunctionName": "[concat(toLower(trim(parameters('FunctionName'))), uniqueString(resourceGroup().id))]",
        "StorageSuffix": "[environment().suffixes.storage]",
        "suffix": "[concat('A', uniqueString(resourceGroup().id))]",
        "endpointName": "[concat(toLower(parameters('FunctionName')), 'LogsEndpoint', variables('suffix'))]",
        "mainRuleName": "[concat(toLower(parameters('FunctionName')), 'MainCollectionRule', variables('suffix'))]",
        "logWsResId": "[resourceId('Microsoft.OperationalInsights/workspaces', parameters('WorkspaceName'))]",
        "dcrRoleName": "[concat(toLower(parameters('FunctionName')), 'EntraRole', variables('suffix'))]",
        "dcrRoleId": "[guid(subscription().id, string(variables('dcrRoleName')))]",
        "scope": "[concat(replace(environment().portal, 'portal', 'monitor'), '/.default')]",
        "kvRoleId": "[guid(resourceGroup().id, concat('GTIRelevanceSystemAlerts KV Role assignment', variables('FunctionName')))]"
    },
    "resources": [
        {
            "type": "Microsoft.Insights/dataCollectionEndpoints",
            "apiVersion": "2022-06-01",
            "name": "[variables('endpointName')]",
            "location": "[parameters('Location')]",
            "kind": "Linux",
            "properties": {
                "description": "Data collection endpoint for GTI Alerts Log Ingestion API",
                "networkAcls": {
                    "publicNetworkAccess": "Enabled"
                }
            }
        },
        {
            "type": "Microsoft.OperationalInsights/workspaces/tables",
            "apiVersion": "2022-10-01",
            "name": "[concat(parameters('WorkspaceName'), '/', parameters('GTIRelevanceSystemAlertsTableName'), '_CL')]",
            "properties": {
                "plan": "Analytics",
                "schema": {
                    "name": "[concat(parameters('GTIRelevanceSystemAlertsTableName'), '_CL')]",
                    "columns": [
                        {
                            "Name": "TimeGenerated",
                            "Type": "datetime"
                        },
                        {
                            "Name": "name",
                            "Type": "string"
                        },
                        {
                            "Name": "etag",
                            "Type": "string"
                        },
                        {
                            "Name": "state",
                            "Type": "string"
                        },
                        {
                            "Name": "displayName",
                            "Type": "string"
                        },
                        {
                            "Name": "findingCount",
                            "Type": "string"
                        },
                        {
                            "Name": "aiSummary",
                            "Type": "string"
                        },
                        {
                            "Name": "findings",
                            "Type": "dynamic"
                        },
                        {
                            "Name": "audit_createTime",
                            "Type": "datetime"
                        },
                        {
                            "Name": "audit_updateTime",
                            "Type": "datetime"
                        },
                        {
                            "Name": "audit_creator",
                            "Type": "string"
                        },
                        {
                            "Name": "audit_updater",
                            "Type": "string"
                        },
                        {
                            "Name": "detail_detailType",
                            "Type": "string"
                        },
                        {
                            "Name": "detail_dataLeak_severity",
                            "Type": "string"
                        },
                        {
                            "Name": "detail_dataLeak_discoveryDocumentIds",
                            "Type": "dynamic"
                        },
                        {
                            "Name": "detail_insiderThreat_severity",
                            "Type": "string"
                        },
                        {
                            "Name": "detail_insiderThreat_discoveryDocumentIds",
                            "Type": "dynamic"
                        },
                        {
                            "Name": "detail_initialAccessBroker_severity",
                            "Type": "string"
                        },
                        {
                            "Name": "detail_initialAccessBroker_discoveryDocumentIds",
                            "Type": "dynamic"
                        },
                        {
                            "Name": "relevanceAnalysis_relevant",
                            "Type": "boolean"
                        },
                        {
                            "Name": "relevanceAnalysis_relevanceLevel",
                            "Type": "string"
                        },
                        {
                            "Name": "relevanceAnalysis_confidence",
                            "Type": "string"
                        },
                        {
                            "Name": "relevanceAnalysis_reasoning",
                            "Type": "string"
                        },
                        {
                            "Name": "relevanceAnalysis_evidence_commonThemes",
                            "Type": "dynamic"
                        },
                        {
                            "Name": "relevanceAnalysis_evidence_distinctThemes",
                            "Type": "dynamic"
                        },
                        {
                            "Name": "severityAnalysis_severityLevel",
                            "Type": "string"
                        },
                        {
                            "Name": "severityAnalysis_confidence",
                            "Type": "string"
                        },
                        {
                            "Name": "severityAnalysis_reasoning",
                            "Type": "string"
                        },
                        {
                            "Name": "priorityAnalysis_priorityLevel",
                            "Type": "string"
                        },
                        {
                            "Name": "priorityAnalysis_reasoning",
                            "Type": "string"
                        }
                    ]
                }
            }
        },
        {
            "type": "Microsoft.Insights/dataCollectionRules",
            "apiVersion": "2022-06-01",
            "name": "[variables('mainRuleName')]",
            "location": "[parameters('Location')]",
            "dependsOn": [
                "[resourceId('Microsoft.Insights/dataCollectionEndpoints', variables('endpointName'))]",
                "[concat(variables('logWsResId'), '/tables/', parameters('GTIRelevanceSystemAlertsTableName'), '_CL')]"
            ],
            "properties": {
                "dataCollectionEndpointId": "[resourceId('Microsoft.Insights/dataCollectionEndpoints', variables('endpointName'))]",
                "streamDeclarations": {
                    "[concat('Custom-', parameters('GTIRelevanceSystemAlertsTableName'))]": {
                        "columns": [
                            {
                                "Name": "TimeGenerated",
                                "Type": "datetime"
                            },
                            {
                                "Name": "name",
                                "Type": "string"
                            },
                            {
                                "Name": "etag",
                                "Type": "string"
                            },
                            {
                                "Name": "state",
                                "Type": "string"
                            },
                            {
                                "Name": "displayName",
                                "Type": "string"
                            },
                            {
                                "Name": "findingCount",
                                "Type": "string"
                            },
                            {
                                "Name": "aiSummary",
                                "Type": "string"
                            },
                            {
                                "Name": "findings",
                                "Type": "dynamic"
                            },
                            {
                                "Name": "audit",
                                "Type": "dynamic"
                            },
                            {
                                "Name": "detail",
                                "Type": "dynamic"
                            },
                            {
                                "Name": "relevanceAnalysis",
                                "Type": "dynamic"
                            },
                            {
                                "Name": "severityAnalysis",
                                "Type": "dynamic"
                            },
                            {
                                "Name": "priorityAnalysis",
                                "Type": "dynamic"
                            }
                        ]
                    }
                },
                "destinations": {
                    "logAnalytics": [
                        {
                            "workspaceResourceId": "[parameters('AppInsightsWorkspaceResourceID')]",
                            "name": "[concat('RuleDest', variables('suffix'))]"
                        }
                    ]
                },
                "dataFlows": [
                    {
                        "streams": [
                            "[concat('Custom-', parameters('GTIRelevanceSystemAlertsTableName'))]"
                        ],
                        "destinations": [
                            "[concat('RuleDest', variables('suffix'))]"
                        ],
                        "transformKql": "source\n| extend TimeGenerated = now()\n| extend json_audit = parse_json(audit), json_detail = parse_json(detail), json_relevanceAnalysis = parse_json(relevanceAnalysis), json_severityAnalysis = parse_json(severityAnalysis), json_priorityAnalysis = parse_json(priorityAnalysis)\n| extend json_detail_dataLeak = parse_json(json_detail.dataLeak), json_detail_insiderThreat = parse_json(json_detail.insiderThreat), json_detail_initialAccessBroker = parse_json(json_detail.initialAccessBroker), json_relevance_evidence = parse_json(json_relevanceAnalysis.evidence)\n| extend audit_createTime = todatetime(json_audit.createTime), audit_updateTime = todatetime(json_audit.updateTime), audit_creator = tostring(json_audit.creator), audit_updater = tostring(json_audit.updater)\n| extend detail_detailType = tostring(json_detail.detailType), detail_dataLeak_severity = tostring(json_detail_dataLeak.severity), detail_dataLeak_discoveryDocumentIds = json_detail_dataLeak.discoveryDocumentIds\n| extend detail_insiderThreat_severity = tostring(json_detail_insiderThreat.severity), detail_insiderThreat_discoveryDocumentIds = json_detail_insiderThreat.discoveryDocumentIds\n| extend detail_initialAccessBroker_severity = tostring(json_detail_initialAccessBroker.severity), detail_initialAccessBroker_discoveryDocumentIds = json_detail_initialAccessBroker.discoveryDocumentIds\n| extend relevanceAnalysis_relevant = tobool(json_relevanceAnalysis.relevant), relevanceAnalysis_relevanceLevel = tostring(json_relevanceAnalysis.relevanceLevel), relevanceAnalysis_confidence = tostring(json_relevanceAnalysis.confidence), relevanceAnalysis_reasoning = tostring(json_relevanceAnalysis.reasoning)\n| extend relevanceAnalysis_evidence_commonThemes = json_relevance_evidence.commonThemes, relevanceAnalysis_evidence_distinctThemes = json_relevance_evidence.distinctThemes\n| extend severityAnalysis_severityLevel = tostring(json_severityAnalysis.severityLevel), severityAnalysis_confidence = tostring(json_severityAnalysis.confidence), severityAnalysis_reasoning = tostring(json_severityAnalysis.reasoning)\n| extend priorityAnalysis_priorityLevel = tostring(json_priorityAnalysis.priorityLevel), priorityAnalysis_reasoning = tostring(json_priorityAnalysis.reasoning)\n| project-away json_audit, json_detail, json_relevanceAnalysis, json_severityAnalysis, json_priorityAnalysis, json_detail_dataLeak, json_detail_insiderThreat, json_detail_initialAccessBroker, json_relevance_evidence, audit, detail, relevanceAnalysis, severityAnalysis, priorityAnalysis",
                        "outputStream": "[concat('Custom-', parameters('GTIRelevanceSystemAlertsTableName'), '_CL')]"
                    }
                ]
            }
        },
        {
            "type": "Microsoft.Insights/components",
            "apiVersion": "2020-02-02",
            "name": "[variables('FunctionName')]",
            "location": "[resourceGroup().location]",
            "kind": "web",
            "properties": {
                "Application_Type": "web",
                "ApplicationId": "[variables('FunctionName')]",
                "WorkspaceResourceId": "[trim(parameters('AppInsightsWorkspaceResourceID'))]"
            }
        },
        {
            "type": "Microsoft.Storage/storageAccounts",
            "apiVersion": "2023-01-01",
            "name": "[tolower(variables('FunctionName'))]",
            "location": "[resourceGroup().location]",
            "sku": {
                "name": "Standard_LRS",
                "tier": "Standard"
            },
            "kind": "StorageV2",
            "properties": {
                "networkAcls": {
                    "bypass": "AzureServices",
                    "virtualNetworkRules": [],
                    "ipRules": [],
                    "defaultAction": "Allow"
                },
                "supportsHttpsTrafficOnly": true,
                "encryption": {
                    "services": {
                        "file": {
                            "keyType": "Account",
                            "enabled": true
                        },
                        "blob": {
                            "keyType": "Account",
                            "enabled": true
                        }
                    },
                    "keySource": "Microsoft.Storage"
                },
                "minimumTlsVersion": "TLS1_2"
            }
        },
        {
            "type": "Microsoft.Storage/storageAccounts/blobServices",
            "apiVersion": "2023-01-01",
            "name": "[concat(variables('FunctionName'), '/default')]",
            "dependsOn": [
                "[resourceId('Microsoft.Storage/storageAccounts', tolower(variables('FunctionName')))]"
            ],
            "sku": {
                "name": "Standard_LRS",
                "tier": "Standard"
            },
            "properties": {
                "cors": {
                    "corsRules": []
                },
                "deleteRetentionPolicy": {
                    "enabled": false
                }
            }
        },
        {
            "type": "Microsoft.Storage/storageAccounts/fileServices",
            "apiVersion": "2023-01-01",
            "name": "[concat(variables('FunctionName'), '/default')]",
            "dependsOn": [
                "[resourceId('Microsoft.Storage/storageAccounts', tolower(variables('FunctionName')))]"
            ],
            "sku": {
                "name": "Standard_LRS",
                "tier": "Standard"
            },
            "properties": {
                "cors": {
                    "corsRules": []
                }
            }
        },
        {
            "type": "Microsoft.Web/sites",
            "apiVersion": "2022-03-01",
            "name": "[variables('FunctionName')]",
            "location": "[resourceGroup().location]",
            "dependsOn": [
                "[resourceId('Microsoft.Storage/storageAccounts', tolower(variables('FunctionName')))]",
                "[resourceId('Microsoft.Insights/components', variables('FunctionName'))]"
            ],
            "kind": "functionapp,linux",
            "identity": {
                "type": "SystemAssigned"
            },
            "properties": {
                "name": "[variables('FunctionName')]",
                "httpsOnly": true,
                "clientAffinityEnabled": true,
                "alwaysOn": true,
                "reserved": true,
                "siteConfig": {
                    "linuxFxVersion": "python|3.12"
                }
            },
            "resources": [
                {
                    "apiVersion": "2022-03-01",
                    "type": "config",
                    "name": "appsettings",
                    "dependsOn": [
                        "[concat('Microsoft.Web/sites/', variables('FunctionName'))]",
                        "[resourceId('Microsoft.Insights/dataCollectionEndpoints', variables('endpointName'))]",
                        "[resourceId('Microsoft.Insights/dataCollectionRules', variables('mainRuleName'))]"
                    ],
                    "properties": {
                        "FUNCTIONS_EXTENSION_VERSION": "~4",
                        "FUNCTIONS_WORKER_RUNTIME": "python",
                        "PYTHON_VERSION": "3.12",
                        "APPINSIGHTS_INSTRUMENTATIONKEY": "[reference(resourceId('Microsoft.insights/components', variables('FunctionName')), '2015-05-01').InstrumentationKey]",
                        "APPLICATIONINSIGHTS_CONNECTION_STRING": "[reference(resourceId('microsoft.insights/components', variables('FunctionName')), '2015-05-01').ConnectionString]",
                        "AzureWebJobsStorage": "[concat('DefaultEndpointsProtocol=https;AccountName=', toLower(variables('FunctionName')), ';AccountKey=', listKeys(resourceId('Microsoft.Storage/storageAccounts', toLower(variables('FunctionName'))), '2023-01-01').keys[0].value, ';EndpointSuffix=', toLower(variables('StorageSuffix')))]",
                        "AZURE_CLIENT_ID": "[parameters('AzureClientID')]",
                        "AZURE_CLIENT_SECRET": "[parameters('AzureClientSecret')]",
                        "AZURE_TENANT_ID": "[parameters('AzureTenantID')]",
                        "GTI_API_KEY": "[parameters('GTIApiKey')]",
                        "GTI_PROJECT_ID": "[trim(parameters('GTIProjectId'))]",
                        "File_Share_Name": "gti-connector-state",
                        "StartDate": "[trim(parameters('StartDate'))]",
                        "Schedule": "[trim(parameters('Schedule'))]",
                        "LogLevel": "[trim(parameters('LogLevel'))]",
                        "SCOPE": "[variables('scope')]",
                        "AZURE_DATA_COLLECTION_ENDPOINT": "[reference(resourceId('Microsoft.Insights/dataCollectionEndpoints', variables('endpointName')), '2022-06-01').logsIngestion.endpoint]",
                        "AZURE_DATA_COLLECTION_RULE_ID": "[reference(resourceId('Microsoft.Insights/dataCollectionRules', variables('mainRuleName')), '2022-06-01').immutableId]",
                        "GTI_FILTER_EXPRESSION": "[trim(parameters('GTIFilterExpression'))]",
                        "KEYVAULT_NAME": "[trim(parameters('KeyVaultName'))]",
                        "WEBSITE_RUN_FROM_PACKAGE": "https://aka.ms/sentinel-GTIRelevanceSystemAlerts-functionapp"
                    }
                }
            ]
        },
        {
            "type": "Microsoft.Storage/storageAccounts/blobServices/containers",
            "apiVersion": "2023-01-01",
            "name": "[concat(variables('FunctionName'), '/default/azure-webjobs-hosts')]",
            "dependsOn": [
                "[resourceId('Microsoft.Storage/storageAccounts/blobServices', variables('FunctionName'), 'default')]",
                "[resourceId('Microsoft.Storage/storageAccounts', variables('FunctionName'))]"
            ],
            "properties": {
                "publicAccess": "None"
            }
        },
        {
            "type": "Microsoft.Storage/storageAccounts/blobServices/containers",
            "apiVersion": "2023-01-01",
            "name": "[concat(variables('FunctionName'), '/default/azure-webjobs-secrets')]",
            "dependsOn": [
                "[resourceId('Microsoft.Storage/storageAccounts/blobServices', variables('FunctionName'), 'default')]",
                "[resourceId('Microsoft.Storage/storageAccounts', variables('FunctionName'))]"
            ],
            "properties": {
                "publicAccess": "None"
            }
        },
        {
            "type": "Microsoft.Storage/storageAccounts/fileServices/shares",
            "apiVersion": "2023-01-01",
            "name": "[concat(variables('FunctionName'), '/default/', tolower(variables('FunctionName')))]",
            "dependsOn": [
                "[resourceId('Microsoft.Storage/storageAccounts/fileServices', variables('FunctionName'), 'default')]",
                "[resourceId('Microsoft.Storage/storageAccounts', variables('FunctionName'))]"
            ],
            "properties": {
                "shareQuota": 5120
            }
        },
        {
            "type": "Microsoft.Authorization/roleDefinitions",
            "apiVersion": "2022-04-01",
            "name": "[variables('dcrRoleId')]",
            "properties": {
                "assignableScopes": [
                    "[resourceGroup().id]",
                    "[resourceId('Microsoft.Insights/dataCollectionRules', variables('mainRuleName'))]"
                ],
                "description": "Entra ID application access role for GTI Alerts DCR",
                "permissions": [
                    {
                        "actions": [
                            "Microsoft.Insights/Register/Action",
                            "Microsoft.Support/*",
                            "Microsoft.Resources/subscriptions/resourceGroups/read"
                        ],
                        "dataActions": [
                            "Microsoft.Insights/Metrics/Write",
                            "Microsoft.Insights/Telemetry/Write"
                        ]
                    }
                ],
                "roleName": "[variables('dcrRoleName')]",
                "type": "customRole"
            }
        },
        {
            "type": "Microsoft.Authorization/roleAssignments",
            "apiVersion": "2022-04-01",
            "name": "[guid(resourceGroup().id, concat('GTIRelevanceSystemAlerts DCR Role assignment', variables('FunctionName')))]",
            "dependsOn": [
                "[variables('dcrRoleId')]",
                "[variables('mainRuleName')]"
            ],
            "scope": "[resourceId('Microsoft.Insights/dataCollectionRules', variables('mainRuleName'))]",
            "properties": {
                "roleDefinitionId": "[resourceId('Microsoft.Authorization/roleDefinitions', variables('dcrRoleId'))]",
                "principalId": "[parameters('AzureEntraObjectID')]"
            }
        }
    ],
    "outputs": {
        "functionAppName": {
            "type": "string",
            "value": "[variables('FunctionName')]"
        },
        "workspaceName": {
            "type": "string",
            "value": "[parameters('WorkspaceName')]"
        }
    }
}
