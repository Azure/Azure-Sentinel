{
  "name": "CiscoMerakiNetworkClients_CL",
  "type": "Microsoft.OperationalInsights/workspaces/tables",
  "apiVersion": "2022-10-01",
  "tags": {
    "StreamName": "Custom-CiscoMerakiNetworkClients_CL",
    "DataSource": "CiscoMeraki",
    "Category": "NetworkManagement",
    "CreatedFrom": "DCR-StreamDeclaration"
  },
  "properties": {
    "schema": {
      "name": "CiscoMerakiNetworkClients_CL",
      "description": "The CiscoMerakiNetworkClients table contains information about network clients detected on Cisco Meraki networks, including device details, connection information, and usage statistics.",
      "columns": [
        {
          "name": "TimeGenerated",
          "type": "datetime",
          "isDefaultDisplay": true
        },
        {
          "name": "ClientId",
          "type": "string",
          "description": "Unique client identifier."
        },
        {
          "name": "MacAddress",
          "type": "string",
          "description": "Client MAC address."
        },
        {
          "name": "IpAddress",
          "type": "string",
          "description": "IPv4 address of the client."
        },
        {
          "name": "IpV6Address",
          "type": "string",
          "description": "IPv6 address of the client."
        },
        {
          "name": "IpV6LocalAddress",
          "type": "string",
          "description": "IPv6 local link address."
        },
        {
          "name": "Description",
          "type": "string",
          "description": "Client device description or name."
        },
        {
          "name": "FirstSeen",
          "type": "datetime",
          "description": "Timestamp when the client was first seen on the network."
        },
        {
          "name": "LastSeen",
          "type": "datetime",
          "description": "Timestamp when the client was last seen on the network."
        },
        {
          "name": "Manufacturer",
          "type": "string",
          "description": "Device manufacturer."
        },
        {
          "name": "OperatingSystem",
          "type": "string",
          "description": "Operating system of the client device."
        },
        {
          "name": "Username",
          "type": "string",
          "description": "Username associated with the client."
        },
        {
          "name": "Vlan",
          "type": "string",
          "description": "VLAN identifier."
        },
        {
          "name": "Ssid",
          "type": "string",
          "description": "SSID name for wireless clients."
        },
        {
          "name": "Switchport",
          "type": "string",
          "description": "Switch port name or identifier."
        },
        {
          "name": "WirelessCapabilities",
          "type": "string",
          "description": "Wireless capabilities or standards (e.g., 802.11b)."
        },
        {
          "name": "SmInstalled",
          "type": "boolean",
          "description": "Indicates if Meraki Systems Manager is installed."
        },
        {
          "name": "RecentDeviceMac",
          "type": "string",
          "description": "MAC address of the recent device."
        },
        {
          "name": "Status",
          "type": "string",
          "description": "Client status (Online/Offline)."
        },
        {
          "name": "Usage",
          "type": "dynamic",
          "description": "Usage statistics including sent and received bytes."
        },
        {
          "name": "NamedVlan",
          "type": "string",
          "description": "Named VLAN assigned to the client."
        },
        {
          "name": "AdaptivePolicyGroup",
          "type": "string",
          "description": "Adaptive policy group assignment."
        },
        {
          "name": "DeviceTypePrediction",
          "type": "string",
          "description": "Predicted device type and OS version."
        },
        {
          "name": "RecentDeviceSerial",
          "type": "string",
          "description": "Serial number of the recent device."
        },
        {
          "name": "RecentDeviceName",
          "type": "string",
          "description": "Name of the recent device."
        },
        {
          "name": "RecentDeviceConnection",
          "type": "string",
          "description": "Connection type (Wired/Wireless)."
        },
        {
          "name": "Notes",
          "type": "string",
          "description": "Additional notes about the client."
        },
        {
          "name": "GroupPolicy8021x",
          "type": "string",
          "description": "802.1x group policy."
        },
        {
          "name": "PskGroup",
          "type": "string",
          "description": "Pre-shared key group assignment."
        },
        {
          "name": "NetworkId",
          "type": "string",
          "description": "Network ID where the client was detected."
        }
      ]
    }
  }
}