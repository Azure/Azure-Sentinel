[
    {
        "name": "ImpervaCloudWAFLogsCCF",
        "apiVersion": "2025-03-01",
        "type": "Microsoft.SecurityInsights/dataConnectors",
        "location": "{{location}}",
        "kind": "AmazonWebServicesS3",
        "properties": {
            "connectorDefinitionName": "ImpervaCloudWAFLogsCCFDefinition",
            "dataTypes": {
                "logs": {
                    "state": "enabled"
                }
            },
            "destinationTable": "SentinelImpervaWAFCloudV2Logs",
            "dataFormat": {
                "CsvDelimiter": "|",
                "HasCsvHeader": false,
                "HasCsvBoundary": false,
                "CsvEscapeMode": "NoEscape",
                "Format": "csv",
                "IsCompressed": false
            },
            "dataType": "SentinelImpervaWAFCloudV2Logs",
            "dcrConfig": {
                "streamName": "SENTINEL_IMPERVA_WAF_CLOUD_V2_LOGS",
                "dataCollectionEndpoint": "{{dataCollectionEndpoint}}",
                "dataCollectionRuleImmutableId": "{{dataCollectionRuleImmutableId}}"
            },
            "roleArn": "{{roleArn}}",
            "sqsUrls": [
                "{{queueUrl}}"
            ]
        }
    }
]