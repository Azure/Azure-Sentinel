[
  {
    "type": "Microsoft.SecurityInsights/dataConnectors",
    "apiVersion": "2022-10-01-preview",
    "name": "ZoomDailyReports",
    "location": "{{location}}",
    "kind": "RestApiPoller",
    "properties": {
      "auth": {
        "type": "JwtToken",
        "TokenEndpoint": "[[concat(parameters('TokenBaseUrl'),'?grant_type=account_credentials&account_id=',parameters('AccountId'))]",
        "IsJsonRequest": false,
        "Headers": {
          "Content-Type": "application/x-www-form-urlencoded"
        },
        "JwtTokenJsonPath": "$.access_token",
        "NoAccessTokenPrepend": false,
        "TokenEndpointHttpMethod": "POST",
        "UserTokenPrepend": "Basic",
        "UserToken": "[[base64(concat(parameters('ClientId'),':',parameters('ClientSecret')))]"
      },
      "request": {
        "apiEndpoint": "[[concat(parameters('ApiBaseUrl'),'/report/daily')]",
        "httpMethod": "GET",
        "rateLimitQPS": 2,
        "queryWindowInMin": 60,
        "queryTimeFormat": "yyyy-MM-dd",
        "retryCount": 3,
        "timeoutInSeconds": 20,
        "headers": {
          "Accept": "application/json"
        },
        "queryParameters": {
          "page_size": "300",
          "from": "{_QueryWindowStartTime}",
          "to": "{_QueryWindowEndTime}"
        }
      },
      "response": {
        "eventsJsonPaths": [
          "$.dates"
        ],
        "format": "json"
      },
      "paging": {
        "pagingType": "NextPageToken",
        "nextPageTokenJsonPath": "$.next_page_token",
        "NextPageParaName": "next_page_token",
        "pageSize": 300,
        "pageSizeParameterName": "page_size"
      },
      "connectorDefinitionName": "ZoomReportsConnector",
      "dataType": "ZoomV2",
      "dcrConfig": {
        "streamName": "Custom-ZoomReportsV2General_CL",
        "dataCollectionEndpoint": "{{dataCollectionEndpoint}}",
        "dataCollectionRuleImmutableId": "{{dataCollectionRuleImmutableId}}"
      },
      "addOnAttributes": {
        "event_type": "dates",
        "event_name": "Daily Usage Reports."
      }
    }
  },
