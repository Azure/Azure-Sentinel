{
  "type": "Microsoft.SecurityInsights/dataConnectors",
  "apiVersion": "2022-10-01-preview",
  "name": "[[concat('parameters('workspace')', '/Microsoft.SecurityInsights/','Auth0Logs' , uniqueString(parameters('domain')) )]",
  "location": "{{location}}",
  "kind": "RestApiPoller",
  "properties": {
    "auth": {
      "type": "OAuth2",
      "ClientId": "[[parameters('clientId')]",
      "ClientSecret": "[[parameters('clientSecret')]",
      "GrantType": "client_credentials",
      "TokenEndpoint": "[[concat(parameters('domain'), '/oauth/token')]",
      "TokenEndpointQueryParameters": {
        "audience": "[[concat(parameters('domain'), '/api/v2/')]"
      }
    },
    "request": {
      "apiEndpoint": "[[concat(parameters('domain'), '/api/v2/logs')]",
      "httpMethod": "GET",
      "rateLimitQPS": 5,
      "queryWindowInMin": 5,
      "retryCount": 3,
      "timeoutInSeconds": 20,
      "headers": {
        "Accept": "application/json"
      }
    },
    "response": {
      "eventsJsonPaths": [
        "$"
      ],
      "format": "json"
    },
    "paging": {
      "pagingType": "PersistentToken",
      "nextPageTokenJsonPath": "$.[-1:].log_id",
      "nextPageParaName": "from",
      "pageSize": 100,
      "pageSizeParameterName": "take"
    },
    "connectorDefinitionName": "Auth0ConnectorCCPDefinition",
    "dataType": "Auth0Logs",
    "dcrConfig": {
      "streamName": "Custom-Auth0Logs_CL",
      "dataCollectionEndpoint": "{{dataCollectionEndpoint}}",
      "dataCollectionRuleImmutableId": "{{dataCollectionRuleImmutableId}}"
    },
    "addOnAttributes": {
      "Auth0Domain": "[[parameters('domain')]"
    }
  }
}
