{
  "name": "TrendMicroCASConnector",
  "apiVersion": "2025-07-01-preview",
  "type": "Microsoft.SecurityInsights/dataConnectorDefinitions",
  "location": "{{location}}",
  "kind": "Customizable",
  "properties": {
    "connectorUiConfig": {
      "id": "TrendMicroCASConnector",
      "title": "Trend Micro Cloud App Security (via Codeless Connector Framework)",
      "publisher": "Microsoft",
      "descriptionMarkdown": "The [Trend Micro Cloud App Security](https://www.trendmicro.com/en_be/business/products/user-protection/sps/email-and-collaboration/cloud-app-security.html) data connector provides the capability to retrieve security event logs of the services that Cloud App Security protects into Microsoft Sentinel through the SIEM API. The connector provides the ability to get events which helps to examine potential security risks, analyze your team's use of collaboration, diagnose configuration problems and more. It supports DCR-based [ingestion time transformations](https://docs.microsoft.com/azure/azure-monitor/logs/custom-logs-overview) that parse the received security event data into custom columns so that queries don't need to parse it again, thus resulting in better performance.",
      "graphQueriesTableName": "TrendMicroCASV2",
      "graphQueries": [
        {
          "metricName": "Total security events received",
          "legend": "Trend Micro CAS Security Events",
          "baseQuery": "TrendMicroCASV2"
        },
        {
          "metricName": "Recent Events",
          "legend": "Recent Events",
          "baseQuery": "TrendMicroCASV2 | where TimeGenerated > ago(24h)"
        }
      ],
      "sampleQueries": [
        {
          "description": "Get sample of recent security events",
          "query": "TrendMicroCASV2\n| take 20"
        }
      ],
      "dataTypes": [
        {
          "name": "TrendMicroCASV2",
          "lastDataReceivedQuery": "TrendMicroCASV2\n| where TimeGenerated > ago(6h)\n| summarize Time = max(TimeGenerated)\n| where isnotempty(Time)"
        }
      ],
      "connectivityCriteria": [
        {
          "type": "HasDataConnectors"
        },
        {
          "type": "IsConnectedQuery",
          "value": [
            "TrendMicroCASV2 | where TimeGenerated > ago(7d) | take 1"
          ]
        }
      ],
      "availability": {
        "isPreview": false,
        "status": 1
      },
      "permissions": {
        "resourceProvider": [
          {
            "provider": "Microsoft.OperationalInsights/workspaces",
            "permissionsDisplayText": "Read and Write permissions are required.",
            "providerDisplayName": "Workspace",
            "scope": "Workspace",
            "requiredPermissions": {
              "write": true,
              "read": true,
              "delete": true,
              "action": false
            }
          }
        ],
        "customs": [
          {
            "name": "Trend Micro CAS API Token",
            "description": "A Trend Micro Cloud App Security API token is required. [See the documentation to learn more about Trend Micro CAS API](https://docs.trendmicro.com/enterprise/cloud-app-security-integration-api-online-help/supported-cloud-app-/log-retrieval-api/get-security-logs.aspx)."
          }
        ]
      },
      "instructionSteps": [
        {
          "title": "1. Configure Trend Micro CAS Data Streams",
          "description": "Add one or more data streams by selecting the cloud service and event type combinations you want to monitor.",
          "instructions": [
            {
              "type": "DataConnectorsGrid",
              "parameters": {
                "mapping": [
                  {
                    "columnName": "Friendly Name",
                    "columnValue": "properties.addOnAttributes.friendlyName"
                  },
                  {
                    "columnName": "Service",
                    "columnValue": "properties.request.queryParameters.service"
                  },
                  {
                    "columnName": "Event Type",
                    "columnValue": "properties.request.queryParameters.event"
                  }
                ],
                "menuItems": [
                  "DeleteConnector"
                ]
              }
            },
            {
              "type": "ContextPane",
              "parameters": {
                "label": "Add Data Stream",
                "title": "Add Trend Micro CAS Stream",
                "subtitle": "Configure a new service and event type combination",
                "contextPaneType": "DataConnectorsContextPane",
                "instructionSteps": [
                  {
                    "instructions": [
                      {
                        "type": "Markdown",
                        "parameters": {
                          "content": "## Configuration\n\nConfigure the connection to your Trend Micro Cloud App Security instance and select which service and event type to monitor."
                        }
                      },
                      {
                        "type": "Textbox",
                        "parameters": {
                          "label": "Trend Micro CAS Service URL",
                          "placeholder": "api.tmcas.trendmicro.com",
                          "type": "text",
                          "name": "serviceURL",
                          "validations": {
                            "required": true
                          }
                        }
                      },
                      {
                        "type": "Textbox",
                        "parameters": {
                          "label": "API Token",
                          "placeholder": "Enter your Trend Micro CAS API Token",
                          "type": "password",
                          "name": "apiToken",
                          "validations": {
                            "required": true
                          }
                        }
                      },
                      {
                        "type": "InfoMessage",
                        "parameters": {
                          "text": "The API token will be securely stored and used for authentication with the Trend Micro CAS API.",
                          "visible": true,
                          "inline": true
                        }
                      },
                      {
                        "type": "Markdown",
                        "parameters": {
                          "content": "## Stream Configuration\n\nSelect the cloud service and event type for this data stream."
                        }
                      },
                      {
                        "type": "Dropdown",
                        "parameters": {
                          "label": "Cloud Service",
                          "name": "service",
                          "options": [
                            {
                              "key": "exchange",
                              "text": "Exchange"
                            },
                            {
                              "key": "sharepoint",
                              "text": "SharePoint"
                            },
                            {
                              "key": "onedrive",
                              "text": "OneDrive"
                            },
                            {
                              "key": "dropbox",
                              "text": "Dropbox"
                            },
                            {
                              "key": "box",
                              "text": "Box"
                            },
                            {
                              "key": "googledrive",
                              "text": "Google Drive"
                            },
                            {
                              "key": "gmail",
                              "text": "Gmail"
                            },
                            {
                              "key": "teams",
                              "text": "Teams"
                            },
                            {
                              "key": "exchangeserver",
                              "text": "Exchange Server"
                            },
                            {
                              "key": "salesforce_sandbox",
                              "text": "Salesforce Sandbox"
                            },
                            {
                              "key": "salesforce_production",
                              "text": "Salesforce Production"
                            },
                            {
                              "key": "teams_chat",
                              "text": "Teams Chat"
                            }
                          ],
                          "required": true
                        }
                      },
                      {
                        "type": "Dropdown",
                        "parameters": {
                          "label": "Event Type",
                          "name": "eventType",
                          "options": [
                            {
                              "key": "securityrisk",
                              "text": "Security Risk"
                            },
                            {
                              "key": "virtualanalyzer",
                              "text": "Virtual Analyzer"
                            },
                            {
                              "key": "ransomware",
                              "text": "Ransomware"
                            },
                            {
                              "key": "dlp",
                              "text": "Data Loss Prevention (DLP)"
                            }
                          ],
                          "required": true
                        }
                      },
                      {
                        "type": "Textbox",
                        "parameters": {
                          "label": "Friendly Name",
                          "placeholder": "Descriptive name combining service and event type (e.g., 'SharePoint-Ransomware')",
                          "type": "text",
                          "name": "friendlyName",
                          "validations": {
                            "required": true
                          }
                        }
                      },
                      {
                        "type": "InfoMessage",
                        "parameters": {
                          "text": "Each data stream configuration creates a dedicated poller for the selected service and event type combination. You can add multiple streams as needed.",
                          "visible": true,
                          "inline": true
                        }
                      }
                    ]
                  }
                ]
              }
            }
          ]
        }
      ]
    }
  }
}