{
  "type": "Microsoft.SecurityInsights/dataConnectors",
  "apiVersion": "2024-09-01",
  "name": "[[concat('parameters('workspace')', '/Microsoft.SecurityInsights/','TrendMicroCASV2_CL' , uniqueString(parameters('friendlyName')) )]",
  "location": "{{location}}",
  "kind": "RestApiPoller",
  "properties": {
    "auth": {
      "type": "APIKey",
      "ApiKey": "[[parameters('apiToken')]",
      "ApiKeyName": "Authorization",
      "ApiKeyIdentifier": "Bearer"
    },
    "request": {
      "apiEndpoint": "[[concat('https://', parameters('serviceURL'), '/v1/siem/security_events')]",
      "httpMethod": "GET",
      "rateLimitQPS": 1,
      "queryWindowInMin": 10,
      "queryTimeFormat": "yyyy-MM-ddTHH:mm:ssZ",
      "retryCount": 3,
      "timeoutInSeconds": 120,
      "headers": {
        "Content-Type": "application/json",
        "Accept": "application/json"
      },
      "queryParameters": {
        "service": "[[parameters('service')]",
        "event": "[[parameters('eventType')]",
        "start": "{_QueryWindowStartTime}",
        "end": "{_QueryWindowEndTime}"
      }
    },
    "response": {
      "eventsJsonPaths": [
        "$.security_events[*]"
      ],
      "format": "json"
    },
    "paging": {
      "pagingType": "NextPageUrl",
      "nextPageTokenJsonPath": "$.next_link",
      "isNextPageTokenRelativeUrl": false
    },
    "connectorDefinitionName": "TrendMicroCASConnector",
    "dataType": "TrendMicroCASV2_CL",
    "dcrConfig": {
      "streamName": "Custom-TrendMicroCASV2_CL",
      "dataCollectionEndpoint": "{{dataCollectionEndpoint}}",
      "dataCollectionRuleImmutableId": "{{dataCollectionRuleImmutableId}}"
    },
    "addOnAttributes": {
      "friendlyName": "[[parameters('friendlyName')]"
    }
  }
}