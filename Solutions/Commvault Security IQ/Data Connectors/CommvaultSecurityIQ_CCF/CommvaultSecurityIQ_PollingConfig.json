[
  {
    "name": "CommvaultSecurityIQEvents",
    "apiVersion": "2023-01-01-preview",
    "type": "Microsoft.SecurityInsights/dataConnectors",
    "location": "{{location}}",
    "kind": "RestApiPoller",
    "properties": {
      "connectorDefinitionName": "CommvaultSecurityIQDefinition",
      "dataType": "CommvaultSecurityIQ_CL",
      "dcrConfig": {
        "dataCollectionEndpoint": "{{dataCollectionEndpoint}}",
        "dataCollectionRuleImmutableId": "{{dataCollectionRuleImmutableId}}",
        "streamName": "Custom-CommvaultSecurityIQ_CL"
      },
      "auth": {
        "type": "APIKey",
        "apiKey": "{{AccessToken}}",
        "apiKeyName": "authtoken",
        "apiKeyIdentifier": "RequestHeader"
      },
      "request": {
        "apiEndpoint": "{{BaseUrl}}/events",
        "httpMethod": "GET",
        "queryTimeFormat": "UnixTimestamp",
        "queryParameters": {
          "level": "10",
          "showMajor": "true",
          "showCritical": "true",
          "showAnomalous": "true"
        },
        "queryParametersTemplate": "level=10&showMajor=true&showCritical=true&showAnomalous=true&fromTime={_QueryWindowStartTime}&toTime={_QueryWindowEndTime}",
        "startTimeAttributeName": "fromTime",
        "endTimeAttributeName": "toTime",
        "queryWindowInMin": 5,
        "rateLimitQPS": 1,
        "timeoutInSeconds": 20,
        "retryCount": 3,
        "headers": {
          "Content-Type": "application/json",
          "Accept": "application/json",
          "Authorization": "Bearer {{AccessToken}}",
          "pagingInfo": "0,1000"
        }
      },
      "response": {
        "eventsJsonPaths": [
          "$.commservEvents"
        ],
        "format": "json"
      }
    }
  }
]