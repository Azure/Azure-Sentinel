[
  {
    "type": "Microsoft.SecurityInsights/dataConnectors",
    "apiVersion": "2025-03-01",
    "name": "CommvaultSecurityIQPoller",
    "location": "{{location}}",
    "kind": "RestApiPoller",
    "properties": {
      "connectorDefinitionName": "CommvaultSecurityIQConnector",
      "dataType": "CommvaultAlertsCCF_CL",
      "auth": {
        "type": "APIKey",
        "ApiKey": "[[parameters('qsdkToken')]",
        "ApiKeyName": "Authorization",
        "ApiKeyIdentifier": "Bearer"
      },
      "request": {
        "apiEndpoint": "[[concat(parameters('endpointUrl'), '/Client/Anomaly')]",
        "httpMethod": "GET",
        "rateLimitQPS": 10,
        "queryWindowInMin": 30,
        "retryCount": 3,
        "timeoutInSeconds": 120,
        "queryTimeFormat": "UnixTimestampInSeconds",
        "queryParameters": {
          "fromTime": "{_QueryWindowStartTime}",
          "toTime": "{_QueryWindowEndTime}"
        },
        "headers": {
          "Accept": "application/json",
          "User-Agent": "MS-Sentinel-CCF-CommvaultSecurityIQ"
        }
      },
      "response": {
        "eventsJsonPaths": [
          "$.anomalyClients[*]"
        ],
        "format": "json"
      },
      "dcrConfig": {
        "streamName": "Custom-CommvaultAlertsCCF_CL",
        "dataCollectionEndpoint": "{{dataCollectionEndpoint}}",
        "dataCollectionRuleImmutableId": "{{dataCollectionRuleImmutableId}}"
      }
    }
  }
]
