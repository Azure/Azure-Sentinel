{
  "name": "CommvaultSecurityIQDCR",
  "type": "Microsoft.Insights/dataCollectionRules",
  "apiVersion": "2021-09-01-preview",
  "location": "{{location}}",
  "properties": {
    "description": "Data collection rule for Commvault Security IQ connector",
    "streamDeclarations": {
      "Custom-CommvaultSecurityIQ_CL": {
        "columns": [
          {
            "name": "TimeGenerated",
            "type": "datetime"
          },
          {
            "name": "EventCode",
            "type": "string"
          }
        ]
      }
    },
    "destinations": {
      "logAnalytics": [
        {
          "workspaceResourceId": "{{workspaceResourceId}}",
          "workspaceId": "{{workspaceId}}",
          "name": "la1"
        }
      ]
    },
    "dataFlows": [
      {
        "streams": [
          "Custom-CommvaultSecurityIQ_CL"
        ],
        "destinations": [
          "la1"
        ],
        "outputStream": "Custom-CommvaultSecurityIQ_CL",
        "transformKql": "source | extend TimeGenerated = now(), EventCode = coalesce(tostring(columnifexists('eventCodeString', '')), tostring(columnifexists('eventCode', ''))) | project TimeGenerated, EventCode"
      }
    ]
  }
}