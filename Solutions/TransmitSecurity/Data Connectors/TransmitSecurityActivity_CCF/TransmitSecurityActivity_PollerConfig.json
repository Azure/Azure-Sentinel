[
    {
        "name": "TransmitSecurityPoller",
        "apiVersion": "2022-12-01-preview",
        "type": "Microsoft.SecurityInsights/dataConnectors",
        "location": "{{location}}",
        "kind": "RestApiPoller",
        "properties": {
            "connectorDefinitionName": "TransmitSecurityConnectorDefinition",
            "dataType": "TransmitSecurityActivity_V2_CL",
            "dcrConfig": {
                "dataCollectionEndpoint": "{{dataCollectionEndpoint}}",
                "dataCollectionRuleImmutableId": "{{dataCollectionRuleImmutableId}}",
                "streamName": "Custom-TransmitSecurityActivity_V2_CL"
            },
            "auth": {
                "type": "OAuth2",
                "ClientId": "{{clientId}}",
                "ClientSecret": "{{clientSecret}}",
                "GrantType": "client_credentials",
                "TokenEndpoint": "{{transmitSecurityTokenEndpoint}}",
                "TokenEndpointHeaders": {
                    "Content-Type": "application/x-www-form-urlencoded"
                }
            },
            "request": {
                "apiEndpoint": "{{transmitSecurityPullEndpoint}}",
                "httpMethod": "POST",
                "rateLimitQPS": 1,
                "queryWindowInMin": 5,
                "retryCount": 3,
                "timeoutInSeconds": 60,
                "isPostPayloadJson": true,
                "headers": {
                    "Accept": "application/json",
                    "Content-Type": "application/json"
                },
                "queryParametersTemplate": "{}"
            },
            "response": {
                "eventsJsonPaths": [
                    "$[*]"
                ],
                "format": "json"
            }
        }
    }
]
