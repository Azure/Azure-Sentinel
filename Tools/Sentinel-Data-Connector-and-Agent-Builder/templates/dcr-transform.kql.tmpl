// This transform runs on ingestion to normalize ISV data into the custom table schema

source
| extend TimeGenerated = todatetime({{TIMESTAMP_FIELD}})
| project
    TimeGenerated,
    {{OUTPUT_COLUMN_1}} = tostring({{SOURCE_FIELD_1}}),
    {{OUTPUT_COLUMN_2}} = tostring({{SOURCE_FIELD_2}}),
    {{OUTPUT_COLUMN_3}} = tostring({{SOURCE_FIELD_3}})
