{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "description": "Deploys an ADLS Gen2 storage account (hierarchical namespace enabled) with a blob container for the ContosoFort CCF Blob Connector accelerator. Required by Microsoft Sentinel CCF StorageAccountBlobContainer connectors."
  },
  "parameters": {
    "storageAccountName": {
      "type": "string",
      "minLength": 3,
      "maxLength": 24,
      "metadata": {
        "description": "Unique name for the storage account (3-24 lowercase alphanumeric characters, globally unique). Example: contosofortlogs1234"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for the storage account. Must match or be compatible with your Sentinel workspace region."
      }
    },
    "blobContainerName": {
      "type": "string",
      "defaultValue": "contosofort-logs",
      "metadata": {
        "description": "Name of the blob container (filesystem) that will receive log files."
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2022-09-01",
      "name": "[parameters('storageAccountName')]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Standard_LRS"
      },
      "kind": "StorageV2",
      "properties": {
        "isHnsEnabled": true,
        "minimumTlsVersion": "TLS1_2",
        "allowBlobPublicAccess": false,
        "supportsHttpsTrafficOnly": true,
        "accessTier": "Hot"
      }
    },
    {
      "type": "Microsoft.Storage/storageAccounts/blobServices/containers",
      "apiVersion": "2022-09-01",
      "name": "[concat(parameters('storageAccountName'), '/default/', parameters('blobContainerName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', parameters('storageAccountName'))]"
      ],
      "properties": {
        "publicAccess": "None"
      }
    }
  ],
  "outputs": {
    "storageAccountName": {
      "type": "string",
      "value": "[parameters('storageAccountName')]",
      "metadata": {
        "description": "The deployed storage account name."
      }
    },
    "blobContainerUrl": {
      "type": "string",
      "value": "[concat('https://', parameters('storageAccountName'), '.blob.core.windows.net/', parameters('blobContainerName'))]",
      "metadata": {
        "description": "The Blob container URL — paste this into the Sentinel connector UI."
      }
    },
    "storageAccountResourceId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Storage/storageAccounts', parameters('storageAccountName'))]",
      "metadata": {
        "description": "Resource ID of the storage account."
      }
    }
  }
}
