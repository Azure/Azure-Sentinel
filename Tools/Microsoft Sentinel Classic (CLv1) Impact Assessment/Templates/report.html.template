<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Microsoft Sentinel Classic (CLv1) Impact Assessment</title>
<style>
  :root {
    --bg: #0a0f1e;
    --bg-subtle: #0f1629;
    --panel: #141b2d;
    --panel-hover: #1a2340;
    --card: #111827;
    --border: #1e293b;
    --border-hover: #334155;
    --text: #f1f5f9;
    --text-secondary: #cbd5e1;
    --muted: #64748b;
    --accent: #3b82f6;
    --accent-dim: rgba(59, 130, 246, 0.12);
    --cyan: #06b6d4;
    --cyan-dim: rgba(6, 182, 212, 0.12);
    --ok: #10b981;
    --ok-dim: rgba(16, 185, 129, 0.12);
    --warn: #f59e0b;
    --warn-dim: rgba(245, 158, 11, 0.12);
    --err: #ef4444;
    --err-dim: rgba(239, 68, 68, 0.12);
    --purple: #8b5cf6;
    --purple-dim: rgba(139, 92, 246, 0.12);
    --code-bg: #0b1120;
    --radius: 12px;
    --radius-sm: 8px;
    --radius-xs: 6px;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Segoe UI', system-ui, sans-serif;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  /* ── Header ── */
  .header {
    background: linear-gradient(135deg, #0f172a 0%, #1e3a5f 50%, #1e3a8a 100%);
    border-bottom: 1px solid var(--border);
    position: relative;
    overflow: hidden;
  }
  .header::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(59, 130, 246, 0.08) 0%, transparent 70%);
    pointer-events: none;
  }
  .header-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 40px 48px;
    position: relative;
  }
  .header-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 24px;
  }
  .header h1 {
    font-size: 28px;
    font-weight: 700;
    letter-spacing: -0.5px;
    margin-bottom: 6px;
  }
  .header .subtitle {
    color: var(--muted);
    font-size: 14px;
    max-width: 600px;
  }
  .version-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 14px;
    border-radius: 999px;
    font-size: 12px;
    font-weight: 600;
    border: 1px solid rgba(59, 130, 246, 0.3);
    background: rgba(59, 130, 246, 0.1);
    color: var(--accent);
    font-family: ui-monospace, 'SF Mono', Menlo, monospace;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .meta-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 20px;
  }
  .meta-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 12px;
    border-radius: var(--radius-xs);
    font-size: 12px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: var(--text-secondary);
    font-family: ui-monospace, 'SF Mono', Menlo, monospace;
  }
  .meta-chip .meta-label {
    color: var(--muted);
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
    font-weight: 500;
    text-transform: uppercase;
    font-size: 10px;
    letter-spacing: 0.5px;
  }

  /* ── Layout ── */
  main {
    max-width: 1400px;
    margin: 0 auto;
    padding: 32px 48px 64px;
  }

  /* ── Stats grid ── */
  .stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 12px;
    margin-bottom: 40px;
  }
  .stat {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 20px 24px;
    position: relative;
    overflow: hidden;
    transition: border-color 0.2s, transform 0.15s;
  }
  .stat:hover {
    border-color: var(--border-hover);
    transform: translateY(-1px);
  }
  .stat .icon-bg {
    position: absolute;
    top: -8px;
    right: -8px;
    width: 64px;
    height: 64px;
    border-radius: 50%;
    opacity: 0.5;
  }
  .stat .label {
    color: var(--muted);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    font-weight: 600;
    margin-bottom: 8px;
  }
  .stat .value {
    font-size: 36px;
    font-weight: 800;
    letter-spacing: -1px;
    line-height: 1;
  }
  .stat .desc {
    font-size: 11px;
    color: var(--muted);
    margin-top: 6px;
  }

  /* ── Section headers ── */
  .section-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 40px 0 16px;
  }
  .section-header .section-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: var(--radius-sm);
    flex-shrink: 0;
  }
  .section-header h2 {
    font-size: 16px;
    font-weight: 700;
    letter-spacing: -0.2px;
    color: var(--text);
    text-transform: none;
    margin: 0;
  }
  .section-header .section-count {
    font-size: 12px;
    color: var(--muted);
    font-weight: 500;
  }

  /* ── Filter bar ── */
  .filter-bar {
    display: flex;
    gap: 6px;
    margin-bottom: 16px;
    flex-wrap: wrap;
    padding: 4px;
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    width: fit-content;
  }
  .filter-btn {
    background: transparent;
    border: none;
    color: var(--muted);
    padding: 7px 16px;
    border-radius: var(--radius-sm);
    cursor: pointer;
    font-size: 12px;
    font-family: inherit;
    font-weight: 500;
    transition: all 0.15s;
  }
  .filter-btn:hover { color: var(--text); background: rgba(255,255,255,0.05); }
  .filter-btn.active {
    background: var(--accent);
    color: #fff;
    box-shadow: 0 2px 8px rgba(59, 130, 246, 0.3);
  }

  /* ── Table cards ── */
  .table-card {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    margin-bottom: 12px;
    overflow: hidden;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .table-card:hover { border-color: var(--border-hover); }
  .table-card[open] {
    border-color: var(--accent);
    box-shadow: 0 0 0 1px rgba(59, 130, 246, 0.15), 0 4px 24px rgba(0, 0, 0, 0.3);
  }
  .table-card > summary {
    padding: 18px 24px;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 14px;
    user-select: none;
    list-style: none;
    transition: background 0.15s;
  }
  .table-card > summary:hover { background: var(--panel-hover); }
  .table-card > summary::-webkit-details-marker { display: none; }
  .table-card > summary .chevron {
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
    background: rgba(255,255,255,0.04);
    transition: transform 0.2s, background 0.15s;
    flex-shrink: 0;
    color: var(--muted);
    font-size: 10px;
  }
  .table-card[open] > summary .chevron { transform: rotate(90deg); background: var(--accent-dim); color: var(--accent); }
  .table-name {
    font-family: ui-monospace, 'SF Mono', Menlo, monospace;
    font-size: 14px;
    font-weight: 600;
    flex: 1;
    letter-spacing: -0.2px;
  }
  .badge-row { display: flex; gap: 6px; flex-wrap: wrap; align-items: center; }

  /* ── Badges ── */
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 3px 10px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 600;
    white-space: nowrap;
  }
  .badge.impacted { background: var(--err-dim); color: var(--err); }
  .badge.clean { background: var(--ok-dim); color: var(--ok); }
  .badge.warn { background: var(--warn-dim); color: var(--warn); }
  .badge.info { background: var(--accent-dim); color: var(--accent); }
  .badge.platform { background: var(--cyan-dim); color: var(--cyan); }
  .badge.ccf { background: var(--ok-dim); color: var(--ok); }
  .badge.purple { background: var(--purple-dim); color: var(--purple); }

  /* ── Detail body ── */
  .detail-body { border-top: 1px solid var(--border); }
  .detail-section { padding: 20px 24px; border-bottom: 1px solid var(--border); }
  .detail-section:last-child { border-bottom: none; }
  .detail-section h3 {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    color: var(--muted);
    font-weight: 600;
    margin-bottom: 12px;
  }
  .detail-section h3 .count {
    background: rgba(255,255,255,0.06);
    padding: 1px 8px;
    border-radius: 999px;
    font-size: 10px;
    color: var(--text-secondary);
  }

  /* ── Item lists ── */
  .item-list { display: flex; flex-direction: column; gap: 4px; }
  .item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    background: var(--code-bg);
    border: 1px solid rgba(255,255,255,0.04);
    border-radius: var(--radius-sm);
    font-size: 13px;
    transition: border-color 0.15s;
  }
  .item:hover { border-color: var(--border); }
  .item .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .item .item-name { flex: 1; font-weight: 500; }
  .item .item-meta {
    color: var(--muted);
    font-size: 10px;
    font-family: ui-monospace, 'SF Mono', Menlo, monospace;
  }
  .item .severity {
    padding: 2px 8px;
    border-radius: var(--radius-xs);
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.3px;
  }
  .severity.high { background: var(--err-dim); color: var(--err); }
  .severity.medium { background: var(--warn-dim); color: var(--warn); }
  .severity.low { background: var(--cyan-dim); color: var(--cyan); }
  .severity.informational { background: rgba(255,255,255,0.06); color: var(--muted); }

  .solution-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 16px;
    background: var(--code-bg);
    border: 1px solid rgba(255,255,255,0.04);
    border-radius: var(--radius-sm);
    font-size: 13px;
  }
  .solution-item .sol-icon {
    width: 32px;
    height: 32px;
    border-radius: var(--radius-xs);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: 14px;
  }
  .solution-item .sol-details { flex: 1; }
  .solution-item .sol-name { font-weight: 600; font-size: 13px; }
  .solution-item .sol-sub { font-size: 11px; color: var(--muted); margin-top: 2px; }
  .solution-item .sol-actions { display: flex; gap: 6px; align-items: center; flex-wrap: wrap; }

  /* ── Empty state ── */
  .empty-state {
    color: var(--muted);
    font-size: 13px;
    font-style: italic;
    padding: 16px 0;
  }

  /* ── Callout boxes ── */
  .callout {
    border-radius: var(--radius-sm);
    padding: 16px 20px;
    margin-top: 4px;
    display: flex;
    gap: 14px;
    align-items: flex-start;
  }
  .callout .callout-icon {
    width: 36px;
    height: 36px;
    border-radius: var(--radius-xs);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: 16px;
  }
  .callout .callout-body { flex: 1; }
  .callout .callout-title { font-weight: 700; font-size: 13px; margin-bottom: 4px; }
  .callout .callout-text { font-size: 12px; line-height: 1.6; }

  .callout.action-required {
    background: rgba(239, 68, 68, 0.06);
    border: 1px solid rgba(239, 68, 68, 0.2);
  }
  .callout.action-required .callout-icon { background: var(--err-dim); color: var(--err); }
  .callout.action-required .callout-title { color: var(--err); }
  .callout.action-required .callout-text { color: var(--text-secondary); }

  .callout.attention {
    background: rgba(245, 158, 11, 0.06);
    border: 1px solid rgba(245, 158, 11, 0.2);
  }
  .callout.attention .callout-icon { background: var(--warn-dim); color: var(--warn); }
  .callout.attention .callout-title { color: var(--warn); }
  .callout.attention .callout-text { color: var(--text-secondary); }

  .callout.success {
    background: rgba(16, 185, 129, 0.06);
    border: 1px solid rgba(16, 185, 129, 0.2);
  }
  .callout.success .callout-icon { background: var(--ok-dim); color: var(--ok); }
  .callout.success .callout-title { color: var(--ok); }
  .callout.success .callout-text { color: var(--text-secondary); }

  .callout.info {
    background: rgba(59, 130, 246, 0.06);
    border: 1px solid rgba(59, 130, 246, 0.2);
  }
  .callout.info .callout-icon { background: var(--accent-dim); color: var(--accent); }
  .callout.info .callout-title { color: var(--accent); }
  .callout.info .callout-text { color: var(--text-secondary); }

  /* ── About section ── */
  .about-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
  .about-card {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 24px;
    transition: border-color 0.2s;
  }
  .about-card:hover { border-color: var(--border-hover); }
  .about-card h3 { font-size: 14px; font-weight: 700; margin-bottom: 8px; display: flex; align-items: center; gap: 8px; }
  .about-card p { font-size: 13px; color: var(--text-secondary); line-height: 1.7; }
  .about-card .doc-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    margin-top: 8px;
    font-size: 12px;
    color: var(--accent);
    text-decoration: none;
    font-weight: 500;
  }
  .about-card .doc-link:hover { text-decoration: underline; }

  .contributor {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 20px 24px;
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .contributor.primary { border-color: rgba(59, 130, 246, 0.3); }
  .contributor .avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 16px;
    flex-shrink: 0;
  }
  .contributor .contrib-info { flex: 1; }
  .contributor .contrib-name { font-weight: 700; font-size: 14px; }
  .contributor .contrib-roles { display: flex; gap: 4px; margin-top: 4px; flex-wrap: wrap; }
  .contributor .role-tag {
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.3px;
  }
  .role-tag.developer { background: var(--accent-dim); color: var(--accent); }
  .role-tag.designer { background: var(--purple-dim); color: var(--purple); }
  .role-tag.tester { background: var(--ok-dim); color: var(--ok); }
  .contributor .contrib-desc { font-size: 11px; color: var(--muted); margin-top: 6px; }
  .contributor .contrib-links { display: flex; gap: 6px; flex-shrink: 0; }
  .contrib-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: var(--radius-xs);
    color: var(--muted);
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
    font-size: 12px;
  }
  .contrib-link:hover { background: rgba(255,255,255,0.06); color: var(--text); }

  /* ── Links ── */
  a { color: var(--accent); text-decoration: none; }
  a:hover { text-decoration: underline; }

  /* ── Footer ── */
  footer {
    max-width: 1400px;
    margin: 0 auto;
    padding: 24px 48px 40px;
    color: var(--muted);
    font-size: 12px;
    text-align: center;
    border-top: 1px solid var(--border);
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .header-inner, main, footer { padding-left: 20px; padding-right: 20px; }
    .header-top { flex-direction: column; }
    .stats { grid-template-columns: repeat(2, 1fr); }
    .about-grid { grid-template-columns: 1fr; }
  }

  /* ── SVG icons ── */
  .icon { width: 14px; height: 14px; display: inline-block; vertical-align: middle; }
  .icon-sm { width: 12px; height: 12px; }
  .icon-lg { width: 18px; height: 18px; }

  /* ── About button (header) ── */
  .about-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 7px 16px;
    border-radius: var(--radius-sm);
    font-size: 12px;
    font-weight: 600;
    color: var(--text-secondary);
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    cursor: pointer;
    font-family: inherit;
    transition: all 0.15s;
  }
  .about-btn:hover { background: rgba(255,255,255,0.1); color: var(--text); border-color: rgba(255,255,255,0.2); }

  /* ── Modal overlay ── */
  body.modal-open { overflow: hidden; }
  .modal-backdrop {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    z-index: 1000;
    justify-content: center;
    align-items: center;
    padding: 24px;
    overflow-y: auto;
  }
  .modal-backdrop.open { display: flex; }
  .modal {
    background: var(--bg-subtle);
    border: 1px solid var(--border);
    border-radius: 16px;
    width: 100%;
    max-width: 960px;
    margin: auto;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(255,255,255,0.05);
    animation: modalIn 0.2s ease-out;
    position: relative;
  }
  @keyframes modalIn {
    from { opacity: 0; transform: translateY(-12px) scale(0.98); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }
  .modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 24px 28px 0;
  }
  .modal-header h2 {
    font-size: 18px;
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 0;
    color: var(--text);
    text-transform: none;
  }
  .modal-close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: var(--radius-sm);
    border: none;
    background: rgba(255,255,255,0.06);
    color: var(--muted);
    cursor: pointer;
    font-size: 16px;
    transition: all 0.15s;
  }
  .modal-close:hover { background: rgba(255,255,255,0.1); color: var(--text); }
  .modal-body { padding: 24px 28px 28px; }
  .modal-section-label {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    color: var(--muted);
    font-weight: 600;
    margin: 24px 0 12px;
  }
  .modal-section-label:first-child { margin-top: 0; }
  .modal-app-info {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    margin-bottom: 4px;
  }
  .modal-app-info .app-name { font-weight: 700; font-size: 14px; }
  .modal-app-info .app-desc { font-size: 12px; color: var(--muted); margin-top: 2px; }
</style>
</head>
<body>

<!-- ══ Header ══ -->
<div class="header">
  <div class="header-inner">
    <div class="header-top">
      <div>
        <h1>Microsoft Sentinel Classic (CLv1) Impact Assessment</h1>
        <p class="subtitle">Classic custom log table discovery, dependency impact analysis, and Content Hub solution mapping.</p>
      </div>
      <div style="display:flex;gap:8px;align-items:center;flex-shrink:0;">
        <button class="about-btn" onclick="document.getElementById('about-modal').classList.add('open');document.body.classList.add('modal-open')">
          <svg class="icon-sm" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
          About
        </button>
      </div>
    </div>
    <div class="meta-bar" id="meta"></div>
  </div>
</div>

<!-- ══ Main ══ -->
<main>
  <div class="stats" id="stats"></div>

  <!-- Tables section -->
  <div class="section-header">
    <div class="section-icon" style="background: var(--accent-dim); color: var(--accent);">
