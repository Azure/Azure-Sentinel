<script>
const DATA = JSON.parse("{{DATA_JSON}}");

// ── Normalize arrays (PowerShell single-item unwrapping) ──
function ensureArray(v) { return Array.isArray(v) ? v : v == null ? [] : [v]; }
DATA.Impacts = ensureArray(DATA.Impacts);
DATA.Tables = ensureArray(DATA.Tables);
DATA.SolutionMatches = ensureArray(DATA.SolutionMatches);
DATA.Impacts.forEach(i => {
  i.AnalyticsRules = ensureArray(i.AnalyticsRules);
  i.HuntingQueries = ensureArray(i.HuntingQueries);
  i.Parsers = ensureArray(i.Parsers);
  i.SavedSearches = ensureArray(i.SavedSearches);
  i.Workbooks = ensureArray(i.Workbooks);
  i.Playbooks = ensureArray(i.Playbooks);
  i.Dcrs = ensureArray(i.Dcrs);
});
DATA.SolutionMatches.forEach(m => {
  m.Solutions = ensureArray(m.Solutions);
  m.ConnectorClassification = ensureArray(m.ConnectorClassification);
});

// ── Header ──
const metaItems = [
  { label: 'Workspace', value: DATA.Workspace },
  { label: 'Resource Group', value: DATA.ResourceGroup },
  { label: 'Subscription', value: DATA.Subscription },
  { label: 'Generated', value: DATA.GeneratedAt },
];
document.getElementById('meta').innerHTML = metaItems
  .map(m => '<div class="meta-chip"><span class="meta-label">' + m.label + '</span>' + escapeHtml(m.value) + '</div>')
  .join('');

// ── Stats ──
const impactedCount = DATA.Impacts.filter(i => i.TotalImpacted > 0).length;
const cleanCount = DATA.Tables.length - impactedCount;
const matchedCount = DATA.SolutionMatches.filter(m => m.MatchCount > 0).length;
const unmatchedCount = DATA.SolutionMatches.length - matchedCount;

document.getElementById('stats').innerHTML =
  '<div class="stat">' +
    '<div class="icon-bg" style="background: var(--accent-dim);"></div>' +
    '<div class="label">Classic Tables</div>' +
    '<div class="value" style="color: var(--text);">' + DATA.TotalTables + '</div>' +
    '<div class="desc">V1 custom log tables discovered</div>' +
  '</div>' +
  '<div class="stat">' +
    '<div class="icon-bg" style="background: var(--err-dim);"></div>' +
    '<div class="label">Impacted</div>' +
    '<div class="value" style="color: var(--err);">' + impactedCount + '</div>' +
    '<div class="desc">Tables with content dependencies</div>' +
  '</div>' +
  '<div class="stat">' +
    '<div class="icon-bg" style="background: var(--ok-dim);"></div>' +
    '<div class="label">Clean</div>' +
    '<div class="value" style="color: var(--ok);">' + cleanCount + '</div>' +
    '<div class="desc">Ready to migrate immediately</div>' +
  '</div>' +
  '<div class="stat">' +
    '<div class="icon-bg" style="background: var(--warn-dim);"></div>' +
    '<div class="label">Total Dependencies</div>' +
    '<div class="value" style="color: var(--warn);">' + (DATA.TotalImpacted || 0) + '</div>' +
    '<div class="desc">Rules, queries, workbooks, etc.</div>' +
  '</div>' +
  '<div class="stat">' +
    '<div class="icon-bg" style="background: var(--cyan-dim);"></div>' +
    '<div class="label">Solution Matched</div>' +
    '<div class="value" style="color: var(--cyan);">' + matchedCount + '</div>' +
    '<div class="desc">Mapped to Content Hub solutions</div>' +
  '</div>' +
  '<div class="stat">' +
    '<div class="icon-bg" style="background: ' + (unmatchedCount > 0 ? 'var(--err-dim)' : 'var(--ok-dim)') + '"></div>' +
    '<div class="label">No Match</div>' +
    '<div class="value" style="color: ' + (unmatchedCount > 0 ? 'var(--err)' : 'var(--ok)') + ';">' + unmatchedCount + '</div>' +
    '<div class="desc">' + (unmatchedCount > 0 ? 'Require manual investigation' : 'All tables matched') + '</div>' +
  '</div>';

// ── Table count ──
document.getElementById('table-count').textContent = DATA.Tables.length + ' table' + (DATA.Tables.length === 1 ? '' : 's');

// ── Helpers ──
var impactByName = {};
DATA.Impacts.forEach(function(i) { impactByName[i.TableName] = i; });
var matchByName = {};
DATA.SolutionMatches.forEach(function(m) { matchByName[m.TableName] = m; });

function escapeHtml(s) {
  if (s === null || s === undefined) return '';
  return String(s).replace(/[&<>"']/g, function(c) {
    return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c];
  });
}

function shortId(id) {
  if (!id) return '';
  var parts = id.split('/');
  return parts.slice(-2).join('/');
}

function severityClass(sev) {
  if (!sev) return '';
  var s = sev.toLowerCase();
  if (s === 'high') return 'high';
  if (s === 'medium') return 'medium';
  if (s === 'low') return 'low';
  return 'informational';
}

function dotColor(type) {
  var colors = {
    AnalyticsRules: 'var(--err)',
    HuntingQueries: 'var(--purple)',
    Parsers: 'var(--cyan)',
    SavedSearches: 'var(--accent)',
    Workbooks: 'var(--warn)',
    Playbooks: 'var(--ok)',
    Dcrs: 'var(--text-secondary)'
  };
  return colors[type] || 'var(--muted)';
}

// ── Render items ──
function renderImpactItem(item, type) {
  var meta = item.ResourceId ? '<span class="item-meta">' + escapeHtml(shortId(item.ResourceId)) + '</span>' : '';
  var severity = item.Severity ? '<span class="severity ' + severityClass(item.Severity) + '">' + escapeHtml(item.Severity) + '</span>' : '';
  var enabled = item.Enabled === false ? '<span class="badge warn">Disabled</span>' : '';
  return '<div class="item">' +
    '<span class="dot" style="background: ' + dotColor(type) + ';"></span>' +
    '<span class="item-name">' + escapeHtml(item.Name) + '</span>' +
    severity + enabled + meta +
  '</div>';
}

function renderSolution(s, connectorKind) {
  var installed = s.IsInstalled
    ? '<span class="badge clean">Installed</span>'
    : '<span class="badge warn">Not Installed</span>';
  var hubStatus = s.IsInContentHub ? '' : '<span class="badge info">Not in catalog</span>';
  var github = s.GithubUrl
    ? '<a href="' + escapeHtml(s.GithubUrl) + '" target="_blank" rel="noopener" style="font-size:11px;">View source &#8594;</a>'
    : '';
  var kindBadge = connectorKind && connectorKind !== 'Unknown'
    ? '<span class="badge ' + connectorKind.toLowerCase() + '">' + escapeHtml(connectorKind) + '</span>'
    : '';
  var icon = s.IsInstalled ? '&#10003;' : '&#11045;';
  var iconBg = s.IsInstalled ? 'background:var(--ok-dim);color:var(--ok);' : 'background:var(--warn-dim);color:var(--warn);';

  return '<div class="solution-item">' +
    '<div class="sol-icon" style="' + iconBg + '">' + icon + '</div>' +
    '<div class="sol-details">' +
      '<div class="sol-name">' + escapeHtml(s.DisplayName || s.SolutionName) + '</div>' +
      '<div class="sol-sub">' + (s.IsInContentHub ? 'Available in Content Hub' : 'Not found in workspace catalog') + '</div>' +
    '</div>' +
    '<div class="sol-actions">' + kindBadge + installed + hubStatus + github + '</div>' +
  '</div>';
}

// ── Render connector callout ──
function renderConnectorCallout(match) {
  var classifications = match.ConnectorClassification || [];
  var hasUnknown = classifications.some(function(c) { return c.ConnectorKind === 'Unknown'; });
  var hasAzureFunc = classifications.some(function(c) { return c.ConnectorKind === 'AzureFunctions'; });
  var hasCCF = classifications.some(function(c) { return c.ConnectorKind === 'CCF'; });
  var hasPlatform = classifications.some(function(c) { return c.ConnectorKind === 'Platform'; });
  var hasAMA = classifications.some(function(c) { return c.ConnectorKind === 'AMA'; });

  if (match.MatchCount === 0) {
    return '<div class="callout action-required">' +
      '<div class="callout-icon">&#9888;</div>' +
      '<div class="callout-body">' +
        '<div class="callout-title">No Content Hub Solution Available</div>' +
        '<div class="callout-text">' +
          'No Content Hub solution matches this table. No data connector is available to ingest data into a DCR-based replacement.<br><br>' +
          '<strong>Action required:</strong> Contact your Microsoft CSAM / SSP and raise a <strong>Feature Request</strong> with the Engineering team to prioritise building a connector for this data source. Include the table name and your business justification for continued data collection.' +
        '</div>' +
      '</div>' +
    '</div>';
  }

  if (hasUnknown && !hasCCF && !hasPlatform && !hasAMA) {
    return '<div class="callout attention">' +
      '<div class="callout-icon">&#9889;</div>' +
      '<div class="callout-body">' +
        '<div class="callout-title">Data Connector Not Identified</div>' +
        '<div class="callout-text">' +
          'A Content Hub solution exists for this table, but no compatible data connector (CCF, AMA, or Platform) was detected in the solution package.<br><br>' +
          '<strong>Action required:</strong> Check the Content Hub solution for connector availability. If no modern connector exists, contact your Microsoft CSAM / SSP and raise a <strong>Feature Request</strong> with Engineering to build a Codeless Connector Framework (CCF) connector for this data source.' +
        '</div>' +
      '</div>' +
    '</div>';
  }

  if (hasAzureFunc && !hasCCF) {
    return '<div class="callout attention">' +
      '<div class="callout-icon">&#9889;</div>' +
      '<div class="callout-body">' +
        '<div class="callout-title">Legacy Azure Functions Connector</div>' +
        '<div class="callout-text">' +
          'This table is served by a legacy Azure Functions-based connector. These connectors require customer-managed infrastructure, incur additional compute costs, and do not benefit from the Codeless Connector Framework (CCF).<br><br>' +
          '<strong>Action required:</strong> Check Content Hub for a CCF equivalent. If none exists yet, contact your Microsoft CSAM / SSP and raise a <strong>Feature Request</strong> with Engineering to prioritise CCF parity for this data source.' +
        '</div>' +
      '</div>' +
    '</div>';
  }

  if (hasCCF || hasPlatform || hasAMA) {
    var connType = hasPlatform ? 'Platform-native' : hasCCF ? 'Codeless Connector Framework (CCF)' : 'Azure Monitor Agent (AMA)';
    return '<div class="callout success">' +
      '<div class="callout-icon">&#10003;</div>' +
      '<div class="callout-body">' +
        '<div class="callout-title">Modern Connector Available</div>' +
        '<div class="callout-text">' +
          'This table has a <strong>' + connType + '</strong> connector available. You can migrate to a DCR-based table and use the modern connector for continued data ingestion.' +
        '</div>' +
      '</div>' +
    '</div>';
  }

  return '';
}

// ── Render table card ──
function renderTable(t) {
  var impact = impactByName[t.Name] || { TotalImpacted: 0, AnalyticsRules: [], HuntingQueries: [], Parsers: [], SavedSearches: [], Workbooks: [], Playbooks: [], Dcrs: [] };
  var match = matchByName[t.Name] || { MatchCount: 0, Solutions: [], ConnectorClassification: [] };

  var sections = [];

  var impactTypes = [
    { key: 'AnalyticsRules', label: 'Analytics Rules', icon: '&#9889;' },
    { key: 'HuntingQueries', label: 'Hunting Queries', icon: '&#127919;' },
    { key: 'Parsers', label: 'Parsers', icon: '&#9881;' },
    { key: 'SavedSearches', label: 'Saved Searches', icon: '&#128269;' },
    { key: 'Workbooks', label: 'Workbooks', icon: '&#128202;' },
    { key: 'Playbooks', label: 'Playbooks', icon: '&#128260;' },
    { key: 'Dcrs', label: 'Data Collection Rules', icon: '&#128225;' }
  ];

  impactTypes.forEach(function(it) {
    var items = impact[it.key];
    if (!items || items.length === 0) return;
    sections.push(
      '<div class="detail-section">' +
        '<h3>' + it.icon + ' ' + it.label + ' <span class="count">' + items.length + '</span></h3>' +
        '<div class="item-list">' + items.map(function(item) { return renderImpactItem(item, it.key); }).join('') + '</div>' +
      '</div>');
  });

  // Solutions
  if (match.Solutions && match.Solutions.length > 0) {
    var connMap = {};
    (match.ConnectorClassification || []).forEach(function(c) { connMap[c.SolutionName] = c.ConnectorKind; });
    sections.push(
      '<div class="detail-section">' +
        '<h3>&#128230; Content Hub Solutions <span class="count">' + match.Solutions.length + '</span></h3>' +
        '<div class="item-list">' + match.Solutions.map(function(s) { return renderSolution(s, connMap[s.SolutionName]); }).join('') + '</div>' +
      '</div>');
  }

  // Connector availability callout
  var callout = renderConnectorCallout(match);
  if (callout) {
    sections.push('<div class="detail-section">' + callout + '</div>');
  }

  // Table metadata
  sections.push(
    '<div class="detail-section" style="background: rgba(255,255,255,0.015);">' +
      '<h3>&#128203; Table Properties</h3>' +
      '<div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 12px;">' +
        '<div><span style="font-size:10px;text-transform:uppercase;letter-spacing:0.5px;color:var(--muted);font-weight:600;">Plan</span><div style="font-size:13px;font-weight:600;margin-top:2px;">' + escapeHtml(t.Plan) + '</div></div>' +
        '<div><span style="font-size:10px;text-transform:uppercase;letter-spacing:0.5px;color:var(--muted);font-weight:600;">Retention</span><div style="font-size:13px;font-weight:600;margin-top:2px;">' + t.RetentionInDays + ' days</div></div>' +
        '<div><span style="font-size:10px;text-transform:uppercase;letter-spacing:0.5px;color:var(--muted);font-weight:600;">Columns</span><div style="font-size:13px;font-weight:600;margin-top:2px;">' + t.ColumnCount + '</div></div>' +
        '<div><span style="font-size:10px;text-transform:uppercase;letter-spacing:0.5px;color:var(--muted);font-weight:600;">Sub Type</span><div style="font-size:13px;font-weight:600;margin-top:2px;">' + escapeHtml(t.TableSubType) + '</div></div>' +
      '</div>' +
    '</div>');

  // Badges
  var badges = [];
  if (impact.TotalImpacted > 0) {
    badges.push('<span class="badge impacted">' + impact.TotalImpacted + ' dependenc' + (impact.TotalImpacted === 1 ? 'y' : 'ies') + '</span>');
  } else {
    badges.push('<span class="badge clean">No dependencies</span>');
  }
  if (match.MatchCount > 0) {
    badges.push('<span class="badge info">' + match.MatchCount + ' solution' + (match.MatchCount === 1 ? '' : 's') + '</span>');
  } else {
    badges.push('<span class="badge warn">No match</span>');
  }

  var classifications = match.ConnectorClassification || [];
  var hasModernConnector = classifications.some(function(c) { return ['CCF', 'Platform', 'AMA'].indexOf(c.ConnectorKind) !== -1; });
  var hasAzureFunc = classifications.some(function(c) { return c.ConnectorKind === 'AzureFunctions'; });
  var allUnknown = classifications.length > 0 && classifications.every(function(c) { return c.ConnectorKind === 'Unknown'; });

  if (hasModernConnector) {
    var kind = classifications.filter(function(c) { return ['CCF', 'Platform', 'AMA'].indexOf(c.ConnectorKind) !== -1; })[0].ConnectorKind;
    badges.push('<span class="badge platform">' + kind + '</span>');
  } else if (hasAzureFunc) {
    badges.push('<span class="badge warn">Azure Functions</span>');
  } else if (match.MatchCount === 0) {
    badges.push('<span class="badge impacted">No connector</span>');
  } else if (allUnknown) {
    badges.push('<span class="badge purple">Connector unknown</span>');
  }

  var azureFuncCount = classifications.filter(function(c) { return c.ConnectorKind === 'AzureFunctions'; }).length;
  var noConnector = (match.MatchCount === 0 || allUnknown) ? 1 : 0;

  return '<details class="table-card" data-impact="' + impact.TotalImpacted + '" data-match="' + match.MatchCount + '" data-azurefunc="' + azureFuncCount + '" data-noconnector="' + noConnector + '">' +
      '<summary>' +
        '<span class="chevron">&#9656;</span>' +
        '<span class="table-name">' + escapeHtml(t.Name) + '</span>' +
        '<div class="badge-row">' + badges.join('') + '</div>' +
      '</summary>' +
      '<div class="detail-body">' +
        sections.join('') +
      '</div>' +
    '</details>';
}

document.getElementById('tables').innerHTML = DATA.Tables.map(renderTable).join('');

// ── Filters ──
document.querySelectorAll('.filter-btn').forEach(function(btn) {
  btn.addEventListener('click', function() {
    document.querySelectorAll('.filter-btn').forEach(function(b) { b.classList.remove('active'); });
    btn.classList.add('active');
    var f = btn.dataset.filter;
    var visible = 0;
    document.querySelectorAll('.table-card').forEach(function(el) {
      var impact = Number(el.dataset.impact);
      var match = Number(el.dataset.match);
      var af = Number(el.dataset.azurefunc);
      var nc = Number(el.dataset.noconnector);
      var show = true;
      if (f === 'impacted') show = impact > 0;
      else if (f === 'unmatched') show = match === 0;
      else if (f === 'azurefunctions') show = af > 0;
      else if (f === 'noconnector') show = nc > 0;
      el.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    document.getElementById('table-count').textContent = visible + ' of ' + DATA.Tables.length + ' table' + (DATA.Tables.length === 1 ? '' : 's');
  });
});
</script>
</body>
</html>
